---
const comparisonData = [
  { topic: "AI Web Development", topPick: "Vibe Coding Bootcamp", price: "$12.99", savings: "93%", coupon: "AUTO-APPLIED" },
  { topic: "Full-Stack Development", topPick: "Angela Yu's 2026 Bootcamp", price: "$13.99", savings: "92%", coupon: "VERIFIED" },
  { topic: "Next.js 15 Mastery", topPick: "AI-Accelerated Next.js", price: "$12.99", savings: "89%", coupon: "ACTIVE" },
  { topic: "Python Automation", topPick: "Indie Hacking Course", price: "$0.00", savings: "100%", coupon: "LIMITED" },
  { topic: "Cloud Foundations", topPick: "AWS Cloud Practitioner", price: "$12.99", savings: "91%", coupon: "VERIFIED" }
];
---

<section id="market-comparison" class="py-24 bg-[#07090f] relative overflow-hidden border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
        
        <div class="mb-12">
            <h2 class="text-3xl font-black text-white mb-4 tracking-tight">Quick Overview: Top Topics</h2>
            <p class="text-gray-500 max-w-2xl text-lg">
                We've picked the best learning paths and current verification status for each. Updated regularly to keep you informed.
            </p>
        </div>

        <div class="overflow-x-auto rounded-[2.5rem] border border-white/10 bg-[#0c1219]/50 backdrop-blur-xl">
            <table class="w-full text-left border-collapse min-w-[800px]">
                <thead>
                    <tr class="bg-white/5 border-b border-white/10">
                        <th class="px-8 py-6 text-xs font-black text-gray-500 uppercase tracking-widest">Learning Path Topic</th>
                        <th class="px-8 py-6 text-xs font-black text-gray-500 uppercase tracking-widest">Primary Recommendation</th>
                        <th class="px-8 py-6 text-xs font-black text-gray-500 uppercase tracking-widest">Current Deal</th>
                        <th class="px-8 py-6 text-xs font-black text-gray-500 uppercase tracking-widest">Estimated Saving</th>
                        <th class="px-8 py-6 text-xs font-black text-gray-500 uppercase tracking-widest">Status</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    {comparisonData.map((row) => (
                        <tr class="border-b border-white/5 hover:bg-white/3 transition-colors group">
                            <td class="px-8 py-6">
                                <span class="text-white font-bold group-hover:text-emerald-400 transition-colors">{row.topic}</span>
                            </td>
                            <td class="px-8 py-6 text-gray-400 font-medium">
                                {row.topPick}
                            </td>
                            <td class="px-8 py-6 tabular-nums text-white font-black">
                                {row.price}
                            </td>
                            <td class="px-8 py-6">
                                <span class={`px-2 py-1 rounded text-[10px] font-black ${row.savings === "100%" ? 'bg-emerald-500/20 text-emerald-400' : 'bg-blue-500/20 text-blue-400'}`}>
                                    {row.savings} OFF
                                </span>
                            </td>
                            <td class="px-8 py-6">
                                <div class="flex items-center gap-2">
                                    <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>
                                    <span class="text-gray-500 text-[10px] font-black uppercase tracking-widest">{row.coupon}</span>
                                </div>
                            </td>
                        </tr>
                    ))}
                </tbody>
            </table>
        </div>

        <div class="mt-8 flex items-center justify-between text-xs text-gray-600 font-bold uppercase tracking-widest">
            <span>Last checked: {new Date().toLocaleDateString()}</span>
            <span>Source: CoursesWyn Tracking System</span>
        </div>
    </div>
</section>
