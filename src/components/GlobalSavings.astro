---
const globalData = [
  { region: "Indonesia", code: "🇮🇩", localPrice: "Rp 129K - 179K", usdPrice: "~$8.20", status: "Active" },
  { region: "India", code: "🇮🇳", localPrice: "₹449 - ₹649", usdPrice: "~$5.40", status: "Active" },
  { region: "Brazil", code: "🇧🇷", localPrice: "R$49 - R$69", usdPrice: "~$9.85", status: "Active" },
  { region: "Europe", code: "🇪🇺", localPrice: "€11.99 - €12.99", usdPrice: "~$13.00", status: "Active" },
  { region: "USA", code: "🇺🇸", localPrice: "$11.99 - $13.99", usdPrice: "$12.99", status: "Active" }
];
---

<section id="global-pricing" class="py-24 bg-[#07090f] relative overflow-hidden border-t border-white/5">
    <!-- Subtle glow background -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[400px] bg-blue-500/5 rounded-full blur-[160px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
            <div class="max-w-2xl">
                <div class="inline-flex items-center gap-2 bg-blue-500/10 border border-blue-500/25 rounded-full px-4 py-1.5 mb-5">
                    <span class="text-blue-400 text-[10px] font-black uppercase tracking-widest">Pricing in different regions</span>
                </div>
                <h2 class="text-3xl md:text-5xl font-black text-white leading-tight tracking-tight mb-4">
                  How prices change <span class="text-blue-500 italic">worldwide</span>
                </h2>
                <p class="text-gray-500 text-lg">
                    Course prices often change depending on where you are. We track these global differences to help you find the best deal for your region.
                </p>
            </div>
            <div class="text-left md:text-right">
                <div class="text-white font-black text-2xl mb-1">92% Savings</div>
                <div class="text-gray-600 text-xs font-bold uppercase tracking-widest">Global Average Discount</div>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
            {globalData.map((item) => (
                <div class="group bg-white/5 border border-white/10 rounded-3xl p-6 hover:bg-white/8 hover:border-blue-500/30 transition-all duration-500">
                    <div class="text-4xl mb-6 flex items-center justify-between">
                        <span>{item.code}</span>
                        <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></div>
                    </div>
                    <div class="text-gray-400 text-[10px] font-black uppercase tracking-[0.2em] mb-1">{item.region}</div>
                    <div class="text-white font-black text-lg mb-3 leading-tight">{item.localPrice}</div>
                    
                    <div class="pt-4 border-t border-white/5 flex items-center justify-between">
                        <span class="text-gray-600 text-[10px] font-bold">In USD:</span>
                        <span class="text-blue-400 text-[10px] font-black">{item.usdPrice}</span>
                    </div>
                </div>
            ))}
        </div>

        <div class="mt-12 p-6 bg-blue-500/5 border border-blue-500/20 rounded-3xl flex flex-col md:flex-row items-center gap-6">
            <div class="flex-shrink-0 w-12 h-12 bg-blue-500 text-white rounded-2xl flex items-center justify-center text-xl shadow-lg shadow-blue-500/20">
                🌏
            </div>
            <p class="text-blue-200/80 text-sm leading-relaxed text-center md:text-left">
              <strong class="text-white">Pro Tip:</strong> All Udemy instructors use dynamic pricing. For Indonesia, prices usually range from <strong>Rp 129,000 to Rp 179,000</strong> during flash sales. Our coupons automatically trigger the lowest possible price point for your IP address.
            </p>
        </div>
    </div>
</section>
