---
import { getCollection } from 'astro:content';

// Fetch 3 latest posts for "Learning Guides & Hacks"
const allPosts = await getCollection('blog');
const topics = allPosts
  .sort((a, b) => {
    const dateA = a.data.updatedAt || a.data.pubDate;
    const dateB = b.data.updatedAt || b.data.pubDate;
    return dateB.getTime() - dateA.getTime();
  })
  .slice(0, 3);

function formatDate(post: any) {
  const date = post.data.updatedAt || post.data.pubDate;
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<section id="blog-guides" class="py-24 bg-[#07090f] border-t border-white/5 relative overflow-hidden">
  
  <div class="max-w-6xl mx-auto px-4 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/25 rounded-full px-4 py-1.5 mb-5">
        <span class="text-indigo-400 text-[10px] font-black uppercase tracking-widest">Expert Insights</span>
      </div>
      <h2 class="text-3xl md:text-5xl font-black text-white leading-tight mb-5">
        Deep-Dive Learning Guides & <br class="hidden md:block"/> 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-emerald-400">Udemy Savings Hacks</span>
      </h2>
      <p class="text-gray-500 text-lg max-w-2xl mx-auto leading-relaxed">
        Master the art of free education. Our experts break down the best courses, coupon strategies, and career paths for 2026.
      </p>
    </div>

    <!-- Blog Card Grid (Journal Style) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {topics.map((post) => (
        <a 
          href={`/blog/${post.id}`}
          class="group block bg-[#0c1219] border border-white/8 rounded-3xl overflow-hidden hover:border-indigo-500/30 transition-all duration-500 flex flex-col h-full hover:shadow-[0_8px_40px_rgba(0,0,0,0.5)]"
        >
          <!-- Image Section -->
          <div class="relative aspect-[16/10] overflow-hidden">
            <img 
              src={post.data.image?.src || 'https://images.unsplash.com/photo-1526379095098-d400fd0bf935?w=800&h=400&fit=crop'} 
              alt={post.data.title}
              class="w-full h-full object-cover grayscale-[0.3] group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0c1219] via-transparent to-transparent opacity-60"></div>
            
            {/* Category Tag */}
            <div class="absolute top-4 left-4 z-20">
                <span class="bg-indigo-600 text-white text-[9px] font-black px-2 py-1 rounded-lg uppercase tracking-widest shadow-xl">
                  {post.data.category || 'Guide'}
                </span>
            </div>
          </div>
          
          <!-- Content Section -->
          <div class="p-8 flex flex-col flex-1">
            <h3 class="font-bold text-xl text-white mb-4 group-hover:text-indigo-400 transition-colors line-clamp-2 leading-tight">
              {post.data.title}
            </h3>
            
            <p class="text-gray-500 text-sm leading-relaxed line-clamp-3 mb-8">
               {post.data.description || "Discover professional insights and actionable strategies to accelerate your learning journey and maximize your savings."}
            </p>

            <div class="mt-auto pt-6 border-t border-white/5 flex items-center justify-between">
              <div class="flex items-center gap-3">
                 <div class="w-8 h-8 rounded-full bg-indigo-500/20 flex items-center justify-center text-indigo-400 text-xs font-bold ring-1 ring-indigo-500/30">W</div>
                 <span class="text-gray-600 text-[10px] font-bold uppercase tracking-widest">{formatDate(post)}</span>
              </div>
              <span class="text-indigo-400 font-bold text-xs group-hover:translate-x-1 transition-all">Read More →</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-16 text-center">
       <a 
        href="/blog" 
        class="inline-flex items-center gap-3 px-8 py-4 bg-white/5 border border-white/10 rounded-2xl text-white font-black text-sm uppercase tracking-widest hover:bg-white/10 hover:border-indigo-500/30 transition-all shadow-xl group"
      >
        <span>Explore All Guides</span>
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

  </div>
</section>
