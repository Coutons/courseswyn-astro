---

interface Props {

  category: string;

  subcategories: string[];

  courseCount: number;

}



const { category, subcategories, courseCount } = Astro.props;

const displaySubcategories = subcategories.slice(0, 6);

const remainingCount = subcategories.length - 6;

---



<div class="bg-white/5 border border-white/10 rounded-3xl p-6 flex flex-col h-full hover:border-emerald-500/40 hover:shadow-[0_0_30px_rgba(16,185,129,0.15)] hover:-translate-y-1 transition-all duration-300 group relative overflow-hidden">
  <div class="absolute -top-12 -right-12 w-32 h-32 bg-emerald-500/10 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
  
  <div class="flex flex-col flex-grow relative z-10">
    <!-- Category Header -->
    <div class="mb-5 flex items-start justify-between">
      <span class="inline-block bg-emerald-500/10 text-emerald-400 text-sm font-black px-4 py-1.5 rounded-xl border border-emerald-500/20 shadow-[inset_0_1px_3px_rgba(16,185,129,0.2)]">
        {category}
      </span>
      <span class="text-[10px] font-bold text-gray-400 bg-black/40 px-2.5 py-1.5 rounded-lg border border-white/5 uppercase tracking-wide">
        {courseCount} courses
      </span>
    </div>

    <!-- Subcategory Count Info -->
    <p class="text-gray-400 text-[10px] font-black uppercase tracking-widest mb-4 border-b border-white/5 pb-3">
      {subcategories.length} Specialized Topics
    </p>

    <!-- Subcategory List -->
    <ul class="space-y-3 mb-6">
      {displaySubcategories.map((sub) => (
        <li class="group/link flex items-start gap-2">
          <svg class="w-4 h-4 text-emerald-500/50 group-hover/link:text-emerald-400 mt-0.5 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
          <a 
            href={`/courses/category/${encodeURIComponent(category)}?topic=${encodeURIComponent(sub)}`} 
            class="text-gray-300 hover:text-white text-sm font-medium transition-all group-hover/link:translate-x-1 duration-300"
          >
            {sub}
          </a>
        </li>
      ))}
      {remainingCount > 0 && (
        <li class="text-gray-500 text-xs italic pt-2 font-medium flex items-center gap-2">
           <span class="w-4 h-px bg-gray-700"></span> +{remainingCount} more technical paths
        </li>
      )}
    </ul>
  </div>

  <!-- Footer Link -->
  <div class="pt-5 mt-auto relative z-10">
    <a 
      href={`/courses/category/${encodeURIComponent(category)}`} 
      class="block w-full text-center bg-gradient-to-r from-emerald-600/10 to-cyan-600/10 hover:from-emerald-600 hover:to-cyan-600 text-emerald-400 hover:text-white text-xs font-black px-4 py-3.5 rounded-xl border border-emerald-500/30 hover:border-transparent transition-all uppercase tracking-widest shadow-lg"
    >
      Explore All →
    </a>
  </div>
</div>

