---
const currentYear = new Date().getFullYear();

const footerLinks = [
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact-us' },
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Terms of Service', href: '/terms' },
  { label: 'Udemy Coupon Code', href: '/udemy-coupon-code' },
  { label: 'Blog', href: '/blog' },
];

const categories = [
  { label: 'Development', href: '/courses/category/development' },
  { label: 'Business', href: '/courses/category/business' },
  { label: 'Design', href: '/courses/category/design' },
  { label: 'Marketing', href: '/courses/category/marketing' },
  { label: 'IT & Software', href: '/courses/category/it-software' },
];
---

<footer class="bg-[#0a0f16] border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- About Section -->
      <div>
        <h3 class="text-lg font-semibold text-white mb-4">
         <a href="/" class="flex items-center gap-1 group">
           <span class="text-2xl font-bold text-white tracking-tight group-hover:text-gray-200 transition-colors">Courses</span>
           <span class="text-2xl font-bold text-emerald-400 tracking-tight group-hover:text-emerald-300 transition-colors">Wyn</span>
        </a>
        </h3>
        <p class="text-slate-400 text-sm leading-relaxed">
        Get Free Online Courses with Certificates, Udemy Coupon, Udemy Coupon Codes, Free Udemy Online Courses, Udemy Free Courses, Online Sales and More...
        </p>
        
        <!-- Astro Showcase Recognition -->
        <div class="mt-8 p-4 bg-white/5 rounded-2xl border border-white/10 flex items-center gap-4 text-xs text-gray-400">
          <div class="shrink-0 w-10 h-10 bg-[#FF5D01]/10 rounded-xl flex items-center justify-center p-2">
            <svg class="w-full h-full" viewBox="0 0 85 107" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M27.5893 91.1365C22.7555 86.7178 21.3443 77.4335 23.3583 70.7072C26.8503 74.948 31.6888 76.2914 36.7005 77.0497C44.4374 78.2199 52.0358 77.7822 59.2231 74.2459C60.0453 73.841 60.8052 73.3027 61.7036 72.7574C62.378 74.714 62.5535 76.6892 62.3179 78.6996C61.7452 83.5957 59.3086 87.3778 55.4332 90.2448C53.8835 91.3916 52.2437 92.4167 50.6432 93.4979C45.7262 96.8213 44.3959 100.718 46.2435 106.386C46.2874 106.525 46.3267 106.663 46.426 107C43.9155 105.876 42.0817 104.24 40.6844 102.089C39.2086 99.8193 38.5065 97.3081 38.4696 94.5909C38.4511 93.2686 38.4511 91.9345 38.2733 90.6309C37.8391 87.4527 36.3471 86.0297 33.5364 85.9478C30.6518 85.8636 28.37 87.6469 27.7649 90.4554C27.7187 90.6707 27.6517 90.8837 27.5847 91.1341L27.5893 91.1365Z" fill="#FF5D01"/>
              <path d="M0 69.5866C0 69.5866 14.3139 62.6137 28.6678 62.6137L39.4901 29.1204C39.8953 27.5007 41.0783 26.3999 42.4139 26.3999C43.7495 26.3999 44.9325 27.5007 45.3377 29.1204L56.1601 62.6137C73.1601 62.6137 84.8278 69.5866 84.8278 69.5866C84.8278 69.5866 60.5145 3.35233 60.467 3.21944C59.7692 1.2612 58.5911 0 57.0029 0H27.8274C26.2392 0 25.1087 1.2612 24.3634 3.21944C24.3108 3.34983 0 69.5866 0 69.5866Z" fill="white"/>
            </svg>
          </div>
          <span>
            Featured in the <a href="https://astro.build/blog/whats-new-february-2026/" target="_blank" rel="noopener noreferrer" class="text-white hover:text-emerald-400 font-bold transition-colors">Official Astro Showcase</a> • 
            <a href="/blog/astro-showcase-courseswyn" class="text-white hover:text-emerald-400 font-bold transition-colors">Read our story</a>
          </span>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-bold text-white mb-6 tracking-tight">
          Quick Links
        </h3>
        <ul class="space-y-2">
          {footerLinks.map((link) => (
            <li>
              <a 
                href={link.href}
                class="text-gray-400 hover:text-emerald-400 text-sm transition-colors font-medium"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Helpful Guides -->
      <div>
        <h3 class="text-lg font-bold text-white mb-6 tracking-tight">
          Helpful Guides
        </h3>
        <ul class="space-y-2">
          <li>
            <a 
              href="/udemy-coupons-guide"
              class="text-gray-400 hover:text-emerald-400 text-sm transition-colors font-medium"
            >
              Udemy Coupons Guide
            </a>
          </li>
          <li>
            <a 
              href="/how-to-redeem-coupon"
              class="text-gray-400 hover:text-emerald-400 text-sm transition-colors font-medium"
            >
              How to Redeem Coupon
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-16 pt-8 border-t border-white/5">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-slate-400 text-sm">
          © {currentYear} CoursesWyn. All rights reserved.
        </p>
        <div class="flex gap-6">
          <a href="https://facebook.com/BestCouponPromo" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-emerald-400 transition-all hover:scale-110">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://twitter.com/CoursesGift" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-emerald-400 transition-all hover:scale-110">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
          <a href="https://medium.com/@coursewyn" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-emerald-400 transition-all hover:scale-110 flex items-center justify-center" aria-label="Medium @coursewyn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M2.846 6.887c.03-.295-.083-.586-.303-.784l-2.24-2.7v-.403h6.958l5.378 11.795 4.728-11.795h6.633v.403l-1.916 1.837c-.165.126-.247.333-.213.538v13.498c-.034.204.048.411.213.537l1.871 1.837v.403h-9.412v-.403l1.939-1.882c.19-.19.19-.246.19-.537v-10.91l-5.389 13.688h-.728l-6.275-13.688v9.174c-.052.385.076.774.347 1.052l2.521 3.058v.404h-7.148v-.404l2.521-3.058c.27-.279.39-.67.325-1.052v-10.61z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
