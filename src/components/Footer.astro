---
const currentYear = new Date().getFullYear();

const footerLinks = [
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact-us' },
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Terms of Service', href: '/terms' },
  { label: 'Blog', href: '/blog' },
  { label: 'How to Redeem Coupon', href: '/how-to-redeem-coupon' },
  { label: 'Udemy Coupons Guide', href: '/udemy-coupons-guide' },
  { label: 'Free Coupon Codes', href: '/udemy-coupon-code' },
];

const devTopics = [
  { label: 'Python', href: '/search?q=python' },
  { label: 'JavaScript', href: '/search?q=javascript' },
  { label: 'Web Development', href: '/search?q=web+development' },
  { label: 'React', href: '/search?q=react' },
  { label: 'Java', href: '/search?q=java' },
  { label: 'Machine Learning', href: '/search?q=machine+learning' },
  { label: 'Flutter', href: '/search?q=flutter' },
  { label: 'Node.js', href: '/search?q=nodejs' },
];

const aiTopics = [
  { label: 'Artificial Intelligence', href: '/search?q=artificial+intelligence' },
  { label: 'ChatGPT & Prompt Engineering', href: '/search?q=chatgpt' },
  { label: 'Generative AI', href: '/search?q=generative+ai' },
  { label: 'Data Science', href: '/search?q=data+science' },
  { label: 'Deep Learning', href: '/search?q=deep+learning' },
  { label: 'LangChain', href: '/search?q=langchain' },
  { label: 'CrewAI', href: '/search?q=crewai' },
  { label: 'n8n Automation', href: '/search?q=n8n' },
];

const businessTopics = [
  { label: 'Digital Marketing', href: '/search?q=digital+marketing' },
  { label: 'SEO', href: '/search?q=seo' },
  { label: 'Excel', href: '/search?q=excel' },
  { label: 'Project Management', href: '/search?q=project+management' },
  { label: 'Financial Modeling', href: '/search?q=financial+modeling' },
  { label: 'Entrepreneurship', href: '/search?q=entrepreneurship' },
  { label: 'Leadership', href: '/search?q=leadership' },
  { label: 'Public Speaking', href: '/search?q=public+speaking' },
];

const designTopics = [
  { label: 'UI/UX Design', href: '/search?q=ui+ux' },
  { label: 'Figma', href: '/search?q=figma' },
  { label: 'Photoshop', href: '/search?q=photoshop' },
  { label: 'Graphic Design', href: '/search?q=graphic+design' },
  { label: 'Canva', href: '/search?q=canva' },
  { label: 'Adobe Illustrator', href: '/search?q=adobe+illustrator' },
  { label: 'Blender 3D', href: '/search?q=blender' },
  { label: 'Video Editing', href: '/search?q=video+editing' },
];

const categories = [
  { label: 'Development', href: '/courses/category/development', emoji: '💻' },
  { label: 'Business', href: '/courses/category/business', emoji: '💼' },
  { label: 'Design', href: '/courses/category/design', emoji: '🎨' },
  { label: 'Marketing', href: '/courses/category/marketing', emoji: '📢' },
  { label: 'IT & Software', href: '/courses/category/it-software', emoji: '🖥️' },
  { label: 'Photography', href: '/search?q=photography', emoji: '📷' },
  { label: 'Health & Fitness', href: '/search?q=health', emoji: '💪' },
  { label: 'Music', href: '/search?q=music', emoji: '🎸' },
];
---

<footer class="bg-[#050810] border-t border-white/5 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-[500px] h-full bg-indigo-500/5 blur-[120px] pointer-events-none"></div>

  <!-- Main Footer Grid -->
  <div class="max-w-7xl mx-auto px-6 pt-20 pb-12 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8">

      <!-- Col 1: Brand Authority (Spans 4) -->
      <div class="lg:col-span-4 space-y-8">
        <div>
          <a href="/" class="inline-flex items-center gap-1 group mb-6">
            <span class="text-3xl font-black text-white tracking-tighter group-hover:text-gray-200 transition-all">Courses</span>
            <span class="text-3xl font-black text-indigo-400 tracking-tighter group-hover:text-indigo-300 transition-all">Wyn</span>
          </a>
          <p class="text-gray-500 text-sm leading-relaxed max-w-sm">
            The authoritative daily directory for verified Udemy coupon codes. We find, verify, and organize instructor offers so you can master the tech stacks of 2026 for $0.
          </p>
        </div>

        <div class="flex gap-4">
           {[
             { name: 'FB', href: 'https://facebook.com/BestCouponPromo', icon: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z' },
             { name: 'TW', href: 'https://twitter.com/CoursesGift', icon: 'M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z' },
             { name: 'MD', href: 'https://medium.com/@coursewyn', icon: 'M2.846 6.887c.03-.295-.083-.586-.303-.784l-2.24-2.7v-.403h6.958l5.378 11.795 4.728-11.795h6.633v.403l-1.916 1.837c-.165.126-.247.333-.213.538v13.498c-.034.204.048.411.213.537l1.871 1.837v.403h-9.412v-.403l1.939-1.882c.19-.19.19-.246.19-.537v-10.91l-5.389 13.688h-.728l-6.275-13.688v9.174c-.052.385.076.774.347 1.052l2.521 3.058v.404h-7.148v-.404l2.521-3.058c.27-.279.39-.67.325-1.052v-10.61z' }
           ].map(social => (
             <a href={social.href} class="w-10 h-10 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center text-gray-400 hover:text-indigo-400 hover:border-indigo-500/30 transition-all active:scale-95 shadow-lg">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d={social.icon}/></svg>
             </a>
           ))}
        </div>

        <!-- Technical Authority & Backlink -->
        <div class="p-5 bg-indigo-500/5 rounded-[2rem] border border-indigo-500/10 max-w-sm">
           <div class="flex items-center gap-3 mb-2">
              <div class="w-1.5 h-1.5 bg-indigo-500 rounded-full animate-pulse"></div>
              <span class="text-white text-[10px] font-black uppercase tracking-widest">Astro Showcase</span>
           </div>
           <p class="text-gray-500 text-xs leading-relaxed font-bold">
              Recognized for technical performance in the <a href="https://astro.build/blog/whats-new-february-2026/" target="_blank" class="text-indigo-400 hover:underline">Official Astro Showcase</a>.
           </p>
        </div>

        <!-- Real-time Verification Badge -->
        <div class="px-5 py-3 bg-indigo-500/5 rounded-2xl border border-indigo-500/10 max-w-sm mt-4 flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-indigo-500 rounded-full animate-ping"></div>
            <span class="text-white text-[10px] font-bold uppercase tracking-widest">Hourly Verification Active</span>
        </div>
      </div>

      <!-- Col 2: Tech Skills (Spans 2) -->
      <div class="lg:col-span-2">
        <h4 class="text-white font-black text-[11px] uppercase tracking-[0.2em] mb-8 border-l-2 border-indigo-500 pl-4">Engineering</h4>
        <ul class="space-y-4">
          {[...devTopics, { label: 'LangChain', href: '/search?q=langchain' }, { label: 'CrewAI', href: '/search?q=crewai' }].slice(0, 10).map(link => (
            <li>
              <a href={link.href} class="text-gray-500 hover:text-white text-xs font-bold transition-all hover:translate-x-1 inline-block">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: AI & Professional (Spans 2) -->
      <div class="lg:col-span-2">
        <h4 class="text-white font-black text-[11px] uppercase tracking-[0.2em] mb-8 border-l-2 border-indigo-500 pl-4">AI & Mastery</h4>
        <ul class="space-y-4">
          {[...aiTopics.filter(t => !['LangChain', 'CrewAI'].includes(t.label)), ...businessTopics].slice(0, 10).map(link => (
            <li>
              <a href={link.href} class="text-gray-500 hover:text-white text-xs font-bold transition-all hover:translate-x-1 inline-block">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Design & Creative (Spans 2) -->
      <div class="lg:col-span-2">
        <h4 class="text-white font-black text-[11px] uppercase tracking-[0.2em] mb-8 border-l-2 border-indigo-500 pl-4">Creative</h4>
        <ul class="space-y-4">
          {designTopics.map(link => (
            <li>
              <a href={link.href} class="text-gray-500 hover:text-white text-xs font-bold transition-all hover:translate-x-1 inline-block">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 5: Resources Column (Spans 2) -->
      <div class="lg:col-span-2 flex flex-col h-full bg-white/[0.02] border border-white/5 rounded-[2.5rem] p-8 -mt-2">
        <h4 class="text-white font-black text-[11px] uppercase tracking-[0.2em] mb-8">Resources</h4>
        <ul class="space-y-4 mb-auto">
          {footerLinks.map(link => (
            <li>
              <a href={link.href} class="text-gray-500 hover:text-indigo-400 text-xs font-black transition-all block">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-8 border-t border-white/5 pt-6">
           <span class="text-indigo-500 text-[10px] font-black uppercase">Directory Status</span>
           <div class="text-white text-lg font-black mt-1">Live & Active</div>
        </div>
      </div>

    </div>

    <!-- Bottom Categories Bar -->
    <div class="mt-20 pt-10 border-t border-white/5 flex flex-wrap items-center gap-3">
       <span class="text-gray-700 text-[10px] font-black uppercase tracking-widest mr-4">Common Silos:</span>
       {categories.map(cat => (
         <a
           href={cat.href}
           class="flex items-center gap-2 bg-white/3 border border-white/5 hover:border-indigo-500/30 hover:bg-white/5 text-gray-500 hover:text-indigo-400 text-[10px] font-black px-4 py-2 rounded-xl transition-all"
         >
           <span>{cat.emoji}</span>
           <span>{cat.label}</span>
         </a>
       ))}
    </div>

    <!-- Legal & Final Copy -->
    <div class="mt-12 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-gray-600 text-[11px] leading-relaxed max-w-2xl text-center md:text-left">
        © {currentYear} CoursesWyn Directory. All listings are subject to instructor availability. We may earn a commission from affiliate links to support our daily verification efforts.
      </p>
      <div class="flex gap-6 text-[10px] font-black uppercase tracking-widest shrink-0">
        <a href="/privacy" class="text-gray-500 hover:text-white transition-colors">Privacy</a>
        <a href="/terms" class="text-gray-500 hover:text-white transition-colors">Terms</a>
        <a href="/about" class="text-gray-500 hover:text-white transition-colors">About</a>
      </div>
    </div>
  </div>
</footer>
