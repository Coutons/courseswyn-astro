---
interface Props {
  name?: string;
  bio?: string;
  image?: string;
}

const { name = "Andrew Derek", bio = "Expert in digital education and curriculum mapping with 8+ years of experience.", image } = Astro.props;
const initials = name.split(' ').map((n: string) => n[0]).join('').substring(0, 2).toUpperCase();
---

<div style={{
  marginTop: "48px",
  padding: "32px",
  background: "var(--card)",
  border: "1px solid var(--border)",
  borderRadius: "16px",
  display: "flex",
  flexDirection: "column",
  gap: "24px"
}} class="md:flex-row">
  <div style={{ position: "relative", flexShrink: 0 }}>
    {image ? (
      <img src={image} alt={name} width="80" height="80" style={{
        width: "80px", height: "80px", borderRadius: "50%", objectFit: "cover",
        border: "2px solid var(--border)"
      }} />
    ) : (
      <div style={{
        width: "80px", height: "80px",
        background: "var(--accent)",
        border: "2px solid var(--border)",
        borderRadius: "50%",
        display: "flex", alignItems: "center", justifyContent: "center",
        color: "white", fontWeight: 900, fontSize: "2rem"
      }}>
        {initials}
      </div>
    )}
  </div>

  <div style={{ flex: 1 }}>
    <div style={{ display: "flex", flexWrap: "wrap", alignItems: "center", gap: "12px", marginBottom: "12px" }}>
      <h3 style={{ margin: 0, fontSize: "1.2rem", fontWeight: 700, color: "var(--text)" }}>{name}</h3>
      <span style={{
        background: "var(--brand-soft)", color: "var(--brand)",
        padding: "2px 10px", borderRadius: "6px", fontSize: "0.7rem", fontWeight: 600,
        textTransform: "uppercase", letterSpacing: "0.04em"
      }}>
        Lead Course Analyst
      </span>
    </div>
    <p style={{ margin: "0 0 20px", fontSize: "0.9rem", color: "var(--muted)", lineHeight: 1.6, fontWeight: 400 }}>
      {bio}
    </p>
    <div style={{ display: "flex", flexWrap: "wrap", gap: "20px", alignItems: "center" }}>
      <a href="mailto:admin@courseswyn.com" style={{
        fontSize: "0.8rem", fontWeight: 600, color: "var(--brand)",
        textDecoration: "none"
      }}>
        Contact Editorial Team →
      </a>
      <span style={{ fontSize: "0.7rem", color: "var(--muted)", fontWeight: 500, fontStyle: "italic" }}>
        Verified by CoursesWyn Editorial Board
      </span>
    </div>
  </div>
</div>

<style>
  @media (min-width: 768px) {
    .md\:flex-row { flex-direction: row !important; }
  }
</style>
