---
interface Props {
  name?: string;
  bio?: string;
  image?: string;
}

const { name = "Andrew Derek", bio = "Andrew Derek is a lead course analyst and digital education expert with 8+ years of experience evaluating online learning platforms. He has personally reviewed over 500 Udemy courses across programming, AI, data science, and cloud computing — helping students save money with verified 100% off coupon codes while finding high-quality instruction that delivers real career outcomes.", image } = Astro.props;
const initials = name.split(' ').map((n: string) => n[0]).join('').substring(0, 2).toUpperCase();
---

<div class="nl" itemscope itemtype="https://schema.org/Person">
  <div class="nl-inner">
    <div class="nl-top">
      <div class="nl-avatar">
        {image ? (
          <img src={image} alt={name} width="44" height="44" itemprop="image" style="width:44px;height:44px;border-radius:10px;object-fit:cover" />
        ) : (
          <span class="nl-init">{initials}</span>
        )}
      </div>
      <div>
        <div class="nl-name" itemprop="name">{name}</div>
        <div class="nl-role">Lead Course Analyst · CoursesWyn</div>
      </div>
    </div>

    <p class="nl-bio" itemprop="description">{bio}</p>

    <div class="nl-social">
      <a href="https://twitter.com/CourseGift" target="_blank" rel="noopener noreferrer" itemprop="sameAs" aria-label="Twitter">𝕏 Twitter</a>
      <a href="https://www.linkedin.com/in/andrew-derek/" target="_blank" rel="noopener noreferrer" itemprop="sameAs" aria-label="LinkedIn">in LinkedIn</a>
    </div>
  </div>
</div>

<style>
  .nl {
    margin-top: 3rem;
    padding: 1.5rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  .nl-inner { max-width: 480px; }
  .nl-top { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
  .nl-avatar {
    width: 44px; height: 44px;
    border-radius: 10px;
    background: var(--brand);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .nl-init { color: #fff; font-weight: 800; font-size: 0.9rem; }
  .nl-name { font-weight: 700; font-size: 0.95rem; color: var(--text); }
  .nl-role { font-size: 0.78rem; color: var(--muted); margin-top: 1px; }

  .nl-bio { font-size: 0.85rem; color: var(--muted); line-height: 1.55; margin: 0 0 0.75rem; }

  .nl-social { display: flex; gap: 1rem; margin-bottom: 1rem; }
  .nl-social a { font-size: 0.8rem; color: var(--muted); text-decoration: none; transition: color 0.2s; }
  .nl-social a:hover { color: var(--brand); }
</style>
