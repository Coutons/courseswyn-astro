---
import coupons from '../data/coupons.json';

// Get current date for display
const now = new Date();
const todayShort = now.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

// Get top 24 verified courses (recently updated) for better filtering experience
const featuredCourses = coupons
  .sort((a: any, b: any) => {
    const dateA = new Date(a.updatedAt || 0).getTime();
    const dateB = new Date(b.updatedAt || 0).getTime();
    return dateB - dateA;
  })
  .slice(0, 24);

// Helper function to get time ago
function getTimeAgo(date: string) {
  const diffMs = now.getTime() - new Date(date).getTime();
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  if (diffHours < 1) return 'Just now';
  if (diffHours < 24) return `${diffHours}h ago`;
  return `${Math.floor(diffHours / 24)}d ago`;
}

// Mastery Pillar Mapping Logic
const pillarMap: Record<string, { label: string, icon: string }> = {
  'all': { label: 'All Deals', icon: '💎' },
  'engineering': { label: 'Engineering', icon: '💻' },
  'ai': { label: 'AI & Data', icon: '🤖' },
  'business': { label: 'Business', icon: '💼' },
  'design': { label: 'Design', icon: '🎨' }
};

// Group categories found in featuredCourses dynamically
const foundPillarIds = new Set(['all']);
featuredCourses.forEach(course => {
   const cat = course.category?.toLowerCase() || '';
   const title = course.title?.toLowerCase() || '';
   if (cat.includes('development') || cat.includes('it & software') || cat.includes('engineering')) foundPillarIds.add('engineering');
   else if (cat.includes('business') || cat.includes('marketing') || cat.includes('finance')) foundPillarIds.add('business');
   else if (cat.includes('design') || cat.includes('photography')) foundPillarIds.add('design');
   if (title.includes('ai') || title.includes('gpt') || title.includes('agents') || cat.includes('data')) foundPillarIds.add('ai');
});

// Final Pillars to render
const activePillars = Object.keys(pillarMap)
  .filter(id => foundPillarIds.has(id))
  .map(id => ({ id, ...pillarMap[id] }));
---

<section id="featured-courses" class="py-24 bg-[#07090f] relative overflow-hidden">
  <!-- Subtle Grid Pattern (CSS Only) -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 30px 30px;"></div>

  <div class="max-w-6xl mx-auto px-4 relative z-10">
    
    <!-- Section Header: High Authority -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-10 mb-12">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/25 rounded-full px-4 py-1.5 mb-5">
            <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
            <span class="text-emerald-400 text-[10px] font-black uppercase tracking-widest">Live Verification: {todayShort}</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-black text-white leading-[0.9] mb-6 tracking-tighter">
          Instant <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-400">Coupon Discovery</span>
        </h2>
        <p class="text-gray-500 text-lg leading-relaxed">
           Select your mastery goal below. We verify instructor coupons hourly to ensure 100% enrollment success for the tech stacks of 2026.
        </p>
      </div>
      
      <!-- Quick Goal Filters -->
      <div class="flex flex-wrap gap-2 lg:justify-end" id="pillar-filters">
        {activePillars.map(pillar => (
          <button
            data-pillar={pillar.id}
            class="group px-6 py-3 bg-[#0c1219] border border-white/10 rounded-2xl text-xs font-black uppercase tracking-widest hover:border-emerald-500/50 hover:bg-emerald-500/5 transition-all flex items-center gap-2 pillar-btn active:scale-95 shadow-xl"
            class:list={pillar.id === 'all' ? 'active-pillar border-emerald-500/50 bg-emerald-500/5 text-emerald-400' : 'text-gray-500'}
          >
            <span>{pillar.icon}</span>
            {pillar.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Grid: Compact & High Impact -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="course-grid">
      {featuredCourses.map((course) => {
        const subcategorySlug = course.subcategory ? course.subcategory.toLowerCase().replace(/[^a-z0-9]+/g, '-') : '';
        const categorySlug = course.category ? course.category.toLowerCase().replace(/[^a-z0-9]+/g, '-') : '';
        
        // Map category to pillar
        let pillar = 'other';
        const cat = course.category?.toLowerCase() || '';
        const title = course.title?.toLowerCase() || '';
        if (cat.includes('development') || cat.includes('it & software') || cat.includes('engineering')) pillar = 'engineering';
        else if (cat.includes('business') || cat.includes('marketing') || cat.includes('finance')) pillar = 'business';
        else if (cat.includes('design') || cat.includes('photography') || cat.includes('music')) pillar = 'design';
        if (title.includes('ai') || title.includes('mastery') || title.includes('gpt') || title.includes('agents') || cat.includes('data')) pillar = 'ai';
        
        return (
          <div 
            class="course-item group relative bg-[#0c1219] border border-white/8 rounded-3xl overflow-hidden hover:border-emerald-500/30 transition-all flex flex-col h-full hover:shadow-[0_20px_50px_rgba(0,0,0,0.6)]"
            data-pillar={pillar}
          >
            
            <!-- Link Wrapper -->
            <a href={`/coupon/${course.slug}`} class="absolute inset-0 z-10" aria-label={`View details for ${course.title}`}></a>
            
            <!-- Thumbnail Section (Compact) -->
            <div class="relative aspect-[16/9] overflow-hidden flex-shrink-0">
               <img 
                src={course.image} 
                alt={course.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#0c1219] via-transparent to-transparent opacity-80"></div>
              
              <!-- Badges -->
              <div class="absolute top-3 left-3 z-20 flex flex-wrap gap-1.5">
                  <div class="bg-black/70 backdrop-blur-md text-emerald-400 text-[9px] font-black px-2 py-0.5 rounded border border-emerald-500/30 uppercase tracking-tighter">
                    Verified {getTimeAgo(course.updatedAt || new Date().toISOString())}
                  </div>
              </div>
              
              {course.rating >= 4.7 && (
                <div class="absolute bottom-3 right-3 z-20">
                    <span class="bg-yellow-500 text-black text-[8px] font-black px-1.5 py-0.5 rounded shadow-xl">TOP RATED</span>
                </div>
              )}
            </div>

            <!-- Content Section -->
            <div class="p-5 flex flex-col flex-1">
              <div class="flex items-center justify-between mb-2">
                 <span class="text-gray-600 text-[10px] font-medium uppercase tracking-widest">{course.category}</span>
                 <div class="flex items-center gap-1 text-[10px] text-gray-500">
                    <svg class="w-3 h-3 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    <span class="truncate max-w-[100px]">{course.instructor || "Instructor"}</span>
                 </div>
              </div>

              <h3 class="font-bold text-white text-base leading-tight group-hover:text-emerald-400 transition-colors line-clamp-2 mb-2 min-h-[2.5rem]">
                {course.title}
              </h3>

              <p class="text-gray-500 text-[11px] leading-relaxed line-clamp-2 mb-4 opacity-80">
                {course.description || course.seoDescription || "Master this subject with expert-led tutorials and practical hands-on experience."}
              </p>

              <div class="flex items-center gap-2 mb-5">
                 <div class="flex text-yellow-500 text-[10px]">★ <span class="text-white font-bold ml-1">{course.rating || '4.8'}</span></div>
                 <span class="w-1 h-1 bg-gray-700 rounded-full"></span>
                 <span class="text-gray-600 text-[10px] font-bold uppercase tracking-wider">{course.students?.toLocaleString() || '1,000'}+ ENROLLED</span>
              </div>

              <!-- Price & CTA Line -->
              <div class="mt-auto pt-4 border-t border-white/5 flex items-center justify-between gap-4">
                  <div class="flex flex-col">
                      <span class={`font-black text-xl leading-none ${course.price === 0 ? 'text-emerald-400 animate-pulse' : 'text-white'}`}>
                        {course.price === 0 ? 'FREE' : `$${course.price}`}
                      </span>
                      {course.originalPrice && course.originalPrice > course.price && (
                        <span class="text-gray-700 line-through text-[10px] mt-1">${course.originalPrice}</span>
                      )}
                  </div>
                  <a 
                    href={course.url} 
                    target="_blank" 
                    rel="nofollow noopener" 
                    class="relative z-20 px-4 py-2.5 bg-emerald-500/10 border border-emerald-500/25 text-emerald-400 text-[10px] font-black rounded-lg uppercase tracking-widest hover:bg-emerald-500 hover:text-white transition-all whitespace-nowrap block"
                  >
                    Get Coupon →
                  </a>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Mobile CTA -->
    <div class="mt-12 text-center md:hidden">
       <a href="/udemy-coupon-code" class="inline-flex items-center gap-2 text-emerald-400 font-bold text-sm bg-emerald-500/5 px-6 py-3 rounded-xl border border-emerald-500/20">
        View All {coupons.length}+ Udemy Coupon Codes
      </a>
    </div>

  </div>
</section>

<script>
  function initFilters() {
    const buttons = document.querySelectorAll('.pillar-btn');
    const items = document.querySelectorAll('.course-item');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const pillar = btn.getAttribute('data-pillar');
        
        // Toggle active state
        buttons.forEach(b => {
           b.classList.remove('active-pillar', 'border-emerald-500/50', 'bg-emerald-500/5', 'text-emerald-400');
           b.classList.add('text-gray-500', 'border-white/10');
        });
        btn.classList.add('active-pillar', 'border-emerald-500/50', 'bg-emerald-500/5', 'text-emerald-400');
        btn.classList.remove('text-gray-500', 'border-white/10');

        // Filter items
        items.forEach(item => {
           const itemPillar = item.getAttribute('data-pillar');
           if (pillar === 'all' || itemPillar === pillar) {
              (item as HTMLElement).style.display = 'flex';
              setTimeout(() => (item as HTMLElement).style.opacity = '1', 10);
           } else {
              (item as HTMLElement).style.opacity = '0';
              setTimeout(() => (item as HTMLElement).style.display = 'none', 300);
           }
        });
      });
    });
  }

  // Init on page load and after transition
  initFilters();
  document.addEventListener('astro:page-load', initFilters);
</script>

<style>
  .course-item {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .active-pillar {
    box-shadow: 0 0 20px rgba(16, 185, 129, 0.2);
  }
</style>
