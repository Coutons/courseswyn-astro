---
import type { HTMLAttributes } from 'astro/types';
import coupons from '../data/coupons.json';

interface Props extends HTMLAttributes<'div'> {}

const { ...props } = Astro.props;
const totalCoupons = coupons.length;
---

<section class="relative bg-[#0a0f16] border-b border-[#2d3748] py-24 overflow-hidden" {...props}>
  <!-- Ambient Background Glows -->
  <div class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-emerald-500/20 rounded-full blur-[120px] mix-blend-screen pointer-events-none animate-pulse" style="animation-duration: 4s;"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[600px] h-[600px] bg-blue-600/10 rounded-full blur-[150px] mix-blend-screen pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Left Column: Text -->
      <div>
        <!-- OPTIMIZED H1 dengan keyword "udemy coupon codes 2026" & Premium Typography -->
        <h1 class="text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-[1.1] tracking-tight drop-shadow-sm">
          Udemy Coupon Codes {new Date().getFullYear()}: <br class="hidden lg:block"/>
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-emerald-400 to-cyan-400">Get 100% OFF Discount</span> <br class="hidden lg:block"/>
          on {totalCoupons}+ Courses
        </h1>
        
        <!-- OPTIMIZED subtitle dengan keyword variations -->
        <p class="text-xl text-gray-300 mb-6 font-medium">
          Verified Udemy Promo Codes & Discount Coupons Updated Every Day
        </p>
        
        <!-- OPTIMIZED description dengan semantic keywords -->
        <p class="text-gray-400 leading-relaxed max-w-xl text-lg">
          Discover the latest Udemy coupon codes for {new Date().getFullYear()} with verified 100% OFF discounts. Access premium courses in Python, Web Development, AI, Business, and 500+ topics instantly.
        </p>
        
        <!-- Feature checklist - Redesigned as Glassmorphism Pills -->
        <div class="mt-8 flex flex-wrap gap-3 text-sm text-gray-200 font-medium tracking-wide">
          <div class="flex items-center gap-2 bg-white/5 backdrop-blur-md px-4 py-2.5 rounded-full border border-white/10 shadow-lg shadow-black/20">
            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            {totalCoupons}+ Verified Daily
          </div>
          <div class="flex items-center gap-2 bg-white/5 backdrop-blur-md px-4 py-2.5 rounded-full border border-white/10 shadow-lg shadow-black/20">
            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            100% OFF Discounts
          </div>
          <div class="flex items-center gap-2 bg-white/5 backdrop-blur-md px-4 py-2.5 rounded-full border border-white/10 shadow-lg shadow-black/20">
            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Lifetime Access
          </div>
          <div class="flex items-center gap-2 bg-white/5 backdrop-blur-md px-4 py-2.5 rounded-full border border-white/10 shadow-lg shadow-black/20">
            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Free Certificates
          </div>
        </div>
      </div>

      <!-- Right Column: Search & Buttons -->
      <div>
      <!-- OPTIMIZED Search Bar with Glassmorphism -->
      <form action="/search" method="GET" class="max-w-xl lg:ml-auto mb-10 relative group w-full">
        <div class="flex items-center bg-white/5 backdrop-blur-xl rounded-2xl border border-white/10 p-2 shadow-[0_8px_32px_rgba(0,0,0,0.3)] group-focus-within:border-emerald-500/50 group-focus-within:bg-white/10 transition-all duration-300 h-16">
           
           <!-- Icon -->
           <div class="pl-4 pr-3 text-emerald-400">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
           </div>
           
           <!-- Input -->
           <input 
              type="text" 
              name="q"
              id="hero-search-input"
              class="w-full bg-transparent border-none focus:ring-0 text-white placeholder-gray-400 text-lg h-full outline-none font-medium"
              autocomplete="off"
           />

           <!-- Right Hint (Cmd + K) -->
           <div class="hidden sm:flex items-center pr-4 text-xs text-gray-400 font-bold pointer-events-none gap-1.5 uppercase tracking-widest">
               <span>Press</span> 
               <kbd class="bg-black/30 border border-white/10 rounded-md px-2 py-1 text-white shadow-inner">⌘</kbd> 
               <span>+</span>
               <kbd class="bg-black/30 border border-white/10 rounded-md px-2 py-1 text-white shadow-inner">K</kbd>
           </div>
        </div>
      </form>

      <!-- Buttons -->
      <div class="flex flex-col sm:flex-row justify-end gap-4 max-w-xl lg:ml-auto">
         <a href="/courses" class="flex-1 flex items-center justify-center gap-3 px-8 py-4 bg-white text-[#0a0f16] rounded-xl font-extrabold hover:scale-[1.03] transition-transform shadow-[0_0_20px_rgba(255,255,255,0.2)]">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
            Browse Coupon Codes
         </a>
         <a href="/categories" class="flex-1 flex items-center justify-center gap-3 px-8 py-4 bg-white/5 backdrop-blur-md border border-white/10 text-white rounded-xl font-bold hover:bg-white/10 hover:border-white/20 transition-all">
             <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
             Explore Categories
         </a>
      </div>
      
      <!-- OPTIMIZED Typewriter Script with keyword-rich placeholders -->
      <script define:vars={{ totalCoupons }}>
        const input = document.getElementById('hero-search-input');
        const placeholders = [
            "Search for Udemy coupon codes...", 
            "Try: Python, Web Dev, Marketing...", 
            `${totalCoupons}+ discount codes updated daily`, 
            "Find 100% OFF Udemy promo codes"
        ];
        let pIndex = 0;
        let charIndex = 0;
        let isDeleting = false;
        let typeSpeed = 100;

        function type() {
            if (!input) return;
            
            const currentText = placeholders[pIndex];
            
            if (isDeleting) {
                input.placeholder = currentText.substring(0, charIndex--);
                typeSpeed = 50;
            } else {
                input.placeholder = currentText.substring(0, charIndex++);
                typeSpeed = 100;
            }

            if (!isDeleting && charIndex === currentText.length) {
                isDeleting = true;
                typeSpeed = 2000; // Pause at end
            } else if (isDeleting && charIndex === 0) {
                isDeleting = false;
                pIndex = (pIndex + 1) % placeholders.length;
                typeSpeed = 500;
            }

            setTimeout(type, typeSpeed);
        }

        // Start typing on load
        document.addEventListener('DOMContentLoaded', type);
        
        // Handle Cmd+K Focus
        document.addEventListener('keydown', (e) => {
            if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
                e.preventDefault();
                input?.focus();
            }
        });
      </script>

      </div>

    </div>
  </div>
</section>