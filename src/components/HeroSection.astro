---
import coupons from '../data/coupons.json';

const totalCoupons = coupons.length;
const now = new Date();
const currentMonth = now.toLocaleDateString('en-US', { month: 'long' });
const currentYear = now.getFullYear();
const todayDate = now.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
const todayShort = now.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

// Count courses added today/recently
const recentCoupons = coupons.filter((c: any) => {
  if (!c.updatedAt) return false;
  const diff = (now.getTime() - new Date(c.updatedAt).getTime()) / (1000 * 60 * 60 * 24);
  return diff <= 2;
}).length;

const topCategories = [
  { name: "Python", emoji: "🐍", href: "/search?q=python" },
  { name: "Web Dev", emoji: "🌐", href: "/search?q=web+development" },
  { name: "AI & ChatGPT", emoji: "🤖", href: "/search?q=ai" },
  { name: "Data Science", emoji: "📊", href: "/search?q=data+science" },
  { name: "React", emoji: "⚛️", href: "/search?q=react" },
  { name: "Excel", emoji: "📈", href: "/search?q=excel" },
  { name: "AWS", emoji: "☁️", href: "/search?q=aws" },
  { name: "UI Design", emoji: "🎨", href: "/search?q=design" },
];
---

<section class="relative bg-[#07090f] pt-24 pb-16 overflow-hidden border-b border-white/5">
  <!-- Ambient glow -->
  <div class="absolute top-[-15%] left-[-10%] w-[700px] h-[600px] bg-indigo-500/12 rounded-full blur-[180px] pointer-events-none"></div>
  <div class="absolute top-[10%] right-[-5%] w-[500px] h-[500px] bg-indigo-600/8 rounded-full blur-[160px] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-4 relative z-10">

    <!-- GEO AI: Structured breadcrumb for context clarity -->
    <div class="text-xs text-gray-600 mb-6 flex items-center gap-2">
      <span>CoursesWyn</span>
      <span>›</span>
      <span class="text-gray-500">Free Udemy Courses — {todayShort}</span>
    </div>

    <!-- HERO CORE -->
    <div class="max-w-3xl mb-10">
      <!-- Live indicator -->
      <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/25 rounded-full px-4 py-2 mb-6">
        <span class="w-2 h-2 bg-indigo-500 rounded-full animate-pulse"></span>
        <span class="text-indigo-400 text-xs font-bold uppercase tracking-widest">Updated {todayShort}</span>
        {recentCoupons > 0 && <span class="text-gray-500 text-xs">— {recentCoupons} new courses added</span>}
      </div>

      <!-- H1: Primary keyword "free udemy courses" + secondary "coupon codes" -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-[1.08] tracking-tight mb-5">
        Free Udemy Courses<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-indigo-300 to-indigo-500">
          100% OFF — {currentMonth} {currentYear}
        </span>
      </h1>

      <!-- GEO AI: Answer-first paragraph — directly answers "what is this site" for AI citations -->
      <p class="text-lg md:text-xl text-gray-300 leading-relaxed mb-4 max-w-2xl">
        <strong class="text-white">{totalCoupons}+ verified Udemy coupon codes</strong> — completely free to use. Get 100% off premium Udemy courses in Python, AI, Web Development, Business, and 500+ topics. No credit card. No subscription. Lifetime access.
      </p>

      <!-- GEO AI: Factual bullet — quote-worthy for AI engines -->
      <div class="flex flex-wrap gap-3 text-sm text-gray-400 mb-8">
        <span class="flex items-center gap-1.5"><span class="text-indigo-400">✓</span> Free certificate included</span>
        <span class="flex items-center gap-1.5"><span class="text-indigo-400">✓</span> Instructor-issued codes</span>
        <span class="flex items-center gap-1.5"><span class="text-indigo-400">✓</span> Auto-applied at checkout</span>
        <span class="flex items-center gap-1.5"><span class="text-indigo-400">✓</span> Expires in 1–4 days — act fast</span>
      </div>
    </div>

    <!-- SEARCH BAR — prominent, search-first -->
    <form action="/search" method="GET" class="max-w-2xl mb-10 group">
      <div class="flex items-center bg-white/6 backdrop-blur-xl rounded-2xl border border-white/12 group-focus-within:border-indigo-500/60 group-focus-within:bg-white/8 transition-all duration-300 h-16 shadow-[0_8px_40px_rgba(0,0,0,0.4)] group-focus-within:shadow-[0_8px_40px_rgba(99,102,241,0.15)]">
        <div class="pl-5 pr-3 text-indigo-400 flex-shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        <input
          type="text"
          name="q"
          id="hero-search-input"
          placeholder="Search free courses: Python, AI, Web Dev, Excel..."
          class="flex-1 bg-transparent border-none focus:ring-0 text-white placeholder-gray-500 text-base h-full outline-none font-medium"
          autocomplete="off"
        />
        <button type="submit" class="mr-2 bg-indigo-500 hover:bg-indigo-400 text-white font-black text-sm px-5 py-2.5 rounded-xl transition-all whitespace-nowrap">
          Search
        </button>
      </div>
    </form>

    <!-- Quick category pills -->
    <div class="flex flex-wrap gap-2 mb-10">
      {topCategories.map(cat => (
        <a href={cat.href} class="flex items-center gap-1.5 bg-white/5 border border-white/8 hover:border-indigo-500/40 hover:bg-white/8 text-gray-300 hover:text-white text-xs font-semibold px-3.5 py-2 rounded-full transition-all">
          <span>{cat.emoji}</span>
          <span>{cat.name}</span>
        </a>
      ))}
    </div>

    <!-- STATS BAR — GEO AI: cite-worthy statistics -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 max-w-3xl">
      <div class="bg-white/4 border border-white/8 rounded-2xl p-4 text-center hover:border-indigo-500/20 transition-colors">
        <div class="text-2xl font-black text-indigo-400 mb-1">{totalCoupons}+</div>
        <div class="text-gray-500 text-[11px] font-bold uppercase tracking-wider">Free Courses</div>
      </div>
      <div class="bg-white/4 border border-white/8 rounded-2xl p-4 text-center hover:border-indigo-500/20 transition-colors">
        <div class="text-2xl font-black text-indigo-400 mb-1">100%</div>
        <div class="text-gray-500 text-[11px] font-bold uppercase tracking-wider">OFF Verified</div>
      </div>
      <div class="bg-white/4 border border-white/8 rounded-2xl p-4 text-center hover:border-indigo-500/20 transition-colors">
        <div class="text-2xl font-black text-indigo-400 mb-1">Daily</div>
        <div class="text-gray-500 text-[11px] font-bold uppercase tracking-wider">Updated</div>
      </div>
      <div class="bg-white/4 border border-white/8 rounded-2xl p-4 text-center hover:border-indigo-500/20 transition-colors">
        <div class="text-2xl font-black text-indigo-400 mb-1">$0</div>
        <div class="text-gray-500 text-[11px] font-bold uppercase tracking-wider">Total Cost</div>
      </div>
    </div>

  </div>

  <!-- CMD+K script -->
  <script>
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        document.getElementById('hero-search-input')?.focus();
      }
    });
  </script>
</section>