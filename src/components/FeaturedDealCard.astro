---
import { Image } from 'astro:assets';

interface Deal {
  id?: string;
  slug?: string;
  title: string;
  description?: string;
  image?: string;
  rating?: number;
  students?: number;
  price?: number;
  originalPrice?: number;
  category?: string;
  subcategory?: string;
  duration?: string;
  url?: string;
  provider?: string;
  updatedAt?: string;
}

const { deal, rank } = Astro.props;

function formatStudents(n: number) {
  if (n >= 1000000) return (n / 1000000).toFixed(1).replace(/\.0$/, "") + "m";
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, "") + "k";
  return String(n);
}

function genRating(key: string): number {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < key.length; i++) {
    h ^= key.charCodeAt(i);
    h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24);
  }
  const r = (h >>> 0) / 0xffffffff;
  const val = 4.5 + 0.3 * r;
  return Math.round(val * 10) / 10;
}

function genStudents(key: string): number {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < key.length; i++) {
    h ^= key.charCodeAt(i);
    h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24);
  }
  const r = (h >>> 0) / 0xffffffff;
  const min = 1000, max = 80000;
  const val = Math.floor(min + (max - min) * Math.pow(r, 0.6));
  return Math.round(val / 10) * 10;
}

const key = String(deal.id || "");
const p = typeof deal.price === "number" && isFinite(deal.price) && deal.price > 0 ? deal.price : 0;
const opRaw = typeof deal.originalPrice === "number" && isFinite(deal.originalPrice) ? deal.originalPrice : 119.99;
const op = opRaw > p ? opRaw : 119.99;
const r = typeof deal.rating === "number" && isFinite(deal.rating) ? deal.rating : genRating(key);
const s = (typeof deal.students === "number" && isFinite(deal.students) && deal.students > 0) ? deal.students : genStudents(key);
const hasDiscount = op > p && p > 0;
const discountPct = hasDiscount ? Math.round(100 - (p / op) * 100) : null;
const title = String(deal.title || "").replace(/&amp;/g, "&").replace(/&quot;/g, '"').replace(/&apos;|&#8217;/g, "'").replace(/&ndash;|&#8211;/g, " & ").replace(/\s{2,}/g, " ").trim();
---

<div style={{
  background: "var(--card)",
  borderRadius: "20px",
  border: "2px solid rgba(255, 215, 0, 0.3)",
  overflow: "hidden",
  transition: "all 0.4s cubic-bezier(0.4, 0, 0.2, 1)",
  position: "relative",
  boxShadow: "0 12px 24px -4px rgba(255, 215, 0, 0.15), 0 4px 8px -2px rgba(0, 0, 0, 0.1)",
  cursor: "pointer"
}}>
  {/* Premium Badge */}
  <div style={{
    position: "absolute",
    top: "12px",
    right: "12px",
    background: "linear-gradient(135deg, #FFD700 0%, #FFA500 100%)",
    color: "var(--bg)",
    padding: "6px 12px",
    borderRadius: "16px",
    fontSize: "0.75rem",
    fontWeight: 800,
    textTransform: "uppercase",
    letterSpacing: "0.5px",
    boxShadow: "0 4px 12px -2px rgba(255, 215, 0, 0.4)",
    zIndex: 10,
    display: "flex",
    alignItems: "center",
    gap: "4px"
  }}>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
    #{rank}
  </div>

  {/* Course Image with Golden Border */}
  <div style={{
    height: "200px",
    background: `linear-gradient(135deg, var(--brand-soft) 0%, var(--accent-soft) 100%)`,
    display: "flex",
    alignItems: "center",
    justifyContent: "center",
    position: "relative",
    borderBottom: "2px solid rgba(255, 215, 0, 0.2)"
  }}>
    {deal.image ? (
      <Image
        src={deal.image}
        alt={title}
        width={400}
        height={225}
        style={{
          width: "100%",
          height: "100%",
          objectFit: "cover",
          borderRadius: "2px"
        }}
        loading="lazy"
        inferSize={false}
      />
    ) : (
      <svg width="80" height="80" viewBox="0 0 24 24" fill="var(--muted)" opacity="0.5">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    )}

    {/* Duration Badge */}
    {deal.duration && (
      <div style={{
        position: "absolute",
        bottom: "12px",
        left: "12px",
        background: "rgba(255, 215, 0, 0.95)",
        color: "var(--bg)",
        padding: "4px 8px",
        borderRadius: "12px",
        fontSize: "0.75rem",
        fontWeight: 700,
        display: "flex",
        alignItems: "center",
        gap: "4px",
        boxShadow: "0 2px 8px rgba(255, 215, 0, 0.3)"
      }}>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
        </svg>
        {deal.duration}
      </div>
    )}

    {/* FREE Badge */}
    {p === 0 && (
      <div style={{
        position: "absolute",
        top: "12px",
        left: "12px",
        background: "linear-gradient(135deg, #22C55E 0%, #16A34A 100%)",
        color: "white",
        padding: "6px 12px",
        borderRadius: "16px",
        fontSize: "0.75rem",
        fontWeight: 800,
        textTransform: "uppercase",
        letterSpacing: "0.5px",
        boxShadow: "0 4px 12px -2px rgba(34, 197, 94, 0.4)"
      }}>
        100% FREE
      </div>
    )}
  </div>

  {/* Course Content with Premium Styling */}
  <div style={{ padding: "2rem" }}>
    {/* Rating Stars */}
    <div style={{
      display: "flex",
      alignItems: "center",
      gap: "0.5rem",
      marginBottom: "1rem"
    }}>
      <div style={{ display: "flex", gap: "2px", alignItems: "center" }}>
        {[...Array(5)].map((_, i) => (
          <svg width="18" height="18" viewBox="0 0 24 24" fill={i < Math.floor(r) ? "#FFD700" : "rgba(255, 215, 0, 0.3)"}>
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        ))}
      </div>
      <span style={{
        color: "#D97706",
        fontSize: "0.9rem",
        fontWeight: 700
      }}>
        {r.toFixed(1)}
      </span>
      <span style={{
        color: "var(--muted)",
        fontSize: "0.8rem"
      }}>
        ({formatStudents(s)})
      </span>
    </div>

    {/* Title */}
    <h3 style={{
      fontSize: "1.25rem",
      fontWeight: 800,
      color: "var(--text)",
      marginBottom: "0.75rem",
      lineHeight: 1.3,
      display: "-webkit-box",
      WebkitLineClamp: 2,
      WebkitBoxOrient: "vertical",
      overflow: "hidden"
    }}>
      <a href={`/coupon/${deal.slug || deal.id}`} style={{
        color: "inherit",
        textDecoration: "none"
      }}>
        {title}
      </a>
    </h3>

    {/* Description */}
    <p style={{
      color: "var(--muted)",
      fontSize: "0.95rem",
      marginBottom: "1.25rem",
      lineHeight: 1.5,
      display: "-webkit-box",
      WebkitLineClamp: 2,
      WebkitBoxOrient: "vertical",
      overflow: "hidden"
    }}>
      {deal.description || "Master this in-demand skill with comprehensive training from industry experts and earn valuable certificates."}
    </p>

    {/* Category Badge */}
    {deal.category && (
      <div style={{
        display: "inline-flex",
        alignItems: "center",
        gap: "4px",
        background: "rgba(255, 215, 0, 0.1)",
        color: "#D97706",
        padding: "4px 8px",
        borderRadius: "8px",
        fontSize: "0.75rem",
        fontWeight: 600,
        marginBottom: "1rem"
      }}>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
          <path d="M10 4H4c-1.11 0-2 .89-2 2v3h2V6h4V4zM10 19v-2H4v-3H2v3c0 1.11.89 2 2 2h6zM20 4h-6v2h4v3h2V6c0-1.11-.89-2-2-2zM20 16h-2v3h-4v2h6c1.11 0 2-.89 2-2v-3z"/>
        </svg>
        {deal.category}
      </div>
    )}

    {/* Price Section */}
    <div style={{
      display: "flex",
      alignItems: "center",
      justifyContent: "space-between",
      marginBottom: "1.25rem"
    }}>
      <div style={{ display: "flex", alignItems: "center", gap: "0.75rem" }}>
        <span style={{
          fontSize: "1.5rem",
          fontWeight: 800,
          color: p === 0 ? "#16A34A" : "var(--brand)"
        }}>
          {p === 0 ? "FREE" : `$${p.toFixed(2)}`}
        </span>
        {hasDiscount && (
          <>
            <span style={{
              textDecoration: "line-through",
              color: "var(--muted)",
              fontSize: "1rem"
            }}>
              ${op.toFixed(2)}
            </span>
            <span style={{
              background: "linear-gradient(135deg, #EF4444 0%, #DC2626 100%)",
              color: "white",
              padding: "2px 6px",
              borderRadius: "6px",
              fontSize: "0.7rem",
              fontWeight: 800
            }}>
              -{discountPct}%
            </span>
          </>
        )}
      </div>
    </div>

    {/* CTA Button */}
    <a
      href={deal.url || `/coupon/${deal.slug || deal.id}`}
      target="_blank"
      rel="noopener noreferrer"
      style={{
        display: "block",
        width: "100%",
        padding: "0.875rem",
        background: "linear-gradient(135deg, #FFD700 0%, #FFA500 100%)",
        color: "var(--bg)",
        textDecoration: "none",
        borderRadius: "12px",
        textAlign: "center",
        fontWeight: 700,
        fontSize: "1rem",
        transition: "all 0.3s ease",
        border: "none",
        cursor: "pointer",
        boxShadow: "0 4px 16px -4px rgba(255, 215, 0, 0.4)"
      }}
    >
      {p === 0 ? "🎉 Enroll for FREE" : "🚀 Get Premium Deal"}
    </a>
  </div>
</div>

<style>
  div:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -8px rgba(255, 215, 0, 0.25), 0 8px 16px -4px rgba(0, 0, 0, 0.15) !important;
  }

  div:hover a:last-child {
    background: linear-gradient(135deg, #FFA500 0%, #FF8C00 100%) !important;
    box-shadow: 0 6px 20px -4px rgba(255, 165, 0, 0.5) !important;
  }
</style>
