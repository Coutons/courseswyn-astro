---
// Udemy Personal Plan — Cinematic Pro Banner
---

<section id="personal-plan" class="py-12 bg-[#07090f] relative overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-[500px] bg-indigo-500/5 blur-[160px] pointer-events-none"></div>
  
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <a
      href="https://trk.udemy.com/c/6564357/3775958/39854"
      target="_blank"
      rel="nofollow noopener"
      class="group relative block rounded-[2.5rem] p-[1px] bg-gradient-to-br from-indigo-500/30 via-transparent to-white/5 overflow-hidden transition-all duration-500 hover:scale-[1.01] hover:shadow-[0_20px_60px_-15px_rgba(79,70,229,0.3)]"
    >
      <!-- Glass Inner -->
      <div class="relative bg-[#0c1219]/90 backdrop-blur-2xl rounded-[2.5rem] p-8 md:p-10 flex flex-col lg:flex-row items-center justify-between gap-10">
        
        <!-- Left: Branding & Offer -->
        <div class="flex flex-col md:flex-row items-center gap-8 text-center md:text-left">
           <div class="relative">
              <div class="w-16 h-16 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center text-3xl shadow-xl transform rotate-3 group-hover:rotate-0 transition-transform duration-500">
                💎
              </div>
              <div class="absolute -top-2 -right-2 w-6 h-6 bg-emerald-500 border-4 border-[#0c1219] rounded-full animate-pulse"></div>
           </div>
           
           <div>
              <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/20 rounded-full px-4 py-1 mb-4">
                 <span class="text-indigo-400 text-[10px] font-black uppercase tracking-widest">Mastery Choice</span>
              </div>
              <h2 class="text-2xl md:text-3xl font-black text-white leading-tight mb-2">
                Unlock <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">27,000+ Premium Courses</span>
              </h2>
              <p class="text-gray-400 font-medium">
                 Get unlimited access to Udemy's top-rated professional content with a <strong class="text-white">7-day free trial</strong>.
              </p>
           </div>
        </div>

        <!-- Right: Social Proof & CTA -->
        <div class="flex flex-col md:flex-row items-center gap-8 w-full lg:w-auto">
           <div class="hidden sm:block border-l border-white/5 pl-8 py-2">
              <div class="text-yellow-400 flex gap-0.5 mb-1">
                 {[...Array(5)].map(() => (
                   <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                 ))}
              </div>
              <div class="text-white font-black text-sm">4.6/5 Trust Rating</div>
              <div class="text-gray-600 text-[10px] font-bold uppercase tracking-widest">Global Student Choice</div>
           </div>

           <div class="w-full md:w-auto">
              <span class="block w-full text-center bg-white text-black font-black px-10 py-5 rounded-2xl transition-all hover:bg-indigo-50 hover:shadow-[0_0_20px_rgba(255,255,255,0.3)] active:scale-95 text-sm uppercase tracking-widest">
                Start Learning Now →
              </span>
           </div>
        </div>

      </div>
    </a>
  </div>
</section>
