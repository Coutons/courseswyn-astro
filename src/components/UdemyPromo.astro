---
// Udemy Personal Plan Promo - High Authority Rebuild
import udemyImage from '../assets/images/Udemy Personal Plan Offers.png';

const planFeatures = [
  {
    title: "26,000+ Premium Courses",
    desc: "Unlimited access to Udemy's top-rated professional content in development, IT, business, and more.",
    icon: "📚"
  },
  {
    title: "Learn at Your Own Pace",
    desc: "Lifetime access to subscription content with new premium courses added automatically every month.",
    icon: "⏳"
  },
  {
    title: "Professional Certification",
    desc: "Earn official completion certificates to showcase your skills to employers or on LinkedIn.",
    icon: "📜"
  },
  {
    title: "No Risk Trial",
    desc: "Try the Personal Plan free for 7 days. Cancel anytime if it's not the right fit for your learning goals.",
    icon: "✨"
  }
];
---

<section id="personal-plan" class="py-24 bg-[#07090f] relative overflow-hidden border-t border-white/5">
  <!-- Subtle Cinematic Background -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-indigo-500/10 rounded-full blur-[150px] mix-blend-screen pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[400px] bg-emerald-500/8 rounded-full blur-[120px] mix-blend-screen pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-4 relative z-10">
    <div class="bg-[#111827]/80 backdrop-blur-3xl border border-white/8 rounded-[2.5rem] overflow-hidden shadow-2xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center p-8 lg:p-16 relative">
        
        <!-- Decoration: Background Text -->
        <div class="absolute top-10 left-10 text-white/5 font-black text-8xl uppercase pointer-events-none select-none tracking-tighter">
          PREMIUM
        </div>

        <!-- Left Column: Content Area -->
        <div class="relative z-10">
          <div class="inline-flex items-center gap-2 bg-indigo-500/15 border border-indigo-500/30 rounded-full px-4 py-1.5 mb-8">
            <span class="w-2 h-2 bg-indigo-400 rounded-full animate-pulse"></span>
            <span class="text-indigo-300 text-[10px] font-black uppercase tracking-widest">Recommended Learning Path</span>
          </div>

          <h2 class="text-3xl md:text-5xl font-black text-white leading-tight mb-6">
            Beyond Coupons:<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-emerald-400">Udemy Personal Plan</span>
          </h2>

          <p class="text-gray-400 text-lg leading-relaxed mb-10 max-w-lg">
            Unlock the most powerful subscription in online learning. One monthly price for thousands of premium courses with <strong class="text-white">full certificate support</strong> and exclusive content.
          </p>

          <!-- Savings/Value Box -->
          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 mb-10 group hover:border-indigo-500/30 transition-all">
            <div class="flex items-center gap-4">
              <div class="text-3xl">💎</div>
              <div>
                <div class="text-white font-bold text-sm">Estimated Total Value</div>
                <div class="text-indigo-400 text-2xl font-black tracking-tight leading-none mt-1">$5,000+ Included</div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-12">
            {planFeatures.map(item => (
              <div class="flex gap-4">
                <div class="text-2xl mt-1">{item.icon}</div>
                <div>
                  <h4 class="text-white font-bold text-sm mb-1">{item.title}</h4>
                  <p class="text-gray-500 text-[11px] leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- CTA Area -->
          <div class="flex flex-col sm:flex-row items-center gap-6">
            <a 
              href="https://trk.udemy.com/c/6564357/3775958/39854" 
              target="_blank"
              rel="nofollow noopener"
              class="w-full sm:w-auto px-10 py-5 bg-gradient-to-r from-indigo-600 to-indigo-500 text-white rounded-2xl font-black text-sm uppercase tracking-widest shadow-[0_10px_30px_rgba(79,70,229,0.3)] hover:shadow-[0_15px_40px_rgba(79,70,229,0.5)] hover:scale-[1.03] active:scale-95 transition-all text-center group"
            >
              Start Free Trial →
            </a>
            <div class="flex flex-col items-center sm:items-start leading-none gap-2">
              <div class="flex text-yellow-400 gap-0.5">
                {[...Array(5)].map(() => (
                  <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                ))}
              </div>
              <span class="text-gray-500 text-[10px] font-bold uppercase tracking-wider">4.6 Rated by 400K+ Students</span>
            </div>
          </div>
        </div>

        <!-- Right Column: Visual Section -->
        <div class="hidden lg:block relative z-10">
          <div class="relative group">
            <!-- Decorative halo behind the image -->
            <div class="absolute -inset-10 bg-gradient-to-br from-indigo-500/20 to-emerald-500/20 rounded-full blur-3xl opacity-50 transition-opacity duration-500 group-hover:opacity-80"></div>
            
            <div class="relative rotate-2 group-hover:rotate-0 transition-transform duration-700">
               <div class="absolute -inset-1 bg-gradient-to-r from-white/10 to-transparent rounded-3xl blur opacity-25"></div>
               <img 
                src={udemyImage.src} 
                alt="Udemy Personal Plan — Access thousands of premium professional courses"
                class="relative rounded-3xl shadow-2xl border border-white/5 transition-transform duration-500 group-hover:scale-[1.02]"
                loading="lazy"
              />
            </div>

            <!-- Floater badge -->
            <div class="absolute -bottom-10 -right-10 bg-[#07090f] border border-white/12 rounded-3xl p-6 shadow-2xl animate-float">
                <div class="text-emerald-400 font-black text-2xl tracking-tighter leading-none mb-1">FREE</div>
                <div class="text-gray-500 text-[10px] font-bold uppercase tracking-wide">7-Day Access Pass</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(2deg); }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
</style>
