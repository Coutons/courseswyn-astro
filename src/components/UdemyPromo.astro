---
// Udemy Personal Plan Promo
import udemyImage from '../assets/images/Udemy Personal Plan Offers.png';
---

<section class="py-20 bg-[#0a0f16] relative overflow-hidden">
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-emerald-500/10 rounded-full blur-[150px] mix-blend-screen pointer-events-none"></div>
  <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="bg-[#131922]/80 backdrop-blur-xl border border-white/10 rounded-3xl overflow-hidden shadow-[0_8px_32px_rgba(0,0,0,0.5)]">
      <div class="grid grid-cols-1 lg:grid-cols-[40%_60%] gap-8 items-center p-8 lg:p-12 relative">
        <!-- Ambient Glow strictly inside the card -->
        <div class="absolute -bottom-1/2 -left-1/4 w-[400px] h-[400px] bg-emerald-500/20 rounded-full blur-[100px] mix-blend-screen pointer-events-none"></div>
        
        <!-- Left: Content -->
        <div>
          <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4">
            Looking for more than just free Udemy coupon codes?
          </h2>
          <p class="text-gray-300 text-lg mb-6">
            Try the Udemy Personal Plan. Get unlimited access to 26,000+ top premium courses, anytime, anywhere.
          </p>
          
          <div class="flex items-center gap-4 mb-8">
            <div class="flex text-yellow-400 gap-0.5">
              {[...Array(5)].map(() => (
                <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <span class="text-gray-400 text-sm font-medium">4.6 (400,000+ students)</span>
          </div>
          
          <!-- Features -->
          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-[#10b981]/20 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-[#10b981]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <h3 class="text-white font-semibold mb-1">Access 26,000+ courses</h3>
                <p class="text-gray-400 text-sm">Learn from industry experts in tech, business, design, and more</p>
              </div>
            </div>
            
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-[#10b981]/20 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-[#10b981]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <h3 class="text-white font-semibold mb-1">Learn at your own pace</h3>
                <p class="text-gray-400 text-sm">Lifetime access to courses with new content added monthly</p>
              </div>
            </div>
            
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-[#10b981]/20 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-[#10b981]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <h3 class="text-white font-semibold mb-1">Get certificates</h3>
                <p class="text-gray-400 text-sm">Earn certificates of completion to showcase your achievements</p>
              </div>
            </div>
          </div>
          
          <!-- CTA Button -->
          <a 
            href="https://trk.udemy.com/c/6564357/3775958/39854" 
            target="_blank"
            rel="noopener noreferrer"
            class="relative overflow-hidden inline-flex px-8 py-4 bg-gradient-to-r from-emerald-500 to-emerald-400 text-white rounded-xl hover:scale-105 transition-all font-bold text-lg shadow-[0_0_15px_rgba(16,185,129,0.3)] hover:shadow-[0_0_25px_rgba(16,185,129,0.5)] uppercase tracking-wider group/btn"
          >
            <div class="absolute inset-0 -translate-x-full group-hover/btn:animate-[shimmer_1.5s_infinite] bg-gradient-to-r from-transparent via-white/30 to-transparent skew-x-12"></div>
            <span class="relative z-10">Start Free Trial</span>
          </a>
        </div>
        
        <!-- Right: Image/Illustration -->
        <div class="hidden lg:block relative z-10">
          <div class="relative h-96 flex items-center justify-center">
            <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/10 to-transparent rounded-2xl transform rotate-3"></div>
            <img 
              src={udemyImage.src} 
              alt="Udemy Personal Plan Offers - Premium Learning Access"
              class="w-full h-full object-contain rounded-2xl drop-shadow-[0_10px_20px_rgba(0,0,0,0.5)] transform -rotate-2 hover:rotate-0 hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
