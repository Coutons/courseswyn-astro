---
import coupons from '../data/coupons.json';

const totalCoupons = coupons.length;
const now = new Date();
const currentMonth = now.toLocaleDateString('en-US', { month: 'long' });
const currentYear = now.getFullYear();
const todayDate = now.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });

// GEO: Geo-targeted pricing by region (for AI citation + local SEO)
const geoPricing = [
  { flag: "🇮🇩", country: "Indonesia", local: "Rp 129.000 – Rp 179.000", usd: "≈ $8–$11" },
  { flag: "🇮🇳", country: "India", local: "₹449 – ₹649", usd: "≈ $5–$8" },
  { flag: "🇧🇷", country: "Brazil", local: "R$49 – R$69", usd: "≈ $9–$13" },
  { flag: "🇵🇭", country: "Philippines", local: "₱549 – ₱799", usd: "≈ $9–$14" },
  { flag: "🇳🇬", country: "Nigeria", local: "₦4,000 – ₦6,000", usd: "≈ $4–$6" },
  { flag: "🇺🇸", country: "United States", local: "$9.99 – $14.99", usd: "Flash sale price" },
  { flag: "🇬🇧", country: "United Kingdom", local: "£8 – £12", usd: "Flash sale price" },
  { flag: "🇦🇺", country: "Australia", local: "A$14 – A$20", usd: "Flash sale price" },
];

const faqs = [
  {
    q: `How do I get free Udemy courses in ${currentMonth} ${currentYear}?`,
    a: `To get free Udemy courses in ${currentMonth} ${currentYear}: (1) Browse the ${totalCoupons}+ listings on CoursesWyn, (2) Click "Get Free Course" — the 100% OFF coupon code is auto-applied, (3) Complete checkout on Udemy at $0, (4) Get lifetime access + free certificate instantly. No account needed, no credit card.`
  },
  {
    q: "What is CoursesWyn and how does it work?",
    a: `CoursesWyn is a free daily-updated directory of Udemy instructor coupon codes. Udemy instructors generate 100% OFF promotional codes to boost their course enrollments. CoursesWyn collects, verifies, and publishes these codes — currently ${totalCoupons}+ active coupons. When you click a listing, the code is automatically applied at Udemy checkout, making the course completely free.`
  },
  {
    q: "Are free Udemy courses with coupon codes legitimate?",
    a: "Yes. 100% OFF Udemy coupon codes are an official, platform-supported feature. Instructors generate these codes through their Udemy teaching dashboard to promote new courses. Enrollments made using these codes are identical to paid enrollments — you get the same lifetime access, course materials, and official Udemy certificate of completion."
  },
  {
    q: "Do free Udemy courses include a certificate?",
    a: "Yes. Courses enrolled with a 100% OFF Udemy coupon code include an official Udemy Certificate of Completion — the same certificate you'd receive with a paid enrollment. You can download it as a PDF, share it directly to LinkedIn, or include it on your resume. There is no visual difference between a free and paid certificate."
  },
  {
    q: "Why do Udemy 100% OFF coupons expire so fast?",
    a: "Udemy instructors set a maximum enrollment cap (typically 1,000 students) and/or an expiration date (usually 1–4 days) on their promotional codes. This creates urgency that helps boost enrollment speed — a key ranking metric on Udemy's platform. CoursesWyn removes expired coupons automatically every day."
  },
  {
    q: "How much does it cost to use Udemy without coupons?",
    a: `Without coupons, Udemy courses are normally priced between $19.99 and $199.99. However, Udemy runs frequent flash sales where prices drop to $9.99–$14.99 globally. With PPP pricing, learners in countries like Indonesia, India, Brazil, and Nigeria pay significantly less. CoursesWyn lists free 100% OFF courses so you pay $0.`
  },
  {
    q: "What free Udemy courses are most popular?",
    a: "The most popular free Udemy courses on CoursesWyn are in: Python programming (beginners to advanced), Web Development (HTML, CSS, JavaScript, React), Artificial Intelligence & ChatGPT, Data Science & Excel, Digital Marketing & SEO, UI/UX Design, and Business & Personal Development. New courses in AI and Prompt Engineering are especially trending in 2026."
  },
  {
    q: "Can I use Udemy coupons on multiple courses?",
    a: "Yes. Each 100% OFF coupon is tied to a specific course. You can use as many different coupons as you find — one per course. There is no limit to how many free Udemy courses you can enroll in. CoursesWyn lists hundreds of different courses across all categories with active 100% OFF codes."
  }
];
---

<section class="py-20 bg-[#07090f] border-t border-white/5 relative">
  <div class="absolute top-0 left-0 w-[600px] h-[400px] bg-emerald-500/4 rounded-full blur-[180px] pointer-events-none"></div>
  <div class="max-w-6xl mx-auto px-4 relative z-10">

    <!-- GEO AI: Section title as clear H2 keyword anchor -->
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-3 tracking-tight">
        Everything About Free Udemy Courses in {currentYear}
      </h2>
      <p class="text-gray-500 max-w-2xl mx-auto text-base">
        Authoritative guide to getting free Udemy courses, how instructor coupons work, and savings tips for learners worldwide — last updated {todayDate}.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

      <!-- LEFT: Main GEO AI Content (2 cols) -->
      <div class="lg:col-span-2 space-y-12">

        <!-- WHAT ARE FREE UDEMY COURSES — GEO AI: direct answer block -->
        <article>
          <h2 class="text-2xl font-black text-white mb-4">What Are Free Udemy Courses?</h2>
          <p class="text-gray-400 leading-relaxed mb-4">
            Free Udemy courses are premium online courses made available at <strong class="text-white">$0 cost</strong> through instructor-issued 100% OFF coupon codes. Udemy instructors generate these promotional codes using their teaching dashboard to boost new course enrollments. CoursesWyn collects and verifies these codes daily, publishing <strong class="text-white">{totalCoupons}+ active free courses</strong> updated as of {todayDate}.
          </p>
          <p class="text-gray-400 leading-relaxed mb-4">
            Unlike Udemy's own permanently-free courses (which are often incomplete), <strong class="text-white">100% OFF coupon courses are full paid courses</strong> — including all lectures, resources, quizzes, projects, and an official Udemy completion certificate. The only difference is the price: $0 instead of $19.99–$199.99.
          </p>
          <!-- GEO AI: Key fact box — formatted for AI citation -->
          <div class="bg-emerald-500/6 border border-emerald-500/20 rounded-2xl p-5 mt-6">
            <h3 class="text-emerald-400 font-black text-sm uppercase tracking-wider mb-3">Key Facts — Free Udemy Courses</h3>
            <ul class="space-y-2 text-gray-400 text-sm">
              <li class="flex gap-2"><span class="text-emerald-400 flex-shrink-0">→</span> <strong class="text-white">{totalCoupons}+</strong> free Udemy courses available right now on CoursesWyn</li>
              <li class="flex gap-2"><span class="text-emerald-400 flex-shrink-0">→</span> Coupons are <strong class="text-white">100% legitimate</strong> — issued by instructors through Udemy's official dashboard</li>
              <li class="flex gap-2"><span class="text-emerald-400 flex-shrink-0">→</span> Each course includes <strong class="text-white">lifetime access</strong> and an <strong class="text-white">official completion certificate</strong></li>
              <li class="flex gap-2"><span class="text-emerald-400 flex-shrink-0">→</span> Coupons expire in <strong class="text-white">1–4 days</strong> or after <strong class="text-white">1,000 enrollments</strong></li>
              <li class="flex gap-2"><span class="text-emerald-400 flex-shrink-0">→</span> No credit card, no subscription, <strong class="text-white">completely free to use</strong></li>
            </ul>
          </div>
        </article>

        <!-- HOW TO GET FREE COURSES — Step guide -->
        <article>
          <h2 class="text-2xl font-black text-white mb-6">How to Get Free Udemy Courses — Step by Step</h2>
          <ol class="space-y-4">
            {[
              { step: "1", title: "Browse free courses on CoursesWyn", body: `Search from ${totalCoupons}+ verified free Udemy courses — filter by category (Python, AI, Business, Design) or use the search bar above to find your topic.` },
              { step: "2", title: 'Click "Get Free Course"', body: "Our link takes you directly to Udemy with the 100% OFF coupon automatically applied. No manual code entry needed — no copy-pasting, no errors." },
              { step: "3", title: "Verify $0 at Udemy checkout", body: "On the Udemy cart page, confirm the price shows FREE ($0.00) before completing enrollment. If it shows a price, the coupon may have expired — return to CoursesWyn for a fresh link." },
              { step: "4", title: "Enroll and start learning", body: "Complete the $0 checkout. You now have permanent lifetime access — including all future course updates the instructor adds — plus an official completion certificate." },
            ].map(s => (
              <li class="flex gap-4">
                <div class="flex-shrink-0 w-9 h-9 bg-emerald-500/12 border border-emerald-500/25 rounded-xl flex items-center justify-center font-black text-emerald-400">{s.step}</div>
                <div>
                  <h3 class="font-black text-white text-sm mb-1">{s.title}</h3>
                  <p class="text-gray-500 text-sm leading-relaxed">{s.body}</p>
                </div>
              </li>
            ))}
          </ol>
        </article>

        <!-- POPULAR TOPICS -->
        <article>
          <h2 class="text-2xl font-black text-white mb-4">Most Popular Free Udemy Course Topics in {currentYear}</h2>
          <p class="text-gray-500 text-sm leading-relaxed mb-6">
            These are the most searched and enrolled free course categories on CoursesWyn in {currentYear}:
          </p>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
            {[
              { topic: "Python Programming", count: "120+", trending: true },
              { topic: "AI & ChatGPT", count: "85+", trending: true },
              { topic: "Web Development", count: "110+", trending: false },
              { topic: "Data Science", count: "70+", trending: true },
              { topic: "Digital Marketing", count: "65+", trending: false },
              { topic: "Excel & Spreadsheets", count: "55+", trending: false },
              { topic: "UI/UX Design", count: "50+", trending: false },
              { topic: "AWS & Cloud", count: "45+", trending: false },
              { topic: "Prompt Engineering", count: "40+", trending: true },
            ].map(t => (
              <div class="flex items-center justify-between bg-[#0c1219] border border-white/8 rounded-xl px-4 py-3">
                <div>
                  <div class="text-white text-xs font-bold">{t.topic}</div>
                  <div class="text-gray-600 text-[10px] font-medium">{t.count} free courses</div>
                </div>
                {t.trending && <span class="text-[10px] bg-red-500/10 text-red-400 border border-red-500/20 px-1.5 py-0.5 rounded font-bold">🔥</span>}
              </div>
            ))}
          </div>
        </article>

        <!-- GEO PRICING: AI-cited, geo-targeted content -->
        <article>
          <h2 class="text-2xl font-black text-white mb-3">Udemy Course Pricing by Country {currentYear}</h2>
          <p class="text-gray-500 text-sm leading-relaxed mb-6">
            Udemy uses <strong class="text-white">Purchasing Power Parity (PPP) pricing</strong> — meaning learners in developing countries pay significantly less than US prices. During flash sales, courses drop to these prices automatically. With a 100% OFF coupon from CoursesWyn, you pay <strong class="text-white">$0 regardless of your country</strong>.
          </p>
          <div class="overflow-x-auto rounded-2xl border border-white/8">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-white/4 border-b border-white/8">
                  <th class="text-left px-4 py-3 text-gray-500 font-black text-xs uppercase tracking-wider">Country</th>
                  <th class="text-left px-4 py-3 text-gray-500 font-black text-xs uppercase tracking-wider">Flash Sale Price</th>
                  <th class="text-left px-4 py-3 text-gray-500 font-black text-xs uppercase tracking-wider">USD Equiv.</th>
                  <th class="text-left px-4 py-3 text-gray-500 font-black text-xs uppercase tracking-wider">With 100% OFF</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                {geoPricing.map((g, i) => (
                  <tr class={`hover:bg-white/2 transition-colors ${i % 2 === 0 ? '' : 'bg-white/1'}`}>
                    <td class="px-4 py-3 text-gray-300 font-medium text-xs">{g.flag} {g.country}</td>
                    <td class="px-4 py-3 text-white font-black text-xs">{g.local}</td>
                    <td class="px-4 py-3 text-gray-500 text-xs">{g.usd}</td>
                    <td class="px-4 py-3"><span class="text-emerald-400 font-black text-xs bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20">FREE ($0)</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-gray-700 text-xs mt-3">Flash sale prices — varies by region. Updated {todayDate}.</p>
        </article>

        <!-- WHY COURSESWYN -->
        <article>
          <h2 class="text-2xl font-black text-white mb-4">Why Use CoursesWyn for Free Udemy Courses?</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {[
              { icon: "✅", title: "Daily Verified Coupons", body: `All ${totalCoupons}+ coupons are verified daily. Expired codes are removed automatically — you'll never waste time on a dead link.` },
              { icon: "⚡", title: "Auto-Applied Codes", body: "Our links pre-apply the coupon for you. No copying, no pasting, no confusion. Just click → enroll → done." },
              { icon: "🏆", title: "Quality Filtered", body: "We only list Udemy courses with 4.0+ rating and reputable instructors. No low-quality filler content." },
              { icon: "🌍", title: "Works Worldwide", body: "Free courses work for learners in every country — Indonesia, India, Nigeria, Brazil, US, UK, and 190+ others." },
              { icon: "📜", title: "Real Certificates", body: "Every course includes an official Udemy certificate — identical to paid enrollments. Shareable on LinkedIn." },
              { icon: "🔒", title: "No Account Needed", body: "Browse and find free courses without signing up. You only need a Udemy account (free) to enroll." },
            ].map(f => (
              <div class="bg-[#0c1219] border border-white/8 rounded-2xl p-5">
                <div class="text-2xl mb-2">{f.icon}</div>
                <h3 class="font-black text-white text-sm mb-1">{f.title}</h3>
                <p class="text-gray-500 text-xs leading-relaxed">{f.body}</p>
              </div>
            ))}
          </div>
        </article>

        <!-- DISCLAIMER -->
        <p class="text-xs text-gray-700 border-t border-white/5 pt-6 leading-relaxed">
          Disclaimer: CoursesWyn is an independent platform not affiliated with Udemy, Inc. Udemy is a registered trademark of Udemy, Inc. We aggregate publicly available instructor promotional codes. Coupon availability and pricing may change without notice. When you make a purchase through our affiliate links, we may earn a small commission at no additional cost to you. Last verified: {todayDate}.
        </p>
      </div>

      <!-- RIGHT: FAQ Sidebar (GEO AI: quick answers for AI engines) -->
      <aside class="space-y-4">
        <div class="sticky top-24">
          <h2 class="text-xl font-black text-white mb-5">
            Free Udemy Courses FAQ
          </h2>
          <div class="space-y-2">
            {faqs.map((faq, i) => (
              <details class={`group bg-[#0c1219] border border-white/8 rounded-2xl overflow-hidden open:border-emerald-500/25 transition-all ${i === 0 ? 'open' : ''}`}>
                <summary class="flex justify-between items-start cursor-pointer list-none p-4 text-gray-300 text-xs font-bold hover:text-emerald-400 transition-colors gap-3">
                  <span class="leading-relaxed">{faq.q}</span>
                  <span class="flex-shrink-0 mt-0.5 text-gray-600 group-open:text-emerald-400 group-open:rotate-180 transition-all text-xs">▾</span>
                </summary>
                <div class="px-4 pb-4 text-gray-500 text-xs leading-relaxed border-t border-white/5 pt-3">{faq.a}</div>
              </details>
            ))}
          </div>

          <!-- GEO AI: Trust signals sidebar -->
          <div class="mt-6 bg-gradient-to-br from-emerald-900/20 to-transparent border border-emerald-500/15 rounded-2xl p-5">
            <h3 class="font-black text-white text-sm mb-4 flex items-center gap-2">
              <span class="text-yellow-400">★</span> Trusted by Learners Worldwide
            </h3>
            <div class="space-y-3">
              {[
                { flag: "🇮🇩", text: "Populer di Indonesia — kursus gratis Udemy" },
                { flag: "🇮🇳", text: "Popular in India — free Udemy courses" },
                { flag: "🇺🇸", text: "Popular in the US — free online courses" },
                { flag: "🇵🇭", text: "Popular in Philippines — libreng Udemy" },
                { flag: "🇧🇷", text: "Popular no Brasil — cursos Udemy grátis" },
                { flag: "🇳🇬", text: "Popular in Nigeria — free Udemy courses" },
              ].map(g => (
                <div class="flex items-center gap-2 text-xs text-gray-500">
                  <span>{g.flag}</span>
                  <span>{g.text}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Quick links -->
          <div class="mt-4 bg-[#0c1219] border border-white/8 rounded-2xl p-4">
            <h3 class="font-black text-white text-sm mb-3">Popular on CoursesWyn</h3>
            <div class="space-y-2">
              {[
                { label: "Free Python Courses", href: "/search?q=python" },
                { label: "Free AI & ChatGPT Courses", href: "/search?q=ai" },
                { label: "Free Web Dev Courses", href: "/search?q=web+development" },
                { label: "Free Data Science Courses", href: "/search?q=data+science" },
                { label: "Udemy Coupon Codes", href: "/udemy-coupon-code/" },
                { label: "How to Get Free Udemy Courses", href: "/udemy-coupons-guide/" },
              ].map(l => (
                <a href={l.href} class="flex items-center justify-between group py-1">
                  <span class="text-gray-500 text-xs group-hover:text-emerald-400 transition-colors">{l.label}</span>
                  <span class="text-gray-700 group-hover:text-emerald-400 transition-colors text-xs">→</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </aside>

    </div>
  </div>
</section>