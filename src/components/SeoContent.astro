---
import coupons from '../data/coupons.json';
const totalCoupons = coupons.length;
---

<section class="py-20 bg-[#0a0f16] border-t border-white/5 text-gray-300 relative">
    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-emerald-500/5 rounded-full blur-[150px] mix-blend-screen pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            
            <!-- Main Content (2 cols) - OPTIMIZED dengan keyword "udemy coupon codes" -->
            <div class="lg:col-span-2 prose prose-invert prose-lg max-w-none">
                <h2 class="text-3xl font-bold text-white mb-6">
                    Get the Best Udemy Coupon Codes & Promo Codes for 2026
                </h2>
                
                <p class="text-gray-400 leading-relaxed mb-8">
                    CoursesWyn is your ultimate destination for <strong>verified Udemy coupon codes</strong> and <strong>discount promo codes</strong> in 2026. We automatically collect, test, and verify <strong>100% OFF Udemy coupons</strong> every single day, ensuring you get instant access to premium courses without spending a dime. Whether you want to learn Python programming, master digital marketing, or advance your career in web development, we have the perfect Udemy coupon code for you.
                </p>

                <div class="grid md:grid-cols-2 gap-6 mb-12">
                    <div class="bg-[#1c252e] p-6 rounded-2xl border border-[#2d3748] hover:border-green-500/50 transition-all">
                        <h3 class="text-lg font-bold text-white mb-2 flex items-center gap-2">
                            <span class="text-green-500 bg-green-500/10 p-1 rounded-lg">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                            </span>
                            Daily Verified Coupons
                        </h3>
                        <p class="text-gray-400 text-sm leading-relaxed">
                            Our automated system verifies {totalCoupons}+ Udemy coupon codes daily to ensure every discount works. No expired codes, no wasted time—just instant savings on premium courses.
                        </p>
                    </div>
                    <div class="bg-[#1c252e] p-6 rounded-2xl border border-[#2d3748] hover:border-blue-500/50 transition-all">
                        <h3 class="text-lg font-bold text-white mb-2 flex items-center gap-2">
                            <span class="text-blue-500 bg-blue-500/10 p-1 rounded-lg">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                            </span>
                            100% OFF Discounts
                        </h3>
                        <p class="text-gray-400 text-sm leading-relaxed">
                            Access courses normally priced at $100+ for absolutely free using our exclusive Udemy promo codes. Get lifetime access and official completion certificates with every enrollment.
                        </p>
                    </div>
                </div>

                <h3 class="text-2xl font-bold text-white mb-6">
                    How to Use Udemy Coupon Codes from CoursesWyn
                </h3>
                <div class="bg-[#242938] border border-[#2d3748] rounded-xl p-6 mb-8">
                    <ol class="space-y-3 text-gray-300 list-decimal list-inside">
                        <li class="leading-relaxed">
                            <strong class="text-white">Browse our coupon collection:</strong> Search for courses by topic, category, or instructor name.
                        </li>
                        <li class="leading-relaxed">
                            <strong class="text-white">Click "Get Coupon":</strong> Our verified Udemy discount code will be automatically applied at checkout.
                        </li>
                        <li class="leading-relaxed">
                            <strong class="text-white">Enroll for FREE:</strong> Complete your Udemy registration and start learning immediately with lifetime access.
                        </li>
                        <li class="leading-relaxed">
                            <strong class="text-white">Get your certificate:</strong> Finish the course and receive an official Udemy completion certificate.
                        </li>
                    </ol>
                </div>

                <h3 class="text-2xl font-bold text-white mb-6">
                    Popular Udemy Coupon Code Categories
                </h3>
                <p class="text-gray-400 leading-relaxed mb-4">
                    Explore our most popular categories to find the best Udemy promo codes for your learning goals:
                </p>
                <div class="flex flex-wrap gap-2 mb-12">
                    {[
                        {name: "Python", courses: "120+"},
                        {name: "React", courses: "60+"},
                        {name: "Java", courses: "85+"},
                        {name: "Docker", courses: "45+"},
                        {name: "AWS", courses: "90+"},
                        {name: "Excel", courses: "55+"},
                        {name: "Photoshop", courses: "40+"},
                        {name: "SEO", courses: "35+"},
                        {name: "Marketing", courses: "70+"}
                    ].map(tag => (
                        <a 
                            href={`/search?q=${tag.name}`} 
                            class="bg-[#1c252e] border border-[#2d3748] px-4 py-2 rounded-full text-sm text-gray-300 hover:text-white hover:border-green-500 hover:bg-[#242938] transition-all group"
                        >
                            <span class="font-medium">{tag.name}</span>
                            <span class="text-xs text-gray-500 ml-1 group-hover:text-green-400">({tag.courses})</span>
                        </a>
                    ))}
                </div>

                <div class="bg-gradient-to-r from-emerald-500/10 to-blue-500/10 border border-emerald-500/20 rounded-2xl p-8 mb-8 backdrop-blur-xl">
                    <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-3">
                        <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Why Our Udemy Coupon Codes Are Different
                    </h3>
                    <ul class="space-y-3 text-gray-300 text-sm">
                        <li class="flex items-start gap-2">
                            <svg class="w-5 h-5 text-emerald-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                            <span><strong>Auto-Verified Daily:</strong> Every Udemy promo code is tested automatically before being published</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <svg class="w-5 h-5 text-emerald-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                            <span><strong>Instant Application:</strong> Coupon codes apply automatically when you click our links</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <svg class="w-5 h-5 text-emerald-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                            <span><strong>Quality Guaranteed:</strong> Only courses with 4.0+ ratings and verified instructors</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <svg class="w-5 h-5 text-emerald-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                            <span><strong>No Hidden Costs:</strong> Completely free enrollment, no credit card required</span>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- FAQ Sidebar (1 col) - OPTIMIZED dengan keyword variations -->
            <div class="lg:col-span-1">
                <h2 class="text-2xl font-bold text-white mb-6">
                    Udemy Coupon Codes FAQ
                </h2>
                <div class="space-y-4">
                    <details class="group bg-[#131922]/80 backdrop-blur-md rounded-xl border border-white/5 open:border-emerald-500/50 open:bg-white/5 transition-all duration-300">
                        <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-5 text-gray-200 hover:text-white">
                            <span>How do I redeem Udemy coupon codes?</span>
                            <span class="transition-transform duration-300 group-open:rotate-180">
                                <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </span>
                        </summary>
                        <div class="text-gray-400 px-5 pb-5 text-sm leading-relaxed border-t border-[#1c252e]/50 pt-4 animate-fadeIn">
                            Simply click "Get Coupon" on any course card. You'll be redirected to Udemy with the discount code automatically applied at checkout. No manual code entry needed!
                        </div>
                    </details>

                    <details class="group bg-[#131922]/80 backdrop-blur-md rounded-xl border border-white/5 open:border-emerald-500/50 open:bg-white/5 transition-all duration-300">
                        <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-5 text-gray-200 hover:text-white">
                            <span>Are these Udemy promo codes really 100% free?</span>
                            <span class="transition-transform duration-300 group-open:rotate-180">
                                <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </span>
                        </summary>
                        <div class="text-gray-400 px-5 pb-5 text-sm leading-relaxed border-t border-[#1c252e]/50 pt-4 animate-fadeIn">
                            Yes! These are legitimate 100% OFF promotional codes provided by Udemy instructors. Once enrolled using our coupon code, you own the course forever with full lifetime access—no subscription required.
                        </div>
                    </details>

                    <details class="group bg-[#131922]/80 backdrop-blur-md rounded-xl border border-white/5 open:border-emerald-500/50 open:bg-white/5 transition-all duration-300">
                        <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-5 text-gray-200 hover:text-white">
                            <span>Do I get a certificate with free Udemy courses?</span>
                            <span class="transition-transform duration-300 group-open:rotate-180">
                                <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </span>
                        </summary>
                        <div class="text-gray-400 px-5 pb-5 text-sm leading-relaxed border-t border-[#1c252e]/50 pt-4 animate-fadeIn">
                            Absolutely! Courses enrolled with 100% OFF coupon codes are treated as paid enrollments by Udemy. You'll receive an official completion certificate that you can add to your LinkedIn profile or resume.
                        </div>
                    </details>

                    <details class="group bg-[#131922]/80 backdrop-blur-md rounded-xl border border-white/5 open:border-emerald-500/50 open:bg-white/5 transition-all duration-300">
                        <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-5 text-gray-200 hover:text-white">
                            <span>How often are new coupon codes added?</span>
                            <span class="transition-transform duration-300 group-open:rotate-180">
                                <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </span>
                        </summary>
                        <div class="text-gray-400 px-5 pb-5 text-sm leading-relaxed border-t border-[#1c252e]/50 pt-4 animate-fadeIn">
                            We update our Udemy coupon code database every single day with 925+ new verified discount codes. Check back daily to discover fresh courses and never miss a limited-time 100% OFF promotion!
                        </div>
                    </details>

                    <details class="group bg-[#131922]/80 backdrop-blur-md rounded-xl border border-white/5 open:border-emerald-500/50 open:bg-white/5 transition-all duration-300">
                        <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-5 text-gray-200 hover:text-white">
                            <span>Why do Udemy coupon codes expire?</span>
                            <span class="transition-transform duration-300 group-open:rotate-180">
                                <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </span>
                        </summary>
                        <div class="text-gray-400 px-5 pb-5 text-sm leading-relaxed border-t border-[#1c252e]/50 pt-4 animate-fadeIn">
                            Instructors set expiration dates on their promotional codes to create urgency and boost enrollments. That's why we verify all coupons daily and remove expired ones immediately. Act fast when you find a course you like!
                        </div>
                    </details>
                </div>

                <!-- BONUS: Trust indicators -->
                <div class="mt-8 bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-6">
                    <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                        Trusted by 50,000+ Learners
                    </h3>
                    <div class="space-y-3 text-sm text-gray-400 font-medium">
                        <div class="flex items-center gap-3">
                            <svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                            <span>{totalCoupons}+ coupons verified daily</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                            <span>100% working guarantee</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                            <span>No spam or hidden fees</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>
</section>