---
import { getCollection } from 'astro:content';

// Fetch ALL posts and sort by the LATEST of updatedAt or pubDate
const allPosts = await getCollection('blog');
const displayPosts = allPosts
  .sort((a, b) => {
    const aDate = a.data.updatedAt?.valueOf() ?? a.data.pubDate.valueOf();
    const bDate = b.data.updatedAt?.valueOf() ?? b.data.pubDate.valueOf();
    return bDate - aDate;
  })
  .slice(0, 3);

// Helper for relative time using the freshest date available
const getRelativeTime = (post: any) => {
  const date = post.data.updatedAt ?? post.data.pubDate;
  const diffTime = Math.abs(new Date().getTime() - date.getTime());
  const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
  if (diffDays === 0) return 'Today';
  if (diffDays === 1) return 'Yesterday';
  if (diffDays < 7) return `${diffDays} days ago`;
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
};
---

<section id="expert-guides" class="py-24 bg-[#07090f] relative overflow-hidden">
  <!-- Glowing Background Orbs -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-indigo-500/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-indigo-500/5 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
        <div class="max-w-2xl">
            <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-1.5 mb-5">
                <span class="text-white text-[10px] font-black uppercase tracking-widest">Mastery Roadmaps</span>
            </div>
            <h2 class="text-4xl md:text-6xl font-black text-white leading-tight tracking-tight mb-4">
              Expert <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-indigo-300">Learning Guides</span>
            </h2>
            <p class="text-gray-500 text-lg">
              We hand-pick and update these roadmap articles daily to help you master new tech stacks from the ground up. Each roadmap includes <a href="/udemy-coupon-code/" class="text-indigo-400 hover:underline">verified course rankings</a> and current coupon codes.
            </p>
        </div>
        <a href="/blog" class="group flex items-center gap-3 text-white font-black text-xs uppercase tracking-[0.2em] border-b-2 border-white/10 pb-2 hover:border-indigo-500 transition-all">
           See All Guides <span class="group-hover:translate-x-1 transition-transform">→</span>
        </a>
    </div>

    <!-- Triple Spotlight Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {displayPosts.map((post, index) => (
        <article class={`group relative flex flex-col h-full rounded-[2.5rem] bg-[#0c1219] border border-white/5 overflow-hidden hover:border-white/20 transition-all duration-500 shadow-2xl hover:-translate-y-2 ${index === 0 ? 'lg:col-span-1' : ''}`}>
           <a href={`/blog/${post.id}`} class="absolute inset-0 z-30"></a>
           
           <!-- Image Area -->
           <div class="relative aspect-[16/10] overflow-hidden">
              <img 
                src={post.data.image?.src || "/api/placeholder/800/500"} 
                alt={post.data.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-[2s]"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#0c1219] via-transparent to-transparent"></div>
              
              <!-- Freshness Tag -->
              <div class="absolute top-6 left-6 flex items-center gap-2 bg-black/60 backdrop-blur-md border border-white/10 rounded-full px-4 py-1.5 shadow-xl">
                 <div class="w-1.5 h-1.5 bg-indigo-500 rounded-full animate-pulse"></div>
                 <span class="text-white text-[10px] font-black uppercase tracking-widest">{getRelativeTime(post)}</span>
              </div>
           </div>

           <!-- Content Area -->
           <div class="p-8 flex flex-col flex-1">
              <div class="flex items-center gap-3 mb-4">
                 <span class="text-indigo-400 text-[10px] font-black uppercase tracking-widest">Mastery Level</span>
                 <div class="flex gap-0.5">
                    {[...Array(5)].map(() => (
                       <div class="w-1.5 h-1.5 rounded-full bg-indigo-500 shrink-0"></div>
                    ))}
                 </div>
              </div>

              <h3 class="text-2xl font-black text-white leading-tight mb-5 group-hover:text-indigo-400 transition-colors">
                {post.data.title}
              </h3>

              <p class="text-gray-500 text-sm leading-relaxed mb-8 line-clamp-3">
                {post.data.description}
              </p>

              <div class="mt-auto flex items-center justify-between border-t border-white/5 pt-6">
                 <div class="flex flex-col">
                    <span class="text-gray-600 text-[9px] font-black uppercase mb-0.5">Read Time</span>
                    <span class="text-white text-xs font-bold">12 Min</span>
                 </div>
                 <div class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white group-hover:bg-indigo-500 group-hover:text-black group-hover:border-indigo-500 transition-all duration-300">
                    <span class="text-xl">→</span>
                 </div>
              </div>
           </div>
        </article>
      ))}
    </div>

  </div>
</section>
