---
import coupons from '../data/coupons.json';

// Get the most recent course with 5.0 rating as "Course of the Day"
const courseOfDay = coupons
  .filter((course: any) => course.rating === 5.0)
  .sort((a: any, b: any) => {
    const dateA = new Date(a.updatedAt || 0).getTime();
    const dateB = new Date(b.updatedAt || 0).getTime();
    return dateB - dateA;
  })[0];

if (!courseOfDay) return null; // Fallback if no 5.0 course exists

const price = courseOfDay.price;
const originalPrice = courseOfDay.originalPrice;
const saveAmount = originalPrice && originalPrice > price ? Math.round(originalPrice - price) : 0;
---

<section id="spotlight-deal" class="py-12 bg-[#07090f] relative overflow-hidden border-t border-white/5">
  <!-- Dynamic Aura Background -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-emerald-500/10 rounded-full blur-[120px] mix-blend-screen pointer-events-none opacity-50"></div>

  <div class="max-w-5xl mx-auto px-4 relative z-10">
    <!-- Compact Section Header (SEO) -->
    <div class="text-center mb-8">
      <h2 class="text-2xl md:text-3xl font-black text-white mb-2 leading-tight">
        Best Udemy Coupon Code Pick for Today
      </h2>
      <p class="text-gray-500 text-sm max-w-xl mx-auto">
        Don't miss our editor's top-rated pick verified at 100% OFF today.
      </p>
    </div>

    <div class="group relative bg-[#111827]/60 backdrop-blur-3xl border border-white/10 rounded-[2rem] overflow-hidden hover:border-emerald-500/30 transition-all duration-500 hover:shadow-[0_20px_50px_rgba(16,185,129,0.1)]">
      
      <!-- Content Grid: More balanced and compact -->
      <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] lg:grid-cols-[280px_1fr] gap-0">
        
        <!-- Left: Image Section (Floating Effect) -->
        <div class="relative p-6 lg:p-8 flex items-center justify-center">
            <div class="relative z-10 w-full aspect-video rounded-xl overflow-hidden shadow-2xl group-hover:scale-[1.03] transition-transform duration-500 border border-white/5">
               <img 
                src={courseOfDay.image} 
                alt={courseOfDay.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            </div>
            <!-- Glow behind image -->
            <div class="absolute inset-10 bg-emerald-500/20 blur-3xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
        </div>

        <!-- Right: Details Section -->
        <div class="p-6 lg:p-10 flex flex-col justify-center relative">
          
          <!-- Spotlight Badge (Internal) -->
          <div class="flex items-center gap-3 mb-4">
             <div class="flex items-center gap-1.5 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-3 py-1">
                <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
                <span class="text-emerald-400 text-[9px] font-black uppercase tracking-widest">Premium Spotlight</span>
             </div>
             <span class="text-gray-600 text-[10px] font-bold uppercase tracking-wider">Top-Rated Course</span>
          </div>

          <h2 class="text-xl lg:text-2xl font-black text-white leading-tight mb-3 group-hover:text-emerald-400 transition-colors">
            <a href={`/coupon/${courseOfDay.slug}`} class="after:absolute after:inset-0 after:z-0">
              {courseOfDay.title}
            </a>
          </h2>

          <div class="flex items-center gap-4 mb-4 text-[11px]">
             <span class="text-gray-400 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                By <span class="text-white font-bold">{courseOfDay.instructor || "Expert Instructor"}</span>
             </span>
             <span class="w-1 h-1 bg-gray-700 rounded-full"></span>
             <span class="text-gray-400 font-bold uppercase">{courseOfDay.category}</span>
          </div>

          <p class="text-gray-500 text-xs lg:text-sm leading-relaxed line-clamp-2 mb-6 max-w-2xl">
            {courseOfDay.description || courseOfDay.seoDescription || "Unlock master-level skills with today's absolute top-rated course verified at 100% OFF."}
          </p>

          <!-- Bottom Row: Price & CTA -->
          <div class="mt-auto flex flex-wrap items-center justify-between gap-6 pt-5 border-t border-white/5">
             <div class="flex items-end gap-3">
                <div class="flex flex-col">
                   <span class={`text-3xl font-black leading-none ${price === 0 ? 'text-emerald-400 animate-pulse' : 'text-white'}`}>
                      {price === 0 ? 'FREE' : `$${price}`}
                   </span>
                   {originalPrice && originalPrice > price && (
                     <span class="text-gray-700 line-through text-[10px] mt-1 font-bold">${originalPrice} VALUE</span>
                   )}
                </div>
                <div class="bg-red-500/10 border border-red-500/20 text-red-500 text-[9px] font-black px-2 py-0.5 rounded-lg uppercase tracking-tighter self-start mt-1">
                   100% OFF
                </div>
             </div>

             <div class="relative z-10 flex items-center gap-4">
                <div class="flex flex-col items-end text-[10px]">
                   <span class="text-white font-black">★ {courseOfDay.rating || "5.0"}</span>
                   <span class="text-gray-600 font-medium whitespace-nowrap">{courseOfDay.students?.toLocaleString() || "1,200"}+ Enrolled</span>
                </div>
                <div class="px-6 py-3 bg-emerald-500 text-white text-[10px] font-black rounded-xl uppercase tracking-widest shadow-lg shadow-emerald-500/20 hover:scale-[1.05] active:scale-95 transition-all">
                  Get Offer →
                </div>
             </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>
