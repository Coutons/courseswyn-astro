---
const languages = [
  { name: "English", flag: "https://flagcdn.com/w40/us.png", url: "https://www.udemy.com/?locale=en_US" },
  { name: "Spanish", flag: "https://flagcdn.com/w40/es.png", url: "https://www.udemy.com/?locale=es_ES" },
  { name: "French", flag: "https://flagcdn.com/w40/fr.png", url: "https://www.udemy.com/?locale=fr_FR" },
  { name: "German", flag: "https://flagcdn.com/w40/de.png", url: "https://www.udemy.com/?locale=de_DE" },
  { name: "Portuguese", flag: "https://flagcdn.com/w40/br.png", url: "https://www.udemy.com/?locale=pt_BR" },
  { name: "Italian", flag: "https://flagcdn.com/w40/it.png", url: "https://www.udemy.com/?locale=it_IT" },
  { name: "Japanese", flag: "https://flagcdn.com/w40/jp.png", url: "https://www.udemy.com/?locale=ja_JP" },
  { name: "Korean", flag: "https://flagcdn.com/w40/kr.png", url: "https://www.udemy.com/?locale=ko_KR" },
  { name: "Chinese", flag: "https://flagcdn.com/w40/cn.png", url: "https://www.udemy.com/?locale=zh_CN" },
  { name: "Russian", flag: "https://flagcdn.com/w40/ru.png", url: "https://www.udemy.com/?locale=ru_RU" },
  { name: "Dutch", flag: "https://flagcdn.com/w40/nl.png", url: "https://www.udemy.com/?locale=nl_NL" },
  { name: "Polish", flag: "https://flagcdn.com/w40/pl.png", url: "https://www.udemy.com/?locale=pl_PL" },
  { name: "Turkish", flag: "https://flagcdn.com/w40/tr.png", url: "https://www.udemy.com/?locale=tr_TR" },
  { name: "Indonesian", flag: "https://flagcdn.com/w40/id.png", url: "https://www.udemy.com/?locale=id_ID" },
  { name: "Arabic", flag: "https://flagcdn.com/w40/sa.png", url: "https://www.udemy.com/?locale=ar_SA" },
  { name: "Hindi", flag: "https://flagcdn.com/w40/in.png", url: "https://www.udemy.com/?locale=hi_IN" },
];
---

<section class="max-w-[1240px] mx-auto px-4 py-12">
  <div class="text-center mb-8">
    <h2 class="text-3xl font-black text-white leading-none mb-4">Browse by Language</h2>
    <p class="text-gray-500 text-lg">Courses available in multiple languages</p>
  </div>

  <div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-8 gap-4">
    {languages.map((lang) => (
      <a
        href={lang.url}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative bg-[#0b1016] border border-[#1f2330] rounded-2xl p-4 flex flex-col items-center justify-center gap-2 transition-all hover:border-indigo-500/50 hover:-translate-y-1 hover:shadow-xl hover:shadow-indigo-500/10"
      >
        <img src={lang.flag} alt={lang.name} class="w-8 h-6 object-cover rounded shadow-lg group-hover:scale-110 transition-transform" />
        <div class="text-center">
          <h3 class="text-white font-bold text-xs mb-1 group-hover:text-indigo-400 transition-colors">
            {lang.name}
          </h3>
        </div>
      </a>
    ))}
  </div>
</section>
