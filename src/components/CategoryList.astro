---
import coupons from '../data/coupons.json';

// Extract unique categories and take top 8
const categories = [...new Set(coupons.map(c => c.category))].slice(0, 8);

// Create URL-safe slugs for categories (matching the routing logic)
const categorySlugs = categories.map(category => 
  category ? String(category).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') : 'uncategorized'
);

const categoryIcons: Record<string, string> = {
  'Development': '<path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />',
  'Business': '<path d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
  'IT & Software': '<path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
  'Design': '<path d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />',
  'Marketing': '<path d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z" /><path d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z" />',
  'Personal Development': '<path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />',
  'Photography': '<path d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><path d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />',
  'Photography & Video': '<path d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><path d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />',
  'Music': '<path d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />',
  'Finance': '<path d="M9 7h6m0 3h-6m3 3h3m-6 3h6m2 3H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />',
  'Financial': '<path d="M9 7h6m0 3h-6m3 3h3m-6 3h6m2 3H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />',
  'Finance & Accounting': '<path d="M9 7h6m0 3h-6m3 3h3m-6 3h6m2 3H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />',
  'Teaching': '<path d="M12 14l9-5-9-5-9 5 9 5z" /><path d="M12 14v7" />',
  'Teaching & Academics': '<path d="M12 14l9-5-9-5-9 5 9 5z" /><path d="M12 14v7" />'
};
---

<section class="py-20 bg-[#0a0f16] relative border-b border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex justify-between items-end mb-8">
      <div>
        <h2 class="text-2xl font-bold text-white mb-2">Browse Udemy Coupon Codes by Category</h2>
        <p class="text-gray-400">Find 100% OFF discount coupons for your favorite topics</p>
      </div>
      <a href="/categories" class="text-emerald-400 font-bold hover:text-emerald-300 transition-colors flex items-center gap-1.5 uppercase tracking-wide text-sm">
        View All
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
      {categories.map((category, index) => (
        <a filter-search
          href={`/courses/category/${categorySlugs[index]}`} 
          class="flex items-center gap-4 p-5 bg-white/5 backdrop-blur-xl border border-white/5 rounded-2xl hover:border-emerald-500/40 hover:bg-white/10 hover:shadow-[0_8px_32px_rgba(16,185,129,0.1)] hover:-translate-y-1 transition-all duration-300 group"
        >
          <div class="w-12 h-12 rounded-xl bg-emerald-500/10 text-emerald-400 flex items-center justify-center text-2xl group-hover:scale-110 group-hover:bg-emerald-500/20 transition-all duration-300">
            <span set:html={(() => {
              const icon = categoryIcons[category] || categoryIcons[category.toLowerCase()] || categoryIcons[category.charAt(0).toUpperCase() + category.slice(1).toLowerCase()];
              const defaultIcon = '<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>';
              return `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">${icon || defaultIcon}</svg>`;
            })()}></span>
          </div>
          <div>
            <h3 class="font-medium text-gray-200 group-hover:text-white text-sm">{category}</h3>
            <p class="text-xs text-gray-500">View Courses</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
