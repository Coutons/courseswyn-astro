---
const steps = [
  { 
    title: "Finding Deals", 
    desc: "We look through instructor social media, student communities, and newsletters to find the latest coupons.", 
    icon: "📡" 
  },
  { 
    title: "Double-Checking", 
    desc: "Every deal is tested to make sure it's still active and hasn't run out of registration slots.", 
    icon: "🔍" 
  },
  { 
    title: "Organizing", 
    desc: "Courses are grouped so you can easily find exactly what you need for your career path.", 
    icon: "🏗️" 
  },
  { 
    title: "Hourly Updates", 
    desc: "We refresh the list every hour, removing anything that has expired to save you time.", 
    icon: "⚡" 
  }
];
---

<section id="methodology" class="py-24 bg-zinc-950 relative overflow-hidden border-t border-white/5">
  <!-- Grid Pattern Overlay -->
  <div class="absolute inset-0 opacity-[0.02] pointer-events-none" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 80px 80px;"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      
      <!-- Visualization Logic -->
      <div class="space-y-6">
        <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/25 rounded-full px-4 py-1.5 mb-2">
            <span class="text-indigo-400 text-[10px] font-black uppercase tracking-widest">Our Verification Process</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-black text-white leading-[1.1] tracking-tight">
          How we keep <span class="text-gray-500 italic">deals fresh</span>
        </h2>
        <p class="text-gray-500 text-lg leading-relaxed max-w-xl">
          Unlike static lists, our platform is updated constantly. We check each offer at the source to make sure you don't waste time on expired links.
        </p>

        <div class="pt-10 space-y-8">
           {steps.map((step, i) => (
             <div class="flex gap-6 group">
                <div class="flex-shrink-0 w-12 h-12 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center text-xl group-hover:border-indigo-500/40 transition-colors">
                  {step.icon}
                </div>
                <div>
                   <h3 class="text-white font-black text-lg mb-1">{step.title}</h3>
                   <p class="text-gray-500 text-sm leading-relaxed max-w-sm">{step.desc}</p>
                </div>
             </div>
           ))}
        </div>
      </div>

      <!-- Hero Visual: Agentic Core -->
      <div class="relative group">
         <div class="absolute -inset-4 bg-gradient-to-tr from-indigo-500/20 via-emerald-500/20 to-blue-500/20 rounded-[3rem] blur-2xl opacity-50 group-hover:opacity-100 transition-opacity duration-1000"></div>
         <div class="relative bg-[#0c1219] border border-white/10 rounded-[3rem] p-12 overflow-hidden">
            <div class="flex items-center justify-between mb-10">
               <div class="flex gap-2">
                  <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
                  <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
                  <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
               </div>
               <span class="text-[10px] font-black text-gray-600 uppercase tracking-widest">Activity Log</span>
            </div>

            <div class="space-y-6 font-mono text-[11px]">
               <div class="flex gap-4 text-emerald-400">
                  <span class="opacity-50">09:42:11</span>
                  <span class="font-bold">[VERIFIED]</span>
                  <span class="text-white">Python for Beginners coupon is active</span>
               </div>
               <div class="flex gap-4 text-blue-400">
                  <span class="opacity-50">09:42:08</span>
                  <span class="font-bold">[CHECKING]</span>
                  <span class="text-white">Reviewing new instructor social posts...</span>
               </div>
               <div class="flex gap-4 text-yellow-500">
                  <span class="opacity-50">09:41:55</span>
                  <span class="font-bold">[EXPIRED]</span>
                  <span class="text-white">Cleaning up expired Java coupon (cap reached)</span>
               </div>
               <div class="flex gap-4 text-emerald-400">
                  <span class="opacity-50">09:41:30</span>
                  <span class="font-bold">[VERIFIED]</span>
                  <span class="text-white">Next.js 15 discount still available</span>
               </div>
               <div class="flex gap-4 text-emerald-400/50 italic animate-pulse">
                  <span class="opacity-50">09:42:15</span>
                  <span class="font-bold">[WORKING]</span>
                  <span>Scanning for more deals...</span>
               </div>
            </div>

            <!-- Stats overlay -->
            <div class="mt-12 grid grid-cols-2 gap-4">
               <div class="bg-white/5 p-4 rounded-2xl border border-white/5">
                  <div class="text-[9px] text-gray-500 font-black uppercase mb-1">Items Processed</div>
                  <div class="text-xl font-black text-white">42,000 / hr</div>
               </div>
               <div class="bg-white/5 p-4 rounded-2xl border border-white/5">
                  <div class="text-[9px] text-gray-500 font-black uppercase mb-1">Data Reliability</div>
                  <div class="text-xl font-black text-white">99%</div>
               </div>
            </div>
         </div>
      </div>

    </div>
  </div>
</section>
