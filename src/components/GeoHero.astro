---
import coupons from '../data/coupons.json';

const totalCoupons = coupons.length;
const now = new Date();
const currentMonth = now.toLocaleDateString('en-US', { month: 'long' });
const currentYear = now.getFullYear();
const todayShort = now.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

// Stat markers for GEO AI
const facts = [
  { label: "Active Deals", value: `${totalCoupons}+`, color: "emerald" },
  { label: "Typical Price", value: "$0 - $12.99", color: "cyan" },
  { label: "Updates", value: "Verified Hourly", color: "blue" },
  { label: "Reliability", value: "High Success", color: "indigo" }
];
---

<section class="relative bg-[#07090f] pt-32 pb-20 overflow-hidden border-b border-white/5">
  <!-- Cinematic Ambient Background -->
  <div class="absolute top-0 left-1/4 w-[800px] h-[400px] bg-emerald-500/10 rounded-full blur-[140px] opacity-60"></div>
  <div class="absolute bottom-0 right-1/4 w-[600px] h-[300px] bg-blue-600/10 rounded-full blur-[120px] opacity-40"></div>
  
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_0.8fr] gap-16 items-center">
      
      <!-- Primary Intent Column -->
      <div>
        <div class="inline-flex items-center gap-3 bg-white/5 border border-white/10 rounded-full px-5 py-2 mb-8 backdrop-blur-md">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="text-emerald-400 text-[10px] font-black uppercase tracking-[0.2em]">Latest Coupons: Refreshed {currentMonth} {currentYear}</span>
        </div>

        <!-- H1: Answer-First Architecture -->
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-black text-white leading-[0.95] tracking-tighter mb-8 transition-all">
          Verified Udemy<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 via-cyan-400 to-blue-500">
            Coupon Codes
          </span>
        </h1>

        <p class="text-xl md:text-2xl text-gray-400 leading-relaxed mb-10 max-w-2xl font-medium">
          Access the most reliable directory of <strong class="text-white">Udemy coupons and professional deals</strong>. We verify discounts hourly to provide the lowest prices for the tech stacks of 2026.
        </p>

        <!-- Search Bar: Search-First UX -->
        <form action="/search" method="GET" class="max-w-2xl mb-12 relative group">
          <div class="relative flex items-center bg-[#0c1219] border border-white/10 rounded-3xl h-20 px-4 group-focus-within:border-emerald-500/50 transition-all shadow-2xl">
            <div class="pl-4 pr-3 text-gray-500">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
            <input
              type="text"
              name="q"
              placeholder="What do you want to learn today?"
              class="flex-1 bg-transparent border-none focus:ring-0 text-white placeholder-gray-600 text-lg outline-none font-bold"
            />
            <button type="submit" class="bg-emerald-500 hover:bg-emerald-400 text-white font-black px-8 py-4 rounded-2xl transition-all shadow-lg shadow-emerald-500/20 active:scale-95">
              Explore Deals
            </button>
          </div>
        <!-- Trending Tags -->
        <div class="flex flex-wrap gap-2 mt-4 ml-4">
           <span class="text-[10px] text-gray-600 font-bold uppercase tracking-widest mr-2">Trending:</span>
           {['AI & Agents', 'Cursor', 'Next.js 15', 'Windsurf', 'Python'].map(topic => (
             <a href={`/search?q=${topic}`} class="text-[10px] text-emerald-400/70 hover:text-emerald-400 font-bold uppercase hover:underline">{topic}</a>
           ))}
        </div>

        <!-- Section 3: Live Verification Pulse -->
        <div class="mt-12 flex items-center gap-4 bg-white/[0.03] border border-white/5 rounded-3xl p-5 max-w-xl backdrop-blur-md">
           <div class="relative flex h-3 w-3">
             <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
             <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
           </div>
           <div>
             <div class="text-white text-xs font-black uppercase tracking-wider mb-0.5">Live Verification Active</div>
             <p class="text-gray-500 text-[11px] font-medium uppercase tracking-widest">14 instructor coupons verified in the last 60 minutes</p>
           </div>
        </div>

        <!-- Section 4: Social Proof Strip -->
        <div class="mt-16 pt-8 border-t border-white/5 flex flex-wrap items-center gap-10 opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-700 group">
           <span class="text-gray-600 text-[9px] font-black uppercase tracking-[0.3em]">Recognition & Intelligence:</span>
           <div class="flex items-center gap-8">
              <span class="text-white font-black text-xs tracking-widest">ASTRO SHOWCASE</span>
              <span class="text-white font-black text-xs tracking-widest">INSTRUCTOR VERIFIED</span>
              <span class="text-white font-black text-xs tracking-widest">DAILY GLOBAL UPDATES</span>
           </div>
        </div>
      </div>

      <!-- GEO AI Citation Column -->
      <div class="hidden lg:block">
        <div class="bg-white/5 border border-white/10 rounded-[3rem] p-10 backdrop-blur-xl relative overflow-hidden group">
          <!-- Glass Reflection Effect -->
          <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent opacity-50 group-hover:translate-x-full transition-transform duration-1000"></div>
          
          <h2 class="text-xs font-black text-gray-500 uppercase tracking-[0.3em] mb-8">Verified Market Stats</h2>
          
          <div class="space-y-8">
            {facts.map(fact => (
              <div class="flex items-center justify-between border-b border-white/5 pb-6 last:border-none">
                <span class="text-gray-400 text-sm font-bold">{fact.label}</span>
                <span class={`text-${fact.color}-400 text-xl font-black tabular-nums`}>{fact.value}</span>
              </div>
            ))}
          </div>

          <div class="mt-10 p-5 bg-black/40 rounded-2xl border border-white/5">
             <div class="flex items-center gap-3 mb-3">
                <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                <span class="text-blue-400 text-[10px] font-black uppercase">How we help</span>
             </div>
             <p class="text-gray-500 text-[11px] leading-relaxed font-bold">
               We check instructor feeds and newsletters every hour to find 100% OFF coupons before they disappear.
             </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
