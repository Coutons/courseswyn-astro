---
import { Image } from 'astro:assets';

interface Deal {
  id?: string;
  slug?: string;
  title: string;
  description?: string;
  image?: string;
  rating?: number;
  students?: number;
  price?: number;
  originalPrice?: number;
  category?: string;
  subcategory?: string;
  duration?: string;
  url?: string;
  provider?: string;
  updatedAt?: string;
  instructor?: string;
  coupon?: string;
  expiresAt?: string;
  createdAt?: string;
  language?: string;
  learn?: string[];
  requirements?: string[];
}

const { deal } = Astro.props;

function formatStudents(n: number) {
  if (n >= 1000000) return (n / 1000000).toFixed(1).replace(/\.0$/, "") + "M";
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, "") + "K";
  return String(n);
}

function formatRelativeTime(dateString: string) {
  const date = new Date(dateString);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  const diffDays = Math.floor(diffHours / 24);

  if (diffHours < 1) return "Just updated";
  if (diffHours < 24) return `${diffHours}h ago`;
  return `${diffDays}d ago`;
}

function genRating(key: string): number {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < key.length; i++) {
    h ^= key.charCodeAt(i);
    h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24);
  }
  const r = (h >>> 0) / 0xffffffff;
  return Math.round((4.5 + 0.3 * r) * 10) / 10;
}

function genStudents(key: string): number {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < key.length; i++) {
    h ^= key.charCodeAt(i);
    h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24);
  }
  const r = (h >>> 0) / 0xffffffff;
  return Math.round((1000 + (80000 - 1000) * Math.pow(r, 0.6)) / 10) * 10;
}

const key = String(deal.id || "");
const p = (typeof deal.price === "number") ? deal.price : (parseFloat(String(deal.price || "0")) || 0);
const opRaw = (typeof deal.originalPrice === "number") ? deal.originalPrice : (parseFloat(String(deal.originalPrice || "119.99")) || 119.99);
const op = opRaw > p ? opRaw : 119.99;
const r = typeof deal.rating === "number" && isFinite(deal.rating) ? deal.rating : genRating(key);
const s = typeof deal.students === "number" && isFinite(deal.students) ? deal.students : genStudents(key);
const hasDiscount = op > p && p > 0;
const isFree = p === 0;
const discountPct = hasDiscount ? Math.round(100 - (p / op) * 100) : (isFree ? 100 : null);
const title = String(deal.title || "").replace(/&amp;/g, "&").replace(/&quot;/g, '"').replace(/&apos;|&#8217;/g, "'").replace(/&ndash;|&#8211;/g, " & ").replace(/\s{2,}/g, " ").trim();
const description = String(deal.description || "").replace(/<[^>]*>/g, "").slice(0, 100);
const instructor = deal.instructor || "Udemy Instructor";
---

<div class="deal-card" style={{
  background: "var(--card)",
  border: "2px solid var(--border)",
  boxShadow: "4px 4px 0 var(--border)",
  borderRadius: "4px",
  overflow: "hidden",
  transition: "all 0.15s ease",
  height: "100%",
  display: "flex",
  flexDirection: "column",
  position: "relative"
}}>

  {/* ── Image Header ── */}
  <div style={{
    height: "170px",
    position: "relative",
    overflow: "hidden",
    borderBottom: "2px solid var(--border)",
    background: "var(--bg)"
  }}>
    {deal.image ? (
      <Image
        src={deal.image}
        alt={title}
        width={400}
        height={180}
        style={{ width: "100%", height: "100%", objectFit: "cover" }}
        loading="lazy"
        inferSize={false}
      />
    ) : (
      <div style={{ width: "100%", height: "100%", background: "var(--bg)", display: "flex", alignItems: "center", justifyContent: "center" }}>
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--border)" stroke-width="1.5" opacity="0.3">
          <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    )}

    {/* Verified Badge */}
    <div style={{
      position: "absolute",
      top: "10px",
      right: "10px",
      background: "var(--brand)",
      color: "var(--bg)",
      padding: "2px 8px",
      border: "2px solid var(--border)",
      boxShadow: "2px 2px 0 var(--border)",
      borderRadius: "4px",
      fontSize: "0.62rem",
      fontWeight: 900,
      letterSpacing: "0.05em",
      display: "flex",
      alignItems: "center",
      gap: "4px"
    }}>
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      VERIFIED
    </div>

    {/* Discount / Free Badge */}
    {discountPct !== null && (
      <div style={{
        position: "absolute",
        top: "10px",
        left: "10px",
        background: isFree ? "var(--accent)" : "var(--text)",
        color: "white",
        padding: "3px 10px",
        border: "2px solid var(--border)",
        boxShadow: "2px 2px 0 var(--border)",
        borderRadius: "4px",
        fontSize: "0.72rem",
        fontWeight: 900,
        letterSpacing: "0.04em"
      }}>
        {isFree ? "100% OFF" : `-${discountPct}%`}
      </div>
    )}

    {/* Category Overlay */}
    <div style={{
      position: "absolute",
      bottom: "10px",
      left: "10px",
      background: "var(--bg-primary)",
      border: "1.5px solid var(--border)",
      color: "var(--text)",
      padding: "2px 8px",
      borderRadius: "4px",
      fontSize: "0.65rem",
      fontWeight: 800,
      textTransform: "uppercase"
    }}>
      {deal.category || "General"}
    </div>
  </div>

  {/* ── Body ── */}
  <div style={{ padding: "20px", flex: 1, display: "flex", flexDirection: "column", gap: "14px" }}>

    {/* Rating & Students Line */}
    <div style={{ display: "flex", alignItems: "center", gap: "12px", fontSize: "0.75rem", fontWeight: 800 }}>
      <div style={{ display: "flex", alignItems: "center", gap: "3px", color: "var(--text)" }}>
        <span style={{ color: "#eed49f" }}>★</span> {r.toFixed(1)}
      </div>
      <div style={{ width: "4px", height: "4px", borderRadius: "50%", background: "var(--border)" }}></div>
      <div style={{ color: "var(--muted)" }}>{formatStudents(s)} students</div>
    </div>

    {/* Title */}
    <h3 style={{
      fontSize: "1rem",
      fontWeight: 900,
      color: "var(--text)",
      lineHeight: 1.25,
      display: "-webkit-box",
      WebkitLineClamp: 2,
      WebkitBoxOrient: "vertical",
      overflow: "hidden",
      margin: 0,
      letterSpacing: "-0.03em"
    }}>
      <a href={`/coupon/${deal.slug}`} style={{ color: "inherit", textDecoration: "none" }}>
        {title}
      </a>
    </h3>

    {/* Description Snippet */}
    <p style={{
      fontSize: "0.82rem",
      color: "var(--muted)",
      lineHeight: 1.5,
      fontWeight: 500,
      margin: 0,
      display: "-webkit-box",
      WebkitLineClamp: 2,
      WebkitBoxOrient: "vertical",
      overflow: "hidden"
    }}>
      {description}...
    </p>

    {/* Instructor */}
    <div style={{ display: "flex", alignItems: "center", gap: "8px" }}>
      <div style={{
        width: "22px",
        height: "22px",
        background: "var(--accent)",
        border: "1.5px solid var(--border)",
        color: "var(--bg-primary)",
        display: "flex",
        alignItems: "center",
        justifyContent: "center",
        fontSize: "0.55rem",
        fontWeight: 900,
        borderRadius: "4px"
      }}>
        {instructor.split(" ").map((w: string) => w[0]).slice(0, 2).join("").toUpperCase()}
      </div>
      <span style={{ fontSize: "0.72rem", color: "var(--text)", fontWeight: 700, overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>
        {instructor}
      </span>
    </div>

    {/* Price + CTA Footer */}
    <div style={{ marginTop: "auto", paddingTop: "16px", borderTop: "2px dashed var(--border)" }}>
      <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: "16px" }}>
        <div style={{ display: "flex", flexDirection: "column" }}>
          <div style={{ display: "flex", alignItems: "baseline", gap: "6px" }}>
            <span style={{ fontSize: "1.4rem", fontWeight: 900, color: p === 0 ? "var(--brand)" : "var(--brand)", letterSpacing: "-0.02em" }}>
              {p === 0 ? "FREE" : `$${p.toFixed(2)}`}
            </span>
            <span style={{ textDecoration: "line-through", color: "var(--muted)", fontSize: "0.85rem", fontWeight: 600 }}>
              ${op.toFixed(2)}
            </span>
          </div>
          {hasDiscount && (
            <span style={{ fontSize: "0.68rem", fontWeight: 800, color: "var(--accent)", textTransform: "uppercase" }}>
              Save ${(op - p).toFixed(2)}
            </span>
          )}
        </div>

        {/* Simple Timer Icon / Status */}
        <div style={{
          display: "flex", alignItems: "center", gap: "5px",
          fontSize: "0.65rem", fontWeight: 800, color: "var(--text)",
          background: "var(--bg)", padding: "4px 8px", borderRadius: "4px", border: "1.5px solid var(--border)"
        }}>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          {deal.updatedAt ? formatRelativeTime(deal.updatedAt) : "ACTIVE"}
        </div>
      </div>

      <a
        href={deal.url || `/coupon/${deal.slug}`}
        target={deal.url ? "_blank" : "_self"}
        rel={deal.url ? "noopener noreferrer" : undefined}
        class="btn"
        style={{
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          gap: "8px",
          width: "100%",
          padding: "12px",
          fontSize: "0.85rem",
          fontWeight: 900,
          letterSpacing: "0.03em"
        }}
      >
        <span>{isFree ? "REDEEM NOW" : "GET DISCOUNT"}</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><path d="M7 17L17 7M17 7H7M17 7v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</div>

<style>
  .deal-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 8px 8px 0 var(--border) !important;
    border-color: var(--text);
  }
</style>
