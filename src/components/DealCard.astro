---
import { Image } from 'astro:assets';

interface Deal {
  id?: string;
  slug?: string;
  title: string;
  description?: string;
  image?: string;
  rating?: number;
  students?: number;
  price?: number;
  originalPrice?: number;
  category?: string;
  subcategory?: string;
  duration?: string;
  url?: string;
  provider?: string;
  updatedAt?: string;
  instructor?: string;
  coupon?: string;
  expiresAt?: string;
  createdAt?: string;
  language?: string;
  learn?: string[];
  requirements?: string[];
}

const { deal, loading = "lazy" } = Astro.props;

function formatStudents(n: number) {
  if (!n) return "";
  if (n >= 1000000) return (n / 1000000).toFixed(1).replace(/\.0$/, "") + "M";
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, "") + "K";
  return String(n);
}

function timeAgo(dateStr: string | undefined): string | null {
  if (!dateStr) return null;
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return "just now";
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  if (days < 30) return `${days}d ago`;
  return `${Math.floor(days / 30)}mo ago`;
}

function expiresIn(dateStr: string | undefined): string | null {
  if (!dateStr) return null;
  const diff = new Date(dateStr).getTime() - Date.now();
  if (diff <= 0) return null;
  const hrs = Math.floor(diff / 3600000);
  if (hrs < 1) return `${Math.floor(diff / 60000)}m left`;
  if (hrs < 24) return `${hrs}h left`;
  const days = Math.floor(hrs / 24);
  return `${days}d left`;
}

const r = typeof deal.rating === "number" && isFinite(deal.rating) ? deal.rating : null;
const s = (typeof deal.students === "number" && isFinite(deal.students) && deal.students > 0) ? deal.students : null;
const p = (typeof deal.price === "number" && isFinite(deal.price)) ? deal.price : 9.99;
const op = (typeof deal.originalPrice === "number" && isFinite(deal.originalPrice) && deal.originalPrice > 0) ? deal.originalPrice : 199.99;
const hasDiscount = op > p && p > 0;
const isFree = p === 0;
const discountPct = hasDiscount ? Math.round(100 - (p / op) * 100) : (isFree ? 100 : null);
const title = String(deal.title || "").replace(/&amp;/g, "&").replace(/&quot;/g, '"').replace(/&apos;|&#8217;/g, "'").replace(/&ndash;|&#8211;/g, " & ").replace(/\s{2,}/g, " ").trim();
const description = String(deal.description || "").replace(/<[^>]*>/g, "").slice(0, 120);
const instructor = deal.instructor || "Udemy Instructor";
const duration = deal.duration || "";
const durationLabel = duration ? duration.replace(/^(\d+)\s*hours?.*$/i, "$1h") : "";
---

<div class="deal-card" style={{
  background: "var(--card)",
  border: "1px solid rgba(212,167,55,0.08)",
  borderRadius: "var(--radius)",
  overflow: "hidden",
  transition: "all 0.3s ease",
  height: "100%",
  display: "flex",
  flexDirection: "column",
  position: "relative"
}}>

  <div style={{
    position: "relative",
    aspectRatio: "16/9",
    overflow: "hidden",
    background: "var(--bg-secondary)"
  }}>
    {deal.image ? (
      <Image src={deal.image} alt={title} width={400} height={225}
        style={{ width: "100%", height: "100%", objectFit: "cover" }}
        loading={loading} inferSize={false} />
    ) : (
      <div style={{ width: "100%", height: "100%", display: "flex", alignItems: "center", justifyContent: "center" }}>
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--muted-light)" stroke-width="1.5" opacity="0.4">
          <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    )}

    {discountPct !== null && (
      <div style={{
        position: "absolute", top: "12px", left: "12px",
        background: "linear-gradient(135deg, #B8860B, #D4AF37, #E8C547, #D4AF37)",
        color: "#1a1814", padding: "4px 12px", borderRadius: "8px",
        fontSize: "0.75rem", fontWeight: 800, letterSpacing: "0.02em",
        boxShadow: "0 2px 8px rgba(212,167,55,0.3)"
      }}>
        {isFree ? "FREE" : `-${discountPct}%`}
      </div>
    )}

    <div style={{
      position: "absolute", top: "12px", right: "12px",
      background: "rgba(15,14,12,0.7)", color: "var(--brand)",
      padding: "4px 10px", borderRadius: "8px",
      fontSize: "0.6rem", fontWeight: 700, letterSpacing: "0.04em",
      backdropFilter: "blur(4px)", display: "flex", alignItems: "center", gap: "4px",
      border: "1px solid rgba(212,167,55,0.2)"
    }}>
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      VERIFIED
    </div>
  </div>

  <div style={{ padding: "20px", flex: 1, display: "flex", flexDirection: "column", gap: "10px" }}>

    <div style={{ display: "flex", alignItems: "center", gap: "8px", fontSize: "0.85rem" }}>
      {r && (
        <div style={{ display: "flex", alignItems: "center", gap: "3px", color: "var(--brand)", fontWeight: 700 }}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {r.toFixed(1)}
        </div>
      )}
      {r && s && <span style={{ color: "var(--muted-light)", fontSize: "0.7rem" }}>|</span>}
      {s && <span style={{ color: "var(--text-secondary)", fontWeight: 500 }}>{formatStudents(s)} students</span>}
    </div>

    <h3 style={{
      fontSize: "1.05rem", fontWeight: 700, color: "var(--text)",
      lineHeight: 1.35, margin: 0,
      display: "-webkit-box", WebkitLineClamp: 2, WebkitBoxOrient: "vertical", overflow: "hidden"
    }}>
      <a href={`/coupon/${deal.slug}`} style={{ color: "inherit", textDecoration: "none" }}>{title}</a>
    </h3>

    {description && (
      <p style={{
        fontSize: "0.82rem", color: "var(--text-secondary)", lineHeight: 1.5, fontWeight: 400, margin: 0
      }}>
        {description}
      </p>
    )}

    <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginTop: "2px" }}>
      <div style={{ display: "flex", alignItems: "center", gap: "6px" }}>
        <div style={{
          width: "20px", height: "20px", borderRadius: "6px",
          background: "var(--brand)", color: "white",
          display: "flex", alignItems: "center", justifyContent: "center",
          fontSize: "0.5rem", fontWeight: 700, flexShrink: 0
        }}>
          {instructor.split(" ").map((w: string) => w[0]).slice(0, 2).join("").toUpperCase()}
        </div>
        <span style={{ fontSize: "0.78rem", color: "var(--text-secondary)", fontWeight: 500, overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap", maxWidth: "140px" }}>
          {instructor}
        </span>
      </div>
      {durationLabel && (
        <span style={{ fontSize: "0.78rem", color: "var(--muted-light)", fontWeight: 600 }}>
          {durationLabel}
        </span>
      )}
    </div>

    <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", fontSize: "0.7rem", color: "var(--muted-light)", fontWeight: 600 }}>
      {timeAgo(deal.updatedAt) && (
        <span style={{ display: "flex", alignItems: "center", gap: "3px" }}>
          <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
          Verified {timeAgo(deal.updatedAt)}
        </span>
      )}
      {expiresIn(deal.expiresAt) && (
        <span style={{ color: "#ef4444" }}>{expiresIn(deal.expiresAt)}</span>
      )}
    </div>

    <div style={{ marginTop: "auto", paddingTop: "14px", borderTop: "1px solid var(--border)" }}>
      <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between" }}>
        <div style={{ display: "flex", alignItems: "baseline", gap: "8px" }}>
          <span style={{ fontSize: "1.25rem", fontWeight: 800, color: "var(--brand)" }}>
            {isFree ? "FREE" : `$${p.toFixed(2)}`}
          </span>
          {hasDiscount && (
            <span style={{ textDecoration: "line-through", color: "var(--muted-light)", fontSize: "0.8rem", fontWeight: 500 }}>
              ${op.toFixed(2)}
            </span>
          )}
        </div>
        <a href={deal.url || `/coupon/${deal.slug}`}
          target={deal.url ? "_blank" : "_self"}
          rel={deal.url ? "noopener noreferrer" : undefined}
          style={{
            display: "inline-flex", alignItems: "center", justifyContent: "center", gap: "5px",
            padding: "8px 18px", borderRadius: "10px",
            background: "linear-gradient(135deg, #B8860B 0%, #D4AF37 25%, #E8C547 50%, #D4AF37 75%, #B8860B 100%)", color: "#1a1814",
            fontSize: "0.78rem", fontWeight: 700, textDecoration: "none",
            whiteSpace: "nowrap", transition: "all 0.3s"
          }}
          onmouseover="this.style.background='linear-gradient(135deg, #C5A028 0%, #D4AF37 25%, #E8C547 50%, #D4AF37 75%, #C5A028 100%)';this.style.boxShadow='0 0 20px 4px rgba(212,167,55,0.4)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='linear-gradient(135deg, #B8860B 0%, #D4AF37 25%, #E8C547 50%, #D4AF37 75%, #B8860B 100%)';this.style.boxShadow='none';this.style.transform='none'">
          {isFree ? "GET FREE" : "REDEEM"}
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .deal-card {
    position: relative;
  }
  .deal-card::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, #B8860B, #D4AF37, #E8C547, #D4AF37, #B8860B);
    opacity: 0.15;
    transition: opacity 0.4s ease;
    z-index: 2;
    border-radius: 0.75rem 0.75rem 0 0;
    pointer-events: none;
  }
  .deal-card:hover {
    transform: translateY(-4px) scale(1.01);
    box-shadow: 0 16px 40px -8px rgba(212,167,55,0.15);
    border-color: rgba(212,167,55,0.3) !important;
  }
  .deal-card:hover::before {
    opacity: 1;
  }
  .deal-card:hover img {
    transform: scale(1.06);
    transition: transform 0.6s ease;
  }
  .deal-card img {
    transition: transform 0.6s ease;
  }
</style>
