---
import { Image } from 'astro:assets';

interface Deal {
  id?: string;
  slug?: string;
  title: string;
  description?: string;
  image?: string;
  rating?: number;
  students?: number;
  price?: number;
  originalPrice?: number;
  category?: string;
  subcategory?: string;
  duration?: string;
  url?: string;
  provider?: string;
  updatedAt?: string;
  instructor?: string;
  coupon?: string;
  expiresAt?: string;
  createdAt?: string;
  language?: string;
  learn?: string[];
  requirements?: string[];
}

const { deal } = Astro.props;

function formatStudents(n: number) {
  if (n >= 1000000) return (n / 1000000).toFixed(1).replace(/\.0$/, "") + "m";
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, "") + "k";
  return String(n);
}

function formatDuration(duration: string) {
  if (!duration) return "";
  
  return duration
    .replace(/(\d+)h/g, '$1 hours')
    .replace(/(\d+)m/g, '$1 minutes')
    .replace(/\s+/g, ' ');
}

function formatRelativeTime(dateString: string) {
  const date = new Date(dateString);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  const diffDays = Math.floor(diffHours / 24);

  if (diffHours < 1) {
    return "Updated recently";
  } else if (diffHours < 24) {
    return `Updated ${diffHours} hour${diffHours === 1 ? '' : 's'} ago`;
  } else {
    return `Updated ${diffDays} day${diffDays === 1 ? '' : 's'} ago`;
  }
}

function genRating(key: string): number {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < key.length; i++) {
    h ^= key.charCodeAt(i);
    h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24);
  }
  const r = (h >>> 0) / 0xffffffff;
  const val = 4.5 + 0.3 * r;
  return Math.round(val * 10) / 10;
}

function genStudents(key: string): number {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < key.length; i++) {
    h ^= key.charCodeAt(i);
    h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24);
  }
  const r = (h >>> 0) / 0xffffffff;
  const min = 1000, max = 80000;
  const val = Math.floor(min + (max - min) * Math.pow(r, 0.6));
  return Math.round(val / 10) * 10;
}

const key = String(deal.id || "");
const p = typeof deal.price === "number" && isFinite(deal.price) && deal.price > 0 ? deal.price : 0;
const opRaw = typeof deal.originalPrice === "number" && isFinite(deal.originalPrice) ? deal.originalPrice : 119.99;
const op = opRaw > p ? opRaw : 119.99;
const r = typeof deal.rating === "number" && isFinite(deal.rating) ? deal.rating : genRating(key);
const s = typeof deal.students === "number" && isFinite(deal.students) ? deal.students : genStudents(key);
const hasDiscount = op > p && p > 0;
const discountPct = hasDiscount ? Math.round(100 - (p / op) * 100) : null;
const title = String(deal.title || "").replace(/&amp;/g, "&").replace(/&quot;/g, '"').replace(/&apos;|&#8217;/g, "'").replace(/&ndash;|&#8211;/g, " & ").replace(/\s{2,}/g, " ").trim();
---

<div style={{
  background: "rgba(30, 41, 59, 0.4)",
  backdropFilter: "blur(12px)",
  borderRadius: "20px",
  border: "1px solid rgba(187, 94, 52, 0.15)",
  overflow: "hidden",
  transition: "all 0.4s cubic-bezier(0.4, 0, 0.2, 1)",
  position: "relative"
}}>
  {/* Image at top with timestamp badge */}
  <div style={{
    height: "180px",
    background: `linear-gradient(135deg, var(--brand-soft) 0%, var(--accent-soft) 100%)`,
    display: "flex",
    alignItems: "center",
    justifyContent: "center",
    position: "relative"
  }}>
    {deal.image ? (
      <Image 
        src={deal.image}
        alt={title}
        width={400}
        height={225}
        style={{
          width: "100%",
          height: "100%",
          objectFit: "cover"
        }}
        loading="lazy"
        inferSize={false}
      />
    ) : (
      <svg width="60" height="60" viewBox="0 0 24 24" fill="var(--muted)" opacity="0.5">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    )}

    {/* Timestamp Badge on Image */}
    <div style={{
      position: "absolute",
      top: "1rem",
      right: "1rem",
      background: "rgba(0, 0, 0, 0.8)",
      color: "white",
      padding: "0.25rem 0.5rem",
      borderRadius: "4px",
      fontSize: "0.7rem",
      fontWeight: 600,
      backdropFilter: "blur(4px)"
    }}>
      {deal.updatedAt ? formatRelativeTime(deal.updatedAt) : "Updated recently"}
    </div>

    {/* FREE Badge if applicable */}
    {p === 0 && (
      <div style={{
        position: "absolute",
        top: "1rem",
        left: "1rem",
        background: "var(--brand)",
        color: "#000",
        padding: "0.25rem 0.75rem",
        borderRadius: "8px",
        fontSize: "0.7rem",
        fontWeight: 800,
        zIndex: 10,
        boxShadow: "0 4px 12px rgba(6, 182, 212, 0.3)"
      }}>
        FREE
      </div>
    )}
  </div>

  {/* Content below image */}
  <div style={{ padding: "1.5rem" }}>
    {/* Title */}
    <h3 style={{
      fontSize: "1.1rem",
      fontWeight: 700,
      color: "var(--text)",
      marginBottom: "0.5rem",
      lineHeight: 1.4,
      display: "-webkit-box",
      WebkitLineClamp: 2,
      WebkitBoxOrient: "vertical",
      overflow: "hidden"
    }}>
      <a href={`/coupon/${deal.slug || deal.id}`} style={{
        color: "inherit",
        textDecoration: "none"
      }}>
        {title}
      </a>
    </h3>

    {/* Instructor */}
    {deal.instructor && (
      <div style={{
        display: "flex",
        alignItems: "center",
        gap: "0.5rem",
        marginBottom: "0.75rem"
      }}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--muted)">
          <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
        </svg>
        <span style={{
          color: "var(--text)",
          fontSize: "0.85rem",
          fontWeight: 600
        }}>
          By {deal.instructor}
        </span>
      </div>
    )}

    {/* Description */}
    <p style={{
      color: "var(--muted)",
      fontSize: "0.9rem",
      marginBottom: "1rem",
      lineHeight: 1.5,
      display: "-webkit-box",
      WebkitLineClamp: 3,
      WebkitBoxOrient: "vertical",
      overflow: "hidden"
    }}>
      {deal.description || "Master this in-demand skill with comprehensive training from industry experts."}
    </p>

    {/* Rating, Students & Subcategory - Single Row */}
    <div style={{
      display: "flex",
      alignItems: "center",
      justifyContent: "space-between",
      marginBottom: "1rem"
    }}>
      <div style={{
        display: "flex",
        alignItems: "center",
        gap: "0.5rem"
      }}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--brand)">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        <span style={{
          color: "var(--muted)",
          fontSize: "0.85rem",
          fontWeight: 600
        }} title={`${r.toFixed(1)} out of 5 stars from ${typeof deal.students === "number" && isFinite(deal.students) ? deal.students : genStudents(key)}+ students`}>
          {r.toFixed(1)} ({typeof deal.students === "number" && isFinite(deal.students) ? deal.students : genStudents(key)}+ students)
        </span>
      </div>

      {deal.subcategory && (
        <a href={`/topics/${deal.subcategory.toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-')}`} style={{
          display: "flex",
          alignItems: "center",
          gap: "0.25rem",
          color: "var(--brand)",
          textDecoration: "none",
          fontSize: "0.8rem",
          fontWeight: 600,
          padding: "0.25rem 0.5rem",
          borderRadius: "4px",
          background: "var(--card-hover)",
          transition: "all 0.3s ease"
        }} title={`Browse ${deal.subcategory} courses`}>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
            <path d="M10 4H4c-1.11 0-2 .89-2 2v3h2V6h4V4zM10 19v-2H4v-3H2v3c0 1.11.89 2 2 2h6zM20 4h-6v2h4v3h2V6c0-1.11-.89-2-2-2zM20 16h-2v3h-4v2h6c1.11 0 2-.89 2-2v-3z"/>
          </svg>
          {deal.subcategory}
        </a>
      )}
    </div>

    {/* Price, Discount & Verified */}
    <div style={{
      display: "flex",
      alignItems: "center",
      justifyContent: "space-between",
      marginBottom: "1rem"
    }}>
      <div style={{
        display: "flex",
        alignItems: "center",
        gap: "0.5rem"
      }}>
        <span style={{
          fontSize: "1.2rem",
          fontWeight: 700,
          color: "var(--brand)"
        }}>
          {p === 0 ? "FREE" : `$${p.toFixed(2)}`}
        </span>
        {hasDiscount && (
          <>
            <span style={{
              textDecoration: "line-through",
              color: "var(--muted)",
              fontSize: "0.9rem"
            }}>
              ${op.toFixed(2)}
            </span>
            <span style={{
              background: "hsl(0, 84%, 60%)",
              color: "white",
              padding: "0.25rem 0.5rem",
              borderRadius: "4px",
              fontSize: "0.75rem",
              fontWeight: 700
            }}>
              {discountPct}% OFF
            </span>
          </>
        )}
      </div>

      {/* Verified Badge inline with price */}
      <div style={{
        background: "linear-gradient(135deg, var(--brand) 0%, var(--secondary) 100%)",
        color: "#000",
        padding: "0.2rem 0.6rem",
        borderRadius: "6px",
        fontSize: "0.65rem",
        fontWeight: 800,
        display: "flex",
        alignItems: "center",
        gap: "0.25rem",
        letterSpacing: "0.05em"
      }}>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
          <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
        </svg>
        VERIFIED
      </div>
    </div>

    {/* Duration */}
    {deal.duration && (
      <div style={{
        display: "flex",
        alignItems: "center",
        gap: "0.5rem",
        marginBottom: "1rem"
      }}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--muted)">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12,6 12,12 16,14"/>
        </svg>
        <span style={{
          color: "var(--muted)",
          fontSize: "0.8rem",
          fontWeight: 600
        }}>
          Course Duration: {formatDuration(deal.duration)}
        </span>
      </div>
    )}

    {/* Button */}
    <a
      href={deal.url || `/coupon/${deal.slug || deal.id}`}
      target="_blank"
      rel="noopener noreferrer"
      style={{
        display: "block",
        width: "100%",
        padding: "0.75rem 1.5rem",
        background: "linear-gradient(135deg, var(--brand) 0%, var(--secondary) 100%)",
        color: "#000",
        textDecoration: "none",
        borderRadius: "10px",
        textAlign: "center",
        fontWeight: 700,
        fontSize: "0.9rem",
        transition: "all 0.3s ease",
        border: "none",
        cursor: "pointer",
        boxShadow: "0 4px 15px rgba(6, 182, 212, 0.2)"
      }}
    >
      {p === 0 ? "Enroll for Free" : "Get Coupon"}
    </a>
  </div>
</div>
