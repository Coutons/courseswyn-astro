---
import Layout from '../../layouts/Layout.astro';
import DealCard from '../../components/DealCard.astro';
import type { Deal } from '../../types/deal';
import { readDeals } from '../../lib/store';
import { parseInstructors, createInstructorSlug } from '../../lib/instructors';

const siteUrl = 'https://courseswyn.com';

export async function getStaticPaths() {
  const deals: Deal[] = await readDeals();
  const slugToName = new Map<string, string>();

  for (const deal of deals) {
    if (!deal.instructor) continue;
    for (const name of parseInstructors(deal.instructor)) {
      const slug = createInstructorSlug(name);
      if (!slug) continue;
      if (!slugToName.has(slug)) {
        slugToName.set(slug, name);
      }
    }
  }

  return Array.from(slugToName.entries()).map(([instructor, instructorName]) => ({
    params: { instructor },
    props: { instructorName },
  }));
}

const { instructorName: instructorNameProp } = Astro.props as { instructorName?: string };
const slugParam = Astro.params.instructor ?? '';

const deals: Deal[] = await readDeals();

function dealMatchesInstructorSlug(deal: Deal, targetSlug: string): boolean {
  if (!deal.instructor) return false;
  return parseInstructors(deal.instructor).some((n) => createInstructorSlug(n) === targetSlug);
}

let instructorName = instructorNameProp;
if (!instructorName && slugParam) {
  for (const deal of deals) {
    if (!deal.instructor) continue;
    for (const n of parseInstructors(deal.instructor)) {
      if (createInstructorSlug(n) === slugParam) {
        instructorName = n;
        break;
      }
    }
    if (instructorName) break;
  }
}

if (!instructorName || !slugParam) {
  return Astro.redirect('/instructors');
}

const instructorCourses = deals
  .filter((d) => dealMatchesInstructorSlug(d, slugParam))
  .sort((a, b) => (b.students ?? 0) - (a.students ?? 0));

if (instructorCourses.length === 0) {
  return Astro.redirect('/instructors');
}

const currentMonth = new Date().toLocaleDateString('en-US', { month: 'long' });
const currentYear = new Date().getFullYear();
const canonicalUrl = `${siteUrl}/instructor/${slugParam}`;

function getMaxDiscount(courses: Deal[]): number {
  return Math.max(
    0,
    ...courses.map((c) => {
      if (!c.originalPrice || !c.price || c.price >= c.originalPrice) return 0;
      return Math.round(100 - (c.price / c.originalPrice) * 100);
    })
  );
}

function hasFree(courses: Deal[]): boolean {
  return courses.some((c) => c.price === 0);
}

function getInitials(name: string): string {
  return name
    .split(' ')
    .map((n) => n[0])
    .join('')
    .toUpperCase()
    .slice(0, 2);
}

const totalStudents = instructorCourses.reduce((s, c) => s + (c.students ?? 0), 0);
const rated = instructorCourses.filter((c) => typeof c.rating === 'number' && isFinite(c.rating!));
const avgRating =
  rated.length > 0
    ? (rated.reduce((s, c) => s + (c.rating as number), 0) / rated.length).toFixed(1)
    : '—';
const provider = instructorCourses[0]?.provider || 'Udemy';
const maxDisc = getMaxDiscount(instructorCourses);
const title = `${instructorName} — Udemy Coupons & Promo Codes ${currentMonth} ${currentYear} | CoursesWyn`;
const description = `Verified ${instructorCourses.length} Udemy coupon${instructorCourses.length === 1 ? '' : 's'} from ${instructorName}. ${provider} deals updated daily — up to ${maxDisc}% off${hasFree(instructorCourses) ? ', including free courses' : ''}.`;
---

<Layout title={title} description={description} canonical={canonicalUrl}>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'BreadcrumbList',
          itemListElement: [
            { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
            { '@type': 'ListItem', position: 2, name: 'Instructors', item: `${siteUrl}/instructors` },
            { '@type': 'ListItem', position: 3, name: instructorName, item: canonicalUrl },
          ],
        },
        {
          '@type': 'CollectionPage',
          url: canonicalUrl,
          name: title,
          description,
          mainEntity: {
            '@type': 'ItemList',
            numberOfItems: instructorCourses.length,
          },
        },
      ],
    })}
  />

  <main style="background: var(--bg); color: var(--text);">
    <section style="padding: 100px 0 60px; border-bottom: 2px solid var(--border); background: var(--card);">
      <div class="inst-container">
        <nav style="font-size: 0.85rem; font-weight: 600; color: var(--muted); margin-bottom: 24px;">
          <a href="/" style="color: var(--accent); text-decoration: none;">Home</a>
          <span aria-hidden="true"> / </span>
          <a href="/instructors" style="color: var(--accent); text-decoration: none;">Instructors</a>
          <span aria-hidden="true"> / </span>
          <span style="color: var(--text);">{instructorName}</span>
        </nav>

        <div
          style="display: inline-block; background: var(--accent); color: white; padding: 4px 14px; border: 2px solid var(--border); box-shadow: 3px 3px 0 var(--border); border-radius: 4px; font-size: 0.75rem; font-weight: 800; margin-bottom: 24px; text-transform: uppercase; letter-spacing: 0.1em;"
        >
          {provider} · {currentMonth} {currentYear}
        </div>

        <div style="display: flex; gap: 24px; align-items: flex-start; flex-wrap: wrap;">
          <div
            style="width: 80px; height: 80px; min-width: 80px; background: var(--accent); border: 2px solid var(--border); border-radius: 4px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 900; font-size: 1.75rem; box-shadow: 4px 4px 0 var(--border);"
          >
            {getInitials(instructorName)}
          </div>
          <div style="flex: 1; min-width: 220px;">
            <h1
              style="font-size: clamp(2rem, 6vw, 3.25rem); font-weight: 900; line-height: 1.05; letter-spacing: -0.04em; margin: 0 0 12px;"
            >
              {instructorName}
            </h1>
            <p
              style="font-size: 1.05rem; color: var(--muted); line-height: 1.6; font-weight: 500; margin: 0 0 24px; max-width: 720px;"
            >
              {instructorCourses.length} active coupon{instructorCourses.length === 1 ? '' : 's'} with verified Udemy discounts.
            </p>
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">
              <div
                style="background: white; border: 2px solid var(--border); padding: 10px 18px; border-radius: 4px; box-shadow: 3px 3px 0 var(--border);"
              >
                <span style="font-size: 1.25rem; font-weight: 900; color: var(--accent);">{instructorCourses.length}</span>
                <span style="display: block; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: var(--muted);">Coupons</span>
              </div>
              <div
                style="background: white; border: 2px solid var(--border); padding: 10px 18px; border-radius: 4px; box-shadow: 3px 3px 0 var(--border);"
              >
                <span style="font-size: 1.25rem; font-weight: 900; color: var(--accent);">{totalStudents.toLocaleString()}</span>
                <span style="display: block; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: var(--muted);">Students (sum)</span>
              </div>
              <div
                style="background: white; border: 2px solid var(--border); padding: 10px 18px; border-radius: 4px; box-shadow: 3px 3px 0 var(--border);"
              >
                <span style="font-size: 1.25rem; font-weight: 900; color: var(--accent);">{avgRating}</span>
                <span style="display: block; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: var(--muted);">Avg rating</span>
              </div>
              <div
                style="background: white; border: 2px solid var(--border); padding: 10px 18px; border-radius: 4px; box-shadow: 3px 3px 0 var(--border);"
              >
                <span style="font-size: 1.25rem; font-weight: 900; color: var(--accent);">Up to {maxDisc}%</span>
                <span style="display: block; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: var(--muted);">Max off</span>
              </div>
              {hasFree(instructorCourses) && (
                <div
                  style="background: #22c55e; color: white; border: 2px solid var(--border); padding: 10px 18px; border-radius: 4px; box-shadow: 3px 3px 0 var(--border); align-self: center; font-size: 0.75rem; font-weight: 900; text-transform: uppercase;"
                >
                  Free deals
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section style="padding: 64px 0 80px;">
      <div class="inst-container">
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 28px;">
          {instructorCourses.map((deal) => (
            <DealCard deal={deal} />
          ))}
        </div>
      </div>
    </section>
  </main>

  <style>
    .inst-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }
  </style>
</Layout>
