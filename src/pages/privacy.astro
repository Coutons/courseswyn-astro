---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Privacy Policy | Data Protection & User Rights"
    description="CoursesWyn Privacy Policy: Learn how we collect, use, and protect your personal data. We prioritize user privacy and data security on our Udemy coupon platform."
>
    <!-- Enhanced AI-Friendly Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "@id": "https://courseswyn.com/privacy",
          "url": "https://courseswyn.com/privacy",
          "name": "Privacy Policy | Data Protection & User Rights - CoursesWyn",
          "description": "Comprehensive Privacy Policy for CoursesWyn. Learn about data collection, usage, protection, GDPR compliance, and your privacy rights on our Udemy coupon platform.",
          "isPartOf": {
            "@id": "https://courseswyn.com"
          },
          "primaryImageOfPage": {
            "@type": "ImageObject",
            "url": "https://courseswyn.com/logo.svg"
          },
          "datePublished": "2023-01-01",
          "dateModified": "2026-01-15",
          "inLanguage": "en-US",
          "breadcrumb": {
            "@type": "BreadcrumbList",
            "itemListElement": [
              {
                "@type": "ListItem",
                "position": 1,
                "name": "Home",
                "item": "https://courseswyn.com"
              },
              {
                "@type": "ListItem",
                "position": 2,
                "name": "Privacy Policy",
                "item": "https://courseswyn.com/privacy"
              }
            ]
          },
          "mainEntity": {
            "@type": "PrivacyPolicy",
            "name": "CoursesWyn Privacy Policy",
            "text": "This Privacy Policy explains how CoursesWyn collects, uses, discloses, and safeguards your information. We are committed to protecting user privacy and data security.",
            "datePublished": "2023-01-01",
            "dateModified": "2026-01-15"
          }
        },
        {
          "@type": "Organization",
          "@id": "https://courseswyn.com/#organization",
          "name": "CoursesWyn",
          "url": "https://courseswyn.com",
          "logo": "https://courseswyn.com/logo.svg",
          "description": "Free Udemy coupons and online course deals platform",
          "sameAs": [
            "https://x.com/courseswyn",
            "https://www.facebook.com/BestCouponPromo/"
          ]
        }
      ]
    }
    </script>

    <main>
        <!-- Hero Section -->
        <section class="hero-section">
            <div class="container container-sm">
                <div class="badge">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm3 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/>
                    </svg>
                    Privacy & Data Protection
                </div>

                <h1 class="hero-title">
                    <span class="gradient-text-brand">Privacy Policy</span>
                    <br/>
                    <span class="gradient-text-muted">Data Protection & Rights</span>
                </h1>

                <p class="hero-description">
                    Your privacy matters to us. Learn how CoursesWyn collects, uses, and protects your personal data with complete transparency and control.
                </p>

                <p class="last-updated">
                    <strong>Last Updated:</strong> January 15, 2026
                </p>

                <!-- Trust Indicators -->
                <div class="trust-bar">
                    <div class="trust-item">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--accent)">
                            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                        </svg>
                        <span>GDPR Compliant</span>
                    </div>
                    <div class="trust-item">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--accent)">
                            <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm3 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/>
                        </svg>
                        <span>Secure Encryption</span>
                    </div>
                    <div class="trust-item">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--accent)">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                        <span>User Rights Focused</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Statistics Section -->
        <section class="section bg-secondary">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Privacy & Security by the Numbers</h2>
                    <p class="section-subtitle">Our commitment to data protection and user privacy</p>
                </div>

                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value accent">100%</div>
                        <div class="stat-label">GDPR Compliant</div>
                        <div class="stat-desc">Full compliance with data protection regulations</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-value accent">SSL</div>
                        <div class="stat-label">Encrypted Connection</div>
                        <div class="stat-desc">256-bit SSL encryption for all data transfers</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-value teal">24/7</div>
                        <div class="stat-label">Data Monitoring</div>
                        <div class="stat-desc">Continuous security monitoring and protection</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-value brand">0</div>
                        <div class="stat-label">Data Breaches</div>
                        <div class="stat-desc">Zero security incidents in our history</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Key Features Section -->
        <section class="section">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Privacy Protection Features</h2>
                    <p class="section-subtitle">Advanced security measures and user control options</p>
                </div>

                <div class="features-grid">
                    <div class="card">
                        <div class="card-icon accent-bg">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="white">
                                <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm3 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/>
                            </svg>
                        </div>
                        <h3 class="card-title accent">End-to-End Encryption</h3>
                        <p class="card-text">All your personal data is encrypted using industry-standard AES-256 encryption, ensuring complete protection from unauthorized access.</p>
                    </div>

                    <div class="card">
                        <div class="card-icon accent-bg">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="white">
                                <path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
                            </svg>
                        </div>
                        <h3 class="card-title accent">Data Access Control</h3>
                        <p class="card-text">You have full control over your data. Easily access, update, or delete your personal information through our user dashboard.</p>
                    </div>

                    <div class="card">
                        <div class="card-icon brand-bg">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="white">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                            </svg>
                        </div>
                        <h3 class="card-title brand">Regular Security Audits</h3>
                        <p class="card-text">We conduct regular security audits and penetration testing to ensure our systems remain secure against emerging threats.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Main Privacy Content -->
        <section class="section bg-secondary">
            <div class="container container-narrow">
                <div class="content-cards">
                    <!-- Information We Collect Card -->
                    <div class="content-card">
                        <h2>Information We Collect</h2>
                        <h3>Personal Information</h3>
                        <p>We may collect personal information that you voluntarily provide to us when you:</p>
                        <ul>
                            <li>Subscribe to our newsletter</li>
                            <li>Contact us through our contact form</li>
                            <li>Create an account (if applicable)</li>
                            <li>Participate in surveys or promotions</li>
                        </ul>
                        <p>This may include your name, email address, and any other information you choose to provide.</p>

                        <h3>Usage Data</h3>
                        <p>We automatically collect certain information about your device and usage of our service, including:</p>
                        <ul>
                            <li>IP address and location information</li>
                            <li>Browser type and version</li>
                            <li>Pages visited and time spent on our site</li>
                            <li>Device identifiers</li>
                            <li>Referral sources</li>
                        </ul>
                    </div>

                    <!-- How We Use Your Information Card -->
                    <div class="content-card">
                        <h2>How We Use Your Information</h2>
                        <p>We use the collected data for various purposes:</p>
                        <ul>
                            <li>To provide and maintain our service</li>
                            <li>To notify you about changes to our service</li>
                            <li>To provide customer support</li>
                            <li>To gather analysis and valuable information for improving our service</li>
                            <li>To monitor the usage of our service</li>
                            <li>To detect, prevent, and address technical issues</li>
                            <li>To send you newsletters and promotional communications (with your consent)</li>
                        </ul>
                    </div>

                    <!-- Information Sharing and Disclosure Card -->
                    <div class="content-card">
                        <h2>Information Sharing and Disclosure</h2>
                        <p>We do not sell, trade, or otherwise transfer your personal information to third parties except in the following circumstances:</p>
                        <ul>
                            <li><strong>Service Providers:</strong> We may share information with trusted third-party service providers who assist us in operating our website and conducting our business.</li>
                            <li><strong>Legal Requirements:</strong> We may disclose your information if required by law or in response to valid legal processes.</li>
                            <li><strong>Business Transfers:</strong> In the event of a merger, acquisition, or sale of assets, your information may be transferred.</li>
                            <li><strong>Consent:</strong> With your explicit consent.</li>
                        </ul>
                    </div>

                    <!-- Data Security Card -->
                    <div class="content-card">
                        <h2>Data Security</h2>
                        <p>We implement appropriate technical and organizational measures to protect your personal data against unauthorized access, alteration, disclosure, or destruction. However, no method of transmission over the internet or electronic storage is 100% secure, and we cannot guarantee absolute security.</p>
                    </div>

                    <!-- Your Data Protection Rights Card -->
                    <div class="content-card">
                        <h2>Your Data Protection Rights</h2>
                        <p>Depending on your location, you may have the following rights regarding your personal data:</p>
                        <ul>
                            <li><strong>Access:</strong> Request access to your personal data</li>
                            <li><strong>Rectification:</strong> Request correction of inaccurate data</li>
                            <li><strong>Erasure:</strong> Request deletion of your personal data</li>
                            <li><strong>Restriction:</strong> Request limitation of processing</li>
                            <li><strong>Portability:</strong> Request transfer of your data</li>
                            <li><strong>Objection:</strong> Object to processing based on legitimate interests</li>
                        </ul>
                        <p>To exercise these rights, please contact us using the information provided below.</p>
                    </div>

                    <!-- Cookies and Tracking Technologies Card -->
                    <div class="content-card">
                        <h2>Cookies and Tracking Technologies</h2>
                        <p>We use cookies and similar tracking technologies to enhance your browsing experience, analyze site traffic, and understand where our visitors are coming from. You can control cookies through your browser settings. However, disabling cookies may affect the functionality of our website.</p>
                        <p>Our site uses Google Analytics to collect anonymous usage statistics. This helps us improve our services and provide better content for our users.</p>
                    </div>

                    <!-- Third-Party Links Card -->
                    <div class="content-card">
                        <h2>Third-Party Links</h2>
                        <p>Our website contains links to third-party websites, including Udemy and other online learning platforms. We are not responsible for the privacy practices or content of these external sites. We encourage you to read the privacy policies of any third-party websites you visit.</p>
                    </div>

                    <!-- Children's Privacy Card -->
                    <div class="content-card">
                        <h2>Children's Privacy</h2>
                        <p>Our service is not intended for children under 13 years of age. We do not knowingly collect personal information from children under 13. If you are a parent or guardian and you are aware that your child has provided us with personal information, please contact us so that we can take necessary action.</p>
                    </div>

                    <!-- Changes to This Privacy Policy Card -->
                    <div class="content-card">
                        <h2>Changes to This Privacy Policy</h2>
                        <p>We may update our Privacy Policy from time to time. We will notify you of any changes by posting the new Privacy Policy on this page and updating the "Last Updated" date. We recommend reviewing this Privacy Policy periodically for any changes.</p>
                    </div>

                    <!-- FAQ Structured Data -->
                    <script type="application/ld+json">
                    {
                      "@context": "https://schema.org",
                      "@type": "FAQPage",
                      "mainEntity": [
                        {
                          "@type": "Question",
                          "name": "Do you sell my personal information?",
                          "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "No, we do not sell your personal information to third parties. We only share information as described in this Privacy Policy and with your explicit consent."
                          }
                        },
                        {
                          "@type": "Question",
                          "name": "How long do you keep my data?",
                          "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "We retain your personal information only as long as necessary for the purposes outlined in this policy, unless a longer retention period is required by law."
                          }
                        },
                        {
                          "@type": "Question",
                          "name": "How can I access my data?",
                          "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "You can request access to your personal data at any time by contacting us. We'll provide a copy of the data we hold about you within 30 days."
                          }
                        },
                        {
                          "@type": "Question",
                          "name": "Is my data secure?",
                          "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Yes, we use industry-standard security measures including encryption, secure servers, and regular security audits to protect your personal data."
                          }
                        }
                      ]
                    }
                    </script>

                    <!-- Contact Us Card -->
                    <div class="content-card">
                        <h2>Contact Us</h2>
                        <p>We'd love to hear from you! Whether you have questions about our privacy practices, need to exercise your data rights, or want to discuss any concerns.</p>

                        <div class="contact-row">
                            <strong>Email Us</strong>
                            <a href="mailto:support@courseswyn.com">support@courseswyn.com</a>
                        </div>

                        <div class="contact-row">
                            <strong>General Contact</strong>
                            <a href="/contact">Contact Page</a>
                        </div>

                        <p class="contact-note">We typically respond within 1-2 business days.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- FAQ Section -->
        <section class="section">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Privacy Questions & Answers</h2>
                    <p class="section-subtitle">Everything you need to know about your data privacy and security</p>
                </div>

                <div class="faq-grid">
                    <div class="card faq-card">
                        <div class="faq-icon accent-bg-sm">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/>
                            </svg>
                        </div>
                        <h3 class="faq-question accent">Do you sell my personal information?</h3>
                        <p>No, we do not sell your personal information to third parties. We only share information as described in this Privacy Policy and with your explicit consent.</p>
                    </div>

                    <div class="card faq-card">
                        <div class="faq-icon accent-bg-sm">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
                                <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                            </svg>
                        </div>
                        <h3 class="faq-question accent">How long do you keep my data?</h3>
                        <p>We retain your personal information only as long as necessary for the purposes outlined in this policy, unless a longer retention period is required by law.</p>
                    </div>

                    <div class="card faq-card">
                        <div class="faq-icon teal-bg-sm">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
                                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                            </svg>
                        </div>
                        <h3 class="faq-question teal">How can I access my data?</h3>
                        <p>You can request access to your personal data at any time by contacting us. We'll provide a copy of the data we hold about you within 30 days.</p>
                    </div>

                    <div class="card faq-card">
                        <div class="faq-icon red-bg-sm">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
                                <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm3 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/>
                            </svg>
                        </div>
                        <h3 class="faq-question red">Is my data secure?</h3>
                        <p>Yes, we use industry-standard security measures including encryption, secure servers, and regular security audits to protect your personal data.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Contact Section -->
        <section class="section bg-secondary">
            <div class="container container-sm">
                <div class="cta-section">
                    <h2 class="section-title">Have Privacy Questions?</h2>
                    <p class="section-subtitle">Our privacy team is here to help. Contact us for any questions about your data rights or privacy concerns.</p>

                    <div class="cta-card">
                        <h3>Contact Our Privacy Team</h3>

                        <div class="cta-links">
                            <div class="cta-item">
                                <strong>Privacy Inquiries</strong>
                                <a href="/contact">Contact Page →</a>
                                <span class="cta-hint">Use subject: "Privacy Inquiry"</span>
                            </div>

                            <div class="cta-item">
                                <strong>General Inquiries</strong>
                                <a href="/contact">Contact Page →</a>
                            </div>
                        </div>

                        <p class="cta-note">We typically respond within 1-2 business days.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <style>
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1rem;
        }

        .container-sm {
            max-width: 860px;
        }

        .container-narrow {
            max-width: 860px;
        }

        .section {
            padding: 4rem 1rem;
        }

        .bg-secondary {
            background: var(--bg-secondary);
        }

        .section-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .section-title {
            font-size: clamp(1.8rem, 4vw, 2.5rem);
            font-weight: 800;
            color: var(--text);
            margin-bottom: 1rem;
        }

        .section-subtitle {
            color: var(--muted);
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.6;
        }

        /* Hero */
        .hero-section {
            padding: 8rem 1rem 4rem;
            text-align: center;
            border-bottom: 1px solid var(--border);
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--bg-secondary);
            padding: 0.5rem 1rem;
            border-radius: 9999px;
            margin-bottom: 2rem;
            font-size: 0.9rem;
            color: var(--text);
            font-weight: 600;
            border: 1px solid var(--border);
        }

        .hero-title {
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 800;
            line-height: 1.1;
            margin: 0 auto 1.5rem;
            max-width: 1200px;
        }

        .gradient-text-brand {
            background: linear-gradient(135deg, var(--brand) 0%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .gradient-text-muted {
            background: linear-gradient(135deg, var(--text) 0%, var(--muted) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-description {
            font-size: clamp(1.1rem, 2.5vw, 1.4rem);
            color: var(--muted);
            max-width: 700px;
            margin: 0 auto 2rem;
            line-height: 1.6;
            font-weight: 400;
        }

        .last-updated {
            font-size: 1rem;
            color: var(--muted);
            margin-bottom: 3rem;
        }

        .trust-bar {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 2rem;
            flex-wrap: wrap;
            opacity: 0.8;
        }

        .trust-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            background: var(--bg-secondary);
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            color: var(--text);
            font-weight: 800;
            font-size: 0.8rem;
            text-transform: uppercase;
        }

        /* Stats */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }

        .stat-card {
            background: var(--card);
            padding: 2.5rem 2rem;
            border-radius: var(--radius);
            border: 1px solid var(--border);
            text-align: center;
        }

        .stat-value {
            font-size: 3.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
        }

        .stat-value.accent {
            color: var(--accent);
        }

        .stat-value.teal {
            color: hsl(180, 50%, 40%);
        }

        .stat-value.brand {
            color: var(--brand);
        }

        .stat-label {
            color: var(--text);
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .stat-desc {
            color: var(--muted);
            font-size: 0.9rem;
        }

        /* Features */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
            margin-bottom: 4rem;
        }

        .card {
            background: var(--card);
            padding: 2.5rem;
            border-radius: var(--radius);
            border: 1px solid var(--border);
        }

        .card-icon {
            width: 70px;
            height: 70px;
