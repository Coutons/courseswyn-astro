---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { formatDateWIB, toISODateWIB } from "../../lib/date";

const siteUrl = "https://courseswyn.com";

// Helper: convert relative image paths from MDX frontmatter to a usable URL
function resolveImage(imagePath: string | undefined): string | null {
  if (!imagePath) return null;
  if (imagePath.startsWith('http')) return imagePath;
  const filename = imagePath.split('/').pop();
  if (!filename) return null;
  return `/assets/images/${filename}`;
}

const allPosts = await getCollection("blog");
const posts = allPosts.sort((a, b) => {
  const dateA = a.data.updatedAt || a.data.pubDate;
  const dateB = b.data.updatedAt || b.data.pubDate;
  return dateB.getTime() - dateA.getTime();
});

const featuredPost = posts[0];
const otherPosts = posts.slice(1, 10);

const currentDate = new Date();
const currentYear = Number(currentDate.toLocaleString('en-US', { year: 'numeric', timeZone: 'Asia/Jakarta' }));

const title = `Best Udemy Course Reviews & Free Coupon Guides ${currentYear} | CoursesWyn Blog`;
const description = `Expert-reviewed guides to the best Udemy courses with verified 100% off coupon codes. Find free programming, AI, data science, cloud certification courses and step-by-step career roadmaps. Updated daily with working deals.`;
const canonical = `https://courseswyn.com/blog`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  headline: title,
  description: description,
  url: canonical,
  blogPost: posts.map(post => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    url: `https://courseswyn.com/blog/${post.id}`,
    datePublished: post.data.pubDate.toISOString(),
    author: {
      "@type": "Person",
      name: "Andrew Derek",
      url: "mailto:admin@courseswyn.com",
    },
  })),
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <section style={{ padding: "80px 0", background: "var(--bg)" }}>
    <div class="container">

      {/* ── Blog Header ── */}
      <header style={{ marginBottom: "64px" }}>
        <div style={{
          display: "inline-block",
          background: "var(--bg)",
          color: "var(--text)",
          padding: "4px 14px",
          border: "2px solid var(--border)",
          boxShadow: "3px 3px 0 var(--border)",
          borderRadius: "4px",
          fontSize: "0.75rem",
          fontWeight: 800,
          marginBottom: "24px",
          letterSpacing: "0.1em",
          textTransform: "uppercase"
        }}>
          Editorial Room
        </div>
        <h1 style={{ fontSize: "clamp(2.2rem, 5vw, 3.5rem)", fontWeight: 900, color: "var(--text)", letterSpacing: "-0.04em", lineHeight: 1.1, marginBottom: "20px" }}>
          Best Udemy Course Reviews & <span style={{ background: "var(--color-primary)", color: "var(--text)", padding: "0 8px" }}>Free Coupon Guides</span>
        </h1>
        <p style={{ fontSize: "1.05rem", color: "var(--text)", lineHeight: 1.6, maxWidth: "750px", fontWeight: 500, marginBottom: "12px" }}>
          Our editorial team analyzes thousands of Udemy courses to identify the highest-quality learning resources.
          Each guide includes verified 100% off coupon codes, curriculum breakdowns, and real career outcomes data.
        </p>
        <p style={{ fontSize: "0.95rem", color: "var(--text)", lineHeight: 1.5, maxWidth: "750px", fontWeight: 500 }}>
          <strong style="color:var(--text)">Browse by category:</strong> Programming • AI & Machine Learning • Cloud Certification • Data Science • Web Development • Career Guides
        </p>
      </header>

      {/* ── Featured Post ── */}
      {featuredPost && (
        <article style={{
          display: "grid",
          gridTemplateColumns: "1.3fr 1fr",
          gap: "0",
          marginBottom: "64px",
          border: "2px solid var(--border)",
          boxShadow: "8px 8px 0 var(--border)",
          borderRadius: "8px",
          overflow: "hidden",
          background: "var(--bg)"
        }} class="featured-card">
          <div style={{ height: "100%", minHeight: "450px", borderRight: "2px solid var(--border)" }}>
            <img
              src={typeof featuredPost.data.image === 'string' ? featuredPost.data.image : (featuredPost.data.image as any)?.src || '/og-image.jpg'}
              alt={featuredPost.data.title}
              style={{ width: "100%", height: "100%", objectFit: "cover" }}
            />
          </div>
          <div style={{ padding: "56px", display: "flex", flexDirection: "column", justifyContent: "center" }}>
            <span style={{ color: "var(--accent)", fontWeight: 800, textTransform: "uppercase", fontSize: "0.72rem", letterSpacing: "0.12em", marginBottom: "16px" }}>Featured Guide</span>
            <h2 style={{ fontSize: "2.2rem", fontWeight: 900, marginBottom: "20px", lineHeight: 1.15, letterSpacing: "-0.03em" }}>
              <a href={`/blog/${featuredPost.id}`} style={{ color: "inherit", textDecoration: "none" }}>{featuredPost.data.title}</a>
            </h2>
            <p style={{ fontSize: "1rem", color: "var(--text)", lineHeight: 1.6, marginBottom: "32px", fontWeight: 500 }}>
              {featuredPost.data.description}
            </p>
            <div style={{ display: "flex", alignItems: "center", gap: "12px", borderTop: "2px solid var(--border)", paddingTop: "24px" }}>
              <div style={{ width: "40px", height: "40px", borderRadius: "4px", background: "var(--accent)", border: "2px solid var(--border)", display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 900, color: "white" }}>AD</div>
              <div>
                <p style={{ fontWeight: 800, margin: 0, fontSize: "0.9rem" }}>Andrew Derek</p>
                <p style={{ fontSize: "0.75rem", color: "var(--muted)", margin: 0, fontWeight: 700 }}>
                  Updated {formatDateWIB(featuredPost.data.updatedAt || featuredPost.data.pubDate, { month: 'short', day: 'numeric', year: 'numeric' })}
                </p>
              </div>
            </div>
          </div>
        </article>
      )}

      {/* ── Recent Guides Grid ── */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(340px, 1fr))", gap: "24px" }}>
        {otherPosts.map(post => (
          <article style={{
            background: "var(--bg)",
            border: "2px solid var(--border)",
            boxShadow: "4px 4px 0 var(--border)",
            borderRadius: "8px",
            overflow: "hidden",
            transition: "all 0.15s ease",
            display: "flex",
            flexDirection: "column"
          }} class="article-card">
            <a href={`/blog/${post.id}`} style={{ textDecoration: "none", color: "inherit", height: "100%", display: "flex", flexDirection: "column" }}>
              <div style={{ position: "relative", height: "200px", borderBottom: "2px solid var(--border)", overflow: "hidden" }}>
                <img
                  src={typeof post.data.image === 'string' ? post.data.image : (post.data.image as any)?.src || '/og-image.jpg'}
                  alt={post.data.title}
                  style={{ width: "100%", height: "100%", objectFit: "cover" }}
                  class="article-img"
                />
                <div style={{
                  position: "absolute", top: "12px", left: "12px",
                  background: "var(--bg)", color: "var(--text)",
                  border: "1.5px solid var(--border)", padding: "2px 8px",
                  fontSize: "0.6rem", fontWeight: 800, borderRadius: "3px",
                  textTransform: "uppercase", letterSpacing: "0.05em"
                }}>
                  {post.data.tags?.[0] || 'Guide'}
                </div>
              </div>
              <div style={{ padding: "24px", flex: 1, display: "flex", flexDirection: "column" }}>
                <h3 style={{ fontSize: "1.2rem", fontWeight: 900, color: "var(--text)", marginBottom: "16px", lineHeight: 1.25, letterSpacing: "-0.02em" }}>
                  {post.data.title}
                </h3>
                <p style={{ color: "var(--text)", fontSize: "0.88rem", lineHeight: 1.6, marginBottom: "20px", display: "-webkit-box", WebkitLineClamp: 3, WebkitBoxOrient: "vertical", overflow: "hidden", fontWeight: 500 }}>
                  {post.data.description}
                </p>
                <div style={{ marginTop: "auto", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                  <div style={{ fontSize: "0.72rem", color: "var(--text)", fontWeight: 700, textTransform: "uppercase" }}>
                    {formatDateWIB(post.data.updatedAt || post.data.pubDate, { month: 'short', day: 'numeric', year: 'numeric' })}
                  </div>
                  <div style={{ fontWeight: 800, color: "var(--accent)", fontSize: "0.8rem", textTransform: "uppercase", letterSpacing: "0.06em" }}>
                    Read Review →
                  </div>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      {/* ── SEO Content Section ── */}
      <div style={{ marginTop: "80px", padding: "48px", background: "var(--bg)", border: "2px solid var(--border)", borderRadius: "8px", boxShadow: "4px 4px 0 var(--border)" }}>
        <h2 style={{ fontSize: "1.75rem", fontWeight: 900, marginBottom: "24px", letterSpacing: "-0.02em", color: "var(--text)" }}>
          What Makes Our Udemy Course Reviews Different?
        </h2>
        <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(280px, 1fr))", gap: "32px", marginBottom: "32px" }}>
          <div>
            <h3 style={{ fontSize: "1.1rem", fontWeight: 900, marginBottom: "12px", color: "var(--text)" }}>📊 Data-Driven Analysis</h3>
            <p style={{ color: "var(--text)", fontSize: "0.95rem", lineHeight: 1.6, margin: 0 }}>
              We don't just list popular courses. We analyze review sentiment, completion rates, and career outcome data to identify courses that actually deliver results.
            </p>
          </div>
          <div>
            <h3 style={{ fontSize: "1.1rem", fontWeight: 900, marginBottom: "12px", color: "var(--text)" }}>✅ Verified Free Coupons</h3>
            <p style={{ color: "var(--muted)", fontSize: "0.95rem", lineHeight: 1.6, margin: 0 }}>
              Every guide includes working 100% off coupon codes tested by our team. We update daily to ensure you never encounter expired deals.
            </p>
          </div>
          <div>
            <h3 style={{ fontSize: "1.1rem", fontWeight: 900, marginBottom: "12px", color: "var(--text)" }}>🎯 Career-Focused Roadmaps</h3>
            <p style={{ color: "var(--muted)", fontSize: "0.95rem", lineHeight: 1.6, margin: 0 }}>
              Our learning paths are designed by industry professionals who know what employers actually want. Skip the fluff, learn the skills that get you hired.
            </p>
          </div>
        </div>

        <div style={{ borderTop: "2px solid var(--border)", paddingTop: "32px" }}>
          <h3 style={{ fontSize: "1.2rem", fontWeight: 900, marginBottom: "20px", color: "var(--text)" }}>
            Browse Articles by Topic
          </h3>
          <div style={{ display: "flex", flexWrap: "wrap", gap: "12px" }}>
            {[
              { name: "AI & Machine Learning", link: "/blog/top-ai-and-machine-learning-courses-on-udemy-2026" },
              { name: "ChatGPT & Prompt Engineering", link: "/blog/best-chatgpt-courses-udemy-2026" },
              { name: "AI Agent Development", link: "/blog/best-udemy-agentic-ai-courses-2026" },
              { name: "Cursor AI Coding", link: "/blog/best-cursor-ai-courses-udemy" },
              { name: "Programming & Development", link: "/blog/best-udemy-courses-2026" },
              { name: "React & Next.js", link: "/blog/best-react-nextjs-courses-2026" },
              { name: "Python", link: "/blog/top-10-python-courses-on-udemy" },
              { name: "AWS Certification", link: "/blog/best-aws-certification-courses-2026" },
              { name: "Cloud Computing", link: "/blog/cloud-computing-courses-udemy-2026" },
              { name: "Data Science", link: "/blog/best-data-science-courses-udemy" },
              { name: "SQL & Databases", link: "/blog/best-sql-courses-2026" },
              { name: "Career Guides", link: "/blog/ai-engineer-roadmap-2026" },
              { name: "Platform Comparisons", link: "/blog/udemy-vs-coursera-vs-pluralsight" },
              { name: "Free Courses Guide", link: "/udemy-coupons-guide" }
            ].map(tag => (
              <a
                href={tag.link}
                style={{
                  display: "inline-flex",
                  alignItems: "center",
                  padding: "8px 16px",
                  background: "var(--card)",
                  border: "2px solid var(--border)",
                  borderRadius: "6px",
                  textDecoration: "none",
                  color: "var(--text)",
                  fontWeight: 700,
                  fontSize: "0.85rem",
                  transition: "all 0.15s ease"
                }}
                class="topic-tag"
              >
                {tag.name}
              </a>
            ))}
          </div>
        </div>
      </div>

      {/* Pagination Navigation */}
      {posts.length > 10 && (
        <div style={{ display: "flex", justifyContent: "center", marginTop: "48px" }}>
          <a
            href="/blog/page/2"
            style={{
              display: "inline-flex",
              alignItems: "center",
              gap: "8px",
              padding: "14px 28px",
              background: "var(--brand)",
              color: "var(--bg)",
              textDecoration: "none",
              borderRadius: "6px",
              fontWeight: 800,
              fontSize: "0.85rem",
              textTransform: "uppercase",
              letterSpacing: "0.05em",
              border: "2px solid var(--border)",
              boxShadow: "4px 4px 0 var(--border)",
              transition: "all 0.15s ease"
            }}
            class="view-all-btn"
          >
            View All Articles
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      )}
    </div>
  </section>

  <style>
    .view-all-btn:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--border) !important; }
    .featured-card:hover { transform: translate(-2px, -2px); box-shadow: 10px 10px 0 var(--border) !important; }
    .article-card:hover { transform: translate(-3px, -3px); box-shadow: 7px 7px 0 var(--border) !important; }
    .article-card:hover .article-img { transform: scale(1.05); }
    .article-img { transition: transform 0.4s ease; }
    .topic-tag:hover { background: var(--accent) !important; color: white !important; transform: translate(-2px, -2px); box-shadow: 4px 4px 0 var(--border); }

    @media (max-width: 960px) {
      article[style*="grid-template-columns"] {
        grid-template-columns: 1fr !important;
      }
      .featured-card div[style*="border-right"] {
        border-right: none !important;
        border-bottom: 2px solid var(--border);
      }
    }
  </style>
</Layout>
