---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const siteUrl = "https://courseswyn.com";

// Helper: convert relative image paths from MDX frontmatter to a usable URL
function resolveImage(imagePath: string | undefined): string | null {
  if (!imagePath) return null;
  if (imagePath.startsWith('http')) return imagePath;
  const filename = imagePath.split('/').pop();
  if (!filename) return null;
  return `/assets/images/${filename}`;
}

const allPosts = await getCollection("blog");
const posts = allPosts.sort((a, b) => {
  const dateA = a.data.updatedAt || a.data.pubDate;
  const dateB = b.data.updatedAt || b.data.pubDate;
  return dateB.getTime() - dateA.getTime();
});

const featuredPost = posts[0];
const otherPosts = posts.slice(1, 10);

const title = `Expert Learning Guides & Digital Education Insights | CoursesWyn Blog`;
const description = `Deep-dive course analysis, verified savings strategies, and expert career guidance. Master new skills with the CoursesWyn editorial team.`;
---

<Layout title={title} description={description}>
  <section style={{ padding: "80px 0", background: "var(--bg)" }}>
    <div class="container">
      
      {/* ── Blog Header ── */}
      <header style={{ marginBottom: "64px" }}>
        <div style={{
          display: "inline-block",
          background: "var(--accent)",
          color: "white",
          padding: "4px 14px",
          border: "2px solid var(--border)",
          boxShadow: "3px 3px 0 var(--border)",
          borderRadius: "4px",
          fontSize: "0.75rem",
          fontWeight: 800,
          marginBottom: "24px",
          letterSpacing: "0.1em",
          textTransform: "uppercase"
        }}>
          Editorial Room
        </div>
        <h1 style={{ fontSize: "clamp(2.5rem, 6vw, 4rem)", fontWeight: 900, color: "var(--text)", letterSpacing: "-0.04em", lineHeight: 1.05, marginBottom: "24px" }}>
          Expert <span style={{ background: "var(--accent)", color: "white", padding: "0 10px" }}>Course Guides</span><br/>
          & Career Insights.
        </h1>
        <p style={{ fontSize: "1.15rem", color: "var(--muted)", lineHeight: 1.6, maxWidth: "700px", fontWeight: 500 }}>
          The editorial team at CoursesWyn analyzes thousands of courses to bring you curated roadmaps, technical deep-dives, and verified savings strategies.
        </p>
      </header>

      {/* ── Featured Post ── */}
      {featuredPost && (
        <article style={{ 
          display: "grid", 
          gridTemplateColumns: "1.3fr 1fr", 
          gap: "0", 
          marginBottom: "64px",
          border: "2px solid var(--border)",
          boxShadow: "8px 8px 0 var(--border)",
          borderRadius: "8px",
          overflow: "hidden",
          background: "var(--card)"
        }} class="featured-card">
          <div style={{ height: "100%", minHeight: "450px", borderRight: "2px solid var(--border)" }}>
            <img 
              src={typeof featuredPost.data.image === 'string' ? featuredPost.data.image : (featuredPost.data.image as any)?.src || '/og-image.jpg'} 
              alt={featuredPost.data.title}
              style={{ width: "100%", height: "100%", objectFit: "cover" }}
            />
          </div>
          <div style={{ padding: "56px", display: "flex", flexDirection: "column", justifyContent: "center" }}>
            <span style={{ color: "var(--accent)", fontWeight: 800, textTransform: "uppercase", fontSize: "0.72rem", letterSpacing: "0.12em", marginBottom: "16px" }}>Featured Guide</span>
            <h2 style={{ fontSize: "2.2rem", fontWeight: 900, marginBottom: "20px", lineHeight: 1.15, letterSpacing: "-0.03em" }}>
              <a href={`/blog/${featuredPost.id}`} style={{ color: "inherit", textDecoration: "none" }}>{featuredPost.data.title}</a>
            </h2>
            <p style={{ fontSize: "1rem", color: "var(--muted)", lineHeight: 1.6, marginBottom: "32px", fontWeight: 500 }}>
              {featuredPost.data.description}
            </p>
            <div style={{ display: "flex", alignItems: "center", gap: "12px", borderTop: "2px solid var(--border)", paddingTop: "24px" }}>
              <div style={{ width: "40px", height: "40px", borderRadius: "4px", background: "var(--accent)", border: "2px solid var(--border)", display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 900, color: "white" }}>AD</div>
              <div>
                <p style={{ fontWeight: 800, margin: 0, fontSize: "0.9rem" }}>Andrew Derek</p>
                <p style={{ fontSize: "0.75rem", color: "var(--muted)", margin: 0, fontWeight: 700 }}>
                  Updated {new Date(featuredPost.data.updatedAt || featuredPost.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </p>
              </div>
            </div>
          </div>
        </article>
      )}

      {/* ── Recent Guides Grid ── */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(340px, 1fr))", gap: "24px" }}>
        {otherPosts.map(post => (
          <article style={{
            background: "var(--card)",
            border: "2px solid var(--border)",
            boxShadow: "4px 4px 0 var(--border)",
            borderRadius: "8px",
            overflow: "hidden",
            transition: "all 0.15s ease",
            display: "flex",
            flexDirection: "column"
          }} class="article-card">
            <a href={`/blog/${post.id}`} style={{ textDecoration: "none", color: "inherit", height: "100%", display: "flex", flexDirection: "column" }}>
              <div style={{ position: "relative", height: "200px", borderBottom: "2px solid var(--border)", overflow: "hidden" }}>
                <img 
                  src={typeof post.data.image === 'string' ? post.data.image : (post.data.image as any)?.src || '/og-image.jpg'} 
                  alt={post.data.title}
                  style={{ width: "100%", height: "100%", objectFit: "cover" }}
                  class="article-img"
                />
                <div style={{
                  position: "absolute", top: "12px", left: "12px",
                  background: "var(--accent)", color: "white",
                  border: "1.5px solid var(--border)", padding: "2px 8px",
                  fontSize: "0.6rem", fontWeight: 800, borderRadius: "3px",
                  textTransform: "uppercase", letterSpacing: "0.05em"
                }}>
                  {post.data.tags?.[0] || 'Guide'}
                </div>
              </div>
              <div style={{ padding: "24px", flex: 1, display: "flex", flexDirection: "column" }}>
                <h3 style={{ fontSize: "1.2rem", fontWeight: 900, color: "var(--text)", marginBottom: "16px", lineHeight: 1.25, letterSpacing: "-0.02em" }}>
                  {post.data.title}
                </h3>
                <p style={{ color: "var(--muted)", fontSize: "0.88rem", lineHeight: 1.6, marginBottom: "20px", display: "-webkit-box", WebkitLineClamp: 3, WebkitBoxOrient: "vertical", overflow: "hidden", fontWeight: 500 }}>
                  {post.data.description}
                </p>
                <div style={{ marginTop: "auto", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                  <div style={{ fontSize: "0.72rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase" }}>
                    {new Date(post.data.updatedAt || post.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </div>
                  <div style={{ fontWeight: 800, color: "var(--accent)", fontSize: "0.8rem", textTransform: "uppercase", letterSpacing: "0.06em" }}>
                    Read Review →
                  </div>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      {/* Pagination Navigation */}
      {posts.length > 10 && (
        <div style={{ display: "flex", justifyContent: "center", marginTop: "48px" }}>
          <a 
            href="/blog/page/2" 
            style={{
              display: "inline-flex",
              alignItems: "center",
              gap: "8px",
              padding: "14px 28px",
              background: "var(--text)",
              color: "white",
              textDecoration: "none",
              borderRadius: "6px",
              fontWeight: 800,
              fontSize: "0.85rem",
              textTransform: "uppercase",
              letterSpacing: "0.05em",
              border: "2px solid var(--border)",
              boxShadow: "4px 4px 0 var(--border)",
              transition: "all 0.15s ease"
            }}
            class="view-all-btn"
          >
            View All Articles
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      )}
    </div>
  </section>

  <style>
    .view-all-btn:hover { transform: translate(-2px, -2px); boxShadow: 6px 6px 0 var(--border) !important; }
    .featured-card:hover { transform: translate(-2px, -2px); boxShadow: 10px 10px 0 var(--border) !important; }
    .article-card:hover { transform: translate(-3px, -3px); boxShadow: 7px 7px 0 var(--border) !important; }
    .article-card:hover .article-img { transform: scale(1.05); }
    .article-img { transition: transform 0.4s ease; }

    @media (max-width: 960px) {
      article[style*="grid-template-columns"] {
        grid-template-columns: 1fr !important;
      }
      .featured-card div[style*="border-right"] {
        border-right: none !important;
        border-bottom: 2px solid var(--border);
      }
    }
  </style>
</Layout>
