---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

// Get latest blog posts for blog index page
const posts = await getCollection('blog');
const latestPosts = posts
  .sort((a, b) => {
    const dateA = a.data.updatedAt || a.data.pubDate;
    const dateB = b.data.updatedAt || b.data.pubDate;
    return dateB.getTime() - dateA.getTime();
  })
  .slice(0, 12); // Show 12 posts per page for blog index

// Date formatting function
function formatDate(post: any) {
  const isUpdated = !!post.data.updatedAt;
  const date = post.data.updatedAt || post.data.pubDate;
  const formatted = new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  }).format(date);
  return isUpdated ? `Updated ${formatted}` : formatted;
}

const title = `Udemy Course Reviews & Free Learning Guides ${new Date().getFullYear()} | Expert Rankings & Comparisons`;
const description = "Expert Udemy course reviews, comparisons, and learning guides. Find the best courses for AI, Web Development, Cloud Computing, and more. Updated weekly with honest rankings based on student data.";
const canonical = "https://courseswyn.com/blog/";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  headline: title,
  description: description,
  url: canonical,
  blogPost: latestPosts.map((post: any) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    url: `https://courseswyn.com/blog/${post.id}/`,
    datePublished: post.data.pubDate.toISOString(),
    author: {
      "@type": "Person",
      name: "Andrew Derek",
      url: "mailto:coutonscom@gmail.com",
    },
  }))
};
---

<MainLayout
  title={title}
  description={description}
  canonical={canonical}
  structuredData={structuredData}
>

<div class="fixed inset-0 bg-[#0a0f16] -z-50"></div>
<div class="fixed top-0 left-[-10%] w-[700px] h-[700px] bg-emerald-500/10 rounded-full blur-[180px] mix-blend-screen pointer-events-none -z-40"></div>
<div class="fixed bottom-0 right-[-10%] w-[600px] h-[600px] bg-blue-600/8 rounded-full blur-[180px] mix-blend-screen pointer-events-none -z-40"></div>

<div class="min-h-screen pb-24">

  <!-- Hero Section -->
  <div class="pt-24 pb-16 border-b border-white/5 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">

        <!-- Breadcrumb -->
        <nav class="flex items-center justify-center gap-2 text-xs text-gray-500 mb-6 font-medium">
          <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
          <span>/</span>
          <span class="text-gray-300">Blog</span>
        </nav>

        <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6 leading-tight tracking-tight">
          Expert Udemy Course Reviews &
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-400"> Learning Guides ({new Date().getFullYear()})</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 font-medium mb-6">
          {posts.length}+ In-Depth Reviews &bull; Real Student Data &bull; Weekly Updates
        </p>
        <p class="text-gray-400 max-w-3xl mx-auto leading-relaxed mb-10 text-lg">
          Expert Udemy course reviews, comparisons, and learning guides to help you choose the best courses. Updated weekly with honest rankings based on real student data.
        </p>

        <!-- Category Filter Nav -->
        <nav class="flex flex-wrap justify-center gap-3 mb-10">
          {[
            { label: 'AI & Machine Learning', q: 'ai' },
            { label: 'Web Development', q: 'web' },
            { label: 'Cloud Computing', q: 'cloud' },
            { label: 'Data Science', q: 'data' },
            { label: 'Cybersecurity', q: 'security' },
            { label: 'Business', q: 'business' },
          ].map(tag => (
            <a href={`/search?q=${tag.q}`} class="px-5 py-2.5 bg-white/5 backdrop-blur-md border border-white/10 rounded-xl text-sm font-bold text-gray-300 hover:text-emerald-400 hover:border-emerald-500/40 hover:bg-white/10 transition-all">
              {tag.label}
            </a>
          ))}
        </nav>

        <!-- Quick Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-10 max-w-3xl mx-auto border-t border-b border-white/10 py-10">
          <div class="bg-white/5 backdrop-blur-md rounded-2xl p-4 border border-white/5">
            <div class="text-4xl font-black text-emerald-400">{latestPosts.length}</div>
            <div class="text-gray-400 text-xs font-bold uppercase tracking-widest mt-2">Latest Posts</div>
          </div>
          <div class="bg-white/5 backdrop-blur-md rounded-2xl p-4 border border-white/5">
            <div class="text-4xl font-black text-emerald-400">{posts.length}</div>
            <div class="text-gray-400 text-xs font-bold uppercase tracking-widest mt-2">Total Articles</div>
          </div>
          <div class="bg-white/5 backdrop-blur-md rounded-2xl p-4 border border-white/5">
            <div class="text-4xl font-black text-emerald-400">90%</div>
            <div class="text-gray-400 text-xs font-bold uppercase tracking-widest mt-2">Success Rate</div>
          </div>
          <div class="bg-white/5 backdrop-blur-md rounded-2xl p-4 border border-white/5">
            <div class="text-4xl font-black text-emerald-400">24/7</div>
            <div class="text-gray-400 text-xs font-bold uppercase tracking-widest mt-2">Updates</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Latest Posts Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-2 h-10 bg-emerald-500 rounded-full shadow-[0_0_10px_rgba(16,185,129,0.5)]"></span>
      <h2 class="text-3xl font-extrabold text-white tracking-tight">Latest Articles</h2>
    </div>

    {latestPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        {latestPosts.map((post: any) => (
          <a
            href={`/blog/${post.id}/`}
            class="group block bg-[#131922]/80 backdrop-blur-xl border border-white/5 rounded-2xl overflow-hidden hover:border-emerald-500/50 hover:bg-white/5 hover:shadow-[0_8px_32px_rgba(16,185,129,0.15)] transition-all duration-300 hover:-translate-y-2"
          >
            <!-- Image -->
            <div class="relative aspect-[16/9] overflow-hidden">
              <img
                src={post.data.image?.src || post.data.image || 'https://images.unsplash.com/photo-1526379095098-d400fd0bf935?w=800&h=400&fit=crop'}
                alt={post.data.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              {post.data.tags && post.data.tags[0] && (
                <div class="absolute top-4 left-4">
                  <span class="bg-[#0a0f16]/80 backdrop-blur-md text-emerald-400 text-[10px] font-bold px-2 py-1 rounded-lg border border-emerald-500/30 uppercase tracking-wider">
                    {post.data.tags[0]}
                  </span>
                </div>
              )}
            </div>

            <!-- Content -->
            <div class="p-6">
              <div class="flex flex-wrap items-center gap-2 mb-3 text-xs text-gray-400">
                <div class="flex items-center gap-1.5 bg-white/5 px-2 py-1 rounded-lg border border-white/10">
                  <img src="/assets/authors/andrew-derek.png" alt="Andrew Derek" class="w-5 h-5 rounded-full object-cover border border-emerald-500/30" />
                  <span class="truncate max-w-[80px] text-gray-300 font-medium">Andrew Derek</span>
                </div>
                <span class="text-gray-500">&bull;</span>
                <span>{formatDate(post)}</span>
              </div>

              <h3 class="font-extrabold text-white text-lg mb-3 leading-tight group-hover:text-emerald-400 transition-colors line-clamp-2">
                {post.data.title}
              </h3>

              <p class="text-gray-400 text-sm leading-relaxed line-clamp-3 mb-5">
                {post.data.description}
              </p>

              <div class="flex items-center justify-between">
                <span class="inline-block px-4 py-2 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-bold rounded-xl group-hover:bg-emerald-500 group-hover:text-white transition-all">
                  Read Article &rarr;
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <div class="text-gray-400 text-lg mb-4">No articles found</div>
      </div>
    )}

    <!-- View More Articles -->
    <div class="text-center">
      <a
        href="/blog/page/2"
        class="inline-block px-8 py-4 bg-white/5 backdrop-blur-md border border-white/10 text-white rounded-xl hover:border-emerald-500/50 hover:bg-white/10 transition-all font-bold uppercase tracking-wider"
      >
        View More Articles &rarr;
      </a>
    </div>
  </section>

  <!-- Featured Promo Section -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 border-t border-white/5 pt-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4 tracking-tight">
        &#128293; Udemy Personal Plan Coupon Code
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Get unlimited access to 26,000+ top Udemy courses, anytime, anywhere.
      </p>
    </div>

    <div class="max-w-2xl mx-auto">
      <div class="bg-gradient-to-br from-emerald-500/10 to-blue-500/10 backdrop-blur-xl border border-emerald-500/20 rounded-2xl p-8 hover:border-emerald-500/40 hover:shadow-[0_8px_32px_rgba(16,185,129,0.15)] transition-all">
        <div class="text-center mb-6">
          <h3 class="font-extrabold text-white text-2xl mb-2">Udemy Personal Plan</h3>
          <p class="text-gray-400 text-sm">Unlimited access to 26,000+ top Udemy courses</p>
        </div>

        <div class="flex items-center justify-center gap-4 mb-6">
          <div class="flex text-yellow-400 gap-0.5">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <span class="text-gray-400 text-sm font-medium">4.6 (400,000+ students)</span>
        </div>

        <div class="flex items-center justify-center gap-3 mb-8">
          <span class="text-emerald-400 font-extrabold text-4xl">$48.99</span>
          <span class="text-gray-500 line-through text-xl">$499.99</span>
          <span class="bg-red-500/80 text-white px-3 py-1 rounded-lg text-sm font-bold">90% OFF</span>
        </div>

        <a
          href="https://trk.udemy.com/c/6564357/3775958/39854"
          target="_blank"
          rel="nofollow noopener noreferrer"
          class="block w-full bg-gradient-to-r from-emerald-500 to-emerald-400 text-white font-extrabold py-4 px-6 rounded-xl text-center transition-all shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:shadow-[0_0_30px_rgba(16,185,129,0.5)] hover:scale-[1.02] active:scale-95 uppercase tracking-widest relative overflow-hidden group"
        >
          <div class="absolute inset-0 -translate-x-full group-hover:animate-[shimmer_1.5s_infinite] bg-gradient-to-r from-transparent via-white/30 to-transparent skew-x-12"></div>
          <span class="relative z-10">&#127891; Enroll Now - Limited Time Offer</span>
        </a>
      </div>
    </div>
  </section>

</div>
</MainLayout>
