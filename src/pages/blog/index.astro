---
import Layout from "../../layouts/Layout.astro";
import { Image } from 'astro:assets';
import { getCollection } from "astro:content";
import { formatDateWIB, toISODateWIB } from "../../lib/date";

const siteUrl = "https://courseswyn.com";

function resolveImage(imagePath: string | undefined): string | null {
  if (!imagePath) return null;
  if (imagePath.startsWith('http')) return imagePath;
  const filename = imagePath.split('/').pop();
  if (!filename) return null;
  return `/assets/images/${filename}`;
}

const allPosts = await getCollection("blog");
const posts = allPosts.sort((a: any, b: any) => {
  const dateA = a.data.updatedAt || a.data.pubDate;
  const dateB = b.data.updatedAt || b.data.pubDate;
  return dateB.getTime() - dateA.getTime();
});

const recentPosts = posts.slice(0, 9);

const currentDate = new Date();
const currentYear = Number(currentDate.toLocaleString('en-US', { year: 'numeric', timeZone: 'Asia/Jakarta' }));

const title = `Best Udemy Course Reviews & Free Coupon Guides ${currentYear} | CoursesWyn Blog`;
const description = `Expert-reviewed guides to the best Udemy courses with verified 100% off coupon codes. Find free programming, AI, data science, cloud certification courses and step-by-step career roadmaps. Updated daily with working deals.`;
const canonical = `https://courseswyn.com/blog`;

const allTags = [...new Set(posts.flatMap((p: any) => p.data.tags || []))];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": canonical }
      ]
    },
    {
      "@type": "CollectionPage",
      "@id": canonical,
      "url": canonical,
      "name": title,
      "description": description,
      "isPartOf": { "@id": `${siteUrl}/#website` },
      "inLanguage": "en-US",
      "dateModified": toISODateWIB(posts[0]?.data?.updatedAt || posts[0]?.data?.pubDate || new Date()),
      "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": posts.length,
        "itemListElement": posts.slice(0, 10).map((post: any, i: number) => ({
          "@type": "ListItem",
          "position": i + 1,
          "item": {
            "@type": "BlogPosting",
            "headline": post.data.title,
            "description": post.data.description,
            "url": `${siteUrl}/blog/${post.id}/`,
            "datePublished": post.data.pubDate.toISOString(),
            "dateModified": (post.data.updatedAt || post.data.pubDate).toISOString(),
            "author": { "@type": "Person", "name": "Andrew Derek" }
          }
        }))
      }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <main class="cc-root">
    <div class="cc-container">

      <nav class="cc-breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li>Blog</li>
        </ol>
      </nav>

      <header class="cc-header">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="cc-header-icon">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
          <path d="M8 7h8"/><path d="M8 11h6"/>
        </svg>
        <h1 class="cc-title">
          Udemy Course Reviews & Free Coupon Guides
        </h1>
        <p class="cc-subtitle">
          Our editorial team analyzes thousands of Udemy courses to identify the highest-quality learning resources.
          Each guide includes verified 100% off coupon codes, curriculum breakdowns, and real career outcomes data.
        </p>
        <div class="cc-stats-bar">
          <div class="cc-stat">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            <span class="cc-stat-value">{posts.length}</span>
            <span class="cc-stat-label">Total Guides</span>
          </div>
          <div class="cc-stat-divider"></div>
          <div class="cc-stat">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <span class="cc-stat-value">{allTags.length}</span>
            <span class="cc-stat-label">Topics</span>
          </div>
          <div class="cc-stat-divider"></div>
          <div class="cc-stat">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 7h6v6"/><path d="m22 7-8.5 8.5-5-5L2 17"/></svg>
            <span class="cc-stat-value">{posts.filter((p: any) => p.data.updatedAt).length}</span>
            <span class="cc-stat-label">Updated {currentYear}</span>
          </div>
        </div>
      </header>

      <div class="cc-section cc-guide-topics">
        <div class="cc-topic-list">
          {[
            { name: "AI & Machine Learning", link: "/blog/top-ai-and-machine-learning-courses-on-udemy-2026" },
            { name: "ChatGPT & Prompt Engineering", link: "/blog/best-chatgpt-courses-udemy-2026" },
            { name: "AI Agent Development", link: "/blog/best-udemy-agentic-ai-courses-2026" },
            { name: "Cursor AI Coding", link: "/blog/best-cursor-ai-courses-udemy" },
            { name: "Programming & Development", link: "/blog/best-udemy-courses-2026" },
            { name: "React & Next.js", link: "/blog/best-react-nextjs-courses-2026" },
            { name: "Python", link: "/blog/top-10-python-courses-on-udemy" },
            { name: "AWS Certification", link: "/blog/best-aws-certification-courses-2026" },
            { name: "Cloud Computing", link: "/blog/cloud-computing-courses-udemy-2026" },
            { name: "Data Science", link: "/blog/best-data-science-courses-udemy" },
            { name: "SQL & Databases", link: "/blog/best-sql-courses-2026" },
            { name: "Career Guides", link: "/blog/ai-engineer-roadmap-2026" },
            { name: "Platform Comparisons", link: "/blog/udemy-vs-coursera-vs-pluralsight" },
            { name: "Free Courses Guide", link: "/udemy-coupons-guide" }
          ].map(tag => (
            <a href={tag.link} class="cc-topic-tag">
              {tag.name}
            </a>
          ))}
        </div>
      </div>

      <section class="cc-deals-section">
        <div class="cc-deals-header">
          <h2 class="cc-deals-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            Latest Udemy Blog Guides & Reviews
          </h2>
          <p class="cc-deals-desc">{recentPosts.length} articles on this page</p>
        </div>

        <div class="cc-grid">
          {recentPosts.map((post: any) => (
            <a href={`/blog/${post.id}`} class="cc-card">
              <div class="cc-card-img">
                <Image
                  src={resolveImage(typeof post.data.image === 'string' ? post.data.image : (post.data.image as any)?.src) || '/assets/images/og-default.svg'}
                  alt={post.data.title}
                  width={200}
                  height={150}
                  loading="lazy"
                  inferSize={false}
                />
                <span class="cc-badge-tag">{post.data.tags?.[0] || 'Guide'}</span>
              </div>
              <div class="cc-card-body">
                <h3 class="cc-card-title">{post.data.title}</h3>
                <p class="cc-card-excerpt">{post.data.description}</p>
                <div class="cc-card-footer">
                  <span class="cc-card-date">
                    {formatDateWIB(post.data.updatedAt || post.data.pubDate, { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                  <span class="cc-card-action">Read Review →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section class="cc-seo-section">
        <h2>Why trust CoursesWyn's Udemy course reviews?</h2>
        <p>Every guide on this blog is built on <strong>real data and hands-on analysis</strong>. We examine each course's curriculum depth, instructor credibility, student review sentiment, and practical outcomes — not just star ratings. Our team of edtech researchers has reviewed 1,300+ Udemy courses across <a href="/categories">every major category</a> to bring you detailed, honest reviews.</p>
        <p>All coupon codes listed in our reviews are <strong>verified, tested, and confirmed working</strong> before publication. Since Udemy's free coupon policy update, coupons expire quickly — we monitor every deal and remove expired ones daily. Browse <a href="/udemy-coupon-code">all active coupon codes</a> to start learning for free today.</p>
      </section>

      <section class="cc-section cc-faq">
        <h2 class="cc-section-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Frequently asked questions
        </h2>
        {[
          {
            q: "Are the Udemy coupon codes on CoursesWyn free?",
            a: "Yes. Every coupon code we list is a 100% off Udemy coupon that makes the course completely free. We verify each coupon manually before publishing and re-check periodically to ensure the codes are still valid."
          },
          {
            q: "How often are the blog guides updated?",
            a: "Our editorial team reviews and updates every guide at least once per quarter. Courses that change significantly, receive major curriculum updates, or have expiring coupons are refreshed immediately. Each article displays its last updated date at the top."
          },
          {
            q: "Do you review every course on Udemy?",
            a: "No. We selectively review courses that meet our quality bar — high student ratings, reputable instructors, and current curriculum. Out of 200,000+ Udemy courses, we've reviewed approximately 1,300 that represent the best learning value in each subject area."
          },
          {
            q: "Can I request a course review?",
            a: "Absolutely. If there's a Udemy course you'd like us to analyze and find a coupon for, use the search bar on our site or browse our <a href='/categories'>category pages</a>. We add new reviews every week based on learner demand and trending topics."
          }
        ].map(faq => (
          <div class="cc-faq-item">
            <h3 class="cc-faq-q">{faq.q}</h3>
            <p class="cc-faq-a">{faq.a}</p>
          </div>
        ))}
      </section>



      {posts.length > 10 && (
        <nav class="cc-pagination" style="border-top: 1px solid var(--border); margin-top: 2rem;">
          <a href="/blog/page/2" class="cc-page-link cc-page-more">
            View All Articles
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </nav>
      )}

    </div>
  </main>
</Layout>

<style>
  .cc-root { background: var(--bg); padding: 2rem 1rem 4rem; }
  .cc-container { max-width: 1024px; margin: 0 auto; }

  .cc-breadcrumb { display: flex; justify-content: center; margin-bottom: 1rem; }
  .cc-breadcrumb ol { list-style: none; display: flex; align-items: center; gap: 0.5rem; padding: 0; margin: 0; font-size: 0.8rem; color: var(--muted); }
  .cc-breadcrumb li:not(:last-child)::after { content: '/'; margin-left: 0.5rem; color: var(--border); }
  .cc-breadcrumb a { color: var(--brand); text-decoration: none; }
  .cc-breadcrumb a:hover { text-decoration: underline; }

  .cc-header { text-align: center; margin-bottom: 2rem; }
  .cc-header-icon { display: block; margin: 0 auto 0.75rem; color: var(--brand); }
  .cc-title { font-size: 1.8rem; font-weight: 900; color: var(--text); margin: 0 0 0.5rem; letter-spacing: -0.03em; }
  .cc-subtitle { font-size: 0.92rem; color: var(--muted); max-width: 600px; margin: 0 auto 1.5rem; line-height: 1.65; }

  .cc-stats-bar { display: inline-flex; align-items: center; gap: 1.5rem; background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 0.75rem 1.5rem; }
  .cc-stat { display: flex; flex-direction: column; align-items: center; gap: 0.1rem; }
  .cc-stat svg { width: 20px; height: 20px; margin-bottom: 0.2rem; }
  .cc-stat-value { font-size: 1.15rem; font-weight: 800; color: var(--text); }
  .cc-stat-label { font-size: 0.68rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; white-space: nowrap; }
  .cc-stat-divider { width: 1px; height: 32px; background: var(--border); }

  .cc-deals-section { margin-bottom: 2rem; }
  .cc-deals-header { margin-bottom: 1rem; }
  .cc-deals-title { font-size: 1.1rem; font-weight: 800; color: var(--text); margin: 0 0 0.15rem; display: flex; align-items: center; gap: 0.5rem; }
  .cc-deals-title svg { color: var(--brand); flex-shrink: 0; }
  .cc-deals-desc { font-size: 0.85rem; color: var(--muted); margin: 0; }

  .cc-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.85rem; }

  .cc-card { display: flex; background: var(--card); border: 1px solid var(--border); border-left: 3px solid var(--brand); border-radius: 8px; overflow: hidden; text-decoration: none; transition: all 0.2s; color: var(--text); }
  .cc-card:hover { border-color: var(--brand); background: color-mix(in srgb, var(--brand) 4%, transparent); }
  .cc-card:hover .cc-card-title { color: var(--brand); }

  .cc-card-img { width: 140px; min-height: 105px; flex-shrink: 0; position: relative; display: flex; align-items: center; justify-content: center; background: var(--border); overflow: hidden; }
  .cc-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s; }
  .cc-card:hover .cc-card-img img { transform: scale(1.06); }
  .cc-badge-tag { position: absolute; bottom: 6px; left: 6px; background: rgba(0,0,0,0.65); backdrop-filter: blur(4px); color: white; font-size: 0.55rem; font-weight: 600; padding: 2px 6px; border-radius: 3px; }

  .cc-card-body { flex: 1; padding: 12px 14px; display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .cc-card-title { font-size: 0.95rem; font-weight: 700; color: var(--text); margin: 0; line-height: 1.3; transition: color 0.2s; }
  .cc-card-excerpt { font-size: 0.8rem; color: var(--muted); margin: 0; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .cc-card-footer { margin-top: auto; display: flex; align-items: center; justify-content: space-between; padding-top: 6px; }
  .cc-card-date { font-size: 0.68rem; color: var(--muted); font-weight: 600; }
  .cc-card-action { font-size: 0.72rem; font-weight: 700; color: var(--brand); display: inline-flex; align-items: center; gap: 4px; }
  .cc-card:hover .cc-card-action { gap: 8px; }

  .cc-section { margin-bottom: 2rem; }
  .cc-section-title { font-size: 1.1rem; font-weight: 800; color: var(--text); margin: 0 0 0.25rem; display: flex; align-items: center; gap: 0.65rem; }
  .cc-section-title svg { color: var(--brand); flex-shrink: 0; }

  .cc-guide-topics { margin-bottom: 1.5rem; }
  .cc-topic-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .cc-topic-tag { display: inline-flex; align-items: center; gap: 6px; padding: 7px 16px; border-radius: 100px; border: 1px solid var(--border); font-size: 0.85rem; font-weight: 600; color: var(--text); text-decoration: none; transition: all 0.2s; background: var(--card); }
  .cc-topic-tag:hover { border-color: var(--brand); color: var(--brand); background: color-mix(in srgb, var(--brand) 6%, var(--card)); }

  .cc-seo-section { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; }
  .cc-seo-section h2 { font-size: 1.1rem; font-weight: 700; color: var(--text); margin: 0 0 0.75rem; }
  .cc-seo-section p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; margin: 0 0 0.75rem; }
  .cc-seo-section p:last-child { margin-bottom: 0; }
  .cc-seo-section a { color: var(--brand); text-decoration: none; font-weight: 600; }
  .cc-seo-section a:hover { text-decoration: underline; }

  .cc-faq { margin-bottom: 2rem; }
  .cc-faq-item { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 0.85rem 1rem; margin-bottom: 0.5rem; }
  .cc-faq-q { font-size: 0.9rem; font-weight: 700; color: var(--text); margin: 0 0 0.25rem; }
  .cc-faq-a { font-size: 0.85rem; color: var(--muted); line-height: 1.6; margin: 0; }
  .cc-faq-a a { color: var(--brand); text-decoration: none; font-weight: 600; }
  .cc-faq-a a:hover { text-decoration: underline; }

  .cc-pagination { display: flex; align-items: center; justify-content: center; gap: 0.75rem; padding: 1.5rem 0; }
  .cc-page-link { font-size: 0.85rem; font-weight: 700; color: var(--brand); text-decoration: none; padding: 0.4rem 0.85rem; border-radius: 6px; border: 1px solid var(--border); transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px; }
  .cc-page-link:hover { border-color: var(--brand); background: color-mix(in srgb, var(--brand) 6%, transparent); }
  .cc-page-more { border-color: var(--brand); background: var(--brand); color: white; }
  .cc-page-more:hover { border-color: var(--brand); background: var(--brand); opacity: 0.9; }

  @media (max-width: 768px) {
    .cc-grid { grid-template-columns: repeat(2, 1fr); gap: 0.65rem; }
    .cc-title { font-size: 1.4rem; }
    .cc-stats-bar { gap: 1rem; padding: 0.6rem 1rem; }
  }
  @media (max-width: 480px) {
    .cc-grid { grid-template-columns: 1fr; }
  }
</style>
