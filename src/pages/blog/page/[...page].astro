---
import Layout from "../../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const posts = await getCollection('blog');
  const sortedPosts = posts.sort((a, b) => {
    const dateA = a.data.updatedAt || a.data.pubDate;
    const dateB = b.data.updatedAt || b.data.pubDate;
    return dateB.getTime() - dateA.getTime();
  });

  return paginate(sortedPosts, { pageSize: 8 });
}

const { page } = Astro.props as { page: any };
const posts: any[] = page?.data ?? [];

// Date formatting function
function formatDate(post: any) {
  const isUpdated = !!post.data.updatedAt;
  const date = post.data.updatedAt || post.data.pubDate;
  const formatted = new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  }).format(date);
  return isUpdated ? `Updated ${formatted}` : formatted;
}

const title = `Latest Udemy Course Reviews & Learning Guides - Page ${page.currentPage} | Courses Wyn`;
const description = "Browse all Udemy Courses guides, tutorials, comparisons, and reviews. Find the best Udemy Courses for your project.";
const canonical = `https://courseswyn.com/blog/page/${page.currentPage}`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  headline: title,
  description: description,
  url: canonical,
  blogPost: posts.map((post: any) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    url: `https://courseswyn.com/blog/${post.id}`,
    datePublished: post.data.pubDate.toISOString(),
    author: {
      "@type": "Person",
      name: "Andrew Derek",
      url: "mailto:admin@courseswyn.com",
    },
  })),
};
---

<Layout title={title} description={description} canonical={canonical}>
  <section style={{ padding: "80px 0", background: "var(--bg)" }}>
    <div class="container">
      
      {/* ── Blog Header ── */}
      <header style={{ marginBottom: "64px" }}>
        <div style={{
          display: "inline-block",
          background: "var(--accent)",
          color: "white",
          padding: "4px 14px",
          border: "2px solid var(--border)",
          boxShadow: "3px 3px 0 var(--border)",
          borderRadius: "4px",
          fontSize: "0.75rem",
          fontWeight: 800,
          marginBottom: "24px",
          letterSpacing: "0.1em",
          textTransform: "uppercase"
        }}>
          Page {page.currentPage} of {page.lastPage}
        </div>
        <h1 style={{ fontSize: "clamp(2.5rem, 6vw, 4rem)", fontWeight: 900, color: "var(--text)", letterSpacing: "-0.04em", lineHeight: 1.05, marginBottom: "24px" }}>
          More <span style={{ background: "var(--accent)", color: "white", padding: "0 10px" }}>Articles</span>
        </h1>
        <p style={{ fontSize: "1.15rem", color: "var(--muted)", lineHeight: 1.6, maxWidth: "700px", fontWeight: 500 }}>
          Browse all {page.total} expert guides and reviews. Showing {posts.length} articles on this page.
        </p>
      </header>

      {/* ── Articles Grid ── */}
      {posts.length > 0 ? (
        <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(340px, 1fr))", gap: "24px", marginBottom: "64px" }}>
          {posts.map((post: any) => (
            <article style={{
              background: "var(--card)",
              border: "2px solid var(--border)",
              boxShadow: "4px 4px 0 var(--border)",
              borderRadius: "8px",
              overflow: "hidden",
              transition: "all 0.15s ease",
              display: "flex",
              flexDirection: "column"
            }} class="article-card">
              <a href={`/blog/${post.id}`} style={{ textDecoration: "none", color: "inherit", height: "100%", display: "flex", flexDirection: "column" }}>
                <div style={{ position: "relative", height: "200px", borderBottom: "2px solid var(--border)", overflow: "hidden" }}>
                  <img 
                    src={post.data.image?.src || post.data.image || '/og-image.jpg'} 
                    alt={post.data.title}
                    style={{ width: "100%", height: "100%", objectFit: "cover" }}
                    class="article-img"
                  />
                  {post.data.tags && post.data.tags[0] && (
                    <div style={{
                      position: "absolute", top: "12px", left: "12px",
                      background: "var(--accent)", color: "white",
                      border: "1.5px solid var(--border)", padding: "2px 8px",
                      fontSize: "0.6rem", fontWeight: 800, borderRadius: "3px",
                      textTransform: "uppercase", letterSpacing: "0.05em"
                    }}>
                      {post.data.tags[0]}
                    </div>
                  )}
                </div>
                <div style={{ padding: "24px", flex: 1, display: "flex", flexDirection: "column" }}>
                  <h3 style={{ fontSize: "1.2rem", fontWeight: 900, color: "var(--text)", marginBottom: "16px", lineHeight: 1.25, letterSpacing: "-0.02em" }}>
                    {post.data.title}
                  </h3>
                  <p style={{ color: "var(--muted)", fontSize: "0.88rem", lineHeight: 1.6, marginBottom: "20px", display: "-webkit-box", WebkitLineClamp: 3, WebkitBoxOrient: "vertical", overflow: "hidden", fontWeight: 500 }}>
                    {post.data.description}
                  </p>
                  <div style={{ marginTop: "auto", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                    <div style={{ fontSize: "0.72rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase" }}>
                      {formatDate(post)}
                    </div>
                    <div style={{ fontWeight: 800, color: "var(--accent)", fontSize: "0.8rem", textTransform: "uppercase", letterSpacing: "0.06em" }}>
                      Read Review →
                    </div>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div style={{ textAlign: "center", padding: "64px 0" }}>
          <p style={{ color: "var(--muted)", fontSize: "1.1rem" }}>No articles found.</p>
          <a href="/blog" style={{ display: "inline-block", marginTop: "24px", padding: "12px 24px", background: "var(--accent)", color: "white", textDecoration: "none", borderRadius: "6px", fontWeight: 800 }}>
            Back to Blog
          </a>
        </div>
      )}

      {/* ── Pagination ── */}
      <div style={{ display: "flex", justifyContent: "center", gap: "12px", marginTop: "48px" }}>
        {page.url.prev ? (
          <a 
            href={page.url.prev} 
            style={{
              padding: "12px 24px",
              background: "var(--card)",
              border: "2px solid var(--border)",
              boxShadow: "3px 3px 0 var(--border)",
              color: "var(--text)",
              textDecoration: "none",
              borderRadius: "6px",
              fontWeight: 800,
              fontSize: "0.85rem",
              display: "inline-flex",
              alignItems: "center",
              gap: "8px",
              transition: "all 0.15s ease"
            }}
            class="page-btn"
          >
            ← Prev
          </a>
        ) : null}

        <span style={{
          padding: "12px 24px",
          background: "var(--accent)",
          border: "2px solid var(--border)",
          boxShadow: "3px 3px 0 var(--border)",
          color: "white",
          borderRadius: "6px",
          fontWeight: 800,
          fontSize: "0.85rem"
        }}>
          Page {page.currentPage}
        </span>

        {page.url.next ? (
          <a 
            href={page.url.next} 
            style={{
              padding: "12px 24px",
              background: "var(--card)",
              border: "2px solid var(--border)",
              boxShadow: "3px 3px 0 var(--border)",
              color: "var(--text)",
              textDecoration: "none",
              borderRadius: "6px",
              fontWeight: 800,
              fontSize: "0.85rem",
              display: "inline-flex",
              alignItems: "center",
              gap: "8px",
              transition: "all 0.15s ease"
            }}
            class="page-btn"
          >
            Next →
          </a>
        ) : null}
      </div>
    </div>
  </section>

  <style>
    .article-card:hover { transform: translate(-3px, -3px); box-shadow: 7px 7px 0 var(--border) !important; }
    .article-card:hover .article-img { transform: scale(1.05); }
    .article-img { transition: transform 0.4s ease; }
    .page-btn:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--border) !important; }

    @media (max-width: 960px) {
      .article-card[style*="grid-template-columns"] {
        grid-template-columns: 1fr !important;
      }
    }
  </style>
</Layout>
