---
import Layout from "../../../layouts/Layout.astro";
import { Image } from 'astro:assets';
import { getCollection } from "astro:content";
import { formatDateWIB, toISODateWIB } from "../../../lib/date";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const posts = await getCollection('blog');
  const sortedPosts = posts.sort((a: any, b: any) => {
    const dateA = a.data.updatedAt || a.data.pubDate;
    const dateB = b.data.updatedAt || b.data.pubDate;
    return dateB.getTime() - dateA.getTime();
  });

  return paginate(sortedPosts, { pageSize: 9 });
}

const { page } = Astro.props as { page: any };
const posts: any[] = page?.data ?? [];

function formatDate(post: any) {
  const isUpdated = !!post.data.updatedAt;
  const date = post.data.updatedAt || post.data.pubDate;
  const formatted = formatDateWIB(date, {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
  return isUpdated ? `Updated ${formatted}` : formatted;
}

function resolveImage(imagePath: any): string {
  if (!imagePath) return '/assets/images/og-default.svg';
  if (imagePath?.src) return imagePath.src;
  if (typeof imagePath === 'string') {
    if (imagePath.startsWith('http') || imagePath.startsWith('/')) return imagePath;
    const filename = imagePath.split('/').pop();
    return filename ? `/assets/images/${filename}` : '/assets/images/og-default.svg';
  }
  return '/assets/images/og-default.svg';
}

const title = `Udemy Course Reviews & Learning Guides — Page ${page.currentPage} | CoursesWyn`;
const description = "Browse all Udemy Courses guides, tutorials, comparisons, and reviews. Find the best Udemy Courses for your project.";
const canonical = `https://courseswyn.com/blog/page/${page.currentPage}`;
const siteUrl = "https://courseswyn.com";

function getPageNumbers(current: number, total: number): (number | '...')[] {
  const pages: (number | '...')[] = [];
  if (total <= 7) {
    for (let i = 1; i <= total; i++) pages.push(i);
  } else {
    pages.push(1);
    if (current > 3) pages.push('...');
    const start = Math.max(2, current - 1);
    const end = Math.min(total - 1, current + 1);
    for (let i = start; i <= end; i++) pages.push(i);
    if (current < total - 2) pages.push('...');
    pages.push(total);
  }
  return pages;
}

const currentPosts = posts.slice(0, 9);
const firstPostDate = currentPosts[0]?.data?.updatedAt || currentPosts[0]?.data?.pubDate;

const pageItems: ({ type: 'page'; value: number } | { type: 'ellipsis'; id: string })[] = [];
const windowSize = 2;
let lastAdded = 0;
for (let p = 1; p <= page.lastPage; p++) {
  const inWindow = p >= page.currentPage - windowSize && p <= page.currentPage + windowSize;
  if (p === 1 || p === page.lastPage || inWindow) {
    if (lastAdded > 0 && p - lastAdded > 1) {
      pageItems.push({ type: 'ellipsis', id: `gap-${p}` });
    }
    pageItems.push({ type: 'page', value: p });
    lastAdded = p;
  }
}

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${siteUrl}/blog` },
        { "@type": "ListItem", "position": 3, "name": `Page ${page.currentPage}`, "item": canonical }
      ]
    },
    {
      "@type": "CollectionPage",
      "@id": canonical,
      "url": canonical,
      "name": title,
      "description": description,
      "isPartOf": { "@id": `${siteUrl}/#website` },
      "inLanguage": "en-US",
      "dateModified": firstPostDate ? toISODateWIB(firstPostDate) : undefined,
      "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": currentPosts.length,
        "itemListElement": currentPosts.map((post: any, i: number) => ({
          "@type": "ListItem",
          "position": i + 1 + (page.currentPage - 1) * 8,
          "item": {
            "@type": "BlogPosting",
            "headline": post.data.title,
            "description": post.data.description,
            "url": `${siteUrl}/blog/${post.id}/`,
            "datePublished": post.data.pubDate.toISOString(),
            "dateModified": (post.data.updatedAt || post.data.pubDate).toISOString(),
            "author": { "@type": "Person", "name": "Andrew Derek" }
          }
        }))
      }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    {page.url.prev && <link rel="prev" href={page.url.prev} />}
    {page.url.next && <link rel="next" href={page.url.next} />}
    {page.currentPage > 1 && <meta name="robots" content="noindex, follow" />}
  </Fragment>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <main class="cc-root">
    <div class="cc-container">

      <nav class="cc-breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/blog">Blog</a></li>
          <li>Page {page.currentPage}</li>
        </ol>
      </nav>

      <header class="cc-header">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="cc-header-icon">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
          <path d="M8 7h8"/><path d="M8 11h6"/>
        </svg>
        <h1 class="cc-title">
          More Articles
          <span class="cc-page-label">Page {page.currentPage}</span>
        </h1>
        <p class="cc-subtitle">
          Browse all {page.total} expert guides and reviews. Showing {posts.length} articles on this page.
        </p>
      </header>

      {posts.length > 0 ? (
        <section class="cc-deals-section">
          <div class="cc-deals-header">
            <h2 class="cc-deals-title">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              Guides & Reviews
            </h2>
            <p class="cc-deals-desc">Page {page.currentPage} of {page.lastPage}</p>
          </div>

          <div class="cc-grid">
            {posts.map((post: any) => (
              <a href={`/blog/${post.id}`} class="cc-card">
                <div class="cc-card-img">
                  <Image src={resolveImage(post.data.image)} alt={post.data.title} width={400} height={160} loading="lazy" inferSize={false} />
                  {post.data.tags && post.data.tags[0] && (
                    <span class="cc-badge-tag">{post.data.tags[0]}</span>
                  )}
                </div>
                <div class="cc-card-body">
                  <h3 class="cc-card-title">{post.data.title}</h3>
                  <p class="cc-card-excerpt">{post.data.description}</p>
                  <div class="cc-card-footer">
                    <span class="cc-card-date">{formatDate(post)}</span>
                    <span class="cc-card-action">Read Review →</span>
                  </div>
                </div>
              </a>
            ))}
          </div>

          <nav class="cc-pagination" aria-label="Pagination">
            {page.url.prev ? (
              <a href={page.url.prev} class="cc-page-link cc-page-prev">← Prev</a>
            ) : (
              <span class="cc-page-link cc-page-disabled">← Prev</span>
            )}
            <div class="cc-page-numbers">
              {pageItems.map((item: any) => {
                if (item.type === 'ellipsis') {
                  return <span class="cc-page-ellipsis">...</span>;
                }
                const isActive = item.value === page.currentPage;
                const href = item.value === 1 ? '/blog' : `/blog/page/${item.value}`;
                return isActive
                  ? <span class="cc-page-num cc-page-active">{item.value}</span>
                  : <a href={href} class="cc-page-num">{item.value}</a>;
              })}
            </div>
            {page.url.next ? (
              <a href={page.url.next} class="cc-page-link cc-page-next">Next →</a>
            ) : (
              <span class="cc-page-link cc-page-disabled">Next →</span>
            )}
          </nav>
        </section>
      ) : (
        <div class="cc-empty">
          <p>No articles found.</p>
          <a href="/blog" class="cc-page-link cc-page-more">Back to Blog</a>
        </div>
      )}

    </div>
  </main>
</Layout>

<style>
  .cc-root { background: var(--bg); padding: 2rem 1rem 4rem; }
  .cc-container { max-width: 1024px; margin: 0 auto; }

  .cc-breadcrumb { display: flex; justify-content: center; margin-bottom: 1rem; }
  .cc-breadcrumb ol { list-style: none; display: flex; align-items: center; gap: 0.5rem; padding: 0; margin: 0; font-size: 0.8rem; color: var(--muted); }
  .cc-breadcrumb li:not(:last-child)::after { content: '/'; margin-left: 0.5rem; color: var(--border); }
  .cc-breadcrumb a { color: var(--brand); text-decoration: none; }
  .cc-breadcrumb a:hover { text-decoration: underline; }

  .cc-header { text-align: center; margin-bottom: 2rem; }
  .cc-header-icon { display: block; margin: 0 auto 0.75rem; color: var(--brand); }
  .cc-title { font-size: 1.8rem; font-weight: 900; color: var(--text); margin: 0 0 0.5rem; letter-spacing: -0.03em; display: flex; align-items: center; justify-content: center; gap: 0.75rem; flex-wrap: wrap; }
  .cc-page-label { font-size: 1.1rem; font-weight: 700; color: var(--muted); letter-spacing: normal; }
  .cc-subtitle { font-size: 0.92rem; color: var(--muted); max-width: 600px; margin: 0 auto 1.5rem; line-height: 1.65; }

  .cc-deals-section { margin-bottom: 2rem; }
  .cc-deals-header { margin-bottom: 1rem; }
  .cc-deals-title { font-size: 1.1rem; font-weight: 800; color: var(--text); margin: 0 0 0.15rem; display: flex; align-items: center; gap: 0.5rem; }
  .cc-deals-title svg { color: var(--brand); flex-shrink: 0; }
  .cc-deals-desc { font-size: 0.85rem; color: var(--muted); margin: 0; }

  .cc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.85rem; }

  .cc-card { display: flex; flex-direction: column; background: var(--card); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; text-decoration: none; transition: all 0.2s; }
  .cc-card:hover { border-color: var(--brand); transform: translateY(-2px); }
  .cc-card:hover .cc-card-title { color: var(--brand); }

  .cc-card-img { position: relative; width: 100%; aspect-ratio: 5/2; overflow: hidden; background: var(--border); }
  .cc-card-img img { width: 100%; height: 100%; object-fit: cover; }
  .cc-badge-tag { position: absolute; bottom: 6px; left: 6px; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); color: white; font-size: 0.6rem; font-weight: 600; padding: 2px 7px; border-radius: 3px; }

  .cc-card-body { padding: 1rem; display: flex; flex-direction: column; gap: 0.4rem; flex: 1; }
  .cc-card-title { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .cc-card-excerpt { font-size: 0.85rem; color: var(--muted); margin: 0; line-height: 1.55; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .cc-card-footer { margin-top: auto; display: flex; align-items: center; justify-content: space-between; padding-top: 0.5rem; border-top: 1px solid var(--border); }
  .cc-card-date { font-size: 0.72rem; color: var(--muted); font-weight: 600; }
  .cc-card-action { font-size: 0.78rem; font-weight: 700; color: var(--brand); }

  .cc-pagination { display: flex; align-items: center; justify-content: center; gap: 0.75rem; padding: 1.5rem 0; border-top: 1px solid var(--border); }
  .cc-page-link { font-size: 0.85rem; font-weight: 700; color: var(--brand); text-decoration: none; padding: 0.4rem 0.85rem; border-radius: 6px; border: 1px solid var(--border); transition: all 0.2s; }
  .cc-page-link:hover { border-color: var(--brand); background: color-mix(in srgb, var(--brand) 6%, transparent); }
  .cc-page-disabled { color: var(--muted); opacity: 0.4; pointer-events: none; }
  .cc-page-numbers { display: flex; align-items: center; gap: 4px; }
  .cc-page-num { font-size: 0.85rem; font-weight: 700; color: var(--text); text-decoration: none; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; border-radius: 6px; border: 1px solid var(--border); transition: all 0.2s; }
  .cc-page-num:hover { border-color: var(--brand); color: var(--brand); }
  .cc-page-active { background: var(--brand); color: white; border-color: var(--brand); }
  .cc-page-active:hover { color: white; }
  .cc-page-ellipsis { font-size: 0.85rem; color: var(--muted); width: 34px; text-align: center; }
  .cc-page-more { border-color: var(--brand); background: var(--brand); color: white; }
  .cc-page-more:hover { border-color: var(--brand); background: var(--brand); opacity: 0.9; }

  .cc-empty { text-align: center; padding: 3rem 0; }
  .cc-empty p { color: var(--muted); font-size: 1rem; margin-bottom: 1rem; }

  @media (max-width: 768px) {
    .cc-grid { grid-template-columns: repeat(2, 1fr); gap: 0.65rem; }
    .cc-title { font-size: 1.4rem; }
  }
  @media (max-width: 480px) {
    .cc-grid { grid-template-columns: 1fr; }
  }
</style>
