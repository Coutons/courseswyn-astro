---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import AuthorBox from "../../components/AuthorBox.astro";
import ReadingProgress from "../../components/blog/ReadingProgress.astro";
import { formatDateWIB } from "../../lib/date";

export async function getStaticPaths() {
  const fs = await import('fs');
  const path = await import('path');
  const blogDir = path.join(process.cwd(), 'src/content/blog');

  function getBlogFolders(dir: string, basePath = ''): string[] {
    const folders: string[] = [];
    const items = fs.readdirSync(dir, { withFileTypes: true });

    for (const item of items) {
      if (item.isDirectory()) {
        const folderPath = path.join(dir, item.name);
        const indexPath = path.join(folderPath, 'index.md');
        const indexPathMdx = path.join(folderPath, 'index.mdx');

        if (fs.existsSync(indexPath) || fs.existsSync(indexPathMdx)) {
          const folderSlug = basePath ? `${basePath}/${item.name}` : item.name;
          folders.push(folderSlug);
        } else {
          folders.push(...getBlogFolders(folderPath, basePath ? `${basePath}/${item.name}` : item.name));
        }
      }
    }

    return folders;
  }

  const blogFolders = getBlogFolders(blogDir);

  return blogFolders.map((folder) => ({
    params: { slug: folder },
  }));
}

const { slug } = Astro.params;
const allPosts = await getCollection("blog");
const post = allPosts?.find((p: any) => {
  const normalizedId = p.id.replace(/\/index$/, '');
  return normalizedId === slug || p.id === slug || (p.data as any).slug === slug;
});

if (!post) {
  return Astro.redirect('/404');
}

const { data } = post;

const { Content, headings } = await render(post);

const wordsPerMinute = 200;
const words = post.body ? post.body.split(/\s+/).length : 0;
const readingTime = Math.ceil(words / wordsPerMinute);

const title = data.title;
const description = data.description;
const canonical = `https://courseswyn.com/blog/${post.id}/`;

const ogImage = data.image && typeof data.image === 'object' && 'src' in data.image ? data.image.src : data.image;

const authorName = data.author || "Andrew Derek";
const authorBio = (data as any).authorBio || "Andrew Derek is a lead course analyst and digital education expert with 8+ years of experience evaluating online learning platforms. He has personally reviewed over 500 Udemy courses across programming, AI, data science, and cloud computing — helping students save money with verified 100% off coupon codes while finding high-quality instruction that delivers real career outcomes.";
const authorInitials = authorName.split(' ').map((n: string) => n[0]).join('').substring(0, 2).toUpperCase();

const articleSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${canonical}#article`,
      "headline": title,
      "description": description,
      "url": canonical,
      "datePublished": data.pubDate.toISOString(),
      "dateModified": (data.updatedAt || data.pubDate).toISOString(),
      "author": {
        "@type": "Person",
        "name": authorName,
        "url": "https://courseswyn.com",
        "jobTitle": "Lead Course Analyst",
        "description": authorBio
      },
      "publisher": {
        "@type": "Organization",
        "name": "CoursesWyn",
        "url": "https://courseswyn.com",
        "logo": { "@type": "ImageObject", "url": "https://courseswyn.com/logo.svg" }
      },
      "image": ogImage ? { "@type": "ImageObject", "url": ogImage } : undefined,
      "mainEntityOfPage": { "@type": "WebPage", "@id": canonical }
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://courseswyn.com/blog" },
        { "@type": "ListItem", "position": 3, "name": title, "item": canonical }
      ]
    },
    {
      "@type": "WebPage",
      "@id": canonical,
      "url": canonical,
      "name": title,
      "description": description,
      "isPartOf": { "@id": "https://courseswyn.com/#website" },
      "inLanguage": "en-US",
      "dateModified": (data.updatedAt || data.pubDate).toISOString()
    }
  ]
};

let structuredData: any = articleSchema;

const articleFaqs = (data as any).faqs;
if (articleFaqs && Array.isArray(articleFaqs) && articleFaqs.length > 0) {
  structuredData = {
    "@context": "https://schema.org",
    "@graph": [
      ...articleSchema["@graph"],
      {
        "@type": "FAQPage",
        "@id": `${canonical}#faq`,
        "mainEntity": articleFaqs.slice(0, 8).map((faq: { q: string; a: string }) => ({
          "@type": "Question",
          "name": faq.q,
          "acceptedAnswer": { "@type": "Answer", "text": faq.a }
        }))
      }
    ]
  };
}
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  image={ogImage}
  type="article"
  pubDate={data.pubDate}
  updatedDate={data.updatedAt || data.pubDate}
>
  <ReadingProgress />

  <article class="cc-root cc-article">
    <div class="cc-article-container">

      <nav class="cc-breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/blog">Blog</a></li>
          <li>{title}</li>
        </ol>
      </nav>

      {data.tags && data.tags.length > 0 && (
        <div class="cc-article-tags">
          {data.tags.slice(0, 3).map((tag: string) => (
            <span class="cc-tag-chip">{tag}</span>
          ))}
        </div>
      )}

      <h1 class="cc-article-title">{title}</h1>
      <p class="cc-article-desc">{description}</p>

      <div class="cc-article-meta">
        <div class="cc-article-author">
          <div class="cc-avatar">{authorInitials}</div>
          <div>
            <p class="cc-author-name">{authorName}</p>
            <p class="cc-author-detail">
              {formatDateWIB(data.updatedAt || data.pubDate, { month: 'long', day: 'numeric', year: 'numeric' })}
              {' · '}{readingTime} min read
            </p>
          </div>
        </div>
      </div>

      {data.image && (
        <figure class="cc-article-hero">
          <img
            src={typeof data.image === 'string' ? data.image : data.image && typeof data.image === 'object' && 'src' in data.image ? data.image.src : ''}
            alt={title}
          />
        </figure>
      )}

      <div class="cc-article-content">
        <Content />
      </div>

      <footer class="cc-article-footer">
        <h2 class="cc-about-author-heading">About the Author</h2>
        <AuthorBox name={authorName} bio={authorBio} image="/images/author.jpg" />

        <div class="cc-cta-box">
          <h3>Start Learning for Free</h3>
          <p>Browse <a href="/udemy-coupon-code">all verified Udemy coupons</a> or check <a href="/udemy-coupons-today">today's latest deals</a>.</p>
          <div class="cc-cta-buttons">
            <a href="/udemy-coupon-code" class="cc-cta-btn">Browse All Coupons</a>
            <a href="/blog" class="cc-cta-btn cc-cta-btn-ghost">Back to Blog</a>
          </div>
        </div>
      </footer>

    </div>
  </article>

  <style is:global>
    .cc-root { background: var(--bg); }
    .cc-article-container { max-width: 900px; margin: 0 auto; padding: 2rem 1rem 4rem; }

    .cc-breadcrumb { margin-bottom: 1.5rem; }
    .cc-breadcrumb ol { list-style: none; display: flex; align-items: center; gap: 0.5rem; padding: 0; margin: 0; font-size: 0.8rem; color: var(--muted); }
    .cc-breadcrumb li:not(:last-child)::after { content: '/'; margin-left: 0.5rem; color: var(--border); }
    .cc-breadcrumb a { color: var(--brand); text-decoration: none; }
    .cc-breadcrumb a:hover { text-decoration: underline; }
    .cc-breadcrumb li:last-child { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 300px; }

    .cc-article-tags { display: flex; gap: 8px; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .cc-tag-chip { display: inline-block; font-size: 0.78rem; font-weight: 600; color: var(--muted); padding: 3px 12px; border-radius: 100px; border: 1px solid var(--border); background: var(--card); }

    .cc-article-title { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 900; line-height: 1.15; letter-spacing: -0.03em; margin: 0 0 1.25rem; color: var(--text); }
    .cc-article-desc { font-size: 1.1rem; color: var(--muted); line-height: 1.6; margin: 0 0 1.5rem; font-weight: 500; }

    .cc-article-meta { display: flex; align-items: center; padding-top: 1.25rem; border-top: 1px solid var(--border); margin-bottom: 2rem; }
    .cc-article-author { display: flex; align-items: center; gap: 12px; }
    .cc-avatar { width: 40px; height: 40px; border-radius: 6px; background: var(--brand); display: flex; align-items: center; justify-content: center; font-weight: 900; color: #fff; font-size: 0.85rem; flex-shrink: 0; border: 1px solid var(--border); }
    .cc-author-name { margin: 0; font-size: 0.9rem; font-weight: 700; color: var(--text); }
    .cc-author-detail { margin: 2px 0 0; font-size: 0.82rem; color: var(--muted); font-weight: 500; }

    .cc-article-hero { margin-bottom: 2.5rem; }
    .cc-article-hero img { width: 100%; height: auto; border-radius: 10px; object-fit: cover; border: 1px solid var(--border); }

    .cc-article-content { max-width: 100%; }
    .cc-article-content h2 { font-size: 1.8rem; font-weight: 800; margin: 3rem 0 1rem; letter-spacing: -0.02em; color: var(--text); }
    .cc-article-content h3 { font-size: 1.35rem; font-weight: 700; margin: 2rem 0 0.75rem; color: var(--text); }
    .cc-article-content p { font-size: 1.05rem; line-height: 1.8; margin-bottom: 1.5rem; color: var(--text); }
    .cc-article-content ul, .cc-article-content ol { margin-bottom: 1.5rem; padding-left: 1.5rem; }
    .cc-article-content li { margin-bottom: 0.5rem; line-height: 1.7; color: var(--text); }
    .cc-article-content strong { font-weight: 700; }
    .cc-article-content a { color: var(--brand); font-weight: 600; text-decoration: underline; text-underline-offset: 3px; }
    .cc-article-content a:hover { opacity: 0.85; }
    .cc-article-content img { border-radius: 8px; margin: 2rem 0; width: 100%; border: 1px solid var(--border); }
    .cc-article-content blockquote { border-left: 3px solid var(--brand); padding: 1rem 1.5rem; margin: 2rem 0; background: var(--card); border-radius: 0 10px 10px 0; }
    .cc-article-content blockquote p { margin-bottom: 0; color: var(--muted); }
    .cc-article-content code { background: var(--card); padding: 2px 6px; border-radius: 4px; font-size: 0.9em; border: 1px solid var(--border); }
    .cc-article-content pre { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 1.5rem; overflow-x: auto; margin: 2rem 0; }
    .cc-article-content hr { border: none; border-top: 1px solid var(--border); margin: 3rem 0; }
    .cc-article-content table { width: 100%; border-collapse: collapse; margin: 2rem 0; font-size: 0.9rem; }
    .cc-article-content th { background: var(--card); padding: 0.75rem 1rem; text-align: left; font-weight: 700; border: 1px solid var(--border); }
    .cc-article-content td { padding: 0.75rem 1rem; border: 1px solid var(--border); }
    .cc-article-content tr:nth-child(even) { background: var(--card); }

    .cc-article-footer { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border); }
    .cc-about-author-heading { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 1rem; text-transform: uppercase; letter-spacing: 0.04em; }
    .cc-cta-box { margin-top: 2.5rem; padding: 2rem; background: var(--card); border: 1px solid var(--border); border-radius: 12px; text-align: center; }
    .cc-cta-box h3 { font-size: 1.35rem; font-weight: 900; margin: 0 0 0.75rem; color: var(--brand); }
    .cc-cta-box p { font-size: 0.92rem; color: var(--muted); margin: 0 0 1.25rem; line-height: 1.6; }
    .cc-cta-box p a { color: var(--brand); font-weight: 600; }
    .cc-cta-buttons { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .cc-cta-btn { display: inline-flex; align-items: center; padding: 12px 28px; background: var(--brand); color: #fff; border-radius: 8px; text-decoration: none; font-weight: 800; font-size: 0.92rem; border: 1px solid var(--border); transition: all 0.2s; }
    .cc-cta-btn:hover { opacity: 0.9; transform: translateY(-1px); }
    .cc-cta-btn-ghost { background: transparent; color: var(--text); border-color: var(--border); }
    .cc-cta-btn-ghost:hover { background: var(--card); }

    @media (max-width: 768px) {
      .cc-article-container { padding: 1.5rem 1rem 3rem; }
      .cc-article-content h2 { font-size: 1.5rem; }
      .cc-article-content h3 { font-size: 1.2rem; }
      .cc-article-content p { font-size: 1rem; }
      .cc-breadcrumb li:last-child { max-width: 150px; }
    }
  </style>
</Layout>
