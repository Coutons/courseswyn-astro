---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import AuthorBox from "../../components/AuthorBox.astro";
import ReadingProgress from "../../components/blog/ReadingProgress.astro";
import { formatDateWIB } from "../../lib/date";



export async function getStaticPaths() {
  const fs = await import('fs');
  const path = await import('path');
  const blogDir = path.join(process.cwd(), 'src/content/blog');

  // Recursively find all folders with index.md or index.mdx
  function getBlogFolders(dir: string, basePath = ''): string[] {
    const folders: string[] = [];
    const items = fs.readdirSync(dir, { withFileTypes: true });

    for (const item of items) {
      if (item.isDirectory()) {
        const folderPath = path.join(dir, item.name);
        const indexPath = path.join(folderPath, 'index.md');
        const indexPathMdx = path.join(folderPath, 'index.mdx');

        if (fs.existsSync(indexPath) || fs.existsSync(indexPathMdx)) {
          const folderSlug = basePath ? `${basePath}/${item.name}` : item.name;
          folders.push(folderSlug);
        } else {
          // Recursively check subdirectories
          folders.push(...getBlogFolders(folderPath, basePath ? `${basePath}/${item.name}` : item.name));
        }
      }
    }

    return folders;
  }

  const blogFolders = getBlogFolders(blogDir);

  return blogFolders.map((folder) => ({
    params: { slug: folder },
  }));
}

const { slug } = Astro.params;
const allPosts = await getCollection("blog");
const post = allPosts?.find((p: any) => {
  // glob() loader generates IDs like "best-chatgpt-courses/index"
  const normalizedId = p.id.replace(/\/index$/, '');
  return normalizedId === slug || p.id === slug || (p.data as any).slug === slug;
});

if (!post) {
  return Astro.redirect('/404');
}

const { data } = post;

// Render the content
const { Content, headings } = await render(post);

// Calculate reading time
const wordsPerMinute = 200;
const words = post.body ? post.body.split(/\s+/).length : 0;
const readingTime = Math.ceil(words / wordsPerMinute);



const title = data.title;
const description = data.description;
const canonical = `https://courseswyn.com/blog/${post.id}/`;

// Get related courses based on tags (subtle recommendations)
const ogImage = data.image && typeof data.image === 'object' && 'src' in data.image ? data.image.src : data.image;

// Get related courses based on tags (subtle recommendations)
const relatedCourses = [
  {
    id: 1,
    title: "100 Days of Code™: The Complete Python Pro Bootcamp",
    slug: "/coupon/100-days-of-code",
    image: "https://img-c.udemycdn.com/course/480x270/2776760_f176_10.jpg",
    rating: 4.6,
    students: 1687496,
    price: 10.99,
    originalPrice: 199.99,
    instructor: "Angela Yu",
    category: "Programming"
  }
];

// Get author from post frontmatter or default to Andrew Derek
const authorName = data.author || "Andrew Derek";
const authorBio = (data as any).authorBio || "Expert in digital education and curriculum mapping with 8+ years of experience.";
const authorInitials = authorName.split(' ').map((n: string) => n[0]).join('').substring(0, 2).toUpperCase();

// Article structured data with subtle course mentions
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description,
  url: canonical,
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedAt || data.pubDate).toISOString(),
  author: {
    "@type": "Person",
    name: authorName,
    url: "https://courseswyn.com",
    jobTitle: "Lead Course Analyst",
    description: authorBio
  },
  publisher: {
    "@type": "Organization",
    name: "CoursesWyn",
    url: "https://courseswyn.com",
    logo: {
      "@type": "ImageObject",
      url: "https://courseswyn.com/logo.svg",
    },
  },
  image: ogImage ? { "@type": "ImageObject", url: ogImage } : undefined,
  // Subtle course mentions for SEO
  mentions: relatedCourses.map(course => ({
    "@type": "Course",
    name: course.title,
    provider: {
      "@type": "Organization",
      name: "Udemy"
    }
  }))
};

// Use article schema as default
let structuredData: any = articleSchema;

// If article has FAQ data in frontmatter, add FAQPage schema
const articleFaqs = (data as any).faqs;
if (articleFaqs && Array.isArray(articleFaqs) && articleFaqs.length > 0) {
  structuredData = {
    "@context": "https://schema.org",
    "@graph": [
      articleSchema,
      {
        "@type": "FAQPage",
        "@id": `${canonical}#faq`,
        "mainEntity": articleFaqs.slice(0, 8).map((faq: { q: string; a: string }) => ({
          "@type": "Question",
          "name": faq.q,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": faq.a
          }
        }))
      }
    ]
  };
}
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  image={ogImage}
  type="article"
  pubDate={data.pubDate}
  updatedDate={data.updatedAt || data.pubDate}
>
  <ReadingProgress />

  <article style={{ background: "var(--bg)", minHeight: "100vh" }}>

    {/* ── Article Header ── */}
    <header style={{ padding: "4rem 0 2rem" }}>
      <div class="container" style={{ maxWidth: "900px", margin: "0 auto" }}>

        {/* Breadcrumb */}
        <nav style={{ marginBottom: "2rem", fontSize: "0.85rem" }} aria-label="Breadcrumb">
          <ol style={{ display: "flex", listStyle: "none", padding: 0, margin: 0, gap: "8px", color: "var(--muted)" }} itemscope itemtype="https://schema.org/BreadcrumbList">
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a href="/" style={{ color: "var(--brand)", textDecoration: "none" }} itemprop="item"><span itemprop="name">Home</span></a>
              <meta itemprop="position" content="1" />
            </li>
            <li>/</li>
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a href="/blog" style={{ color: "var(--brand)", textDecoration: "none" }} itemprop="item"><span itemprop="name">Blog</span></a>
              <meta itemprop="position" content="2" />
            </li>
            <li>/</li>
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" style={{ color: "var(--muted)", overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>
              <span itemprop="name">{title}</span>
              <meta itemprop="position" content="3" />
            </li>
          </ol>
        </nav>

        {/* Tags */}
        {data.tags && data.tags.length > 0 && (
          <div style={{ display: "flex", gap: "8px", marginBottom: "1.5rem", flexWrap: "wrap" }}>
            {data.tags.slice(0, 3).map((tag: string) => (
              <span style={{ fontSize: "0.8rem", color: "var(--brand)", fontWeight: 500 }}>#{tag}</span>
            ))}
          </div>
        )}

        {/* Title */}
        <h1 style={{
          fontSize: "clamp(2rem, 4vw, 2.8rem)",
          fontWeight: 800,
          color: "var(--text)",
          lineHeight: 1.2,
          letterSpacing: "-0.02em",
          marginBottom: "1.5rem"
        }}>
          {title}
        </h1>

        {/* Description */}
        <p style={{
          fontSize: "1.15rem",
          color: "var(--muted)",
          lineHeight: 1.6,
          marginBottom: "2rem"
        }}>
          {description}
        </p>

        {/* Meta */}
        <div style={{ display: "flex", alignItems: "center", gap: "1.5rem", flexWrap: "wrap", fontSize: "0.9rem", color: "var(--muted)", paddingTop: "1.5rem", borderTop: "1px solid var(--border)" }}>
          <span>By <strong style={{ color: "var(--text)" }}>{authorName}</strong></span>
          <span>·</span>
          <span>{formatDateWIB(data.updatedAt || data.pubDate, { month: 'long', day: 'numeric', year: 'numeric' })}</span>
          <span>·</span>
          <span>{readingTime} min read</span>
        </div>
      </div>
    </header>

    <div class="container" style={{ maxWidth: "900px", margin: "0 auto", paddingBottom: "4rem" }}>

      {/* Article Image */}
      {data.image && (
        <div style={{ marginBottom: "3rem", borderRadius: "12px", overflow: "hidden" }}>
          <img
            src={typeof data.image === 'string' ? data.image : data.image && typeof data.image === 'object' && 'src' in data.image ? data.image.src : ''}
            alt={title}
            style={{ width: "100%", height: "auto", objectFit: "cover" }}
          />
        </div>
      )}

      {/* Content */}
      <div class="prose neo-content" style={{ maxWidth: "100%" }}>
        <Content />
      </div>

      {/* Footer */}
      <footer style={{ marginTop: "4rem", paddingTop: "2rem", borderTop: "1px solid var(--border)" }}>
        <AuthorBox name={authorName} bio={authorBio} image="/images/author.jpg" />
      </footer>

    </div>
  </article>

  <style is:global>
    .neo-content { max-width: 900px; margin: 0 auto; }
    .neo-content h2 { font-size: 1.8rem; font-weight: 700; margin: 3rem 0 1rem; letter-spacing: -0.02em; color: var(--text); }
    .neo-content h3 { font-size: 1.4rem; font-weight: 600; margin: 2rem 0 0.75rem; color: var(--text); }
    .neo-content p { font-size: 1.05rem; line-height: 1.8; margin-bottom: 1.5rem; color: var(--text); font-weight: 400; }
    .neo-content ul, .neo-content ol { margin-bottom: 1.5rem; padding-left: 1.5rem; color: var(--text); }
    .neo-content li { margin-bottom: 0.5rem; font-weight: 400; line-height: 1.7; }
    .neo-content strong { font-weight: 700; color: var(--text); }
    .neo-content a { color: var(--brand); font-weight: 500; text-decoration: underline; text-underline-offset: 3px; }
    .neo-content a:hover { opacity: 0.8; }
    .neo-content img { border-radius: 8px; margin: 2rem 0; width: 100%; }
    .neo-content blockquote { border-left: 3px solid var(--brand); padding: 1rem 1.5rem; margin: 2rem 0; background: var(--card); border-radius: 0 8px 8px 0; }
    .neo-content blockquote p { margin-bottom: 0; color: var(--muted); }
    .neo-content code { background: var(--card); padding: 2px 6px; border-radius: 4px; font-size: 0.9em; color: var(--text); }
    .neo-content pre { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 1.5rem; overflow-x: auto; margin: 2rem 0; }
    .neo-content hr { border: none; border-top: 1px solid var(--border); margin: 3rem 0; }
    .neo-content table { width: 100%; border-collapse: collapse; margin: 2rem 0; font-size: 0.9rem; }
    .neo-content th { background: var(--card); padding: 0.75rem 1rem; text-align: left; font-weight: 600; color: var(--text); border: 1px solid var(--border); }
    .neo-content td { padding: 0.75rem 1rem; border: 1px solid var(--border); color: var(--text); }
    .neo-content tr:nth-child(even) { background: var(--card); }

    .toc-link:hover { color: var(--brand) !important; }

    @media (max-width: 768px) {
      .neo-content h2 { font-size: 1.5rem; }
      .neo-content h3 { font-size: 1.2rem; }
      .neo-content p { font-size: 1rem; }
    }
  </style>
</Layout>
