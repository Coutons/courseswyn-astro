---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import AuthorBox from "../../components/AuthorBox.astro";
import ReadingProgress from "../../components/blog/ReadingProgress.astro";
import FastFacts from "../../components/blog/FastFacts.astro";
import udemyImage from '../../assets/images/Udemy Personal Plan Offers.png';



export async function getStaticPaths() {
  const fs = await import('fs');
  const path = await import('path');
  const blogDir = path.join(process.cwd(), 'src/content/blog');

  // Recursively find all folders with index.md or index.mdx
  function getBlogFolders(dir: string, basePath = ''): string[] {
    const folders: string[] = [];
    const items = fs.readdirSync(dir, { withFileTypes: true });

    for (const item of items) {
      if (item.isDirectory()) {
        const folderPath = path.join(dir, item.name);
        const indexPath = path.join(folderPath, 'index.md');
        const indexPathMdx = path.join(folderPath, 'index.mdx');

        if (fs.existsSync(indexPath) || fs.existsSync(indexPathMdx)) {
          const folderSlug = basePath ? `${basePath}/${item.name}` : item.name;
          folders.push(folderSlug);
        } else {
          // Recursively check subdirectories
          folders.push(...getBlogFolders(folderPath, basePath ? `${basePath}/${item.name}` : item.name));
        }
      }
    }

    return folders;
  }

  const blogFolders = getBlogFolders(blogDir);

  return blogFolders.map((folder) => ({
    params: { slug: folder },
  }));
}

const { slug } = Astro.params;
const allPosts = await getCollection("blog");
const post = allPosts?.find(p => {
  // glob() loader generates IDs like "best-chatgpt-courses/index"
  const normalizedId = p.id.replace(/\/index$/, '');
  return normalizedId === slug || p.id === slug || (p.data as any).slug === slug;
});

if (!post) {
  return Astro.redirect('/404');
}

const { data } = post;

// Render the content
const { Content, headings } = await render(post);

// Calculate reading time
const wordsPerMinute = 200;
const words = post.body ? post.body.split(/\s+/).length : 0;
const readingTime = Math.ceil(words / wordsPerMinute);



const title = data.title;
const description = data.description;
const canonical = `https://courseswyn.com/blog/${post.id}/`;
const ogImage = data.image && typeof data.image === 'object' && 'src' in data.image ? data.image.src : data.image;

// Get related courses based on tags (subtle recommendations)
const relatedCourses = [
  {
    id: 1,
    title: "100 Days of Code™: The Complete Python Pro Bootcamp",
    slug: "/coupon/100-days-of-code",
    image: "https://img-c.udemycdn.com/course/480x270/2776760_f176_10.jpg",
    rating: 4.6,
    students: 1687496,
    price: 10.99,
    originalPrice: 199.99,
    instructor: "Angela Yu",
    category: "Programming"
  }
];

// Get author from post frontmatter or default to Andrew Derek
const authorName = data.author || "Andrew Derek";
const authorBio = (data as any).authorBio || "Expert in digital education and curriculum mapping with 8+ years of experience.";
const authorInitials = authorName.split(' ').map((n: string) => n[0]).join('').substring(0, 2).toUpperCase();

// Article structured data with subtle course mentions
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description,
  url: canonical,
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedAt || data.pubDate).toISOString(),
  author: {
    "@type": "Person",
    name: authorName,
    url: "https://courseswyn.com",
    jobTitle: "Lead Course Analyst",
    description: authorBio
  },
  publisher: {
    "@type": "Organization",
    name: "CoursesWyn",
    url: "https://courseswyn.com",
    logo: {
      "@type": "ImageObject",
      url: "https://courseswyn.com/logo.png",
    },
  },
  image: ogImage ? { "@type": "ImageObject", url: ogImage } : undefined,
  // Subtle course mentions for SEO
  mentions: relatedCourses.map(course => ({
    "@type": "Course",
    name: course.title,
    provider: {
      "@type": "Organization",
      name: "Udemy"
    }
  }))
};

// Use article schema as default
const structuredData = articleSchema;
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  image={ogImage}
  hideBreadcrumbs={true}
>
  <ReadingProgress />
  
  <article style={{ background: "var(--bg)", minHeight: "100vh" }}>

    {/* ── Editorial Header Section ── */}
    <header style={{ 
      padding: "80px 0 60px", 
      borderBottom: "2px solid var(--border)",
      background: "var(--card)",
      position: "relative",
      overflow: "hidden"
    }}>
      <div class="container" style={{ position: "relative", zIndex: 2 }}>
        
        {/* Breadcrumb */}
        <nav style={{ marginBottom: "40px" }} aria-label="Breadcrumb">
          <ol style={{ display: "flex", listStyle: "none", padding: 0, margin: 0, gap: "10px", fontSize: "0.85rem", fontWeight: 800, color: "var(--muted)", textTransform: "uppercase", letterSpacing: "0.05em" }} itemscope itemtype="https://schema.org/BreadcrumbList">
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a href="/" style={{ color: "inherit", textDecoration: "none" }} itemprop="item">
                <span itemprop="name">Home</span>
              </a>
              <meta itemprop="position" content="1" />
            </li>
            <li>/</li>
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a href="/blog" style={{ color: "inherit", textDecoration: "none" }} itemprop="item">
                <span itemprop="name">Blog</span>
              </a>
              <meta itemprop="position" content="2" />
            </li>
            <li>/</li>
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" style={{ color: "var(--text)", maxWidth: "300px", overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>
              <span itemprop="name" title={title}>{title.length > 40 ? title.substring(0, 40) + '...' : title}</span>
              <meta itemprop="position" content="3" />
            </li>
          </ol>
        </nav>

        <div style={{ maxWidth: "1000px" }}>
          <div style={{ display: "flex", gap: "12px", marginBottom: "24px" }}>
            <span style={{ 
              background: "var(--accent)", color: "white", 
              padding: "4px 12px", border: "2px solid var(--border)",
              boxShadow: "3px 3px 0 var(--border)", borderRadius: "4px",
              fontSize: "0.7rem", fontWeight: 900, textTransform: "uppercase", letterSpacing: "0.1em"
            }}>Editorial Review</span>
            {data.tags && data.tags.slice(0, 2).map((tag: string) => (
              <span style={{ 
                background: "var(--bg)", color: "var(--text)", 
                padding: "4px 12px", border: "2px solid var(--border)",
                borderRadius: "4px", fontSize: "0.7rem", fontWeight: 800, textTransform: "uppercase"
              }}>{tag}</span>
            ))}
          </div>

          <h1 style={{ 
            fontSize: "clamp(2.5rem, 8vw, 4.5rem)", 
            fontWeight: 900, 
            color: "var(--text)", 
            lineHeight: 1.05, 
            letterSpacing: "-0.04em",
            marginBottom: "32px"
          }}>
            {title}
          </h1>

          <p style={{ 
            fontSize: "clamp(1.1rem, 3vw, 1.5rem)", 
            color: "var(--muted)", 
            lineHeight: 1.5, 
            maxWidth: "850px",
            fontWeight: 500,
            marginBottom: "40px",
            borderLeft: "6px solid var(--accent)",
            paddingLeft: "24px"
          }}>
            {description}
          </p>

          {/* Meta info */}
          <div style={{ display: "flex", flexWrap: "wrap", alignItems: "center", gap: "32px" }}>
            <div style={{ display: "flex", alignItems: "center", gap: "12px" }}>
              <div style={{ 
                width: "48px", height: "48px", background: "var(--accent)", 
                border: "2px solid var(--border)", borderRadius: "6px",
                display: "flex", alignItems: "center", justifyContent: "center",
                color: "white", fontWeight: 900, fontSize: "1.1rem"
              }}>{authorInitials}</div>
              <div>
                <p style={{ margin: 0, fontWeight: 900, fontSize: "1rem", color: "var(--text)" }}>{authorName}</p>
                <p style={{ margin: 0, fontSize: "0.75rem", fontWeight: 700, color: "var(--muted)", textTransform: "uppercase" }}>Lead Analyst</p>
              </div>
            </div>
            
            <div style={{ height: "40px", width: "2px", background: "var(--border)", opacity: 0.2 }}></div>

            <div style={{ display: "flex", flexDirection: "column", gap: "6px", background: "var(--bg)", padding: "10px 16px", border: "2px solid var(--border)", boxShadow: "3px 3px 0 var(--border)", borderRadius: "4px" }}>
              <span style={{ fontSize: "0.65rem", fontWeight: 900, color: "var(--accent)", textTransform: "uppercase", letterSpacing: "0.1em" }}>
                {data.updatedAt ? "Last Major Update" : "Original Publication"}
              </span>
              <span style={{ fontSize: "1rem", fontWeight: 900, color: "var(--text)" }}>
                {new Date(data.updatedAt || data.pubDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </span>
            </div>

            <div style={{ display: "flex", flexDirection: "column", gap: "6px", background: "white", padding: "10px 16px", border: "2px solid var(--border)", boxShadow: "3px 3px 0 var(--border)", borderRadius: "4px" }}>
              <span style={{ fontSize: "0.65rem", fontWeight: 900, color: "var(--muted)", textTransform: "uppercase", letterSpacing: "0.1em" }}>Reading Time</span>
              <span style={{ fontSize: "1rem", fontWeight: 900, color: "var(--text)" }}>{readingTime} min read</span>
            </div>
          </div>
        </div>
      </div>

      {/* Decorative large background text */}
      <div style={{ 
        position: "absolute", bottom: "-40px", right: "-20px", 
        fontSize: "12rem", fontWeight: 900, color: "var(--border)", 
        opacity: 0.03, pointerEvents: "none", whiteSpace: "nowrap",
        zIndex: 1
      }}>EDITORIAL</div>
    </header>

    <div class="container" style={{ padding: "60px 24px" }}>
      <div style={{ display: "grid", gridTemplateColumns: "1fr 300px", gap: "60px", alignItems: "start" }}>
        
        {/* Main Content Area */}
        <main style={{ minWidth: 0 }}>
          
          {/* Article Image */}
          {data.image && (
            <div style={{ 
              width: "100%", height: "auto", maxHeight: "500px", 
              border: "2px solid var(--border)", boxShadow: "8px 8px 0 var(--border)",
              borderRadius: "8px", overflow: "hidden", marginBottom: "60px"
            }}>
              <img
                src={typeof data.image === 'string' ? data.image : data.image && typeof data.image === 'object' && 'src' in data.image ? data.image.src : ''}
                alt={title}
                style={{ width: "100%", height: "100%", objectFit: "cover" }}
              />
            </div>
          )}

          <div class="prose neo-content" style={{ maxWidth: "100%" }}>
            <Content />
          </div>

          <footer style={{ marginTop: "80px", paddingTop: "40px", borderTop: "2px solid var(--border)" }}>
            <AuthorBox name={authorName} bio={authorBio} />
          </footer>
        </main>

        {/* Sidebar */}
        <aside style={{ position: "sticky", top: "100px" }}>
          
          {/* Table of Contents */}
          {headings && headings.length > 0 && (
            <div style={{ 
              background: "var(--card)", border: "2px solid var(--border)", 
              boxShadow: "4px 4px 0 var(--border)", borderRadius: "8px",
              padding: "24px", marginBottom: "32px"
            }}>
              <h4 style={{ 
                fontSize: "0.75rem", fontWeight: 900, textTransform: "uppercase", 
                letterSpacing: "0.1em", color: "var(--accent)", marginBottom: "20px",
                display: "flex", alignItems: "center", gap: "8px"
              }}>
                <span style={{ width: "8px", height: "8px", background: "var(--accent)", borderRadius: "50%" }}></span>
                Contents
              </h4>
              <nav>
                <ul style={{ listStyle: "none", padding: 0, margin: 0, display: "flex", flexDirection: "column", gap: "12px" }}>
                  {headings.filter(h => h.depth === 2).map((heading) => (
                    <li>
                      <a href={`#${heading.slug}`} style={{ 
                        fontSize: "0.88rem", fontWeight: 700, color: "var(--text)", 
                        textDecoration: "none", transition: "color 0.15s"
                      }} class="toc-link">
                        {heading.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          )}

          {/* Social Share */}
          <div style={{ 
            background: "var(--text)", color: "white", borderRadius: "8px",
            border: "2px solid var(--border)", boxShadow: "4px 4px 0 var(--border)",
            padding: "24px"
          }}>
            <h4 style={{ fontSize: "0.7rem", fontWeight: 900, textTransform: "uppercase", letterSpacing: "0.1em", marginBottom: "16px", color: "var(--accent)" }}>Spread Knowledge</h4>
            <div style={{ display: "flex", gap: "10px" }}>
              <a href={`https://twitter.com/intent/tweet?url=${canonical}&text=${title}`} target="_blank" rel="noopener noreferrer" style={{ width: "38px", height: "38px", border: "1.5px solid rgba(255,255,255,0.2)", borderRadius: "4px", display: "flex", alignItems: "center", justifyContent: "center", color: "white", textDecoration: "none" }} class="share-btn">X</a>
              <a href={`https://www.facebook.com/sharer/sharer.php?u=${canonical}`} target="_blank" rel="noopener noreferrer" style={{ width: "38px", height: "38px", border: "1.5px solid rgba(255,255,255,0.2)", borderRadius: "4px", display: "flex", alignItems: "center", justifyContent: "center", color: "white", textDecoration: "none" }} class="share-btn">FB</a>
              <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${canonical}`} target="_blank" rel="noopener noreferrer" style={{ width: "38px", height: "38px", border: "1.5px solid rgba(255,255,255,0.2)", borderRadius: "4px", display: "flex", alignItems: "center", justifyContent: "center", color: "white", textDecoration: "none" }} class="share-btn">LN</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>

  <style is:global>
    .neo-content h2 { font-size: 2.2rem; font-weight: 900; margin: 60px 0 24px; letter-spacing: -0.03em; border-bottom: 3px solid var(--border); padding-bottom: 12px; }
    .neo-content h3 { font-size: 1.6rem; font-weight: 900; margin: 40px 0 16px; letter-spacing: -0.02em; }
    .neo-content p { font-size: 1.1rem; line-height: 1.7; margin-bottom: 24px; color: var(--text); font-weight: 500; }
    .neo-content ul, .neo-content ol { margin-bottom: 24px; padding-left: 24px; }
    .neo-content li { margin-bottom: 12px; font-weight: 500; line-height: 1.6; }
    .neo-content strong { font-weight: 900; color: var(--text); }
    .neo-content a { color: var(--accent); font-weight: 800; text-decoration: underline; text-decoration-thickness: 2px; text-underline-offset: 4px; }
    .neo-content img { border: 2px solid var(--border); box-shadow: 6px 6px 0 var(--border); border-radius: 6px; margin: 32px 0; }
    
    .toc-link:hover { color: var(--accent) !important; text-decoration: underline; }
    .share-btn:hover { background: var(--accent); border-color: var(--accent) !important; color: white; }

    @media (max-width: 1000px) {
      article .container > div { grid-template-columns: 1fr !important; }
      aside { position: static !important; }
    }
  </style>
</Layout>



