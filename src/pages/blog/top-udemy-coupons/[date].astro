---
import Layout from '../../../layouts/Layout.astro';
import { getDeals, getAvailableDates } from '../../../lib/store.js';

export async function getStaticPaths() {
  const dates = await getAvailableDates();
  return dates.map(date => ({ params: { date } }));
}

const siteUrl = "https://courseswyn.com";
const { date } = Astro.params;
const allDeals = await getDeals({ date, limit: 100, sortBy: 'rating' });

const grouped: Record<string, typeof allDeals> = {};
for (const deal of allDeals) {
  const cat = (deal.category as string) || 'Other';
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(deal);
}
const categories = Object.entries(grouped).sort((a, b) => b[1].length - a[1].length);

// @ts-ignore
const dateObj = new Date(`${date}T00:00:00.000Z`);
const dateLabel = dateObj.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
// @ts-ignore
const isToday = date === new Date().toISOString().substring(0, 10);

// @ts-ignore
const prev = new Date(dateObj.getTime() - 86400000);
// @ts-ignore
const next = new Date(dateObj.getTime() + 86400000);
const prevDate = prev.toISOString().substring(0, 10);
const nextDate = next.toISOString().substring(0, 10);

const totalCoupons = allDeals.length;
const catCount = categories.length;
const topCats = categories.slice(0, 3).map(([c]) => c).join(', ');
const pageUrl = `${siteUrl}/blog/top-udemy-coupons/${date}/`;

// @ts-ignore - Astro frontmatter variables
const pageTitle = `Udemy Coupons ${dateLabel} - Daily Discount Deals | CoursesWyn`;
// @ts-ignore - Astro frontmatter variables  
const metaDescription = `${allDeals.length} verified Udemy coupons on ${dateLabel} — free courses in Development, Design, Business & more. Daily discount codes.`;

function slugifyCat(cat: string) {
  return cat.toLowerCase().replace(/\s+&\s+/g, '-and-').replace(/\s+/g, '-');
}

const catColors: Record<string, string> = {
  'Development': '#2563eb', 'Design': '#7c3aed', 'Business': '#0891b2', 'Marketing': '#d97706',
  'IT & Software': '#059669', 'Finance': '#16a34a', 'Personal Development': '#dc2626',
  'Photography': '#9333ea', 'Music': '#db2777', 'Health & Fitness': '#ea580c',
  'Office Productivity': '#0284c7', 'Teaching': '#65a30d',
};
const getCatColor = (cat: string) => catColors[cat] || '#374151';

const faqs = [
  {
    q: `Are the Udemy coupons for ${dateLabel} really free?`,
    a: `Yes. Every coupon on this page gives you 100% off the course price for ${dateLabel}'s listings. We verify each code before publishing. No credit card or subscription is required — click through to Udemy and enroll for free.`,
  },
  {
    q: "How long do these Udemy coupon codes last?",
    a: "Udemy coupons typically stay valid for a few days up to a few weeks, and many have enrollment limits (e.g. 1,000 students). We recommend enrolling as soon as you find a course you want. If a code has expired, check our blog for the latest date or visit the main Deals page.",
  },
  {
    q: "How do I redeem a Udemy coupon from this page?",
    a: "Click the course card to open its deal page on CoursesWyn, then click the coupon or \"Get deal\" button. You'll be taken to Udemy with the discount applied. Complete enrollment there — no payment required for 100% off coupons.",
  },
  {
    q: `What categories are in the ${dateLabel} coupon list?`,
    a: `This page lists coupons across ${catCount} categories, including ${topCats}. Courses are grouped by category so you can quickly find deals in Development, Design, Business, Marketing, and more.`,
  },
  {
    q: "Do I get a certificate with free Udemy courses?",
    a: "Yes. Courses enrolled via our coupons include the same benefits as paid courses: lifetime access, downloadable resources, and an official Udemy completion certificate when you finish the course.",
  },
];

// SEO: BlogPosting + BreadcrumbList + ItemList + FAQPage
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      "@id": `${pageUrl}#article`,
      "headline": `Top Udemy Coupons (${dateLabel})`,
      "description": metaDescription,
      "url": pageUrl,
      "datePublished": `${date}T00:00:00Z`,
      "dateModified": `${date}T00:00:00Z`,
      "author": { "@type": "Organization", "name": "CoursesWyn", "url": siteUrl },
      "publisher": { "@type": "Organization", "name": "CoursesWyn", "url": siteUrl, "logo": { "@type": "ImageObject", "url": `${siteUrl}/logo.svg` } },
      "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${siteUrl}/blog` },
        { "@type": "ListItem", "position": 3, "name": `Top Udemy Coupons ${dateLabel}`, "item": pageUrl },
      ],
    },
    {
      "@type": "ItemList",
      "name": `Udemy Coupons ${dateLabel}`,
      "description": `Verified free Udemy courses and discount codes for ${dateLabel}.`,
      "numberOfItems": totalCoupons,
      "itemListElement": allDeals.slice(0, 20).map((d, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": `${siteUrl}/coupon/${d.slug || d.id}`,
        "name": d.title,
      })),
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    },
  ],
};
---

<Layout
  title={pageTitle}
  description={metaDescription}
  canonical={pageUrl}
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="post-root" itemscope itemtype="https://schema.org/BlogPosting">
    <div class="post-container">
      <header class="post-header">
        <h1 class="post-title" itemprop="headline">Top Udemy Coupons ({dateLabel})</h1>
        <p class="post-meta">
          <time itemprop="datePublished" datetime={`${date}T00:00:00Z`}>{dateLabel}</time>
          · {totalCoupons} coupons · {catCount} categories
          {isToday && <span class="meta-today"> · Updated today</span>}
        </p>
        <p class="post-desc" itemprop="description">
          Verified Udemy coupon codes for {dateLabel}. Free courses in <strong>{topCats}</strong> and more. All tested for maximum savings at checkout.
        </p>
      </header>

      <div class="filter-row">
        <span class="tab tab-active" aria-current="true">Select All</span>
        {/* @ts-ignore */}
        <a href={`/blog/top-udemy-coupons/${new Date().toISOString().substring(0, 10)}/`} class="tab">Last 24 Hrs</a>
      </div>

      <!-- Categories: grid of course cards per category -->
      <div class="categories-block">
        {categories.map(([cat, deals]) => (
          <section class="cat-block" aria-labelledby={`cat-${slugifyCat(cat)}`}>
            <div class="cat-head">
              <h2 class="cat-title" id={`cat-${slugifyCat(cat)}`}>
                <span class="cat-badge" style={`background:${getCatColor(cat)}`}>{cat}</span>
              </h2>
              <a href={`/categories/${slugifyCat(cat)}/`} class="cat-link">See all {cat} →</a>
            </div>
            <div class="course-list">
              {deals.slice(0, 6).map(deal => (
                <div class="course-card">
                  <div class="card-image">
                    <img src={deal.image} alt={deal.title} loading="lazy" onerror="this.style.display='none'" />
                  </div>
                  <div class="card-content">
                    <a href={`/coupon/${deal.id}`} class="card-title-link">
                      <h3 class="card-title">{deal.title}</h3>
                    </a>
                    {deal.instructor && <div class="card-instructor">by {deal.instructor}</div>}
                    {deal.description && <p class="card-description">{deal.description.length > 120 ? `${deal.description.substring(0, 120)}...` : deal.description}</p>}
                    <div class="card-meta">
                      {deal.provider && <span class="meta-item provider">{deal.provider}</span>}
                      {deal.rating != null && <span class="meta-item rating">⭐ {deal.rating} out of 5</span>}
                      {deal.category && deal.subcategory && <a href={`/categories/${slugifyCat(deal.category)}/`} class="meta-item category-link">{deal.category} > {deal.subcategory}</a>}
                      {deal.category && !deal.subcategory && <a href={`/categories/${slugifyCat(deal.category)}/`} class="meta-item category-link">{deal.category}</a>}
                      {deal.duration && <span class="meta-item duration">{deal.duration}</span>}
                      {deal.students != null && <span class="meta-item students">{deal.students.toLocaleString()} students</span>}
                      {deal.language && <span class="meta-item language">{deal.language}</span>}
                    </div>
                    <div class="card-pricing">
                      <div class="price-info">
                        {deal.price != null && deal.price > 0 && (
                          <>
                            <span class="current-price">${deal.price.toFixed(2)}</span>
                            {deal.originalPrice && <span class="original-price">${deal.originalPrice.toFixed(2)}</span>}
                            {deal.originalPrice && <span class="discount-price">{Math.round((1 - deal.price / deal.originalPrice) * 100)}% OFF</span>}
                          </>
                        )}
                        {deal.price === 0 && <span class="current-price">Free</span>}
                      </div>
                      <div class="card-actions">
                        <span class="verified-badge">✓ Verified</span>
                        <a href={deal.url} target="_blank" rel="noopener noreferrer" class="card-button">Get Deal</a>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            {deals.length > 6 && (
              <>
                <div class="course-list hidden-rows" id={`hide-${slugifyCat(cat)}`} style="display:none">
                  {deals.slice(6).map(deal => (
                    <div class="course-card">
                      <div class="card-image">
                        <img src={deal.image} alt={deal.title} loading="lazy" onerror="this.style.display='none'" />
                      </div>
                      <div class="card-content">
                        <h3 class="card-title">{deal.title}</h3>
                        {deal.instructor && <div class="card-instructor">by {deal.instructor}</div>}
                        {deal.description && <p class="card-description">{deal.description.length > 120 ? `${deal.description.substring(0, 120)}...` : deal.description}</p>}
                        <div class="card-meta">
                          {deal.provider && <span class="meta-item provider">{deal.provider}</span>}
                          {deal.rating != null && <span class="meta-item rating">⭐ {deal.rating} out of 5</span>}
                          {deal.category && deal.subcategory && <span class="meta-item category">{deal.category} > {deal.subcategory}</span>}
                          {deal.category && !deal.subcategory && <span class="meta-item category">{deal.category}</span>}
                          {deal.duration && <span class="meta-item duration">{deal.duration}</span>}
                          {deal.students != null && <span class="meta-item students">{deal.students.toLocaleString()} students</span>}
                          {deal.language && <span class="meta-item language">{deal.language}</span>}
                        </div>
                        <div class="card-pricing">
                          <div class="price-info">
                            {deal.price != null && deal.price > 0 && (
                              <>
                                <span class="current-price">${deal.price.toFixed(2)}</span>
                                {deal.originalPrice && <span class="original-price">${deal.originalPrice.toFixed(2)}</span>}
                                {deal.originalPrice && <span class="discount-price">{Math.round((1 - deal.price / deal.originalPrice) * 100)}% OFF</span>}
                              </>
                            )}
                            {deal.price === 0 && <span class="current-price">Free</span>}
                          </div>
                          <div class="card-actions">
                            <span class="verified-badge">✓ Verified</span>
                            <a href={`/coupon/${deal.id}`} class="card-button">Get Deal</a>
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
                <button type="button" class="btn-more" data-target={`hide-${slugifyCat(cat)}`}>Load more ({deals.length - 6} {cat})</button>
              </>
            )}
          </section>
        ))}
      </div>

      <!-- Explore all: list of course items -->
      <section class="explore-block" aria-labelledby="explore-heading">
        <h2 id="explore-heading" class="explore-head">Explore all {totalCoupons} coupons</h2>
        <div class="course-list">
          {allDeals.map(deal => (
            <div class="course-card">
              <div class="card-image">
                <img src={deal.image} alt={deal.title} loading="lazy" onerror="this.style.display='none'" />
              </div>
              <div class="card-content">
                <h3 class="card-title">{deal.title}</h3>
                {deal.instructor && <div class="card-instructor">by {deal.instructor}</div>}
                {deal.description && <p class="card-description">{deal.description.length > 120 ? `${deal.description.substring(0, 120)}...` : deal.description}</p>}
                <div class="card-meta">
                  {deal.provider && <span class="meta-item provider">{deal.provider}</span>}
                  {deal.rating != null && <span class="meta-item rating">⭐ {deal.rating}</span>}
                  {deal.category && deal.subcategory && <span class="meta-item category">{deal.category} > {deal.subcategory}</span>}
                  {deal.category && !deal.subcategory && <span class="meta-item category">{deal.category}</span>}
                  {deal.duration && <span class="meta-item duration">{deal.duration}</span>}
                  {deal.students != null && <span class="meta-item students">{deal.students.toLocaleString()} students</span>}
                  {deal.language && <span class="meta-item language">{deal.language}</span>}
                </div>
                <div class="card-pricing">
                  <div class="price-info">
                    {deal.price != null && deal.price > 0 && (
                      <>
                        <span class="current-price">${deal.price.toFixed(2)}</span>
                        {deal.originalPrice && <span class="original-price">${deal.originalPrice.toFixed(2)}</span>}
                        {deal.originalPrice && <span class="discount-price">{Math.round((1 - deal.price / deal.originalPrice) * 100)}% OFF</span>}
                      </>
                    )}
                    {deal.price === 0 && <span class="current-price">Free</span>}
                  </div>
                  <div class="card-actions">
                    <span class="verified-badge">✓ Verified</span>
                    <a href={`/coupon/${deal.id}`} class="card-button">Get Deal</a>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Editorial: SEO content adapted from real.discounts style -->
      <div class="editorial">
        <h2>Discover Udemy Coupons Today</h2>
        <p>
          Looking for the best Udemy discount coupons available today? You've come to the right place. Our curated collection of verified Udemy coupons spans multiple categories including Business, Design, Development and more, giving you access to premium educational content at unbeatable prices. Whether you're looking to learn a new skill, advance your career, or explore a new hobby, these coupon deals provide an excellent opportunity to enroll in high-quality courses without breaking the bank.
        </p>

        <h3>Why Choose Udemy Coupons?</h3>
        <p>
          Udemy coupons have become increasingly popular among learners worldwide seeking affordable education. They offer incredible value, allowing you to access premium courses from expert instructors at up to 100% off the regular price. Many of these coupons come from reputable sources and feature experienced educators who share their expertise. Best of all, coupon deals let you explore premium subjects without financial commitment, making them perfect for beginners and lifelong learners alike.
        </p>

        <h3>How to Redeem Udemy Coupons</h3>
        <p>
          Getting started is simple. Browse through our comprehensive list of verified Udemy coupons available on {dateLabel}. Each coupon listing includes important details like discount percentage, course rating, and enrollment limits. Simply click on any course that interests you to access the coupon details. Most coupons can be applied directly at checkout, giving you instant savings on your selected courses. For detailed instructions, check our <a href="/how-to-redeem-coupon">complete coupon redemption guide</a>.
        </p>

        <h3>Popular Course Categories</h3>
        <p>
          Our Udemy coupon collection covers diverse topics to suit various learning interests. Browse our <a href="/categories">complete categories</a> to find courses in business, technology, and more. Explore <a href="/topics">specific topics</a> within each subject area, or check out our <a href="/popular">most popular</a> courses. Each category features carefully selected deals that provide exceptional value and practical knowledge, helping you build skills that matter in today's competitive job market.
        </p>

        <h3>Coupon Deals vs Regular Pricing</h3>
        <p>
          While regular Udemy courses offer great value, coupon deals provide extraordinary savings for those looking to learn without the full investment. Many coupon courses provide the same high-quality content as full-price courses, making them an ideal choice for budget-conscious learners. The courses featured here are verified deals, so you can access premium education without any financial barrier.
        </p>

        <h3>Maximize Your Learning Experience</h3>
        <p>
          To get the most out of these Udemy coupon deals, we recommend setting aside dedicated time for learning, taking notes, and practicing what you learn. Many courses include practical exercises and projects that help reinforce your understanding. Don't forget to check back regularly, as we update our collection daily with new verified coupons across various subjects.
        </p>

        <p>
          Ready to start learning? Explore our collection of Udemy coupon deals available today and begin your educational journey. With hundreds of courses to choose from, you're sure to find something that matches your interests and learning goals. Remember, the best part about coupon deals is that you can try premium courses without full commitment, allowing you to discover new passions and expand your knowledge base. For more deals, check out our <a href="/udemy-coupon-code">main deals page</a>.
        </p>
      </div>

      <section class="post-faq" aria-labelledby="post-faq-heading">
        <h2 id="post-faq-heading" class="faq-title">Frequently asked questions</h2>
        <div class="faq-cards">
          {faqs.map((faq) => (
            <details class="faq-card">
              <summary class="faq-q">{faq.q}</summary>
              <p class="faq-a">{faq.a}</p>
            </details>
          ))}
        </div>
      </section>

      <nav class="date-nav" aria-label="Article navigation">
        <a href={`/blog/top-udemy-coupons/${prevDate}/`} class="nav-btn">← {prev.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</a>
        <a href="/blog/" class="nav-btn nav-mid">All Articles</a>
        {!isToday && <a href={`/blog/top-udemy-coupons/${nextDate}/`} class="nav-btn">{next.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })} →</a>}
      </nav>
    </div>
  </article>
</Layout>

<script>
  document.querySelectorAll('.btn-more').forEach(btn => {
    btn.addEventListener('click', () => {
      const btnEl = btn as HTMLButtonElement;
      const id = btnEl.dataset.target;
      const el = id ? document.getElementById(id) as HTMLElement : null;
      if (el) {
        el.style.display = 'flex';
        btnEl.style.display = 'none';
      }
    });
  });
</script>

<style>
  .post-root { background: var(--bg); padding: 2rem 1rem 4rem; }
  .post-container { max-width: 1100px; margin: 0 auto; }
  .breadcrumb { font-size: 0.875rem; color: var(--muted); margin-bottom: 0.75rem; }
  .breadcrumb a { color: var(--brand); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb .sep { margin: 0 0.35rem; color: var(--muted); }
  .post-header { margin-bottom: 1.5rem; }
  .post-title { font-size: 1.75rem; font-weight: 800; color: var(--text); margin: 0 0 0.5rem; line-height: 1.25; }
  .post-meta { font-size: 0.875rem; color: var(--muted); margin: 0 0 0.5rem; }
  .meta-today { color: var(--destructive); font-weight: 600; }
  .post-desc { font-size: 0.9375rem; color: var(--muted); line-height: 1.5; margin: 0 0 1.5rem; }
  .post-desc strong { color: var(--text); }
  .filter-row { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; }
  .tab {
    padding: 0.5rem 1rem; border-radius: 999px; font-size: 0.8125rem; font-weight: 600;
    border: 1px solid var(--border); background: var(--card); color: var(--text); text-decoration: none;
  }
  .tab:hover, .tab-active { background: var(--brand); color: var(--bg); border-color: var(--brand); }
  .categories-block { margin-bottom: 2.5rem; }
  .cat-block { margin-bottom: 2rem; }
  .cat-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; }
  .cat-title { margin: 0; font-size: 1rem; font-weight: 700; }
  .cat-badge {
    color: #fff; font-size: 0.75rem; font-weight: 700; padding: 0.25rem 0.75rem; border-radius: 999px;
  }
  .cat-link { font-size: 0.8125rem; color: var(--brand); text-decoration: none; font-weight: 600; }
  .cat-link:hover { text-decoration: underline; }
  .course-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .course-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    transition: all 0.2s ease;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    text-decoration: none;
    color: inherit;
  }
  .course-card:hover {
    border-color: var(--brand);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    transform: translateY(-2px);
  }
  .card-image {
    flex-shrink: 0;
    width: 240px;
    height: 135px;
    overflow: hidden;
    background: var(--border);
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 80%;
    transition: transform 0.2s ease;
  }
  .course-card:hover .card-image img {
    transform: scale(1.05);
  }
  .card-content {
    flex: 1;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .card-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.5rem;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .course-card:hover .card-title {
    color: var(--brand);
  }
  .card-instructor {
    font-size: 0.875rem;
    color: var(--brand);
    font-weight: 500;
    margin-bottom: 0.75rem;
  }
  .card-description {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.5;
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .meta-item {
    font-size: 0.75rem;
    color: var(--muted);
    background: var(--bg);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
  .card-pricing {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .price-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .current-price {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--brand);
  }
  .original-price {
    font-size: 0.875rem;
    color: var(--muted);
    text-decoration: line-through;
  }
  .discount-price {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }
  .card-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .verified-badge {
    font-size: 0.75rem;
    font-weight: 600;
