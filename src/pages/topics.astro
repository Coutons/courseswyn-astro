---
import Layout from '../layouts/Layout.astro';
import { readDeals } from '../lib/store';

const allDeals = await readDeals();

const decodeHtml = (str: string) =>
  str.replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/&#39;/g, "'");

allDeals.forEach(deal => {
  if (deal.subcategory) deal.subcategory = decodeHtml(deal.subcategory);
});

// Build topic data with real counts
const topicCounts: Record<string, number> = {};
allDeals.forEach(deal => {
  if (deal.subcategory) {
    topicCounts[deal.subcategory] = (topicCounts[deal.subcategory] || 0) + 1;
  }
});

const topicsData = (Object.entries(topicCounts) as [string, number][])
  .sort((a, b) => b[1] - a[1])
  .map(([topic, count]) => {
    const slug = topic.toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-');
    return { name: topic, slug, count };
  });

const totalTopics = topicsData.length;
const totalCourses = allDeals.length;
const maxCoursesInTopic = Math.max(...topicsData.map(t => t.count));

// SEO settings - optimized
const currentDate = new Date();
const currentYear = currentDate.getFullYear();

const title = `${totalTopics}+ Udemy Course Topics with Free 100% Off Coupons [${currentYear}] | CoursesWyn`;
const description = `Browse ${totalTopics}+ specialized Udemy course topics with verified free coupons. Find 100% off deals on Python, AI, data science, web development, cloud certification & more. ${totalCourses}+ courses with daily verified discount codes. No payment required for free coupons.`;
const canonicalUrl = "https://courseswyn.com/topics";

// Enhanced topic descriptions
function getTopicDescription(topic: string): string {
  const t = topic.toLowerCase();
  if (t.includes('python')) return "Courses covering Python programming for data science, automation, web development with Flask/Django, and machine learning. Suitable for beginners and experienced developers.";
  if (t.includes('javascript') || t.includes('js')) return "Courses covering modern JavaScript including ES6+, async programming, Node.js, and popular frameworks like React, Vue, and Angular.";
  if (t.includes('web develop')) return "Full-stack and front-end web development courses covering HTML, CSS, JavaScript, frameworks, REST APIs, and deployment.";
  if (t.includes('react')) return "Courses on React.js including hooks, context API, Redux, Next.js, and building production-ready single-page applications.";
  if (t.includes('data science')) return "Data science courses covering statistics, pandas, NumPy, data visualization, Jupyter, and end-to-end ML project workflows.";
  if (t.includes('machine learning') || t.includes('ml')) return "Machine learning courses from regression and classification to neural networks, model evaluation, and deploying ML models to production.";
  if (t.includes('ai') || t.includes('artificial intelligence')) return "Artificial intelligence courses covering generative AI, large language models, AI ethics, and applied AI for real-world business problems.";
  if (t.includes('deep learning')) return "Deep learning courses on neural network architectures, CNNs, RNNs, transformers, and frameworks like TensorFlow and PyTorch.";
  if (t.includes('sql') || t.includes('database')) return "Database and SQL courses covering relational databases, query optimization, PostgreSQL, MySQL, and NoSQL with MongoDB.";
  if (t.includes('cyber') || t.includes('security')) return "Cybersecurity courses on ethical hacking, penetration testing, network security, OWASP, and preparation for certifications like CompTIA Security+.";
  if (t.includes('cloud') || t.includes('aws') || t.includes('azure')) return "Cloud computing courses on AWS, Azure, and Google Cloud covering architecture, deployment, serverless, and cloud certification prep.";
  if (t.includes('devops') || t.includes('docker') || t.includes('kubernetes')) return "DevOps courses covering CI/CD pipelines, Docker containerization, Kubernetes orchestration, infrastructure as code, and monitoring.";
  if (t.includes('mobile') || t.includes('android') || t.includes('ios') || t.includes('flutter')) return "Mobile app development courses for iOS, Android, React Native, and Flutter - from beginner setup to App Store deployment.";
  if (t.includes('design') || t.includes('ui') || t.includes('ux')) return "UI/UX and graphic design courses covering Figma, Adobe XD, user research, prototyping, and design systems.";
  if (t.includes('excel') || t.includes('spreadsheet')) return "Microsoft Excel and spreadsheet courses covering formulas, pivot tables, data analysis, VBA macros, and Power BI integration.";
  if (t.includes('project management') || t.includes('pmp') || t.includes('agile') || t.includes('scrum')) return "Project management courses covering Agile, Scrum, Kanban, PMP certification prep, and tools like Jira and Asana.";
  if (t.includes('marketing') || t.includes('seo') || t.includes('social media')) return "Digital marketing courses on SEO, Google Ads, social media strategy, content marketing, email marketing, and analytics.";
  if (t.includes('photoshop') || t.includes('illustrator') || t.includes('adobe')) return "Adobe Creative Suite courses covering Photoshop, Illustrator, Premiere Pro, and After Effects for design and video professionals.";
  if (t.includes('java')) return "Java programming courses covering core Java, Spring Boot, JPA, REST APIs, and enterprise application development.";
  if (t.includes('c#') || t.includes('dotnet') || t.includes('.net')) return "C# and .NET courses covering ASP.NET Core, Blazor, Entity Framework, and building scalable Windows and web applications.";
  if (t.includes('php') || t.includes('laravel')) return "PHP and Laravel courses covering server-side development, MVC architecture, REST APIs, and building production web apps.";
  if (t.includes('blockchain') || t.includes('web3') || t.includes('solidity')) return "Blockchain and Web3 courses covering smart contract development with Solidity, Ethereum, DeFi, and NFT project deployment.";
  if (t.includes('photogra')) return "Photography courses covering camera fundamentals, lighting, composition, photo editing, and building a professional portfolio.";
  if (t.includes('video') || t.includes('film') || t.includes('editing')) return "Video production and editing courses covering DaVinci Resolve, Premiere Pro, storytelling, color grading, and YouTube production.";
  if (t.includes('music') || t.includes('audio')) return "Music production and audio engineering courses covering DAWs like Ableton and FL Studio, mixing, mastering, and music theory.";
  if (t.includes('finance') || t.includes('accounting') || t.includes('investing')) return "Finance and accounting courses covering financial modeling, investing, budgeting, QuickBooks, CFA prep, and cryptocurrency markets.";
  if (t.includes('english') || t.includes('language') || t.includes('writing')) return "Language and writing courses covering business English, copywriting, technical writing, and communication skills for professionals.";
  if (t.includes('personal develop') || t.includes('productivity') || t.includes('leadership')) return "Personal development courses on productivity, leadership, time management, public speaking, and building high-performance habits.";
  return `Udemy courses on ${topic} covering foundational to advanced skills with practical projects and expert instruction.`;
}

// Structured data
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": canonicalUrl,
      "url": canonicalUrl,
      "name": title,
      "description": description,
      "inLanguage": "en-US",
      "dateModified": new Date().toISOString().split('T')[0],
      "isPartOf": { "@id": "https://courseswyn.com" },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" },
          { "@type": "ListItem", "position": 2, "name": "Course Topics", "item": canonicalUrl }
        ]
      },
      "mainEntity": {
        "@type": "ItemList",
        "name": "Udemy Course Topics",
        "numberOfItems": totalTopics,
        "itemListElement": topicsData.slice(0, 30).map((t, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "item": {
            "@type": "Thing",
            "name": `${t.name} Courses on Udemy`,
            "description": getTopicDescription(t.name),
            "url": `https://courseswyn.com/topics/${t.slug}`
          }
        }))
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What are Udemy course topics on CoursesWyn?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "CoursesWyn organizes Udemy courses into specialized topic pages - such as Python, Web Development, Data Science, and Cybersecurity. Each topic page lists verified coupon deals for courses in that subject area, updated daily."
          }
        },
        {
          "@type": "Question",
          "name": "How do I find free or discounted Udemy courses by topic?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Click any topic on this page to browse verified Udemy coupon deals for that subject. Each listing shows the discount percentage, original price, and a direct enrollment link. Click \"Redeem Coupon\" to apply the discount automatically."
          }
        },
        {
          "@type": "Question",
          "name": "Are the Udemy coupons on CoursesWyn actually free?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Many coupons listed on CoursesWyn offer 100% off, making the course completely free. Others provide significant discounts (80-95% off). Each listing shows the current price after coupon so you know exactly what to expect before clicking."
          }
        },
        {
          "@type": "Question",
          "name": "How often are new Udemy topic deals added?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "New deals are added every day. Udemy coupons expire quickly, so we recommend checking back frequently or bookmarking the topic page most relevant to your learning goals."
          }
        }
      ]
    }
  ]
};

// Topic card accent colors
const accentColors = [
  "#4a90e2", "#e91e63", "#00bcd4", "#4caf50",
  "#ff9800", "#9c27b0", "#607d8b", "#3f51b5",
  "#f44336", "#009688", "#795548", "#ff5722"
];
---

<Layout title={title} description={description}>
  <link rel="canonical" href={canonicalUrl} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <main style="background: var(--bg); color: var(--text);">
    
    {/* ── HERO ── */}
    <section style="padding: 80px 0 60px; border-bottom: 2px solid var(--border); background: var(--bg-secondary);">
      <div class="container">
        <h1 style="font-size: clamp(2.2rem, 5vw, 3.5rem); font-weight: 900; line-height: 1.1; letter-spacing: -0.04em; margin-bottom: 24px;">
          {totalTopics}+ Udemy Course Topics with <span style="background: var(--bg-secondary); color: var(--text); padding: 0 8px;">Free 100% Off Coupons</span>
        </h1>
        
        <p style="font-size: clamp(1.05rem, 2.5vw, 1.2rem); color: var(--muted); max-width: 800px; line-height: 1.6; font-weight: 500; margin-bottom: 16px;">
          Browse {totalTopics} specialized learning categories with {totalCourses}+ verified Udemy courses. 
          Find 100% off coupon codes for Python, AI, data science, web development, cloud certification & more.
        </p>
        <p style="font-size: 1rem; color: var(--muted); max-width: 800px; line-height: 1.5; font-weight: 500; margin-bottom: 32px;">
          <strong style="color: var(--text);">How it works:</strong> Click any topic below to see all available courses with verified discount codes. 
          Coupons are tested daily — grab them before they expire!
        </p>

        <div style="display: flex; gap: 16px; flex-wrap: wrap;">
          {[
            { v: `${totalTopics}`, l: "Topics" },
            { v: `${totalCourses}+`, l: "Courses" },
            { v: "Daily", l: "Updates" }
          ].map(s => (
            <div style="background: var(--bg-secondary); border: 2px solid var(--border); padding: 12px 24px; border-radius: 4px; box-shadow: 4px 4px 0 var(--border); display: flex; flex-direction: column; align-items: center;">
              <span style="font-size: 1.5rem; font-weight: 900; color: var(--text);">{s.v}</span>
              <span style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--muted);">{s.l}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── SEARCH & FILTERS ── */}
    <section style="padding: 40px 0; background: var(--bg-secondary); border-bottom: 2px solid var(--border);">
      <div class="container">
        <div style="display: flex; gap: 16px; flex-wrap: wrap; align-items: stretch;">
          <div style="flex: 1; min-width: 300px; position: relative;">
            <input 
              type="text" 
              id="search-input" 
              placeholder="Search topics..." 
              style="width: 100%; padding: 16px 20px; border: 2px solid var(--border); border-radius: 4px; font-weight: 700; font-size: 1rem; outline: none; box-shadow: 4px 4px 0 var(--border);"
            />
          </div>
          <select 
            id="category-filter" 
            style="padding: 0 20px; border: 2px solid var(--border); border-radius: 4px; font-weight: 700; background: var(--bg-secondary); color: var(--text); cursor: pointer; outline: none; box-shadow: 4px 4px 0 var(--border);"
          >
            <option value="all">All Categories</option>
            <option value="development">Development</option>
            <option value="business">Business</option>
            <option value="design">Design</option>
            <option value="data-science">Data Science</option>
          </select>
          <select 
            id="sort-options" 
            style="padding: 0 20px; border: 2px solid var(--border); border-radius: 4px; font-weight: 700; background: var(--bg-secondary); color: var(--text); cursor: pointer; outline: none; box-shadow: 4px 4px 0 var(--border);"
          >
            <option value="name">Name A-Z</option>
            <option value="courses">Most Courses</option>
          </select>
        </div>
        <div id="result-count" style="margin-top: 24px; font-weight: 800; color: var(--muted); text-transform: uppercase; font-size: 0.8rem;">
          Showing {totalTopics} topics
        </div>
      </div>
    </section>

    {/* ── GRID ── */}
    <section style="padding: 80px 0;">
      <div class="container">
        <div id="topics-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px;">
          {topicsData.map((t, i) => (
            <a href={`/topics/${t.slug}`} class="neo-topic-card">
              <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 20px;">
                <div style="background: var(--bg-secondary); color: var(--text); width: 56px; height: 56px; border-radius: 4px; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.5rem; box-shadow: 3px 3px 0 var(--border);">
                  {t.name.charAt(0).toUpperCase()}
                </div>
                <div>
                  <h3 style="font-size: 1.15rem; font-weight: 900; margin: 0;">{t.name}</h3>
                  <div style="font-size: 0.85rem; font-weight: 800; color: var(--text); text-transform: uppercase;">{t.count} Courses</div>
                </div>
              </div>
              <p style="margin: 0; color: var(--bg-secondary); font-size: 0.9rem; line-height: 1.6; font-weight: 500; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                {getTopicDescription(t.name)}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* ── FAQ SECTION ── */}
    <section style="padding: 80px 0; background: var(--bg-secondary); border-top: 2px solid var(--border);">
      <div class="container" style="max-width: 800px;">
        <h2 style="font-size: 2rem; font-weight: 900; margin-bottom: 16px; text-align: center; letter-spacing: -0.02em;">
          Frequently Asked Questions About Udemy Topics
        </h2>
        <p style="text-align: center; color: var(--muted); font-weight: 500; margin-bottom: 48px; line-height: 1.6;">
          Everything you need to know about finding free Udemy courses by topic
        </p>
        <div style="display: flex; flex-direction: column; gap: 16px;">
          {[
            { q: "What are Udemy course topics on CoursesWyn?", a: "CoursesWyn organizes Udemy courses into specialized topic pages — such as Python, Web Development, Data Science, AI, and Cybersecurity. Each topic page lists verified 100% off coupon deals for courses in that subject area, updated daily." },
            { q: "How do I find free Udemy courses by topic?", a: "Browse the topic categories above and click on any subject that interests you. You'll see all available courses in that topic with verified discount codes. Click 'Redeem Coupon' to get the course for free or at a heavily discounted price." },
            { q: "Are these Udemy coupons actually free?", a: "Many courses offer 100% off coupons making them completely free. Others provide discounts of 80-95% off. Each listing clearly shows the final price after coupon — many are $0.00 (free). All coupons are tested daily by our team." },
            { q: "Which Udemy topics have the most free courses?", a: "Programming topics like Python, JavaScript, and Web Development typically have the most free courses. AI and Machine Learning topics are also growing rapidly with many 100% off deals. Check the course count on each topic card above." },
            { q: "How often are new topics and deals added?", a: "New deals are added every single day. We recommend bookmarking your favorite topic pages and checking back regularly. Popular topics like Python and AI can have new free courses multiple times per week." },
            { q: "Do free Udemy courses include certificates?", a: "Yes! All courses accessed through our free coupons include full Udemy benefits — completion certificates, lifetime access, all video content, and downloadable resources. The certificate is identical to paid enrollments." }
          ].map((faq, i) => (
            <details style="background: var(--card); border: 2px solid var(--border); border-radius: 8px; margin-bottom: 12px; box-shadow: 3px 3px 0 var(--border);" class="faq-item">
              <summary style="padding: 20px 24px; font-weight: 800; cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-size: 1.05rem; list-style: none;">
                {faq.q}
                <span style="color: var(--accent); font-size: 1.3rem;">+</span>
              </summary>
              <div style="padding: 0 24px 20px; color: var(--muted); font-weight: 500; line-height: 1.6;">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    {/* ── RELATED RESOURCES ── */}
    <section style="padding: 80px 0; background: var(--bg); border-top: 2px solid var(--border);">
      <div class="container">
        <h2 style="font-size: 2rem; font-weight: 900; margin-bottom: 16px; letter-spacing: -0.02em; text-align: center;">
          Explore More Learning Resources
        </h2>
        {/* FIX: removed broken inline quote inside style string */}
        <p style="text-align: center; color: var(--muted); font-weight: 500; line-height: 1.6; max-width: 700px; margin: 0 auto 48px;">
          Discover curated guides, coupon tutorials, and career roadmaps to maximize your learning
        </p>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">
          {[
            { title: "Udemy Coupons Guide", desc: "Learn how to find and redeem 100% off coupons", link: "/udemy-coupons-guide", icon: "📖" },
            { title: "Latest AI Courses", desc: "ChatGPT, AI agents, machine learning deals", link: "/blog/best-chatgpt-courses-udemy-2026", icon: "🤖" },
            { title: "Programming Deals", desc: "Python, JavaScript, React free courses", link: "/udemy-coupon-code", icon: "💻" },
            { title: "Cloud Certification", desc: "AWS, Azure, Google Cloud coupons", link: "/blog/best-aws-certification-courses-2026", icon: "☁️" },
            { title: "Career Roadmaps", desc: "Step-by-step learning paths for jobs", link: "/blog/ai-engineer-roadmap-2026", icon: "🎯" },
            { title: "All Free Deals", desc: "Browse all 100% off Udemy coupons", link: "/udemy-coupon-code", icon: "🎫" }
          ].map(resource => (
            <a href={resource.link} style="text-decoration: none; color: inherit;">
              <div style="background: var(--bg-secondary); border: 2px solid var(--border); border-radius: 8px; padding: 24px; box-shadow: 4px 4px 0 var(--border); transition: all 0.15s ease; height: 100%;" class="resource-card">
                <div style="font-size: 2rem; margin-bottom: 12px;">{resource.icon}</div>
                <h3 style="font-size: 1.1rem; font-weight: 900; margin-bottom: 8px; color: var(--text);">{resource.title}</h3>
                <p style="margin: 0; color: var(--muted); font-size: 0.9rem; font-weight: 500; line-height: 1.5;">{resource.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>

  <style>
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .neo-topic-card {
      background: var(--bg-secondary); border: 2px solid var(--border); border-radius: 8px; padding: 24px;
      text-decoration: none; color: inherit; transition: all 0.2s;
      box-shadow: 4px 4px 0 var(--border);
    }
    .neo-topic-card:hover { transform: translate(-4px, -4px); box-shadow: 8px 8px 0 var(--border); border-color: var(--accent); }
    .faq-item[open] { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--border); }
    .faq-item summary::-webkit-details-marker { display: none; }
    .resource-card:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--border); border-color: var(--accent); }
  </style>

  <script define:vars={{ topicsData }}>
    const searchInput = document.getElementById('search-input');
    const categoryFilter = document.getElementById('category-filter');
    const sortOptions = document.getElementById('sort-options');
    const grid = document.getElementById('topics-grid');
    const count = document.getElementById('result-count');

    function filter() {
      const q = searchInput.value.toLowerCase();
      const cat = categoryFilter.value;
      const sort = sortOptions.value;

      let filtered = topicsData.filter(t => t.name.toLowerCase().includes(q));
      
      if (sort === 'courses') filtered.sort((a,b) => b.count - a.count);
      else filtered.sort((a,b) => a.name.localeCompare(b.name));

      grid.innerHTML = filtered.map(t => `
        <a href="/topics/${t.slug}" class="neo-topic-card">
          <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 20px;">
            <div style="background: var(--bg-secondary); color: var(--text); width: 56px; height: 56px; border-radius: 4px; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.5rem; box-shadow: 3px 3px 0 var(--border);">
              ${t.name.charAt(0).toUpperCase()}
            </div>
            <div>
              <h3 style="font-size: 1.15rem; font-weight: 900; margin: 0;">${t.name}</h3>
              <div style="font-size: 0.85rem; font-weight: 800; color: var(--text); text-transform: uppercase;">${t.count} Courses</div>
            </div>
          </div>
          <p style="margin: 0; color: var(--muted); font-size: 0.9rem; line-height: 1.6; font-weight: 500; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
            Explore verified Udemy coupons for ${t.name} and related subjects.
          </p>
        </a>
      `).join('');
      
      count.textContent = `Showing ${filtered.length} topics`;
    }

    searchInput.addEventListener('input', filter);
    categoryFilter.addEventListener('change', filter);
    sortOptions.addEventListener('change', filter);
  </script>
</Layout>