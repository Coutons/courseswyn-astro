---
import Layout from '../layouts/Layout.astro';
import { readDeals } from '../lib/store';

const allDeals = await readDeals();

const normSub = (str: string) =>
  str.replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/&#39;/g, "'").trim();

const topicCounts: Record<string, number> = {};
allDeals.forEach(deal => {
  const sub = deal.subcategory ? normSub(deal.subcategory) : '';
  if (sub) {
    topicCounts[sub] = (topicCounts[sub] || 0) + 1;
  }
});

const topicsData = (Object.entries(topicCounts) as [string, number][])
  .sort((a, b) => b[1] - a[1])
  .map(([topic, count]) => {
    const slug = topic.toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-');
    return { name: topic, slug, count };
  });

const totalTopics = topicsData.length;
const totalCourses = allDeals.length;

const currentDate = new Date();
const currentYear = Number(currentDate.toLocaleString('en-US', { year: 'numeric', timeZone: 'Asia/Jakarta' }));

const title = `${totalTopics}+ Udemy Course Topics with Free 100% Off Coupons [${currentYear}] | CoursesWyn`;
const description = `Browse ${totalTopics}+ specialized Udemy course topics with verified free coupons. Find 100% off deals on Python, AI, data science, web development, cloud certification & more. ${totalCourses}+ courses with daily verified discount codes. No payment required for free coupons.`;
const canonicalUrl = "https://courseswyn.com/topics";

function getTopicDescription(topic: string): string {
  const t = topic.toLowerCase();
  if (t.includes('python')) return "Courses covering Python programming for data science, automation, web development with Flask/Django, and machine learning. Suitable for beginners and experienced developers.";
  if (t.includes('javascript') || t.includes('js')) return "Courses covering modern JavaScript including ES6+, async programming, Node.js, and popular frameworks like React, Vue, and Angular.";
  if (t.includes('web develop')) return "Full-stack and front-end web development courses covering HTML, CSS, JavaScript, frameworks, REST APIs, and deployment.";
  if (t.includes('react')) return "Courses on React.js including hooks, context API, Redux, Next.js, and building production-ready single-page applications.";
  if (t.includes('data science')) return "Data science courses covering statistics, pandas, NumPy, data visualization, Jupyter, and end-to-end ML project workflows.";
  if (t.includes('machine learning') || t.includes('ml')) return "Machine learning courses from regression and classification to neural networks, model evaluation, and deploying ML models to production.";
  if (t.includes('ai') || t.includes('artificial intelligence')) return "AI courses covering deep learning, NLP, computer vision, transformers, GPT, and building intelligent applications with modern frameworks.";
  if (t.includes('chatgpt') || t.includes('gpt')) return "ChatGPT and GPT courses covering prompt engineering, building AI agents, OpenAI API integration, and creating AI-powered applications.";
  if (t.includes('cloud')) return "Cloud computing courses covering AWS, Azure, Google Cloud, DevOps, Docker, Kubernetes, and cloud architecture best practices.";
  if (t.includes('cyber') || t.includes('security')) return "Cybersecurity courses covering ethical hacking, penetration testing, network security, cryptography, and SOC operations.";
  if (t.includes('docker') || t.includes('kubernetes')) return "Containerization and orchestration courses covering Docker, Kubernetes, microservices, and production deployment strategies.";
  if (t.includes('sql') || t.includes('database')) return "Database courses covering SQL, NoSQL, MySQL, PostgreSQL, MongoDB, database design, and data modeling for real-world applications.";
  if (t.includes('blockchain') || t.includes('web3')) return "Blockchain and Web3 courses covering solidity, smart contracts, dApps, cryptocurrency, NFTs, and decentralized finance.";
  if (t.includes('design') || t.includes('ui') || t.includes('ux')) return "Design courses covering UI/UX design, Figma, Adobe XD, wireframing, prototyping, and user research methodologies.";
  if (t.includes('devops')) return "DevOps courses covering CI/CD pipelines, infrastructure as code, monitoring, automation, and site reliability engineering.";
  return `Browse verified Udemy coupons and 100% off deals for ${topic} courses. Find premium ${topic} training with daily updated discount codes.`;
}

const faqs = [
  { q: "What are Udemy course topics on CoursesWyn?", a: "CoursesWyn organizes Udemy courses into specialized topic pages — such as Python, Web Development, Data Science, AI, and Cybersecurity. Each topic page lists verified 100% off coupon deals for courses in that subject area, updated daily." },
  { q: "How do I find free Udemy courses by topic?", a: "Browse the topic categories above and click on any subject that interests you. You'll see all available courses in that topic with verified discount codes. Click 'Redeem Coupon' to get the course for free or at a heavily discounted price." },
  { q: "Are these Udemy coupons actually free?", a: "Many courses offer 100% off coupons making them completely free. Others provide discounts of 80-95% off. Each listing clearly shows the final price after coupon — many are $0.00 (free). All coupons are tested daily by our team." },
  { q: "Which Udemy topics have the most free courses?", a: "Programming topics like Python, JavaScript, and Web Development typically have the most free courses. AI and Machine Learning topics are also growing rapidly with many 100% off deals. Check the course count on each topic card above." },
  { q: "How often are new topics and deals added?", a: "New deals are added every single day. We recommend bookmarking your favorite topic pages and checking back regularly. Popular topics like Python and AI can have new free courses multiple times per week." },
  { q: "Do free Udemy courses include certificates?", a: "Yes! All courses accessed through our free coupons include full Udemy benefits — completion certificates, lifetime access, all video content, and downloadable resources. The certificate is identical to paid enrollments." }
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" }, { "@type": "ListItem", "position": 2, "name": "Course Topics", "item": canonicalUrl }] },
    { "@type": "CollectionPage", "@id": canonicalUrl, "url": canonicalUrl, "name": title, "description": description, "isPartOf": { "@id": "https://courseswyn.com" }, "mainEntity": { "@type": "ItemList", "name": "Udemy Course Topics", "numberOfItems": totalTopics, "itemListElement": topicsData.map((t, i) => ({ "@type": "ListItem", "position": i + 1, "item": { "@type": "ItemList", "name": `${t.name} Courses`, "description": getTopicDescription(t.name), "url": `https://courseswyn.com/topics/${t.slug}`, "numberOfItems": t.count } })) } },
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<Layout title={title} description={description} canonical={canonicalUrl} hideBreadcrumbs={true}>
  <link rel="canonical" href={canonicalUrl} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <style>
    .cc-root { background: var(--bg); padding: 2rem 1rem 4rem; }
    .cc-container { max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; }
    .cc-breadcrumb { display: flex; justify-content: center; margin-bottom: 1rem; }
    .cc-breadcrumb ol { list-style: none; display: flex; align-items: center; gap: 0.5rem; padding: 0; margin: 0; font-size: 0.8rem; color: var(--muted); }
    .cc-breadcrumb li:not(:last-child)::after { content: '/'; margin-left: 0.5rem; color: var(--border); }
    .cc-breadcrumb a { color: var(--brand); text-decoration: none; }
    .cc-breadcrumb a:hover { text-decoration: underline; }
    .cc-header { text-align: center; margin-bottom: 2rem; }
    .cc-header-icon { display: block; margin: 0 auto 0.75rem; color: var(--brand); }
    .cc-title { font-size: 1.8rem; font-weight: 900; color: var(--text); margin: 0 0 0.5rem; letter-spacing: -0.03em; }
    .cc-subtitle { font-size: 0.92rem; color: var(--muted); max-width: 600px; margin: 0 auto 1.5rem; line-height: 1.65; }
    .cc-subtitle strong { color: var(--brand); font-weight: 700; }
    .cc-stats-bar { display: inline-flex; align-items: center; gap: 1.5rem; background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 0.75rem 1.5rem; }
    .cc-stat { display: flex; flex-direction: column; align-items: center; gap: 0.1rem; }
    .cc-stat-value { font-size: 1.15rem; font-weight: 800; color: var(--text); }
    .cc-stat-label { font-size: 0.68rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; white-space: nowrap; }
    .cc-stat-divider { width: 1px; height: 32px; background: var(--border); }
    .cc-filter-bar { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 0.75rem 1rem; margin-bottom: 1.5rem; }
    .search-input { width:100%; padding:12px 16px; background:var(--bg); border:1px solid var(--border); border-radius:var(--radius); font-weight:600; font-size:0.95rem; outline:none; color:var(--text); }
    .search-input:focus { border-color:var(--brand); }
    .sort-select { padding:0 16px; background:var(--bg); border:1px solid var(--border); border-radius:var(--radius); font-weight:600; color:var(--text); cursor:pointer; outline:none; }
    .sort-select:focus { border-color:var(--brand); }
    .cc-section-title { font-size: 1.2rem; font-weight: 800; color: var(--text); margin: 0 0 0.25rem; display: flex; align-items: center; gap: 0.65rem; }
    .cc-section-title svg { color: var(--brand); flex-shrink: 0; }
    .cc-seo-section { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; }
    .cc-seo-section h2 { font-size: 1.1rem; font-weight: 700; color: var(--text); margin: 0 0 0.75rem; }
    .cc-seo-section p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; margin: 0 0 0.75rem; }
    .cc-seo-section p:last-child { margin-bottom: 0; }
    .cc-seo-section a { color: var(--brand); text-decoration: none; font-weight: 600; }
    .cc-seo-section a:hover { text-decoration: underline; }
    .tp-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 2.5rem; }
    .tp-item { display: block; text-decoration: none; padding: 1rem; border: 1px solid var(--border); border-radius: 8px; border-left: 3px solid var(--brand); transition: all 0.2s; color: var(--text); }
    .tp-item:hover { border-color: var(--brand); background: color-mix(in srgb, var(--brand) 4%, transparent); padding-left: 1.25rem; }
    .tp-item:hover .tp-name { color: var(--brand); }
    .tp-name { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 2px; line-height: 1.3; transition: color 0.2s; }
    .tp-count { font-size: 0.75rem; font-weight: 600; color: var(--brand); text-transform: uppercase; letter-spacing: 0.03em; }
    .tp-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.5; margin: 6px 0 0; }
    @media (max-width: 640px) { .tp-grid { grid-template-columns: 1fr; } }
    .cc-section { margin-bottom: 2.5rem; }
    .cc-faq .cc-faq-item { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 0.85rem 1rem; margin-bottom: 0.5rem; }
    .cc-faq-q { font-size: 0.9rem; font-weight: 700; color: var(--text); margin: 0 0 0.35rem; }
    .cc-faq-a { font-size: 0.85rem; color: var(--muted); line-height: 1.5; margin: 0; }
    @media (max-width: 768px) { .cc-title { font-size: 1.4rem; } .cc-stats-bar { gap: 1rem; padding: 0.6rem 1rem; } }
  </style>

  <main class="cc-root">
    <div class="cc-container">

      <nav class="cc-breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li>Course Topics</li>
        </ol>
      </nav>

      <header class="cc-header">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="cc-header-icon">
          <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        <h1 class="cc-title">{totalTopics}+ Udemy Course Topics</h1>
        <p class="cc-subtitle">Browse <strong>{totalTopics} specialized learning topics</strong> with {totalCourses}+ verified Udemy courses — updated daily</p>
        <div class="cc-stats-bar">
          <div class="cc-stat">
            <span class="cc-stat-value">{totalTopics}</span>
            <span class="cc-stat-label">Topics</span>
          </div>
          <div class="cc-stat-divider"></div>
          <div class="cc-stat">
            <span class="cc-stat-value">{totalCourses.toLocaleString()}</span>
            <span class="cc-stat-label">Active Courses</span>
          </div>
          <div class="cc-stat-divider"></div>
          <div class="cc-stat">
            <span class="cc-stat-value">Daily</span>
            <span class="cc-stat-label">Updates</span>
          </div>
        </div>
      </header>

      <div class="cc-filter-bar">
        <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:stretch;">
          <div style="flex:1;min-width:280px;position:relative;">
            <input type="text" id="search-input" placeholder="Search topics..." class="search-input" />
          </div>
          <select id="sort-options" class="sort-select">
            <option value="name">Name A-Z</option>
            <option value="courses">Most Courses</option>
          </select>
        </div>
        <div id="result-count" style="margin-top:12px;font-weight:700;color:var(--text-secondary);font-size:0.85rem;">Showing {totalTopics} topics</div>
      </div>

      <section class="cc-section">
        <h2 class="cc-section-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Browse {totalTopics} Udemy Course Topics
        </h2>
      <div id="topics-grid" class="tp-grid">
        {topicsData.map((t) => (
          <a href={`/topics/${t.slug}`} class="tp-item">
            <h3 class="tp-name">{t.name}</h3>
            <span class="tp-count">{t.count} courses</span>
            <p class="tp-desc">{getTopicDescription(t.name)}</p>
          </a>
        ))}
      </div>
      </section>

      <section class="cc-seo-section">
        <h2>About Udemy Course Topics on CoursesWyn</h2>
        <p>CoursesWyn organizes <strong>{totalCourses}+ verified coupon deals</strong> across <strong>{totalTopics} specialized topic pages</strong> — from <a href="/topics/python">Python programming</a> and <a href="/topics/web-development">Web Development</a> to <a href="/topics/data-science">Data Science</a>, <a href="/topics/artificial-intelligence">Artificial Intelligence</a>, <a href="/topics/cybersecurity">Cybersecurity</a>, and <a href="/topics/react-js">React.js</a>. Each topic page lists verified 100% off coupon deals for courses in that subject area, making it the fastest way to find free training in your chosen specialty. You can use the search bar above to find any topic instantly — simply type "Python", "AI", "Cloud", or any subject you're interested in.</p>
        <p>Topics are sorted by course count so the most active subjects appear first. You can also sort alphabetically using the dropdown. New deals are added every day, and popular topics like <a href="/topics/python">Python</a>, <a href="/topics/javascript">JavaScript</a>, and <a href="/topics/machine-learning">Machine Learning</a> can receive multiple fresh 100% off coupons per week. We recommend bookmarking your favorite topic pages and checking back regularly for new free courses.</p>
        <p>Browse <a href="/udemy-coupon-code">all verified coupons</a>, explore <a href="/categories">course categories</a>, or check <a href="/popular">popular courses</a> for the highest-rated deals. Our system verifies every coupon in real time — when a coupon reaches its redemption limit or expires, it vanishes from our listings automatically so you only see working deals.</p>
      </section>

      <section class="cc-section cc-faq">
        <h2 class="cc-section-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Frequently asked questions
        </h2>
        {faqs.map((faq) => (
          <div class="cc-faq-item">
            <h3 class="cc-faq-q">{faq.q}</h3>
            <p class="cc-faq-a">{faq.a}</p>
          </div>
        ))}
      </section>

    </div>
  </main>
</Layout>

<script define:vars={{ topicsData }}>
  const searchInput = document.getElementById('search-input');
  const sortOptions = document.getElementById('sort-options');
  const grid = document.getElementById('topics-grid');
  const count = document.getElementById('result-count');
  const items = Array.from(grid.querySelectorAll('.tp-item'));

  function filter() {
    const q = searchInput.value.toLowerCase();
    const sort = sortOptions.value;

    let visible = 0;
    items.forEach(function(item) {
      const name = item.querySelector('.tp-name').textContent.toLowerCase();
      const match = !q || name.includes(q);
      item.style.display = match ? '' : 'none';
      if (match) visible++;
    });

    if (sort === 'courses') {
      items.sort(function(a,b) {
        return parseInt(b.querySelector('.tp-count').textContent) - parseInt(a.querySelector('.tp-count').textContent);
      });
    } else {
      items.sort(function(a,b) {
        return a.querySelector('.tp-name').textContent.localeCompare(b.querySelector('.tp-name').textContent);
      });
    }
    items.forEach(function(item) {
      grid.appendChild(item);
    });

    count.textContent = `Showing ${visible} topics`;
  }

  searchInput.addEventListener('input', filter);
  sortOptions.addEventListener('change', filter);
</script>
