---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Search Udemy Courses — Verified Promo Codes & Vouchers | CoursesWyn">
  <main style="background: #fafafa; min-height: 80vh;">

    <section style="background: white; border-bottom: 1px solid #e5e7eb; padding: 6rem 0 4rem;">
      <div class="container">
        <h1 style="font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 900; color: #111827; margin: 0 0 1rem; letter-spacing: -0.03em;">
          Search <span style="background: linear-gradient(135deg,#ea580c,#db2777,#9333ea);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Udemy Coupons</span>
        </h1>
        <p style="font-size: 1.125rem; color: #6b7280; max-width: 640px; line-height: 1.6; font-weight: 500; margin: 0;" id="search-description"></p>
      </div>
    </section>

    <section style="padding: 4rem 0;">
      <div class="container">
        <div id="search-loading" style="display: none; text-align: center; padding: 4rem 0;">
          <div style="width: 48px; height: 48px; border: 4px solid #e5e7eb; border-top-color: #f97316; border-radius: 50%; margin: 0 auto 1.5rem; animation: spin 0.8s linear infinite;"></div>
          <p style="color: #6b7280; font-weight: 600;">Searching courses...</p>
        </div>

        <div id="search-results" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;"></div>

        <div id="no-results" style="display: none; text-align: center; padding: 4rem 2rem; background: white; border: 3px solid rgba(0,0,0,0.07); border-radius: 20px;">
          <div style="font-size: 3rem; margin-bottom: 1rem;">🔍</div>
          <h2 style="font-size: 1.5rem; font-weight: 900; color: #111827; margin: 0 0 0.5rem;">No Courses Found</h2>
          <p style="color: #6b7280; font-weight: 500; margin: 0 0 2rem;">Try browsing our popular categories instead.</p>
          <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
            <a href="/categories/development" style="padding: 0.5rem 1.25rem; background: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 100px; color: #111827; text-decoration: none; font-size: 0.85rem; font-weight: 600;">Development</a>
            <a href="/categories/it-and-software" style="padding: 0.5rem 1.25rem; background: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 100px; color: #111827; text-decoration: none; font-size: 0.85rem; font-weight: 600;">IT & Software</a>
            <a href="/categories/business" style="padding: 0.5rem 1.25rem; background: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 100px; color: #111827; text-decoration: none; font-size: 0.85rem; font-weight: 600;">Business</a>
            <a href="/categories/design" style="padding: 0.5rem 1.25rem; background: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 100px; color: #111827; text-decoration: none; font-size: 0.85rem; font-weight: 600;">Design</a>
          </div>
        </div>

        <div id="search-navigation" style="display: none; justify-content: center; align-items: center; gap: 1rem; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #e5e7eb;">
          <button id="prev-page" style="padding: 0.75rem 1.5rem; border-radius: 10px; border: 1px solid #e5e7eb; background: white; color: #111827; cursor: pointer; font-weight: 700; font-size: 0.85rem;">← PREV</button>
          <span id="page-info" style="font-weight: 700; font-size: 0.85rem; color: #6b7280;"></span>
          <button id="next-page" style="padding: 0.75rem 1.5rem; border-radius: 10px; background: #111827; color: white; border: none; cursor: pointer; font-weight: 700; font-size: 0.85rem;">NEXT →</button>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style is:global>
  @keyframes spin { to { transform: rotate(360deg); } }
  .rc-card { background: white; border: 3px solid rgba(0,0,0,0.07); border-radius: 20px; overflow: hidden; transition: all 0.3s ease; display: flex; flex-direction: column; text-decoration: none; color: inherit; }
  .rc-card:hover { transform: translateY(-4px) scale(1.01); box-shadow: 0 16px 32px -8px rgba(0,0,0,0.12); border-color: rgba(249,115,22,0.3); }
  .rc-img-wrap { position: relative; aspect-ratio: 16/9; overflow: hidden; background: linear-gradient(135deg, #f3f4f6, #e5e7eb); }
  .rc-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .rc-card:hover .rc-img-wrap img { transform: scale(1.05); }
  .rc-badge { position: absolute; top: 12px; left: 12px; padding: 4px 12px; border-radius: 8px; font-size: 0.75rem; font-weight: 800; }
  .rc-badge-free { background: linear-gradient(135deg, #dc2626, #e11d48); color: white; box-shadow: 0 2px 8px rgba(220,38,38,0.3); }
  .rc-badge-hot { background: linear-gradient(135deg, #f97316, #ea580c); color: white; }
  .rc-body { padding: 20px; flex: 1; display: flex; flex-direction: column; }
  .rc-title { font-size: 1.05rem; font-weight: 700; color: #111827; margin: 0 0 8px; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .rc-instructor { font-size: 0.78rem; color: #6b7280; font-weight: 500; margin-bottom: 8px; }
  .rc-desc { font-size: 0.85rem; color: #6b7280; line-height: 1.5; margin-bottom: 16px; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .rc-meta { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 14px; border-top: 2px solid rgba(0,0,0,0.05); }
  .rc-rating { font-size: 0.85rem; font-weight: 700; color: #f59e0b; }
  .rc-btn { display: block; margin-top: 12px; padding: 10px; background: #111827; color: white; text-align: center; border-radius: 10px; font-weight: 700; font-size: 0.85rem; text-decoration: none; transition: all 0.2s; }
  .rc-btn:hover { opacity: 0.85; }
</style>

<script>
  interface Deal {
    id: string; slug?: string; title: string; description?: string;
    category?: string; subcategory?: string; instructor?: string;
    price?: number; originalPrice?: number; rating?: number;
    students?: number; image?: string; updatedAt?: string;
  }

  let currentPage = 1;
  const ITEMS_PER_PAGE = 12;
  let allDeals: Deal[] = [];

  function renderCard(deal: Deal): string {
    const price = deal.price ?? 0;
    const originalPrice = deal.originalPrice ?? 0;
    const hasDiscount = originalPrice > 0 && price < originalPrice;
    const discount = hasDiscount ? Math.round(100 - (price / originalPrice) * 100) : 0;
    const isFree = price === 0;
    const rating = deal.rating ?? 0;

    const imgHtml = deal.image
      ? `<img src="${deal.image}" alt="${deal.title}" loading="lazy">`
      : `<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#9ca3af;"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg></div>`;

    const badgeHtml = isFree
      ? `<div class="rc-badge rc-badge-free">FREE</div>`
      : hasDiscount ? `<div class="rc-badge rc-badge-hot">-${discount}%</div>` : '';

    return `
      <a href="/coupon/${deal.slug}" class="rc-card">
        <div class="rc-img-wrap">${imgHtml}${badgeHtml}</div>
        <div class="rc-body">
          ${rating ? `<div class="rc-rating">★ ${rating.toFixed(1)}</div>` : ''}
          <h2 class="rc-title">${deal.title}</h2>
          ${deal.instructor ? `<p class="rc-instructor">${deal.instructor}</p>` : ''}
          <p class="rc-desc">${deal.description?.slice(0, 120) ?? ''}</p>
          <div class="rc-meta">
            <span style="font-weight:800;color:#f97316;">${isFree ? 'FREE' : `$${price.toFixed(2)}`}</span>
            ${hasDiscount ? `<span style="text-decoration:line-through;color:#9ca3af;font-size:0.8rem;">$${originalPrice.toFixed(2)}</span>` : ''}
          </div>
          <span class="rc-btn">GET COUPON →</span>
        </div>
      </a>`;
  }

  function displayResults(): void {
    const container = document.getElementById('search-results');
    const noResults = document.getElementById('no-results');
    const nav = document.getElementById('search-navigation');
    if (!container) return;
    if (allDeals.length === 0) {
      container.innerHTML = '';
      if (noResults) noResults.style.display = 'block';
      if (nav) nav.style.display = 'none';
      return;
    }
    const start = (currentPage - 1) * ITEMS_PER_PAGE;
    const page = allDeals.slice(start, start + ITEMS_PER_PAGE);
    container.innerHTML = page.map(renderCard).join('');
    if (noResults) noResults.style.display = 'none';
    if (nav) nav.style.display = allDeals.length > ITEMS_PER_PAGE ? 'flex' : 'none';
    updatePagination();
  }

  function updatePagination(): void {
    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement | null;
    const pageInfo = document.getElementById('page-info');
    const total = Math.ceil(allDeals.length / ITEMS_PER_PAGE);
    if (prevBtn) prevBtn.disabled = currentPage === 1;
    if (nextBtn) nextBtn.disabled = currentPage >= total;
    if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${total} · ${allDeals.length} results`;
  }

  async function performSearch(): Promise<void> {
    const params = new URLSearchParams(window.location.search);
    const query = params.get('q') ?? '';
    if (!query) return;
    const loading = document.getElementById('search-loading');
    const descEl = document.getElementById('search-description');
    if (loading) loading.style.display = 'block';
    try {
      const res = await fetch('/api/deals');
      const deals = (await res.json()) as Deal[];
      const q = query.toLowerCase();
      allDeals = deals.filter(deal =>
        deal.title.toLowerCase().includes(q) ||
        (deal.description?.toLowerCase().includes(q) ?? false) ||
        (deal.instructor?.toLowerCase().includes(q) ?? false) ||
        (deal.subcategory?.toLowerCase().includes(q) ?? false)
      );
      currentPage = 1;
      if (descEl) descEl.textContent = `Found ${allDeals.length} verified courses matching "${query}"`;
      displayResults();
    } catch (err) {
      console.error(err);
    } finally {
      if (loading) loading.style.display = 'none';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('prev-page')?.addEventListener('click', () => { currentPage--; displayResults(); window.scrollTo({top:0, behavior:'smooth'}); });
    document.getElementById('next-page')?.addEventListener('click', () => { currentPage++; displayResults(); window.scrollTo({top:0, behavior:'smooth'}); });
    performSearch();
  });
</script>
