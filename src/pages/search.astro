---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Search Udemy Courses — Verified Promo Codes & Vouchers | CoursesWyn">
  <main style="background: var(--bg); color: var(--text);">
    
    {/* ── HERO ── */}
    <section style="padding: 100px 0 80px; border-bottom: 2px solid var(--border); background: var(--card);">
      <div class="container" style="text-align: center;">
        <div style="display: inline-flex; align-items: center; gap: 8px; background: var(--accent); color: white; padding: 6px 16px; border: 2px solid var(--border); box-shadow: 3px 3px 0 var(--border); border-radius: 4px; font-weight: 900; font-size: 0.75rem; text-transform: uppercase; margin-bottom: 32px;">
          <span class="badge-pulse"></span> Live Deals — Updated Daily
        </div>
        <h1 id="search-title" style={{ 
          fontSize: "clamp(2.5rem, 7vw, 4rem)", 
          fontWeight: 900, 
          lineHeight: 1.05, 
          letterSpacing: "-0.04em",
          marginBottom: "24px",
          color: "var(--text)"
        }}>
          Search Udemy<br/>
          <span style={{ background: "var(--color-primary)", color: "var(--color-text)", padding: "0 10px" }}>Promo Codes.</span>
        </h1>
        <p id="search-description" style={{ 
          fontSize: "1.1rem", 
          color: "var(--muted)", 
          maxWidth: "700px", 
          margin: "0 auto", 
          lineHeight: 1.6, 
          fontWeight: 500,
          display: "none"
        }}></p>
      </div>
    </section>

    {/* ── RESULTS ── */}
    <section style="padding: 80px 0; min-height: 60vh;">
      <div class="container">
        
        {/* Loading */}
        <div id="search-loading" style="display: none; text-align: center; padding: 64px 0;">
          <div class="loading-spinner"></div>
          <h3 style="font-size: 1.5rem; font-weight: 900; color: var(--accent); margin-bottom: 8px;">Searching...</h3>
          <p style="color: var(--muted); font-weight: 500;">Finding the best verified coupons for you</p>
        </div>

        {/* Grid */}
        <div id="search-results" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 32px;"></div>

        {/* No Results */}
        <div id="no-results" style="display: none; justify-content: center; padding: 64px 0;">
          <div style="background: var(--bg-secondary); border: 2px solid var(--border); padding: 48px; border-radius: 8px; box-shadow: 8px 8px 0 var(--border); text-align: center; max-width: 600px;">
            <div style="font-size: 3rem; margin-bottom: 24px;">🔍</div>
            <h2 id="no-results-title" style="font-size: 2rem; font-weight: 900; margin-bottom: 16px;">No Courses Found</h2>
            <p style="color: var(--muted); font-size: 1.1rem; line-height: 1.6; font-weight: 500; margin-bottom: 32px;">
              We couldn't find any courses with verified coupons for that search. Try browsing these popular categories instead.
            </p>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px;">
              <a href="/categories/development" class="neo-cat-link">Development</a>
              <a href="/categories/business" class="neo-cat-link">Business</a>
              <a href="/categories/design" class="neo-cat-link">Design</a>
              <a href="/categories/it-and-software" class="neo-cat-link">IT & Software</a>
            </div>
          </div>
        </div>

        {/* Pagination */}
        <div id="search-navigation" style="display: none; justify-content: center; align-items: center; gap: 24px; margin-top: 64px; padding-top: 48px; border-top: 2px solid var(--border);">
          <button id="prev-page" class="btn btn-outline" style="padding: 12px 24px; font-size: 0.9rem;">← PREVIOUS</button>
          <span id="page-info" style="font-weight: 900; font-size: 0.9rem; text-transform: uppercase; color: var(--muted);"></span>
          <button id="next-page" class="btn" style="padding: 12px 24px; font-size: 0.9rem;">NEXT →</button>
        </div>

      </div>
    </section>

  </main>
</Layout>

<style is:global>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .badge-pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--color-primary); animation: blink 2s infinite; }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading-spinner { width: 48px; height: 48px; border: 4px solid var(--border); border-top-color: var(--color-primary); border-radius: 50%; margin: 0 auto 24px; animation: spin 1s linear infinite; }
  
  .neo-cat-link { 
    background: var(--bg); border: 2px solid var(--border); padding: 12px; border-radius: 4px; 
    font-weight: 800; text-decoration: none; color: inherit; font-size: 0.85rem; transition: all 0.2s;
    box-shadow: 3px 3px 0 var(--border);
  }
  .neo-cat-link:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--border); border-color: var(--color-primary); }

  /* DYNAMIC CARD STYLES */
  .rc-card {
    background: var (--bg); border: 2px solid var(--border); border-radius: 8px; overflow: hidden;
    transition: all 0.2s; display: flex; flex-direction: column; box-shadow: 6px 6px 0 var(--border);
    text-decoration: none; color: inherit;
  }
  .rc-card:hover { transform: translate(-4px, -4px); box-shadow: 10px 10px 0 var(--border); border-color: var(--color-primary); }
  .rc-img-wrap { height: 180px; position: relative; border-bottom: 2px solid var(--border); }
  .rc-badge { position: absolute; top: 12px; left: 12px; padding: 4px 10px; font-size: 0.7rem; font-weight: 900; border: 2px solid var(--border); box-shadow: 2px 2px 0 var(--border); }
  .rc-badge-free { background: var(--color-primary); color: white; }
  .rc-badge-hot { background: #ff4757; color: white; }
  .rc-date { position: absolute; bottom: 12px; right: 12px; background: white; border: 2px solid var(--border); padding: 2px 8px; font-size: 0.65rem; font-weight: 800; }
  .rc-body { padding: 24px; flex: 1; display: flex; flex-direction: column; }
  .rc-title { font-size: 1.1rem; font-weight: 900; margin: 0 0 12px; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .rc-instructor { font-size: 0.8rem; font-weight: 700; color: var(--muted); margin-bottom: 12px; }
  .rc-instructor strong { color: var(--text); }
  .rc-desc { font-size: 0.9rem; color: var(--muted); line-height: 1.5; margin-bottom: 20px; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; font-weight: 500; }
  .rc-meta { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 16px; border-top: 1px solid var(--border-light); }
  .rc-rating { font-size: 0.75rem; font-weight: 800; color: var(--accent); text-transform: uppercase; }
  .rc-subcat { font-size: 0.7rem; font-weight: 900; background: var(--bg); border: 2px solid var(--border); padding: 2px 8px; border-radius: 4px; text-transform: uppercase; color: var(--muted); }
  .rc-btn-primary { 
    margin-top: 20px; padding: 12px; background: var(--color-primary); color: var(--color-text); border: 2px solid var(--border);
    font-weight: 900; text-align: center; font-size: 0.9rem; box-shadow: 4px 4px 0 var(--border);
    transition: all 0.1s;
  }
  .rc-btn-primary:active { transform: translate(2px, 2px); box-shadow: 2px 2px 0 var(--border); }
</style>

<script>
  interface Deal {
    id: string;
    slug?: string;
    title: string;
    description?: string;
    category?: string;
    subcategory?: string;
    instructor?: string;
    price?: number;
    originalPrice?: number;
    rating?: number;
    students?: number;
    image?: string;
    updatedAt?: string;
  }

  let currentPage = 1;
  const ITEMS_PER_PAGE = 12;
  let allDeals: Deal[] = [];

  function renderCard(deal: Deal): string {
    const price = deal.price ?? 0;
    const originalPrice = deal.originalPrice ?? 0;
    const hasDiscount = originalPrice > 0 && price < originalPrice;
    const discount = hasDiscount ? Math.round(100 - (price / originalPrice) * 100) : 0;
    const isFree = price === 0;
    const rating = deal.rating ?? 0;
    const updatedLabel = deal.updatedAt
      ? new Date(deal.updatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'Asia/Jakarta' })
      : 'DAILY UPDATE';

    const imgHtml = deal.image
      ? `<img src="${deal.image}" alt="${deal.title}" loading="lazy" style="width:100%;height:100%;object-fit:cover;">`
      : `<div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:3rem;background:var(--bg);">📚</div>`;

    const badgeHtml = isFree
      ? `<div class="rc-badge rc-badge-free">🎁 FREE</div>`
      : hasDiscount
        ? `<div class="rc-badge rc-badge-hot">🔥 ${discount}% OFF</div>`
        : '';

    const subcatHtml = deal.subcategory
      ? `<span class="rc-subcat">${deal.subcategory}</span>`
      : '';

    return `
      <div class="rc-card">
        <div class="rc-img-wrap">
          ${imgHtml}
          ${badgeHtml}
          <span class="rc-date">${updatedLabel.toUpperCase()}</span>
        </div>
        <div class="rc-body">
          <h2 class="rc-title">${deal.title}</h2>
          ${deal.instructor ? `<p class="rc-instructor">BY <strong>${deal.instructor.toUpperCase()}</strong></p>` : ''}
          <p class="rc-desc">${deal.description ?? 'Master this in-demand skill with comprehensive training from industry experts.'}</p>
          <div class="rc-meta">
            <span class="rc-rating">★ ${rating.toFixed(1)}</span>
            ${subcatHtml}
          </div>
          <a href="/coupon/${deal.slug}" class="rc-btn-primary">GET COUPON →</a>
        </div>
      </div>`;
  }

  function displayResults(): void {
    const container = document.getElementById('search-results');
    const noResults = document.getElementById('no-results');
    const nav = document.getElementById('search-navigation');
    if (!container) return;

    if (allDeals.length === 0) {
      container.innerHTML = '';
      if (noResults) noResults.style.display = 'flex';
      if (nav) nav.style.display = 'none';
      return;
    }

    const start = (currentPage - 1) * ITEMS_PER_PAGE;
    const page = allDeals.slice(start, start + ITEMS_PER_PAGE);
    container.innerHTML = page.map(renderCard).join('');
    if (noResults) noResults.style.display = 'none';
    if (nav) nav.style.display = allDeals.length > ITEMS_PER_PAGE ? 'flex' : 'none';
  }

  function updatePagination(): void {
    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement | null;
    const pageInfo = document.getElementById('page-info');
    const total = Math.ceil(allDeals.length / ITEMS_PER_PAGE);
    if (prevBtn) prevBtn.disabled = currentPage === 1;
    if (nextBtn) nextBtn.disabled = currentPage >= total;
    if (pageInfo) pageInfo.textContent = `PAGE ${currentPage} OF ${total} · ${allDeals.length} RESULTS`;
  }

  async function performSearch(): Promise<void> {
    const params = new URLSearchParams(window.location.search);
    const query = params.get('q') ?? '';
    const container = document.getElementById('search-results');
    const noResults = document.getElementById('no-results');
    const nav = document.getElementById('search-navigation');
    const loading = document.getElementById('search-loading');
    const titleEl = document.getElementById('search-title');
    const descEl = document.getElementById('search-description');

    if (!query) return;

    if (loading) loading.style.display = 'block';
    if (container) container.innerHTML = '';
    if (noResults) noResults.style.display = 'none';
    if (nav) nav.style.display = 'none';

    try {
      const res = await fetch('/api/deals');
      const deals = (await res.json()) as Deal[];
      const q = query.toLowerCase();
      allDeals = deals.filter(deal => 
        deal.title.toLowerCase().includes(q) || 
        (deal.description?.toLowerCase().includes(q) ?? false) ||
        (deal.instructor?.toLowerCase().includes(q) ?? false) ||
        (deal.subcategory?.toLowerCase().includes(q) ?? false)
      );
      currentPage = 1;
      if (titleEl) titleEl.innerHTML = `Search: <span style="background:var(--accent);color:white;padding:0 10px;">${query}</span>`;
      if (descEl) {
        descEl.style.display = 'block';
        descEl.textContent = `Found ${allDeals.length} verified ${query} courses with exclusive promo codes. Updated daily by our experts.`;
      }
      displayResults();
      updatePagination();
    } catch (err) {
      console.error(err);
    } finally {
      if (loading) loading.style.display = 'none';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('prev-page')?.addEventListener('click', () => { currentPage--; displayResults(); updatePagination(); window.scrollTo({top:0, behavior:'smooth'}); });
    document.getElementById('next-page')?.addEventListener('click', () => { currentPage++; displayResults(); updatePagination(); window.scrollTo({top:0, behavior:'smooth'}); });
    performSearch();
  });
</script>