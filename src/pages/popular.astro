---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import DealCard from "../components/DealCard.astro";
import { readDeals } from "../lib/store";
import { normName, slugifyCategory } from "../lib/utils";
import { toISODateWIB } from "../lib/date";

const allDeals = await readDeals();
const selectedLanguage = Astro.url.searchParams.get('language');

// ── INTENTIONAL: 4.5+★ rated courses — by design, showing highest-rated ────────
let filteredDeals = allDeals;
if (selectedLanguage) {
  filteredDeals = allDeals.filter((d: any) => 
    d.language && d.language.toLowerCase() === selectedLanguage.toLowerCase()
  );
}

const popularCourses = filteredDeals
  .filter(deal => deal.rating && deal.rating >= 4.5)
  .sort((a, b) => (b.rating || 0) - (a.rating || 0))
  .slice(0, 100);

// ── Stats ─────────────────────────────────────────────────────────────────────
const totalDeals = allDeals.length;
const totalPopular = popularCourses.length;
const avgRating = popularCourses.length > 0
  ? (popularCourses.reduce((sum, c) => sum + (c.rating ?? 0), 0) / popularCourses.filter(c => c.rating).length).toFixed(1)
  : "5.0";

// ── Categories ────────────────────────────────────────────────────────────────
const categoryMap = new Map<string, number>();
allDeals.forEach(deal => {
  const name = normName(deal.category) || "Uncategorized";
  categoryMap.set(name, (categoryMap.get(name) ?? 0) + 1);
});
const categories = Array.from(categoryMap.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 9)
  .map(([name, count]) => ({ name, count }));

// ── SEO — popular online courses keyword matching URL path ───────
const langSuffix = selectedLanguage ? ` in ${selectedLanguage}` : "";
const pageTitle = `Most Popular Udemy Courses & Top-Rated Online Classes${langSuffix} | CoursesWyn`;
const pageDescription = `Browse top-rated Udemy courses with verified coupon codes${langSuffix}. Discover trending classes in programming, design, marketing & data science — updated daily.`;
const canonicalUrl = selectedLanguage 
  ? `https://courseswyn.com/popular?language=${encodeURIComponent(selectedLanguage)}`
  : "https://courseswyn.com/popular";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": canonicalUrl,
      "url": canonicalUrl,
      "name": pageTitle,
      "description": pageDescription,
      "inLanguage": "en-US",
      "dateModified": toISODateWIB(),
      "isPartOf": { "@id": "https://courseswyn.com" },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" },
          { "@type": "ListItem", "position": 2, "name": "Popular Courses", "item": canonicalUrl }
        ]
      },
      "mainEntity": {
        "@type": "ItemList",
        "name": "Popular Online Courses",
        "numberOfItems": totalPopular,
        "itemListElement": popularCourses.slice(0, 10).map((course, index) => ({
          "@type": "ListItem",
          "position": index + 1,
          "item": {
            "@type": "Course",
            "name": course.title,
            "description": course.description || `Popular Udemy course with ${course.rating}★ rating`,
            "url": `https://courseswyn.com/coupon/${course.slug || course.id}`,
            "provider": {
              "@type": "Organization",
              "name": course.provider || "Udemy",
              "sameAs": "https://www.udemy.com"
            },
            ...(course.rating ? {
              "aggregateRating": {
                "@type": "AggregateRating",
                "ratingValue": course.rating.toFixed(1),
                "bestRating": "5",
                "worstRating": "1",
                "ratingCount": Math.max(10, course.students ?? 100)
              }
            } : {})
          }
        }))
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What are popular online courses on CoursesWyn?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "CoursesWyn's Popular page showcases trending online courses with 4.5-5.0★ student ratings. These are the most sought-after Udemy courses — where students consistently give high scores and enroll in high numbers."
          }
        },
        {
          "@type": "Question",
          "name": "Are top-rated Udemy courses free on CoursesWyn?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. CoursesWyn lists verified coupon codes for all featured courses. Many have 100% off coupons making them completely free. Click any course to see the current coupon and discounted price."
          }
        },
        {
          "@type": "Question",
          "name": "How are popular online courses ranked?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Popular courses are ranked by a combination of student rating (4.5-5.0★), enrollment numbers, and recent engagement. This ensures you discover courses that are both high-quality and currently trending among learners."
          }
        },
        {
          "@type": "Question",
          "name": "Do popular online courses include a completion certificate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. All Udemy courses listed on CoursesWyn include a certificate of completion you can share on LinkedIn or add to your resume — regardless of whether you enrolled using a free coupon."
          }
        }
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <link rel="canonical" href={canonicalUrl} slot="head" />
  <meta property="og:title" content={pageTitle} slot="head" />
  <meta property="og:description" content={pageDescription} slot="head" />
  <meta property="og:url" content={canonicalUrl} slot="head" />
  <meta property="og:type" content="website" slot="head" />
  <meta name="twitter:card" content="summary_large_image" slot="head" />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <main style="background: #fafafa;">

    {/* ── HERO ── */}
    <section style="background: linear-gradient(135deg, #eef2ff, #faf5ff, #fdf2f8); padding: 6rem 0 5rem; position: relative; overflow: hidden;">
      <div aria-hidden="true" style="position:absolute;top:-20%;right:-10%;width:600px;height:600px;background:radial-gradient(circle,rgba(249,115,22,0.1) 0%,rgba(236,72,153,0.06) 40%,transparent 70%);border-radius:50%;pointer-events:none;"></div>
      <div aria-hidden="true" style="position:absolute;bottom:-15%;left:-5%;width:500px;height:500px;background:radial-gradient(circle,rgba(99,102,241,0.06) 0%,transparent 70%);border-radius:50%;pointer-events:none;"></div>
      <div class="container" style="position:relative;z-index:1;">
        <h1 style="font-size:clamp(2.5rem,5vw,3.5rem);font-weight:900;line-height:1.1;color:#111827;margin:0 0 1rem;letter-spacing:-0.03em;">
          Popular {selectedLanguage && <span style="color:#f97316">{selectedLanguage}</span>}<br/>
          <span style="background:linear-gradient(135deg,#ea580c,#db2777,#9333ea);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Courses.</span>
        </h1>
        <p style="font-size:1.125rem;color:#6b7280;max-width:640px;line-height:1.7;font-weight:500;margin:0 0 2.5rem;">
          Discover {totalPopular}+ trending online courses with exceptional student ratings. Popular Udemy courses with verified free coupons.
        </p>
        <div style="display:flex;gap:2rem;flex-wrap:wrap;padding-top:1.5rem;border-top:2px solid rgba(0,0,0,0.08);">
          {[
            { v: `${totalPopular}+`, l: "Popular" },
            { v: `${avgRating}★`, l: "Avg Rating" },
            { v: "100%", l: "Free Codes" }
          ].map(s => (
            <div style="display:flex;flex-direction:column;">
              <span style="font-size:1.75rem;font-weight:900;color:#111827;">{s.v}</span>
              <span style="color:#6b7280;font-size:.875rem;font-weight:600;">{s.l}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── COURSES GRID ── */}
    <section style="background:white;padding:5rem 0;">
      <div class="container">
        <div style="display:inline-block;font-size:1rem;font-weight:900;text-transform:uppercase;letter-spacing:0.12em;color:#ea580c;margin-bottom:.75rem;">Top Rated</div>
        <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;margin-bottom:3rem;">
          <h2 style="font-size:2.5rem;font-weight:900;color:#111827;margin:0;letter-spacing:-0.02em;">Top Rated Courses</h2>
          <span style="font-size:0.8rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.1em;">Sorted by Popularity</span>
        </div>

        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:24px;margin-bottom:64px;">
          {popularCourses.length > 0 ? (
            popularCourses.map(course => (
              <DealCard deal={course} />
            ))
          ) : (
            <div style="grid-column:1/-1;text-align:center;padding:64px 24px;background:white;border:3px solid rgba(0,0,0,0.07);border-radius:20px;">
              <h3 style="font-size:1.5rem;font-weight:900;color:#111827;margin-bottom:8px;">No Popular {selectedLanguage} Courses</h3>
              <p style="color:#6b7280;font-weight:500;margin-bottom:24px;">We don't have any 4.5★+ rated {selectedLanguage} courses at the moment.</p>
              <a href="/popular" style="padding:12px 32px;background:linear-gradient(135deg,#f97316,#ea580c);color:#fff;text-decoration:none;border-radius:12px;font-weight:700;">View All Popular Courses</a>
            </div>
          )}
        </div>

        <div style="text-align:center;">
          <a href="/udemy-coupon-code" style="padding:1rem 2.5rem;background:#111827;color:#fff;text-decoration:none;border-radius:12px;font-size:1.1rem;font-weight:700;transition:all 0.3s ease;">
            Browse All {totalDeals}+ Deals
          </a>
        </div>
      </div>
    </section>

    {/* ── CATEGORIES ── */}
    <section style="background:#fafafa;padding:5rem 0;">
      <div class="container">
        <div style="display:inline-block;font-size:1rem;font-weight:900;text-transform:uppercase;letter-spacing:0.12em;color:#ea580c;margin-bottom:.75rem;">Categories</div>
        <h2 style="font-size:2.5rem;font-weight:900;color:#111827;margin:0 0 3rem;letter-spacing:-0.02em;">Browse Categories</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;">
          {categories.map(cat => (
            <a href={`/categories/${slugifyCategory(cat.name)}`} style="display:block;background:white;border:3px solid rgba(0,0,0,0.07);border-radius:20px;padding:1.5rem;text-align:center;text-decoration:none;color:inherit;transition:all 0.3s ease;" class="cat-card">
              <div style="font-weight:900;font-size:1rem;color:#111827;margin-bottom:4px;">{cat.name}</div>
              <div style="font-size:0.75rem;font-weight:800;color:#f97316;text-transform:uppercase;">{cat.count} Courses</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* ── FAQ ── */}
    <section style="background:white;padding:5rem 0;">
      <div class="container" style="max-width:800px;">
        <div style="display:inline-block;font-size:1rem;font-weight:900;text-transform:uppercase;letter-spacing:0.12em;color:#ea580c;margin-bottom:.75rem;">FAQ</div>
        <h2 style="font-size:2.5rem;font-weight:900;color:#111827;margin:0 0 3rem;letter-spacing:-0.02em;">Common Questions</h2>
        <div style="display:flex;flex-direction:column;gap:16px;">
          {[
            {
              q: "What are popular online courses on CoursesWyn?",
              a: "CoursesWyn's Popular page showcases trending online courses with 4.5-5.0★ student ratings. These are the most sought-after Udemy courses — where students consistently give high scores and enroll in high numbers."
            },
            {
              q: "Are popular online courses free on CoursesWyn?",
              a: "Yes. CoursesWyn lists verified coupon codes for all featured courses. Many have 100% off coupons making them completely free. Click any course card to see the current coupon and discounted price before enrolling."
            },
            {
              q: "How are popular online courses ranked?",
              a: "Popular courses are ranked by a combination of student rating (4.5-5.0★), enrollment numbers, and recent engagement. This ensures you discover courses that are both high-quality and currently trending among learners."
            },
            {
              q: "Do popular online courses include a completion certificate?",
              a: "Yes. All Udemy courses listed on CoursesWyn include a certificate of completion you can share on LinkedIn or add to your resume — regardless of whether you enrolled using a free coupon."
            }
          ].map(faq => (
            <details style="background:white;border:3px solid rgba(0,0,0,0.07);border-radius:20px;overflow:hidden;" class="faq-item">
              <summary style="padding:1.5rem;font-weight:700;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-size:1.05rem;color:#111827;list-style:none;">
                {faq.q}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="3" class="fi" style="transition:transform 0.3s;flex-shrink:0;"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div style="padding:0 1.5rem 1.5rem;color:#6b7280;font-size:1rem;line-height:1.7;">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

  </main>

  <style>
    .container { max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; }
    .cat-card:hover { transform: translateY(-4px) scale(1.01); box-shadow: 0 16px 32px -8px rgba(0,0,0,0.12); border-color: rgba(249,115,22,0.3) !important; }
    .faq-item[open] summary { border-bottom: 1px solid rgba(0,0,0,0.07); }
    .faq-item[open] .fi { transform: rotate(180deg); }
    .faq-item summary::-webkit-details-marker { display: none; }
  </style>

  <script define:vars={{ totalPopular }}>
    const GEO_COPY = {
      US: '🇺🇸 Popular in the United States — Top Udemy courses with verified English-language coupons.',
      GB: '🇬🇧 Trending in the UK — Expert Udemy courses with exclusive discount codes for UK learners.',
      IN: '🇮🇳 Top picks for India — Thousands of Indian learners save daily with these Udemy course coupons.',
      AU: '🇦🇺 Trending in Australia — Verified Udemy course coupons available to you right now.',
      CA: '🇨🇦 Popular in Canada — Get free and discounted Udemy courses from top instructors.',
      DE: '🇩🇪 Beliebt in Deutschland — Verifizierte Udemy-Coupons von Top-Kursen, täglich aktualisiert.',
      BR: '🇧🇷 Popular no Brasil — Cupons Udemy verificados dos melhores cursos, atualizados diariamente.',
      NG: '🇳🇬 Trending in Nigeria — Access world-class Udemy courses free with verified course coupons.',
      PH: '🇵🇭 Popular in the Philippines — Free and discounted Udemy courses from expert instructors.',
      ID: '🇮🇩 Populer di Indonesia — Kupon Udemy terverifikasi dari kursus terbaik, diperbarui harian.',
      PK: '🇵🇰 Trending in Pakistan — Get free Udemy courses from top instructors, verified every day.',
      EG: '🇪🇬 Popular in Egypt — Verified Udemy course coupons updated daily.',
      MX: '🇲🇽 Popular en México — Cupones Udemy verificados de los mejores cursos.',
      FR: '🇫🇷 Populaire en France — Coupons Udemy vérifiés auprès des meilleurs cours.',
      TR: '🇹🇷 Türkiye\'de popüler — En iyi Udemy kurslarından doğrulanmış kuponlar.',
      AR: '🇦🇷 Popular en Argentina — Cupones Udemy verificados de los mejores cursos.',
      SA: '🇸🇦 رائج في المملكة العربية السعودية — كوبونات Udemy موثقة من أفضل الدورات.',
      NL: '🇳🇱 Populair in Nederland — Geverifieerde Udemy-coupons van topcursussen.',
      ES: '🇪🇸 Popular en España — Cupones Udemy verificados de los mejores cursos.',
      IT: '🇮🇹 Popolare in Italia — Coupon Udemy verificati dai migliori corsi.',
    };

    async function initGeo() {
      const banner  = document.getElementById('geo-banner');
      const geoText = document.getElementById('geo-text');
      if (!banner || !geoText) return;

      try {
        const cached = sessionStorage.getItem('cs_geo');
        let geo;

        if (cached) {
          geo = JSON.parse(cached);
        } else {
          const res = await fetch('https://ipapi.co/json/', {
            signal: AbortSignal.timeout(4000),
          });
          if (!res.ok) return;
          geo = await res.json();
          sessionStorage.setItem('cs_geo', JSON.stringify(geo));
        }

        const code = (geo.country_code ?? '').toUpperCase();
        const msg  = GEO_COPY[code]
          ?? `📍 Browsing from ${geo.country_name ?? 'your region'} — Verified Udemy course coupons available now.`;

        geoText.textContent = msg;
        banner.style.display = 'block';
      } catch { }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initGeo);
    } else {
      initGeo();
    }
  </script>
</Layout>