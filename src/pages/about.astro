            <div class="card-sm">
              <div class="card-sm-icon accent-bg">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
                  <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                </svg>
              </div>
              <h3>Daily Updates</h3>
              <p>Fresh deals added every single day</p>
            </div>
            <div class="card-sm">
              <div class="card-sm-icon teal-bg">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
              <h3>Premium Quality</h3>
              <p>4.5★+ courses from expert instructors</p>
            </div>
            <div class="card-sm">
              <div class="card-sm-icon red-bg">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
                  <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                </svg>
              </div>
              <h3>Lifetime Access</h3>
              <p>Free courses with lifetime access</p>
            </div>
            <div class="card-sm">
              <div class="card-sm-icon yellow-bg">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
              </div>
              <h3>Community 150K+</h3>
