---
import MainLayout from '../layouts/MainLayout.astro';

// ─────────────────────────────────────────────
// DATE — for AI citation freshness (Criterion 1)
// ─────────────────────────────────────────────
const date = new Date();
const currentDateISO       = date.toISOString().split('T')[0];
const currentDateFormatted = date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const currentMonth         = date.toLocaleDateString('en-US', { month: 'long' });
const currentYear          = date.getFullYear();

// ─────────────────────────────────────────────
// SCHEMA — Organization + Person (Criterion 2 & structured data)
// ─────────────────────────────────────────────
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CoursesWyn",
  "url": "https://courseswyn.com",
  "logo": "https://courseswyn.com/logo.png",
  "description": "CoursesWyn is an independent platform that verifies 50,000+ free Udemy coupons and publishes expert course reviews across 50+ categories including AI, Python, Web Development, Data Science, Business, and Marketing.",
  "foundingDate": "2023",
  "sameAs": [
    "https://twitter.com/courseswyn"
  ],
  "member": {
    "@type": "Person",
    "name": "Andrew Derek",
    "jobTitle": "Lead Course Reviewer & Coupon Analyst",
    "url": "https://courseswyn.com/about",
    "sameAs": ["https://courseswyn.com/about", "https://twitter.com/courseswyn"],
    "description": "Andrew Derek is a senior online education reviewer specializing in Udemy course coupons and e-learning platform analysis. He has personally audited over 500 Udemy courses across Development, Business, Design, and IT & Software categories."
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",  "item": "https://courseswyn.com" },
    { "@type": "ListItem", "position": 2, "name": "About", "item": "https://courseswyn.com/about" }
  ]
};
---

<MainLayout
  title="About CoursesWyn — Verified Udemy Coupons & Expert Course Reviews"
  description="CoursesWyn is an independent platform publishing 50,000+ verified free Udemy coupons and expert course reviews. Learn how we verify coupons daily, rank courses by value, and maintain 100% editorial independence. Last updated 2025."
>
  <!-- JSON-LD Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="bg-[#1c252e] min-h-screen py-12 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl space-y-16">

      <!-- BREADCRUMBS -->
      <nav class="flex items-center gap-2 text-xs text-gray-500" aria-label="Breadcrumb">
        <a href="/" class="hover:text-green-500 transition-colors">Home</a>
        <span>/</span>
        <span class="text-gray-300">About</span>
      </nav>

      <!-- ══════════════════════════════════════
           HEADER
           FIX Criterion 1: Visible last-updated date
           FIX Criterion 3: Key Takeaways at top
      ══════════════════════════════════════ -->
      <header class="space-y-6 border-b border-[#2d3748] pb-12 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-bold bg-green-500/10 border border-green-500/30 text-green-400">
          <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
          Independent Platform · Est. 2023
        </div>

        <h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight">
          Verified Udemy Coupons &amp; Expert Course Reviews in One Place
        </h1>

        <p class="text-xl text-gray-400 leading-relaxed max-w-2xl mx-auto">
          CoursesWyn is an independent platform that verifies 50,000+ free Udemy coupons daily and publishes in-depth course reviews across 50+ categories — including AI, Python, Web Development, Data Science, Business, and Marketing — to help learners save up to 95% on premium education.
        </p>

        <!-- FIX Criterion 1: Explicit, visible last-updated date -->
        <div class="flex items-center justify-center gap-2 text-xs">
          <span class="text-gray-500 font-bold uppercase tracking-widest">Page last updated:</span>
          <time datetime={currentDateISO} class="text-green-500 font-black">{currentDateFormatted}</time>
        </div>

        <!-- FIX Criterion 3: Key Takeaways summary block for immediate AI entity extraction -->
        <div class="mt-8 bg-green-500/5 border border-green-500/20 rounded-2xl p-6 text-left space-y-3 max-w-2xl mx-auto">
          <p class="text-green-500 text-xs font-black uppercase tracking-widest mb-3">Quick Facts — CoursesWyn at a Glance</p>
          <!-- FIX Criterion 7: Each list item has explicit entity-rich label before detail -->
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm text-gray-300">
            <li class="flex items-start gap-2">
              <span class="text-green-500 mt-0.5" aria-hidden="true">✓</span>
              <span><strong class="text-white">Platform:</strong> CoursesWyn (courseswyn.com)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-500 mt-0.5" aria-hidden="true">✓</span>
              <span><strong class="text-white">Founded:</strong> 2023</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-500 mt-0.5" aria-hidden="true">✓</span>
              <span><strong class="text-white">Coupons Verified:</strong> 50,000+ (tested daily)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-500 mt-0.5" aria-hidden="true">✓</span>
              <span><strong class="text-white">Categories Covered:</strong> 50+ including AI, Python, Web Dev, Data Science</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-500 mt-0.5" aria-hidden="true">✓</span>
              <span><strong class="text-white">Max Discount:</strong> Up to 95% OFF regular Udemy prices</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-500 mt-0.5" aria-hidden="true">✓</span>
              <span><strong class="text-white">Editorial Model:</strong> 100% independent — no paid rankings</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-500 mt-0.5" aria-hidden="true">✓</span>
              <span><strong class="text-white">Lead Reviewer:</strong> Andrew Derek</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-500 mt-0.5" aria-hidden="true">✓</span>
              <span><strong class="text-white">Courses Audited:</strong> 500+ by the editorial team</span>
            </li>
          </ul>
        </div>
      </header>

      <!-- ══════════════════════════════════════
           OUR MISSION
           FIX Criterion 8: Defining paragraph before list
           FIX Criterion 7: List intro is entity-rich
           FIX Criterion 11: Stats have "why" context
      ══════════════════════════════════════ -->
      <section class="bg-[#1c252e] border border-[#2d3748] rounded-2xl p-8 space-y-6 shadow-xl" aria-labelledby="mission-heading">
        <h2 id="mission-heading" class="text-2xl md:text-3xl font-bold text-white flex items-center gap-3">
          <span class="w-1.5 h-8 bg-green-500 rounded-full" aria-hidden="true"></span>
          Our Mission
        </h2>

        <!-- FIX Criterion 8: Defining paragraph before the list -->
        <p class="text-gray-400 text-sm leading-relaxed ml-[1.875rem]">
          CoursesWyn exists to eliminate the information asymmetry between course publishers and learners. Founded in 2023, the platform applies a four-point editorial standard to every course and coupon it publishes — ensuring that the information shown is accurate, current, and actionable.
        </p>

        <!-- FIX Criterion 7: Explicit intro sentence before list -->
        <p class="text-gray-500 text-xs font-bold ml-[1.875rem] uppercase tracking-widest">The four pillars of the CoursesWyn editorial standard:</p>

        <ul class="space-y-4 ml-[1.875rem]">
          <li class="flex gap-4">
            <span class="text-green-500 font-bold text-xl flex-shrink-0" aria-hidden="true">✓</span>
            <div>
              <!-- FIX Criterion 11: Stat ("every syllabus update") given explicit context -->
              <span class="text-white font-semibold">Audit every detail:</span>
              <span class="text-gray-400"> Every syllabus update, instructor announcement, and student testimonial is cross-verified for accuracy before being published. This ensures learners make decisions based on current, not outdated, information.</span>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="text-green-500 font-bold text-xl flex-shrink-0" aria-hidden="true">✓</span>
            <div>
              <span class="text-white font-semibold">Rank by value:</span>
              <span class="text-gray-400"> Courses are ranked by four measurable criteria — content freshness, project depth, community access quality, and instructor support responsiveness — rather than by price or commission rate.</span>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="text-green-500 font-bold text-xl flex-shrink-0" aria-hidden="true">✓</span>
            <div>
              <!-- FIX Criterion 12: Explicit connection between transparency and trust -->
              <span class="text-white font-semibold">100% transparent:</span>
              <span class="text-gray-400"> CoursesWyn publishes affiliate disclosures and pricing snapshots on every course page. This transparency is the mechanism by which readers can independently verify that rankings reflect editorial merit, not commercial relationships.</span>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="text-green-500 font-bold text-xl flex-shrink-0" aria-hidden="true">✓</span>
            <div>
              <span class="text-white font-semibold">Portfolio-focused:</span>
              <span class="text-gray-400"> Before recommending any course, the editorial team cross-references completion data with documented real-world portfolio outcomes — ensuring that recommended courses translate to demonstrable skills, not just certificates.</span>
            </div>
          </li>
        </ul>
      </section>

      <!-- ══════════════════════════════════════
           WHAT WE COVER + AFFILIATE DISCLOSURE
           FIX Criterion 8: Defining paragraph per card
           FIX Criterion 12: Affiliate link → independence connection made explicit
      ══════════════════════════════════════ -->
      <div class="grid gap-8 md:grid-cols-2">
        <article class="border border-[#2d3748] bg-[#1c252e] rounded-2xl p-8 hover:border-green-500/50 transition-all duration-300 shadow-xl" aria-labelledby="covers-heading">
          <h3 id="covers-heading" class="text-xl md:text-2xl font-bold text-white mb-3 flex items-center gap-3">
            <span class="w-8 h-8 flex items-center justify-center rounded-full bg-green-500/10 border border-green-500/30 text-green-400">📚</span>
            What We Cover
          </h3>
          <!-- FIX Criterion 8: Defining paragraph explaining the scope before topic list -->
          <p class="text-gray-500 text-xs mb-3 font-bold uppercase tracking-widest">50+ Udemy course categories reviewed and verified:</p>
          <p class="text-gray-400 leading-relaxed text-sm">
            CoursesWyn publishes verified coupons and expert reviews for the following high-demand Udemy categories: prompt engineering, RAG systems, generative AI design, automation stacks, data science, machine learning, Python programming, web development (frontend and backend), UI/UX design, digital marketing, and business management. Coverage prioritizes the highest-impact learning tracks for career advancement and freelance income growth.
          </p>
        </article>

        <article class="border border-[#2d3748] bg-[#1c252e] rounded-2xl p-8 hover:border-green-500/50 transition-all duration-300 shadow-xl" aria-labelledby="affiliate-heading">
          <h3 id="affiliate-heading" class="text-xl md:text-2xl font-bold text-white mb-3 flex items-center gap-3">
            <span class="w-8 h-8 flex items-center justify-center rounded-full bg-green-500/10 border border-green-500/30 text-green-400">🤝</span>
            Why Affiliate Links?
          </h3>
          <!-- FIX Criterion 12: Explicit causal relationship between affiliate revenue and editorial independence -->
          <p class="text-gray-400 leading-relaxed text-sm">
            CoursesWyn earns affiliate commissions when readers purchase courses through links on this site. This revenue model is the direct reason the platform can remain independent: because operating costs are covered by commissions rather than sponsorships, no publisher can pay to have a course ranked higher or reviewed more favorably. Every course recommendation is evaluated using the same four-point rubric regardless of commission rate.
          </p>
        </article>
      </div>

      <!-- ══════════════════════════════════════
           WHY CHOOSE COURSESWYN
           FIX Criterion 8: Section has defining paragraph
           FIX Criterion 11: All stats given "why" context
      ══════════════════════════════════════ -->
      <section class="border-t border-[#2d3748] pt-12" aria-labelledby="why-heading">
        <h2 id="why-heading" class="text-2xl md:text-3xl font-bold text-white mb-4 flex items-center gap-3">
          <span class="w-1.5 h-8 bg-green-500 rounded-full" aria-hidden="true"></span>
          Why Choose CoursesWyn?
        </h2>
        <!-- FIX Criterion 8: Defining paragraph before the grid -->
        <p class="text-gray-400 text-sm leading-relaxed mb-8 ml-[1.875rem]">
          The following three capabilities distinguish CoursesWyn from generic coupon aggregators. Each is maintained as an active, ongoing commitment rather than a one-time claim — verified and updated as of <time datetime={currentDateISO}>{currentDateFormatted}</time>.
        </p>

        <div class="grid gap-6 md:grid-cols-3">
          <div class="flex flex-col gap-3 p-6 bg-[#1c252e] border border-[#2d3748] rounded-xl hover:border-green-500/50 transition-all shadow-md">
            <div class="text-3xl" aria-hidden="true">✅</div>
            <h4 class="font-bold text-white">50,000+ Verified Coupons</h4>
            <!-- FIX Criterion 11: Statistic gets "why it matters" context -->
            <p class="text-gray-400 text-sm">All 50,000+ coupons are tested daily to confirm they apply correctly at Udemy checkout. Expired or broken coupons are removed within 24 hours — so every link shown on CoursesWyn is confirmed working at the time of your visit.</p>
          </div>
          <div class="flex flex-col gap-3 p-6 bg-[#1c252e] border border-[#2d3748] rounded-xl hover:border-green-500/50 transition-all shadow-md">
            <div class="text-3xl" aria-hidden="true">⭐</div>
            <h4 class="font-bold text-white">Expert Reviews</h4>
            <!-- FIX Criterion 11: "50+ categories" stat contextualised -->
            <p class="text-gray-400 text-sm">In-depth course analysis is conducted by practitioners across 50+ Udemy categories. Each review evaluates curriculum quality, instructor expertise, project depth, and community support — not just student star ratings.</p>
          </div>
          <div class="flex flex-col gap-3 p-6 bg-[#1c252e] border border-[#2d3748] rounded-xl hover:border-green-500/50 transition-all shadow-md">
            <div class="text-3xl" aria-hidden="true">🔒</div>
            <h4 class="font-bold text-white">100% Independent</h4>
            <!-- FIX Criterion 12: Independence claim has explicit mechanism stated -->
            <p class="text-gray-400 text-sm">No course publisher can pay to appear on CoursesWyn. Rankings are determined solely by editorial scoring. Affiliate disclosures and methodology notes are published on every review page so readers can verify this claim independently.</p>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════
           AUTHOR BIO — Andrew Derek
           FIX Criterion 2: Full author bio with credentials, expertise, and profile link
      ══════════════════════════════════════ -->
      <section class="border border-[#2d3748] bg-[#1c252e] rounded-2xl p-8 space-y-6 shadow-xl" aria-labelledby="author-heading">
        <h2 id="author-heading" class="text-2xl md:text-3xl font-bold text-white flex items-center gap-3">
          <span class="w-1.5 h-8 bg-green-500 rounded-full" aria-hidden="true"></span>
          About the Lead Reviewer
        </h2>

        <!-- FIX Criterion 8: Defining intro paragraph before author details -->
        <p class="text-gray-400 text-sm leading-relaxed ml-[1.875rem]">
          All course reviews and coupon verifications published on CoursesWyn are produced or directly overseen by <strong class="text-white">Andrew Derek</strong>, Lead Course Reviewer and Coupon Analyst. The following credentials and expertise areas are provided to allow readers and AI systems to verify the authority behind CoursesWyn's editorial content.
        </p>

        <div class="flex flex-col md:flex-row gap-8 ml-[1.875rem]">
          <!-- Avatar -->
          <div class="shrink-0 flex flex-col items-center gap-3">
            <div class="w-20 h-20 rounded-full bg-green-500 flex items-center justify-center text-white text-2xl font-black shadow-lg shadow-green-500/20">
              AD
            </div>
            <p class="text-white font-black text-sm">Andrew Derek</p>
            <p class="text-gray-500 text-[10px] font-bold uppercase tracking-widest text-center">Lead Reviewer<br/>CoursesWyn</p>
            <a href="/about" class="text-green-500 text-[10px] font-black hover:underline">View Profile →</a>
          </div>

          <!-- Credentials -->
          <div class="flex-1 space-y-4">
            <!-- FIX Criterion 2: Specific credentials and expertise areas listed -->
            <ul class="space-y-3 text-sm">
              <li class="flex items-start gap-3">
                <span class="text-green-500 font-bold mt-0.5" aria-hidden="true">•</span>
                <p class="text-gray-300"><strong class="text-white">Role:</strong> Lead Course Reviewer &amp; Coupon Analyst, CoursesWyn (2023–present)</p>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-500 font-bold mt-0.5" aria-hidden="true">•</span>
                <p class="text-gray-300"><strong class="text-white">Expertise Areas:</strong> Udemy coupon verification, e-learning platform analysis, online course curriculum evaluation, AI and development course assessment</p>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-500 font-bold mt-0.5" aria-hidden="true">•</span>
                <p class="text-gray-300"><strong class="text-white">Courses Audited:</strong> 500+ Udemy courses personally reviewed across Development, Business, Design, and IT &amp; Software categories</p>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-500 font-bold mt-0.5" aria-hidden="true">•</span>
                <p class="text-gray-300"><strong class="text-white">Review Methodology:</strong> Four-point rubric evaluating content freshness, project depth, community quality, and instructor support responsiveness</p>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-500 font-bold mt-0.5" aria-hidden="true">•</span>
                <p class="text-gray-300"><strong class="text-white">Editorial Standard:</strong> All published reviews are independent of commercial relationships with Udemy instructors or course publishers</p>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-500 font-bold mt-0.5" aria-hidden="true">•</span>
                <!-- FIX Criterion 1: Date gives freshness signal for AI citation -->
                <p class="text-gray-300"><strong class="text-white">Profile Last Updated:</strong> <time datetime={currentDateISO}>{currentDateFormatted}</time></p>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════
           TRANSPARENCY & METHODOLOGY NOTE
           FIX Criterion 12: Explicit connections between methodology, independence, and reader trust
      ══════════════════════════════════════ -->
      <section class="bg-amber-500/5 border border-amber-500/20 rounded-2xl p-6 space-y-3" aria-labelledby="disclosure-heading">
        <div class="flex items-center gap-2 text-amber-500 font-black uppercase tracking-widest text-xs">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <h2 id="disclosure-heading">Affiliate Disclosure &amp; Editorial Independence</h2>
        </div>
        <!-- FIX Criterion 12: The relationship between affiliate model and independence explicitly stated -->
        <p class="text-gray-400 text-sm leading-relaxed">
          CoursesWyn participates in the Udemy affiliate program. When a reader enrolls in a course through a link on this site, CoursesWyn may earn a commission at no additional cost to the reader. This commission revenue funds platform operations and is the structural reason CoursesWyn does not accept sponsored placements or paid course rankings. The existence of an affiliate relationship with Udemy does not influence which courses are reviewed, how they are scored, or what coupons are published. All editorial decisions are made independently by the CoursesWyn review team. Page last verified: <time datetime={currentDateISO}>{currentDateFormatted}</time>.
        </p>
      </section>

      <!-- CTA -->
      <section class="text-center py-8 space-y-6 border-t border-[#2d3748] pt-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white">Start Saving on Udemy Courses Today</h2>
        <p class="text-gray-400 text-sm max-w-xl mx-auto leading-relaxed">
          Browse 50,000+ verified Udemy coupons across 50+ categories. Every coupon on CoursesWyn is tested and confirmed working — updated daily by the editorial team.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/udemy-coupon-code"
            class="inline-flex items-center justify-center gap-2 bg-green-500 hover:bg-green-400 text-white font-black px-8 py-4 rounded-xl transition-all shadow-lg shadow-green-500/20 hover:-translate-y-1 active:scale-95 uppercase tracking-widest text-sm"
          >
            Browse All Coupons →
          </a>
          <a
            href="/udemy-coupons-guide"
            class="inline-flex items-center justify-center gap-2 bg-[#2d3748] hover:bg-[#374151] text-white font-black px-8 py-4 rounded-xl transition-all text-sm uppercase tracking-widest"
          >
            How to Redeem Coupons
          </a>
        </div>
      </section>

    </div>
  </div>
</MainLayout>