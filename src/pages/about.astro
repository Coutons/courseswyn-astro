---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="About Courses Wyn | Verified Udemy Promo Codes & Savings"
    description="Learn about CoursesWyn's mission to make premium education affordable. We help thousands of learners access verified Udemy promo codes and discount vouchers daily."
>
    <main style={{ background: "var(--bg)" }}>
        {/* ── Hero Section ── */}
        <section style={{ padding: "100px 0 80px", borderBottom: "2px solid var(--border)", background: "var(--bg-secondary)" }}>
            <div class="container">
                <div style={{
                    display: "inline-block",
                    background: "var(--bg-secondary)",
                    color: "var(--text)",
                    padding: "4px 14px",
                    border: "2px solid var(--border)",
                    boxShadow: "3px 3px 0 var(--border)",
                    borderRadius: "4px",
                    fontSize: "0.75rem",
                    fontWeight: 800,
                    marginBottom: "32px",
                    textTransform: "uppercase",
                    letterSpacing: "0.1em"
                }}>
                    Our Story & Mission
                </div>

                <h1 style={{ 
                    fontSize: "clamp(2.5rem, 7vw, 4.5rem)", 
                    fontWeight: 900, 
                    color: "var(--text)", 
                    lineHeight: 1.05, 
                    letterSpacing: "-0.04em",
                    marginBottom: "32px"
                }}>
                    Expert Education,<br/>
                    <span style={{ background: "var(--bg)", color: "var(--text)", padding: "0 10px" }}>Zero Barriers.</span>
                </h1>
                
                <p style={{ 
                    fontSize: "clamp(1.1rem, 3vw, 1.4rem)", 
                    color: "var(--muted)", 
                    maxWidth: "800px", 
                    lineHeight: 1.6,
                    fontWeight: 500 
                }}>
                    Founded in 2023, CoursesWyn is a specialized editorial team dedicated to vetting online education. We read the fine print, audit the curriculums, and verify the deals so you don't have to.
                </p>
            </div>
        </section>

        {/* ── Stats ── */}
        <section style={{ padding: "80px 0", borderBottom: "2px solid var(--border)" }}>
            <div class="container">
                <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(240px, 1fr))", gap: "24px" }}>
                    {[
                        { num: "50K+", label: "Happy Learners", color: "var(--accent)" },
                        { num: "1.2K+", label: "Course Audits", color: "var(--text)" },
                        { num: "100%", label: "Manual Verification", color: "var(--accent)" },
                        { num: "Daily", label: "Deal Updates", color: "var(--text)" }
                    ].map(stat => (
                        <div style={{ 
                            padding: "40px", 
                            background: "var(--bg-secondary)", 
                            border: "2px solid var(--border)", 
                            boxShadow: "5px 5px 0 var(--border)",
                            borderRadius: "8px",
                            textAlign: "center"
                        }}>
                            <div style={{ fontSize: "3rem", fontWeight: 900, color: stat.color, marginBottom: "8px", letterSpacing: "-0.05em" }}>{stat.num}</div>
                            <div style={{ fontSize: "0.85rem", fontWeight: 800, color: "var(--muted)", textTransform: "uppercase", letterSpacing: "0.1em" }}>{stat.label}</div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        {/* ── Mission ── */}
        <section style={{ padding: "100px 0", background: "var(--bg)", color: "var(--text)" }}>
            <div class="container">
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "80px", alignItems: "center" }}>
                    <div>
                        <h2 style={{ fontSize: "3rem", fontWeight: 900, marginBottom: "32px", letterSpacing: "-0.04em", lineHeight: 1.1 }}>
                            Why We Audit the <span style={{ color: "var(--accent)" }}>Udemy Ecosystem.</span>
                        </h2>
                        <p style={{ fontSize: "1.1rem", lineHeight: 1.7, color: "rgba(255,255,255,0.7)", marginBottom: "32px" }}>
                            The online learning market is flooded with low-quality content. Our mission is to protect your time and money by highlighting only the gold standard of digital education.
                        </p>
                        <ul style={{ listStyle: "none", padding: 0, margin: 0, display: "flex", flexDirection: "column", gap: "20px" }}>
                            {[
                                "Manual curriculum verification for every top-rated course.",
                                "Strict 4-hour update & purge window for all promo codes.",
                                "Instructor credibility and history background checks.",
                                "Real outcome tracking from actual students."
                            ].map(item => (
                                <li style={{ display: "flex", gap: "16px", alignItems: "flex-start", fontWeight: 700 }}>
                                    <span style={{ color: "var(--accent)" }}>✓</span>
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div style={{ 
                        border: "4px solid var(--accent)", 
                        padding: "48px", 
                        background: "rgba(255,255,255,0.05)",
                        borderRadius: "12px",
                        boxShadow: "12px 12px 0 var(--accent)"
                    }}>
                        <h3 style={{ fontSize: "1.5rem", fontWeight: 900, marginBottom: "24px" }}>The CoursesWyn Guarantee</h3>
                        <p style={{ fontSize: "1rem", lineHeight: 1.7, color: "rgba(255,255,255,0.6)" }}>
                            We never list a deal we wouldn't use ourselves. Our team tests every single link, coupon, and checkout process manually. If it's on CoursesWyn, it's verified.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        {/* ── CTA ── */}
        <section style={{ padding: "100px 0", textAlign: "center" }}>
            <div class="container">
                <h2 style={{ fontSize: "2.5rem", fontWeight: 900, marginBottom: "24px" }}>Ready to start learning?</h2>
                <div style={{ display: "flex", gap: "16px", justifyContent: "center", flexWrap: "wrap" }}>
                    <a href="/blog" class="btn" style={{ padding: "16px 40px", fontSize: "1.1rem" }}>View Best Courses</a>
                    <a href="/udemy-coupon-code" class="btn btn-outline" style={{ padding: "16px 40px", fontSize: "1.1rem" }}>Get Promo Codes</a>
                </div>
            </div>
        </section>
    </main>

    <style>
        .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
        @media (max-width: 900px) {
            section > .container > div[style*="grid-template-columns: 1fr 1fr"] { grid-template-columns: 1fr !important; gap: 40px !important; }
        }
    </style>
</Layout>
