---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="About CoursesWyn: Free Udemy Coupons"
    description="Discover CoursesWyn: Your trusted source for verified free Udemy coupons and 100% off online courses. Join 150K+ learners accessing premium education without cost."
    image="https://courseswyn.com/logo.svg"
    canonical="https://courseswyn.com/about"
>
    <!-- About Page Enhanced Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "AboutPage",
          "@id": "https://courseswyn.com/about",
          "url": "https://courseswyn.com/about",
          "name": "About CoursesWyn - Free Udemy Coupons Platform",
          "description": "Learn about CoursesWyn's mission to make quality education accessible through verified 100% off Udemy coupons. Helping 150K+ learners access premium courses for free.",
          "isPartOf": {
            "@id": "https://courseswyn.com"
          },
          "primaryImageOfPage": {
            "@type": "ImageObject",
            "url": "https://courseswyn.com/logo.svg"
          },
          "datePublished": "2023-01-01",
          "dateModified": "2026-05-24",
          "inLanguage": "en-US",
          "breadcrumb": {
            "@type": "BreadcrumbList",
            "itemListElement": [
              {
                "@type": "ListItem",
                "position": 1,
                "name": "Home",
                "item": "https://courseswyn.com"
              },
              {
                "@type": "ListItem",
                "position": 2,
                "name": "About",
                "item": "https://courseswyn.com/about"
              }
            ]
          },
          "mainEntity": {
            "@type": "Organization",
            "name": "CoursesWyn",
            "description": "Online learning platform providing free Udemy course coupons and discounts",
            "foundingDate": "2023",
            "mission": "To make quality education accessible and affordable for everyone through verified coupon codes",
            "author": {
              "@type": "Person",
              "name": "CoursesWyn Team",
              "jobTitle": "Founder & Education Advocate",
              "description": "Passionate about democratizing education and removing financial barriers to quality learning"
            }
          }
        },
        {
          "@type": "Organization",
          "@id": "https://courseswyn.com/#organization",
          "name": "CoursesWyn",
          "url": "https://courseswyn.com",
          "logo": "https://courseswyn.com/logo.svg",
          "description": "Free Udemy coupons platform helping learners access premium courses for free",
          "foundingDate": "2023",
          "numberOfEmployees": "1-10",
          "areaServed": "Worldwide",
          "contactPoint": {
            "@type": "ContactPoint",
            "contactType": "Customer Support",
            "url": "https://courseswyn.com/contact"
          },
          "sameAs": [
            "https://x.com/courses_peak",
            "https://www.facebook.com/BestCouponPromo/"
          ],
          "knowsAbout": ["Udemy Coupons", "Online Education", "Free Courses", "Course Discounts", "Educational Technology"],
          "founder": {
            "@type": "Person",
            "name": "CoursesWyn Team",
            "description": "Education Advocate & Platform Creator"
          }
        },
        {
          "@type": "WebSite",
          "@id": "https://courseswyn.com/#website",
          "url": "https://courseswyn.com",
          "name": "CoursesWyn",
          "description": "Free Udemy coupons and premium courses for learners worldwide",
          "publisher": {
            "@id": "https://courseswyn.com/#organization"
          },
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": "https://courseswyn.com/search?q={search_term_string}"
            },
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "Article",
          "@id": "https://courseswyn.com/about#article",
          "headline": "About CoursesWyn - How We're Democratizing Online Education",
          "alternativeHeadline": "Free Udemy Coupons & Premium Courses for 150K+ Learners",
          "description": "Learn how CoursesWyn helps 150K+ students access premium Udemy courses for free with verified coupons. Discover our mission, team, and why educators choose us.",
          "image": "https://courseswyn.com/logo.svg",
          "datePublished": "2023-01-01",
          "dateModified": "2026-05-24",
          "author": {
            "@type": "Person",
            "name": "Josh Smith",
            "jobTitle": "Lead Course Reviewer",
            "url": "https://courseswyn.com/about",
            "sameAs": ["https://x.com/courses_peak", "https://www.facebook.com/BestCouponPromo/"]
          },
          "publisher": {
            "@id": "https://courseswyn.com/#organization"
          },
          "articleBody": "CoursesWyn is a platform dedicated to making quality education accessible to everyone. Founded in 2023, we provide verified 100% off Udemy coupons and free course deals from top learning platforms worldwide. Our mission is to democratize education and remove financial barriers to premium learning. With 150K+ happy learners and 50K+ free courses, we've established ourselves as the most trusted coupon platform. Our team, led by reviewer Josh Smith, meticulously vets every course to ensure only the best educational content reaches our community.",
          "wordCount": 2000,
          "inLanguage": "en-US",
          "isAccessibleForFree": true,
          "isPartOf": {
            "@id": "https://courseswyn.com/#website"
          },
          "mainEntity": {
            "@id": "https://courseswyn.com/#organization"
          }
        },
        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "What makes CoursesWyn different from other coupon sites?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "CoursesWyn offers 100% verified coupons that are tested before sharing. We focus on premium quality courses from reputable instructors with daily updates and lifetime access to all free courses. Our Lead Reviewer Josh Smith personally curates every course to ensure 4.5★+ quality standards."
              }
            },
            {
              "@type": "Question",
              "name": "Is CoursesWyn really free?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes, CoursesWyn is completely free to use. We provide verified free course deals and 100% off Udemy coupons at no cost to our users. Our platform, coupons, and recommendations are all free."
              }
            },
            {
              "@type": "Question",
              "name": "How often are new deals added?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "We add fresh coupons and deals every single day, 24/7. Our team continuously searches and verifies new opportunities for our community. On average we add 50+ new deals daily."
              }
            },
            {
              "@type": "Question",
              "name": "Do free courses include certificates?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes, most of our featured free courses include completion certificates. When you enroll through our verified coupons, you get lifetime access to the course material, completion certificate, and all premium features."
              }
            },
            {
              "@type": "Question",
              "name": "How do you choose which courses to feature?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Every course featured on CoursesWyn goes through rigorous review. We only feature courses with 4.5★+ ratings, reputable instructors, comprehensive content, and proven student satisfaction. Quality over quantity is our priority."
              }
            },
            {
              "@type": "Question",
              "name": "How are coupons verified on CoursesWyn?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Every coupon code is personally tested before publishing to ensure it works. We check expiration dates, discount amounts, and course availability. We remove expired coupons immediately and update daily. This 100% verification guarantee sets us apart."
              }
            },
            {
              "@type": "Question",
              "name": "Is CoursesWyn affiliated with Udemy?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "While we're not officially affiliated with Udemy, we are an independent platform that helps learners find verified discounts and free courses on Udemy and other platforms. We maintain ethical standards and always provide authentic, working coupons."
              }
            },
            {
              "@type": "Question",
              "name": "How can I trust CoursesWyn coupons?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Every coupon on CoursesWyn is 100% verified and tested by our team. We check each code before publishing and remove expired ones immediately. With 150K+ satisfied learners, we've built a trusted reputation in the community."
              }
            }
          ]
        }
      ]
    }
    </script>

    <main>
      <!-- Hero Section -->
      <section class="hero-section">
        <div class="container narrow">
          <div class="hero-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            Our Story & Mission
          </div>
          <h1 class="hero-title">
            <span class="gradient-brand">About CoursesWyn</span>
            <br/>
            <span class="gradient-muted">Making Education Accessible for Everyone</span>
          </h1>
          <p class="hero-desc">
            Founded in 2023, CoursesWyn is on a mission to make quality education accessible to everyone. "Democratizing education" means removing financial barriers so anyone, anywhere can access premium online courses for free through verified Udemy coupons.
          </p>
        </div>
      </section>

      <!-- Impact Statistics -->
      <section class="section">
        <div class="container">
          <div class="section-header">
            <h2>Our Impact in Numbers</h2>
            <p>Making education accessible worldwide through verified coupon codes</p>
          </div>
          <div class="stat-grid">
            <div class="stat-card">
              <div class="stat-number brand">150K+</div>
              <div class="stat-label">Happy Learners</div>
              <div class="stat-desc">Students empowered with free education</div>
            </div>
            <div class="stat-card">
              <div class="stat-number accent">50K+</div>
              <div class="stat-label">Free Courses</div>
              <div class="stat-desc">Premium courses made accessible</div>
            </div>
            <div class="stat-card">
              <div class="stat-number teal">24/7</div>
              <div class="stat-label">Daily Updates</div>
              <div class="stat-desc">Fresh coupons added every day</div>
            </div>
            <div class="stat-card">
              <div class="stat-number red">4.8★</div>
              <div class="stat-label">Average Rating</div>
              <div class="stat-desc">Quality courses with high ratings</div>
            </div>
          </div>
        </div>
      </section>

      <!-- Mission & Values -->
      <section class="section">
        <div class="container">
          <div class="section-header">
            <h2>Our Mission & Values</h2>
            <p>What drives us to make education accessible for everyone</p>
          </div>
          <div class="mission-grid">
            <div class="card card-accent-brand">
              <div class="card-icon brand-bg">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="white">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
              <h3>Democratize Education</h3>
              <p>We believe everyone deserves access to quality education regardless of their financial situation. Our mission is to break down barriers to learning.</p>
            </div>
            <div class="card card-accent-accent">
              <div class="card-icon accent-bg">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="white">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
              </div>
              <h3>Quality First</h3>
              <p>We carefully curate only high-quality courses from reputable instructors and platforms. Every coupon is verified to ensure real value.</p>
            </div>
            <div class="card card-accent-teal">
              <div class="card-icon teal-bg">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="white">
                  <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                </svg>
              </div>
              <h3>Community Focused</h3>
              <p>We're building a global community of learners. Your success stories inspire others to pursue their educational goals without financial barriers.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Why Choose Us - Features Grid -->
      <section class="section">
        <div class="container">
          <div class="section-header">
            <h2>Why Learners Choose CoursesWyn</h2>
            <p>What sets us apart in the world of online education deals</p>
          </div>
          <div class="features-grid">
            <div class="card-sm">
              <div class="card-sm-icon brand-bg">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
