---
import MainLayout from '../layouts/MainLayout.astro';

const currentYear = new Date().getFullYear();

const pageTitle = `How to Redeem a Udemy Coupon in ${currentYear} — Step-by-Step Guide`;
const pageDescription = "Learn exactly how to redeem a Udemy coupon code in 5 steps. Includes what to do when a coupon doesn't work, common errors, and tips to always get the best price.";
---

<MainLayout title={pageTitle} description={pageDescription}>
  <div class="bg-[#1c252e] min-h-screen py-16 px-4">
    <div class="max-w-4xl mx-auto">
      
      <!-- HERO SECTION -->
      <section class="text-center space-y-8 mb-24">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-[10px] font-black uppercase tracking-widest bg-yellow-500/10 border border-yellow-500/20 text-yellow-500">
           Quick Guide: Takes Under 3 Minutes
        </div>
        <h1 class="text-5xl md:text-7xl font-black text-white leading-tight">
          How to Redeem <br/><span class="text-green-500">Udemy Coupons</span>
        </h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto leading-relaxed">
          Follow our verified 5-step process to claim your free or discounted Udemy courses. Works every time on all devices.
        </p>
      </section>

      <!-- STEPS TIMELINE -->
      <div class="space-y-12 relative">
        <!-- Vertical Line -->
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-green-500 via-[#2d3748] to-[#2d3748] opacity-20 hidden md:block"></div>

        {[
          {
            step: "01",
            title: "Find a Course Deal",
            desc: "Browse our verified listings on the CoursesWyn home page or specific category pages. Look for the 100% OFF badge for completely free enrollments.",
            side: "left"
          },
          {
            step: "02",
            title: "Click 'Redeem Coupon'",
            desc: "On the deal page, click the green 'Redeem Coupon' button. This will automatically open Udemy in a new tab with the discount code pre-applied in the URL.",
            side: "right"
          },
          {
            step: "03",
            title: "Verify the Price",
            desc: "Check the price shown in the purchase box on Udemy. It should display $0.00 (Free) or the expected discount. Check this before clicking any other buttons.",
            side: "left"
          },
          {
            step: "04",
            title: "Sign In to Udemy",
            desc: "Click 'Enroll Now'. If you aren't signed in, you'll be prompted to log in or create a free account. Use the same browser session to ensure the coupon carries over.",
            side: "right"
          },
          {
            step: "05",
            title: "Complete Enrollment",
            desc: "Once you click 'Enroll Now', the course is added to your library with lifetime access. No payment info is required for 100% OFF coupons.",
            side: "left"
          }
        ].map((item, idx) => (
          <div class={`flex flex-col md:flex-row items-center gap-8 md:gap-24 relative ${item.side === 'right' ? 'md:flex-row-reverse' : ''}`}>
            <!-- Circle Marker -->
            <div class="absolute left-4 md:left-1/2 w-4 h-4 bg-green-500 rounded-full -translate-x-1/2 border-4 border-[#1c252e] z-10 hidden md:block"></div>
            
            <!-- Content -->
            <div class="md:w-1/2 space-y-4">
              <div class="bg-[#111820] border border-[#2d3748] p-8 rounded-[2.5rem] shadow-xl hover:border-green-500 transition-all group">
                <span class="text-green-500 font-black text-4xl mb-4 block group-hover:scale-110 transition-transform origin-left">{item.step}</span>
                <h3 class="text-white text-2xl font-black">{item.title}</h3>
                <p class="text-gray-400 leading-relaxed font-medium">{item.desc}</p>
              </div>
            </div>
            <div class="md:w-1/2 hidden md:block"></div>
          </div>
        ))}
      </div>

      <!-- TROUBLESHOOTING SECTION -->
      <section class="mt-32 space-y-12 bg-white/5 border border-white/10 rounded-[3rem] p-10 md:p-16">
        <div class="text-center space-y-4">
          <h2 class="text-3xl font-black text-white">Troubleshooting: When it Doesn't Work</h2>
          <p class="text-gray-500">Common issues and how to solve them in seconds.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="space-y-4">
            <h4 class="text-white font-black flex items-center gap-3">
              <span class="w-8 h-8 rounded-lg bg-red-500/10 text-red-500 flex items-center justify-center">!</span>
              Showing Full Price?
            </h4>
            <p class="text-gray-400 text-sm leading-relaxed">
              This usually means the coupon has hit its <strong>1,000-use limit</strong> or has expired. Instructors often issue these in small batches. Check back on CoursesWyn for a newer listing.
            </p>
          </div>
          <div class="space-y-4">
            <h4 class="text-white font-black flex items-center gap-3">
              <span class="w-8 h-8 rounded-lg bg-green-500/10 text-green-500 flex items-center justify-center">?</span>
              Code not Found?
            </h4>
            <p class="text-gray-400 text-sm leading-relaxed">
              If the URL doesn't show a discount, try opening the CoursesWyn link in a <strong>Standard Window</strong> (not Incognito). Some ad-blockers or VPNs can interfere with coupon application.
            </p>
          </div>
        </div>
      </section>

      <!-- WHAT YOU GET SECTION -->
      <section class="mt-32 space-y-12">
        <h2 class="text-3xl font-black text-white text-center">What You Get After Enrolling</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
           {[
             { t: 'Lifetime Access', d: 'Watch anytime, forever' },
             { t: 'Mobile & TV App', d: 'Learn on the go' },
             { t: 'Free Updates', d: 'Always the latest content' },
             { t: 'Certificate', d: 'Official completion proof' },
             { t: 'Course Q&A', d: 'Ask instructors directly' },
             { t: 'Resources', d: 'Pdfs, code files & more' }
           ].map(feature => (
              <div class="text-center p-6 bg-[#111820] border border-[#2d3748] rounded-3xl space-y-2">
                 <h5 class="text-white font-black text-sm">{feature.t}</h5>
                 <p class="text-gray-500 text-[10px] uppercase font-bold tracking-widest">{feature.d}</p>
              </div>
           ))}
        </div>
      </section>

      <!-- FINAL CTA -->
      <div class="mt-32 text-center py-12 border-t border-[#2d3748]">
         <h2 class="text-2xl font-black text-white mb-8">Ready to hunt for free courses?</h2>
         <a href="/udemy-coupon-code" class="inline-block px-10 py-4 bg-[#2d3748] hover:bg-green-500 text-white font-black rounded-2xl transition-all shadow-xl shadow-black/20 uppercase tracking-widest">
            Back to Deals
         </a>
      </div>

    </div>
  </div>
</MainLayout>
