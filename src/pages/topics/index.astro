---
/**
 * src/pages/topics/index.astro
 *
 * TARGET KEYWORD : "udemy course topics 2026", "udemy learning paths by topic"
 * BEDA DARI      : / homepage &rarr; "best free udemy courses"
 *                  /category &rarr; navigasi cepat grid kursus
 *
 * ANGLE UNIK     : Learning Hub &mdash; roadmap karir + editorial per topik
 */

import MainLayout from '../../layouts/MainLayout.astro';
import coupons from '../../data/coupons.json';

const slugify = (t: string) =>
  t.toString().toLowerCase().trim()
   .replace(/[^a-z0-9]+/g, '-')
   .replace(/(^-|-$)/g, '');

const now          = new Date();
const currentMonth = now.toLocaleDateString('en-US', { month: 'long' });
const currentYear  = now.getFullYear();

const allCategories = [...new Set(coupons.map((c: any) => c.category))].filter(Boolean).sort() as string[];

const categoryStats = allCategories.map(cat => {
  const courses   = coupons.filter((c: any) => c.category === cat);
  const rated     = courses.filter((c: any) => c.rating > 0);
  const avgRating = rated.length
    ? parseFloat((rated.reduce((s: number, c: any) => s + c.rating, 0) / rated.length).toFixed(1))
    : 0;
  const subs      = [...new Set(courses.map((c: any) => c.subcategory))].filter(Boolean) as string[];
  const topCourse = [...courses].sort((a: any, b: any) => (b.rating || 0) - (a.rating || 0))[0];
  return { name: cat, slug: slugify(cat), total: courses.length, avgRating, subcounts: subs.length, subs: subs.slice(0, 5), topCourse };
}).sort((a, b) => b.total - a.total);

const totalCourses = coupons.length;
const totalCats    = allCategories.length;
const totalSubs    = [...new Set(coupons.map((c: any) => c.subcategory))].filter(Boolean).length;

const editorialMeta: Record<string, { icon: string; why: string; careers: string[] }> = {
  'Development':          { icon:'\u{1F4BB}', careers:['Full-Stack Dev','Backend Engineer','Mobile Dev','DevOps'],        why:'Software development is the #1 most-hired skill globally. Python, JavaScript, and React developers remain among the highest-paid professionals in any industry.' },
  'Business':             { icon:'\u{1F4C8}', careers:['Product Manager','Business Analyst','Entrepreneur','COO'],        why:'Business and management skills compound across every role. Strategy, leadership, and operations knowledge are essential for career advancement at any level.' },
  'Design':               { icon:'\u{1F3A8}', careers:['UI/UX Designer','Product Designer','Brand Designer','Art Director'], why:'Design bridges creativity and technology. Figma, UX research, and visual communication are now core skills even in non-design roles.' },
  'Marketing':            { icon:'\u{1F4E3}', careers:['Digital Marketer','SEO Specialist','Growth Hacker','CMO'],        why:'Every business needs digital marketing. SEO, paid ads, email, and social media expertise translate directly into measurable business results.' },
  'IT & Software':        { icon:'\u{2699}', careers:['Cloud Architect','Cybersecurity Analyst','SysAdmin','DevOps Eng'], why:'Cloud computing and cybersecurity are the fastest-growing sectors in tech. AWS, Kubernetes, and Linux skills command premium salaries globally.' },
  'Finance & Accounting': { icon:'\u{1F4B0}', careers:['Financial Analyst','Accountant','Investment Analyst','CFO'],      why:'Financial literacy is the foundation of every business decision. Accounting, financial modelling, and investing knowledge pay compounding returns throughout your career.' },
  'Personal Development': { icon:'\u{1F331}', careers:['Team Leader','Executive','Coach','Entrepreneur'],                 why:'Soft skills are the hidden differentiator in every career. Communication, productivity, and leadership separate good professionals from great ones.' },
  'Office Productivity':  { icon:'\u{1F5C2}', careers:['Office Manager','Exec Assistant','Project Coordinator','Analyst'], why:'Excel, PowerPoint, and Google Workspace mastery multiplies output across every job role &mdash; from intern to C-suite.' },
  'Photography & Video':  { icon:'\u{1F4F7}', careers:['Photographer','Video Editor','Content Creator','Filmmaker'],      why:'Visual content drives modern business. YouTube, brand content, and social media demand professional video and photo skills more than ever.' },
  'Music':                { icon:'\u{1F3B5}', careers:['Music Producer','Audio Engineer','Composer','Podcaster'],         why:'Music production has never been more accessible. A laptop and the right Udemy course is all you need to start creating professional-quality audio.' },
};

const learningPaths = [
  { title:'Full-Stack Web Developer',    duration:'6\u{2013}12 months', emoji:'\u{1F4BB}', slug:'web-development',
    steps:['HTML & CSS Fundamentals','JavaScript ES6+','React or Vue.js','Node.js & REST APIs','SQL & MongoDB','Git & Deployment'],
    outcome:'Job-ready full-stack developer \u{00B7} $70k\u{2013}$130k/year' },
  { title:'Data Scientist / ML Engineer', duration:'6\u{2013}9 months',  emoji:'\u{1F4CA}', slug:'data-science',
    steps:['Python for Data Analysis','Statistics & Probability','Pandas & NumPy','Scikit-learn & ML','TensorFlow / PyTorch','SQL & Data Viz'],
    outcome:'Portfolio of ML projects \u{00B7} Data Analyst or Scientist role' },
  { title:'Digital Marketing Manager',   duration:'3\u{2013}5 months',  emoji:'\u{1F4E3}', slug:'marketing',
    steps:['Digital Marketing Fundamentals','SEO & Content Strategy','Google Ads & Meta Ads','Email Marketing','Analytics (GA4)'],
    outcome:'Freelance clients or in-house marketing manager role' },
  { title:'AWS Cloud / DevOps Engineer', duration:'3\u{2013}6 months',  emoji:'\u{2601}', slug:'it-software',
    steps:['Linux Fundamentals','Networking & Security','AWS Core Services','Docker & Kubernetes','CI/CD Pipelines','AWS Practice Exams'],
    outcome:'AWS Solutions Architect Associate cert \u{00B7} $90k\u{2013}$140k/year' },
];

const trendingSkills = [
  { name:'Python', slug:'python' }, { name:'JavaScript', slug:'javascript' }, { name:'React', slug:'react' },
  { name:'Machine Learning', slug:'machine-learning' }, { name:'AWS', slug:'aws' }, { name:'Docker', slug:'docker' },
  { name:'SQL', slug:'sql' }, { name:'TypeScript', slug:'typescript' }, { name:'Node.js', slug:'node-js' },
  { name:'Git & GitHub', slug:'git' }, { name:'Flutter', slug:'flutter' }, { name:'Java', slug:'java' },
  { name:'Angular', slug:'angular' }, { name:'Vue.js', slug:'vue-js' }, { name:'Figma', slug:'figma' },
  { name:'Excel', slug:'excel' }, { name:'ChatGPT / AI', slug:'chatgpt' }, { name:'Cybersecurity', slug:'cybersecurity' },
  { name:'SEO', slug:'seo' }, { name:'WordPress', slug:'wordpress' }, { name:'PHP', slug:'php' },
  { name:'TensorFlow', slug:'tensorflow' }, { name:'Photoshop', slug:'photoshop' }, { name:'Kotlin', slug:'kotlin' },
];

const faqs = [
  { q:`What Udemy topics are most in demand in ${currentYear}?`,
    a:`The most in-demand Udemy topics in ${currentYear} are: AI & Machine Learning, Cloud Computing (AWS/Azure), Full-Stack Development (Python, React, Node.js), Cybersecurity, and Data Science. These align with the fastest-growing job categories globally.` },
  { q:'What is the difference between a Udemy topic and a category?',
    a:`On CoursesWyn, a "category" is a broad subject area (e.g., Development, Business). A "topic" is more specific &mdash; a technology, skill, or sub-discipline like Python, Figma, or AWS. Each topic page lists the best Udemy courses for that exact skill, sorted by rating.` },
  { q:'Which Udemy learning path should I follow as a complete beginner?',
    a:'For complete beginners, we recommend starting with Web Development (HTML &rarr; CSS &rarr; JavaScript &rarr; React) or Digital Marketing. Both have strong beginner-friendly courses, clear job outcomes, and free courses available via 100% OFF coupons on CoursesWyn.' },
  { q:`How do I choose the right Udemy topic to learn in ${currentYear}?`,
    a:`Choose based on: (1) Career goal &mdash; what job do you want? (2) Time available &mdash; AWS cert takes 3 months, Full-Stack takes 12 months. (3) Current skills &mdash; build on what you know. Our learning paths above map the exact sequence for the most popular career goals.` },
  { q:'Are Udemy topic-specific courses better than general courses?',
    a:'Yes, in most cases. Topic-specific courses (e.g., "React for Beginners") go deeper and are more practical than broad overviews. Once you have a goal, a focused topic course will get you job-ready faster.' },
  { q:'How many Udemy topics does CoursesWyn cover?',
    a:`CoursesWyn covers ${totalCats} major categories and ${totalSubs}+ specific topics, with ${totalCourses.toLocaleString()}+ free courses updated daily. From niche topics like Flutter animation to broad areas like Digital Marketing, we have verified free courses across every major skill area.` },
];

// â”€â”€ SEO â”€â”€ keyword angle berbeda dari homepage â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
const pageTitle       = `Udemy Course Topics & Learning Paths ${currentYear} &mdash; ${totalCats} Categories, ${totalSubs}+ Topics`;
const pageDescription = `Explore ${totalCats} Udemy course topics and ${totalSubs}+ sub-topics for ${currentYear}. Follow structured learning paths for Web Development, Data Science, Marketing, AWS & more. Find the right Udemy topic for your career goal.`;
const canonical       = 'https://courseswyn.com/topics/';

const breadcrumbSchema = {
  '@context':'https://schema.org', '@type':'BreadcrumbList',
  itemListElement: [
    { '@type':'ListItem', position:1, name:'Home',         item:'https://courseswyn.com/' },
    { '@type':'ListItem', position:2, name:'Udemy Topics', item:canonical },
  ],
};
const itemListSchema = {
  '@context':'https://schema.org', '@type':'ItemList',
  name:`Udemy Course Topics ${currentYear}`,
  numberOfItems: categoryStats.length,
  itemListElement: categoryStats.map((cat, i) => ({
    '@type':'ListItem', position:i+1,
    name:`${cat.name} Udemy Courses`,
    url:`https://courseswyn.com/topics/best-udemy-courses/${cat.slug}`,
    description: editorialMeta[cat.name]?.why,
  })),
};
const faqSchema = {
  '@context':'https://schema.org', '@type':'FAQPage',
  mainEntity: faqs.map(f => ({ '@type':'Question', name:f.q, acceptedAnswer:{ '@type':'Answer', text:f.a } })),
};
const howToSchema = {
  '@context':'https://schema.org', '@type':'HowTo',
  name:`How to Become a Full-Stack Web Developer Using Free Udemy Courses ${currentYear}`,
  totalTime:'P9M',
  step: learningPaths[0].steps.map((s, i) => ({
    '@type':'HowToStep', position:i+1, name:s,
    url:`https://courseswyn.com/topics/best-udemy-courses/${learningPaths[0].slug}`,
  })),
};
const combinedSchema = [breadcrumbSchema, itemListSchema, faqSchema, howToSchema];
---

<MainLayout title={pageTitle} description={pageDescription} canonical={canonical} structuredData={combinedSchema}>

<!-- Fixed Background -->
<div class="fixed inset-0 bg-[#0a0f16] -z-50"></div>
<div class="fixed top-0 left-[-10%] w-[700px] h-[700px] bg-emerald-500/10 rounded-full blur-[180px] mix-blend-screen pointer-events-none -z-40"></div>
<div class="fixed bottom-0 right-[-10%] w-[600px] h-[600px] bg-blue-600/8 rounded-full blur-[180px] mix-blend-screen pointer-events-none -z-40"></div>

<div class="min-h-screen pb-24">

  <!-- HERO -->
  <header class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
    <nav aria-label="Breadcrumb" class="mb-8 flex items-center gap-2 text-xs text-gray-500 font-medium">
      <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
      <span aria-hidden="true">&rsaquo;</span>
      <span class="text-gray-300" aria-current="page">Udemy Topics</span>
    </nav>
    <div class="text-center">
      <div class="inline-flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-4 py-1.5 mb-6">
        <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
        <span class="text-emerald-400 text-xs font-bold uppercase tracking-widest">
          {currentMonth} {currentYear} &middot; {totalCourses.toLocaleString()}+ Topics Available
        </span>
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6 leading-tight tracking-tight">
        Udemy Course Topics &<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-400">
          Learning Paths {currentYear}
        </span>
      </h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto mb-4 leading-relaxed">
        {totalCats} categories &middot; {totalSubs}+ topics &middot; structured career roadmaps
      </p>
      <p class="text-gray-400 max-w-2xl mx-auto text-base mb-10 leading-relaxed">
        Not sure where to start on Udemy? This hub maps every topic to a
        <strong class="text-white">career path</strong> &mdash; so you learn with purpose,
        not just browse randomly. All courses are available free with verified coupons.
      </p>
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto border-t border-b border-white/10 py-10 mb-10">
        {[
          { v:`${totalCats}`,                      l:'Course Categories' },
          { v:`${totalSubs}+`,                     l:'Specific Topics' },
          { v:`${totalCourses.toLocaleString()}+`, l:'Free Courses' },
          { v:'4 Paths',                           l:'Career Roadmaps' },
        ].map(s => (
          <div class="bg-white/5 backdrop-blur-md rounded-2xl p-4 border border-white/5">
            <dt class="text-4xl font-black text-emerald-400 drop-shadow-sm">{s.v}</dt>
            <dd class="text-gray-400 text-xs font-bold uppercase tracking-widest mt-2">{s.l}</dd>
          </div>
        ))}
      </dl>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="#paths" class="px-8 py-4 bg-gradient-to-r from-emerald-500 to-emerald-400 text-white rounded-xl font-extrabold text-lg shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:shadow-[0_0_30px_rgba(16,185,129,0.5)] hover:scale-105 active:scale-95 transition-all relative overflow-hidden group">
          <div class="absolute inset-0 -translate-x-full group-hover:animate-[shimmer_1.5s_infinite] bg-gradient-to-r from-transparent via-white/30 to-transparent skew-x-12"></div>
          <span class="relative z-10">View Career Paths &darr;</span>
        </a>
        <a href="/categories" class="px-8 py-4 bg-white/5 backdrop-blur-md border border-white/10 hover:border-emerald-500/50 text-gray-300 hover:text-white rounded-xl font-bold text-base transition-all">
          Quick Browse by Category &rarr;
        </a>
      </div>
    </div>
  </header>

  <!-- LEARNING PATHS -->
  <section id="paths" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 border-t border-white/5 pt-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-extrabold text-white mb-3 tracking-tight">Structured Udemy Learning Paths for {currentYear}</h2>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Follow a step-by-step roadmap from zero to job-ready using only free Udemy courses.
        Each path is ordered by learning dependency &mdash; no guesswork.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {learningPaths.map(path => (
        <article class="bg-white/5 backdrop-blur-xl border border-white/5 rounded-2xl p-8 hover:border-emerald-500/40 hover:bg-white/10 hover:shadow-[0_8px_32px_rgba(16,185,129,0.1)] transition-all duration-300 group">
          <div class="flex items-start justify-between mb-5">
            <div class="flex items-center gap-3">
              <span class="text-3xl" aria-hidden="true">{path.emoji}</span>
              <h3 class="text-white font-extrabold text-xl leading-snug group-hover:text-emerald-400 transition-colors">{path.title}</h3>
            </div>
            <span class="text-emerald-400 text-xs font-bold bg-emerald-500/10 border border-emerald-500/20 px-3 py-1 rounded-full whitespace-nowrap ml-3 flex-shrink-0">{path.duration}</span>
          </div>
          <ol class="space-y-3 mb-6">
            {path.steps.map((step, i) => (
              <li class="flex items-center gap-3 text-sm text-gray-400">
                <span class="w-6 h-6 rounded-full bg-emerald-500/20 border border-emerald-500/40 text-emerald-400 text-[10px] font-black flex items-center justify-center flex-shrink-0">{i + 1}</span>
                {step}
              </li>
            ))}
          </ol>
          <div class="border-t border-white/5 pt-4 mb-5">
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-wider mb-1">&#127919; Career Outcome</p>
            <p class="text-white text-sm font-medium">{path.outcome}</p>
          </div>
          <a href={`/topics/best-udemy-courses/${path.slug}`}
             class="block w-full text-center py-3 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-bold rounded-xl group-hover:bg-emerald-500 group-hover:text-white group-hover:border-emerald-500 transition-all">
            Start This Path &mdash; Free Courses &rarr;
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- EDITORIAL TOPIC BREAKDOWN -->
  <section id="topics" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 border-t border-white/5 pt-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-extrabold text-white mb-3 tracking-tight">All Udemy Topics &mdash; Editorial Guide {currentYear}</h2>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Each topic includes why it matters for your career, sub-topics to explore,
        and the highest-rated free course available right now.
      </p>
    </div>
    <div class="space-y-5">
      {categoryStats.map(cat => {
        const meta = editorialMeta[cat.name];
        return (
          <article class="bg-white/5 backdrop-blur-xl border border-white/5 rounded-2xl overflow-hidden hover:border-emerald-500/40 hover:bg-white/8 transition-all duration-300 group">
            <div class="p-6 md:p-8">
              <div class="flex flex-col lg:flex-row lg:items-start gap-6">
                <div class="flex-grow">
                  <div class="flex items-center gap-3 mb-3">
                    {meta && <span class="text-2xl" aria-hidden="true">{meta.icon}</span>}
                    <h3 class="text-white font-bold text-xl group-hover:text-emerald-400 transition-colors">
                      <a href={`/topics/best-udemy-courses/${cat.slug}`}>{cat.name} Udemy Courses</a>
                    </h3>
                  </div>
                  <div class="flex flex-wrap gap-2 mb-4">
                    <span class="text-xs bg-white/5 border border-white/10 text-gray-400 px-3 py-1 rounded-full">{cat.total} courses</span>
                    <span class="text-xs bg-white/5 border border-white/10 text-gray-400 px-3 py-1 rounded-full">&#9733; {cat.avgRating} avg</span>
                    <span class="text-xs bg-white/5 border border-white/10 text-gray-400 px-3 py-1 rounded-full">{cat.subcounts} sub-topics</span>
                  </div>
                  {meta && <p class="text-gray-400 text-sm leading-relaxed mb-4 max-w-2xl">{meta.why}</p>}
                  {cat.subs.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-4">
                      <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider self-center mr-1">Sub-topics:</span>
                      {cat.subs.map((sub: string) => (
                        <a href={`/topics/best-udemy-courses/${slugify(sub)}`}
                           class="text-xs bg-white/5 border border-white/10 text-gray-400 hover:text-emerald-400 hover:border-emerald-500/40 px-3 py-1 rounded-full transition-all">
                          {sub}
                        </a>
                      ))}
                      {cat.subcounts > 5 && (
                        <a href={`/topics/best-udemy-courses/${cat.slug}`} class="text-xs text-gray-500 hover:text-emerald-400 px-2 py-1 transition-colors">
                          +{cat.subcounts - 5} more &rarr;
                        </a>
                      )}
                    </div>
                  )}
                  {meta?.careers && (
                    <div class="flex flex-wrap gap-2">
                      <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider self-center mr-1">Careers:</span>
                      {meta.careers.map((c: string) => (
                        <span class="text-xs text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-3 py-1 rounded-full">{c}</span>
                      ))}
                    </div>
                  )}
                </div>
                <div class="lg:w-60 flex-shrink-0">
                  {cat.topCourse && (
                    <div class="bg-white/5 backdrop-blur-md rounded-xl p-4 mb-3 border border-white/5">
                      <p class="text-[10px] text-gray-500 font-bold uppercase tracking-wider mb-2">&#9733; Top Course</p>
                      <p class="text-white text-sm font-medium leading-snug line-clamp-3 mb-2">{cat.topCourse.title}</p>
                      <p class="text-yellow-400 text-xs">{cat.topCourse.rating} / 5.0</p>
                    </div>
                  )}
                  <a href={`/topics/best-udemy-courses/${cat.slug}`}
                     class="block text-center py-3 bg-gradient-to-r from-emerald-500 to-emerald-400 text-white text-sm font-bold rounded-xl transition-all mb-2 hover:shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:scale-[1.02]">
                    Browse {cat.total} Courses &rarr;
                  </a>
                   <a href={`/courses/category/${cat.slug}`}
                      class="block text-center py-2 bg-white/5 border border-white/10 hover:border-emerald-500/40 text-gray-400 hover:text-white text-xs font-medium rounded-xl transition-all">
                     Quick Browse &rarr;
                   </a>
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <!-- TRENDING SKILLS -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 border-t border-white/5 pt-16">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-extrabold text-white mb-2 tracking-tight">&#128293; Trending Udemy Topics in {currentYear}</h2>
      <p class="text-gray-400 text-sm">Browse free courses by specific skill or technology</p>
    </div>
    <div class="flex flex-wrap justify-center gap-3">
      {trendingSkills.map(t => (
        <a href={`/topics/best-udemy-courses/${t.slug}`}
           class="bg-white/5 backdrop-blur-md border border-white/10 px-4 py-2 rounded-full text-sm text-gray-300 hover:text-emerald-400 hover:border-emerald-500/40 hover:bg-white/10 transition-all font-medium">
          {t.name}
        </a>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 border-t border-white/5 pt-16 relative">
    <div class="absolute top-1/2 left-[-10%] w-[400px] h-[400px] bg-emerald-500/5 rounded-full blur-[120px] mix-blend-screen pointer-events-none -translate-y-1/2"></div>
    <div class="text-center mb-12 relative z-10">
      <h2 class="text-3xl font-extrabold text-white mb-3 tracking-tight">Frequently Asked Questions &mdash; Udemy Topics & Learning Paths</h2>
      <p class="text-gray-400">Common questions about choosing the right Udemy topic for your goals</p>
    </div>
    <div class="grid grid-cols-1 gap-4 relative z-10">
      {faqs.map(f => (
        <details class="group bg-[#131922]/80 backdrop-blur-md rounded-2xl border border-white/5 open:border-emerald-500/50 open:bg-white/5 transition-all duration-300 overflow-hidden shadow-lg">
          <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-gray-200 hover:text-emerald-400 transition-colors">
            <span>{f.q}</span>
            <span class="transition-transform duration-300 group-open:rotate-180 bg-white/5 p-2 rounded-full border border-white/10 flex-shrink-0 ml-4">
              <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
            </span>
          </summary>
          <div class="text-gray-400 px-6 pb-6 text-sm leading-relaxed border-t border-white/5 pt-5 bg-[#0a0f16]/30">
            {f.a}
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- SEO PROSE -->
