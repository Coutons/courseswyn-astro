---
/**
 * src/pages/topics/index.astro
 *
 * TARGET KEYWORD : "udemy course topics 2026", "udemy learning paths by topic"
 * BEDA DARI      : / homepage → "best free udemy courses"
 *                  /category  → navigasi cepat grid kursus
 *
 * ANGLE UNIK     : Learning Hub — roadmap karir + editorial per topik
 */

import MainLayout from '../../layouts/MainLayout.astro';
import coupons from '../../data/coupons.json';

const slugify = (t: string) =>
  t.toString().toLowerCase().trim()
   .replace(/[^a-z0-9]+/g, '-')
   .replace(/(^-|-$)/g, '');

const now          = new Date();
const currentMonth = now.toLocaleDateString('en-US', { month: 'long' });
const currentYear  = now.getFullYear();

const allCategories = [...new Set(coupons.map((c: any) => c.category))].filter(Boolean).sort() as string[];

const categoryStats = allCategories.map(cat => {
  const courses   = coupons.filter((c: any) => c.category === cat);
  const rated     = courses.filter((c: any) => c.rating > 0);
  const avgRating = rated.length
    ? parseFloat((rated.reduce((s: number, c: any) => s + c.rating, 0) / rated.length).toFixed(1))
    : 0;
  const subs      = [...new Set(courses.map((c: any) => c.subcategory))].filter(Boolean) as string[];
  const topCourse = [...courses].sort((a: any, b: any) => (b.rating || 0) - (a.rating || 0))[0];
  return { name: cat, slug: slugify(cat), total: courses.length, avgRating, subcounts: subs.length, subs: subs.slice(0, 5), topCourse };
}).sort((a, b) => b.total - a.total);

const totalCourses = coupons.length;
const totalCats    = allCategories.length;
const totalSubs    = [...new Set(coupons.map((c: any) => c.subcategory))].filter(Boolean).length;

const editorialMeta: Record<string, { icon: string; why: string; careers: string[] }> = {
  'Development':          { icon:'💻', careers:['Full-Stack Dev','Backend Engineer','Mobile Dev','DevOps'],        why:'Software development is the #1 most-hired skill globally. Python, JavaScript, and React developers remain among the highest-paid professionals in any industry.' },
  'Business':             { icon:'📈', careers:['Product Manager','Business Analyst','Entrepreneur','COO'],        why:'Business and management skills compound across every role. Strategy, leadership, and operations knowledge are essential for career advancement at any level.' },
  'Design':               { icon:'🎨', careers:['UI/UX Designer','Product Designer','Brand Designer','Art Director'], why:'Design bridges creativity and technology. Figma, UX research, and visual communication are now core skills even in non-design roles.' },
  'Marketing':            { icon:'📣', careers:['Digital Marketer','SEO Specialist','Growth Hacker','CMO'],        why:'Every business needs digital marketing. SEO, paid ads, email, and social media expertise translate directly into measurable business results.' },
  'IT & Software':        { icon:'⚙️', careers:['Cloud Architect','Cybersecurity Analyst','SysAdmin','DevOps Eng'], why:'Cloud computing and cybersecurity are the fastest-growing sectors in tech. AWS, Kubernetes, and Linux skills command premium salaries globally.' },
  'Finance & Accounting': { icon:'💰', careers:['Financial Analyst','Accountant','Investment Analyst','CFO'],      why:'Financial literacy is the foundation of every business decision. Accounting, financial modelling, and investing knowledge pay compounding returns throughout your career.' },
  'Personal Development': { icon:'🌱', careers:['Team Leader','Executive','Coach','Entrepreneur'],                 why:'Soft skills are the hidden differentiator in every career. Communication, productivity, and leadership separate good professionals from great ones.' },
  'Office Productivity':  { icon:'🗂️', careers:['Office Manager','Exec Assistant','Project Coordinator','Analyst'], why:'Excel, PowerPoint, and Google Workspace mastery multiplies output across every job role — from intern to C-suite.' },
  'Photography & Video':  { icon:'📷', careers:['Photographer','Video Editor','Content Creator','Filmmaker'],      why:'Visual content drives modern business. YouTube, brand content, and social media demand professional video and photo skills more than ever.' },
  'Music':                { icon:'🎵', careers:['Music Producer','Audio Engineer','Composer','Podcaster'],         why:'Music production has never been more accessible. A laptop and the right Udemy course is all you need to start creating professional-quality audio.' },
};

const learningPaths = [
  { title:'Full-Stack Web Developer',    duration:'6–12 months', emoji:'💻', slug:'web-development',
    steps:['HTML & CSS Fundamentals','JavaScript ES6+','React or Vue.js','Node.js & REST APIs','SQL & MongoDB','Git & Deployment'],
    outcome:'Job-ready full-stack developer · $70k–$130k/year' },
  { title:'Data Scientist / ML Engineer', duration:'6–9 months',  emoji:'📊', slug:'data-science',
    steps:['Python for Data Analysis','Statistics & Probability','Pandas & NumPy','Scikit-learn & ML','TensorFlow / PyTorch','SQL & Data Viz'],
    outcome:'Portfolio of ML projects · Data Analyst or Scientist role' },
  { title:'Digital Marketing Manager',   duration:'3–5 months',  emoji:'📣', slug:'marketing',
    steps:['Digital Marketing Fundamentals','SEO & Content Strategy','Google Ads & Meta Ads','Email Marketing','Analytics (GA4)'],
    outcome:'Freelance clients or in-house marketing manager role' },
  { title:'AWS Cloud / DevOps Engineer', duration:'3–6 months',  emoji:'☁️', slug:'it-software',
    steps:['Linux Fundamentals','Networking & Security','AWS Core Services','Docker & Kubernetes','CI/CD Pipelines','AWS Practice Exams'],
    outcome:'AWS Solutions Architect Associate cert · $90k–$140k/year' },
];

const trendingSkills = [
  { name:'Python', slug:'python' }, { name:'JavaScript', slug:'javascript' }, { name:'React', slug:'react' },
  { name:'Machine Learning', slug:'machine-learning' }, { name:'AWS', slug:'aws' }, { name:'Docker', slug:'docker' },
  { name:'SQL', slug:'sql' }, { name:'TypeScript', slug:'typescript' }, { name:'Node.js', slug:'node-js' },
  { name:'Git & GitHub', slug:'git' }, { name:'Flutter', slug:'flutter' }, { name:'Java', slug:'java' },
  { name:'Angular', slug:'angular' }, { name:'Vue.js', slug:'vue-js' }, { name:'Figma', slug:'figma' },
  { name:'Excel', slug:'excel' }, { name:'ChatGPT / AI', slug:'chatgpt' }, { name:'Cybersecurity', slug:'cybersecurity' },
  { name:'SEO', slug:'seo' }, { name:'WordPress', slug:'wordpress' }, { name:'PHP', slug:'php' },
  { name:'TensorFlow', slug:'tensorflow' }, { name:'Photoshop', slug:'photoshop' }, { name:'Kotlin', slug:'kotlin' },
];

const faqs = [
  { q:`What Udemy topics are most in demand in ${currentYear}?`,
    a:`The most in-demand Udemy topics in ${currentYear} are: AI & Machine Learning, Cloud Computing (AWS/Azure), Full-Stack Development (Python, React, Node.js), Cybersecurity, and Data Science. These align with the fastest-growing job categories globally.` },
  { q:'What is the difference between a Udemy topic and a category?',
    a:`On CoursesWyn, a "category" is a broad subject area (e.g., Development, Business). A "topic" is more specific — a technology, skill, or sub-discipline like Python, Figma, or AWS. Each topic page lists the best Udemy courses for that exact skill, sorted by rating.` },
  { q:'Which Udemy learning path should I follow as a complete beginner?',
    a:'For complete beginners, we recommend starting with Web Development (HTML → CSS → JavaScript → React) or Digital Marketing. Both have strong beginner-friendly courses, clear job outcomes, and free courses available via 100% OFF coupons on CoursesWyn.' },
  { q:`How do I choose the right Udemy topic to learn in ${currentYear}?`,
    a:`Choose based on: (1) Career goal — what job do you want? (2) Time available — AWS cert takes 3 months, Full-Stack takes 12 months. (3) Current skills — build on what you know. Our learning paths above map the exact sequence for the most popular career goals.` },
  { q:'Are Udemy topic-specific courses better than general courses?',
    a:'Yes, in most cases. Topic-specific courses (e.g., "React for Beginners") go deeper and are more practical than broad overviews. Once you have a goal, a focused topic course will get you job-ready faster.' },
  { q:'How many Udemy topics does CoursesWyn cover?',
    a:`CoursesWyn covers ${totalCats} major categories and ${totalSubs}+ specific topics, with ${totalCourses.toLocaleString()}+ free courses updated daily. From niche topics like Flutter animation to broad areas like Digital Marketing, we have verified free courses across every major skill area.` },
];

// ── SEO — keyword angle berbeda dari homepage ─────────────────────────────────
const pageTitle       = `Udemy Course Topics & Learning Paths ${currentYear} — ${totalCats} Categories, ${totalSubs}+ Topics`;
const pageDescription = `Explore ${totalCats} Udemy course topics and ${totalSubs}+ sub-topics for ${currentYear}. Follow structured learning paths for Web Development, Data Science, Marketing, AWS & more. Find the right Udemy topic for your career goal.`;
const canonical       = 'https://courseswyn.com/topics/';

const breadcrumbSchema = {
  '@context':'https://schema.org', '@type':'BreadcrumbList',
  itemListElement: [
    { '@type':'ListItem', position:1, name:'Home',         item:'https://courseswyn.com/' },
    { '@type':'ListItem', position:2, name:'Udemy Topics', item:canonical },
  ],
};
const itemListSchema = {
  '@context':'https://schema.org', '@type':'ItemList',
  name:`Udemy Course Topics ${currentYear}`,
  numberOfItems: categoryStats.length,
  itemListElement: categoryStats.map((cat, i) => ({
    '@type':'ListItem', position:i+1,
    name:`${cat.name} Udemy Courses`,
    url:`https://courseswyn.com/topics/best-udemy-courses/${cat.slug}`,
    description: editorialMeta[cat.name]?.why,
  })),
};
const faqSchema = {
  '@context':'https://schema.org', '@type':'FAQPage',
  mainEntity: faqs.map(f => ({ '@type':'Question', name:f.q, acceptedAnswer:{ '@type':'Answer', text:f.a } })),
};
const howToSchema = {
  '@context':'https://schema.org', '@type':'HowTo',
  name:`How to Become a Full-Stack Web Developer Using Free Udemy Courses ${currentYear}`,
  totalTime:'P9M',
  step: learningPaths[0].steps.map((s, i) => ({
    '@type':'HowToStep', position:i+1, name:s,
    url:`https://courseswyn.com/topics/best-udemy-courses/${learningPaths[0].slug}`,
  })),
};
const combinedSchema = [breadcrumbSchema, itemListSchema, faqSchema, howToSchema];
---

<MainLayout title={pageTitle} description={pageDescription} canonical={canonical} structuredData={combinedSchema}>
<div class="bg-[#1c252e] min-h-screen pb-20">

  <!-- HERO -->
  <header class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
    <nav aria-label="Breadcrumb" class="mb-8 flex items-center gap-2 text-sm text-gray-500">
      <a href="/" class="hover:text-[#10b981] transition-colors">Home</a>
      <span aria-hidden="true">›</span>
      <span class="text-gray-300" aria-current="page">Udemy Topics</span>
    </nav>
    <div class="text-center">
      <div class="inline-flex items-center gap-2 bg-[#10b981]/10 border border-[#10b981]/30 rounded-full px-4 py-1.5 mb-6">
        <span class="w-2 h-2 bg-[#10b981] rounded-full animate-pulse"></span>
        <span class="text-[#10b981] text-xs font-bold uppercase tracking-widest">
          {currentMonth} {currentYear} · {totalCourses.toLocaleString()}+ Topics Available
        </span>
      </div>
      <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">
        Udemy Course Topics &<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#10b981] to-[#3b82f6]">
          Learning Paths {currentYear}
        </span>
      </h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto mb-4 leading-relaxed">
        {totalCats} categories · {totalSubs}+ topics · structured career roadmaps
      </p>
      <p class="text-gray-400 max-w-2xl mx-auto text-base mb-10 leading-relaxed">
        Not sure where to start on Udemy? This hub maps every topic to a
        <strong class="text-white">career path</strong> — so you learn with purpose,
        not just browse randomly. All courses are available free with verified coupons.
      </p>
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto border-t border-b border-[#2d3748] py-8 mb-10">
        {[
          { v:`${totalCats}`,                       l:'Course Categories' },
          { v:`${totalSubs}+`,                      l:'Specific Topics' },
          { v:`${totalCourses.toLocaleString()}+`,  l:'Free Courses' },
          { v:'4 Paths',                            l:'Career Roadmaps' },
        ].map(s => (
          <div>
            <dt class="text-4xl font-black text-[#10b981]">{s.v}</dt>
            <dd class="text-gray-500 text-xs font-bold uppercase tracking-wider mt-1">{s.l}</dd>
          </div>
        ))}
      </dl>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="#paths" class="px-8 py-4 bg-[#10b981] hover:bg-[#059669] text-white rounded-xl font-bold text-lg shadow-lg hover:shadow-xl transition-all hover:-translate-y-1">
          View Career Paths ↓
        </a>
        <a href="/category" class="px-8 py-4 bg-[#28323d] border border-[#2d3748] hover:border-[#10b981] text-gray-300 hover:text-white rounded-xl font-bold text-base transition-all">
          Quick Browse by Category →
        </a>
      </div>
    </div>
  </header>

  <!-- LEARNING PATHS -->
  <section id="paths" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-3">Structured Udemy Learning Paths for {currentYear}</h2>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Follow a step-by-step roadmap from zero to job-ready using only free Udemy courses.
        Each path is ordered by learning dependency — no guesswork.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {learningPaths.map(path => (
        <article class="bg-[#28323d] border border-[#2d3748] rounded-2xl p-8 hover:border-[#10b981] transition-colors group">
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-center gap-3">
              <span class="text-3xl" aria-hidden="true">{path.emoji}</span>
              <h3 class="text-white font-bold text-xl leading-snug group-hover:text-[#10b981] transition-colors">{path.title}</h3>
            </div>
            <span class="text-[#10b981] text-xs font-bold bg-[#10b981]/10 border border-[#10b981]/30 px-3 py-1 rounded-full whitespace-nowrap ml-3 flex-shrink-0">{path.duration}</span>
          </div>
          <ol class="space-y-2.5 mb-6">
            {path.steps.map((step, i) => (
              <li class="flex items-center gap-3 text-sm text-gray-400">
                <span class="w-5 h-5 rounded-full bg-[#10b981]/20 border border-[#10b981]/40 text-[#10b981] text-[10px] font-black flex items-center justify-center flex-shrink-0">{i + 1}</span>
                {step}
              </li>
            ))}
          </ol>
          <div class="border-t border-[#2d3748] pt-4 mb-5">
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-wider mb-1">🎯 Career Outcome</p>
            <p class="text-white text-sm font-medium">{path.outcome}</p>
          </div>
          <a href={`/topics/best-udemy-courses/${path.slug}`}
             class="block w-full text-center py-2.5 bg-[#10b981]/10 border border-[#10b981]/30 text-[#10b981] text-sm font-bold rounded-lg group-hover:bg-[#10b981] group-hover:text-white transition-all">
            Start This Path — Free Courses →
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- EDITORIAL TOPIC BREAKDOWN -->
  <section id="topics" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-3">All Udemy Topics — Editorial Guide {currentYear}</h2>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Each topic includes why it matters for your career, sub-topics to explore,
        and the highest-rated free course available right now.
      </p>
    </div>
    <div class="space-y-5">
      {categoryStats.map(cat => {
        const meta = editorialMeta[cat.name];
        return (
          <article class="bg-[#28323d] border border-[#2d3748] rounded-2xl overflow-hidden hover:border-[#10b981]/50 transition-all group">
            <div class="p-6 md:p-8">
              <div class="flex flex-col lg:flex-row lg:items-start gap-6">
                <div class="flex-grow">
                  <div class="flex items-center gap-3 mb-3">
                    {meta && <span class="text-2xl" aria-hidden="true">{meta.icon}</span>}
                    <h3 class="text-white font-bold text-xl group-hover:text-[#10b981] transition-colors">
                      <a href={`/topics/best-udemy-courses/${cat.slug}`}>{cat.name} Udemy Courses</a>
                    </h3>
                  </div>
                  <div class="flex flex-wrap gap-2 mb-4">
                    <span class="text-xs bg-[#1c252e] border border-[#3d4a5a] text-gray-400 px-3 py-1 rounded-full">{cat.total} courses</span>
                    <span class="text-xs bg-[#1c252e] border border-[#3d4a5a] text-gray-400 px-3 py-1 rounded-full">⭐ {cat.avgRating} avg</span>
                    <span class="text-xs bg-[#1c252e] border border-[#3d4a5a] text-gray-400 px-3 py-1 rounded-full">{cat.subcounts} sub-topics</span>
                  </div>
                  {meta && <p class="text-gray-400 text-sm leading-relaxed mb-4 max-w-2xl">{meta.why}</p>}
                  {cat.subs.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-4">
                      <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider self-center mr-1">Sub-topics:</span>
                      {cat.subs.map((sub: string) => (
                        <a href={`/topics/best-udemy-courses/${slugify(sub)}`}
                           class="text-xs bg-[#1c252e] border border-[#2d3748] text-gray-400 hover:text-[#10b981] hover:border-[#10b981] px-3 py-1 rounded-full transition-all">
                          {sub}
                        </a>
                      ))}
                      {cat.subcounts > 5 && (
                        <a href={`/topics/best-udemy-courses/${cat.slug}`} class="text-xs text-gray-500 hover:text-[#10b981] px-2 py-1 transition-colors">
                          +{cat.subcounts - 5} more →
                        </a>
                      )}
                    </div>
                  )}
                  {meta?.careers && (
                    <div class="flex flex-wrap gap-2">
                      <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider self-center mr-1">Careers:</span>
                      {meta.careers.map((c: string) => (
                        <span class="text-xs text-[#10b981] bg-[#10b981]/10 border border-[#10b981]/20 px-3 py-1 rounded-full">{c}</span>
                      ))}
                    </div>
                  )}
                </div>
                <div class="lg:w-60 flex-shrink-0">
                  {cat.topCourse && (
                    <div class="bg-[#1c252e] rounded-xl p-4 mb-3 border border-[#2d3748]">
                      <p class="text-[10px] text-gray-500 font-bold uppercase tracking-wider mb-2">⭐ Top Course</p>
                      <p class="text-white text-sm font-medium leading-snug line-clamp-3 mb-2">{cat.topCourse.title}</p>
                      <p class="text-yellow-400 text-xs">{cat.topCourse.rating} / 5.0</p>
                    </div>
                  )}
                  <a href={`/topics/best-udemy-courses/${cat.slug}`}
                     class="block text-center py-2.5 bg-[#10b981] hover:bg-[#059669] text-white text-sm font-bold rounded-lg transition-all mb-2">
                    Browse {cat.total} Courses →
                  </a>
                  <a href={`/courses/category/${cat.slug}`}
                     class="block text-center py-2 border border-[#2d3748] hover:border-[#10b981] text-gray-400 hover:text-white text-xs font-medium rounded-lg transition-all">
                    Quick Browse ↗
                  </a>
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <!-- TRENDING SKILLS -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-bold text-white mb-2">🔥 Trending Udemy Topics in {currentYear}</h2>
      <p class="text-gray-400 text-sm">Browse free courses by specific skill or technology</p>
    </div>
    <div class="flex flex-wrap justify-center gap-3">
      {trendingSkills.map(t => (
        <a href={`/topics/best-udemy-courses/${t.slug}`}
           class="bg-[#28323d] border border-[#2d3748] px-4 py-2 rounded-full text-sm text-gray-300 hover:text-white hover:border-[#10b981] hover:bg-[#10b981]/10 transition-all font-medium">
          {t.name}
        </a>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-3">Frequently Asked Questions — Udemy Topics & Learning Paths</h2>
      <p class="text-gray-400">Common questions about choosing the right Udemy topic for your goals</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {faqs.map(f => (
        <div class="bg-[#28323d] border border-[#2d3748] p-6 rounded-xl hover:border-[#10b981]/40 transition-colors">
          <h3 class="text-[#10b981] font-bold text-base mb-3 leading-snug">{f.q}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{f.a}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- SEO PROSE -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="space-y-7 text-gray-400 leading-relaxed text-base">
      <h2 class="text-3xl font-bold text-white text-center mb-2">How to Choose the Right Udemy Topic in {currentYear}</h2>
      <p class="text-center text-gray-500 text-sm mb-8">A practical guide to navigating Udemy's 200,000+ course library with purpose</p>

      <h3 class="text-white font-bold text-xl">Step 1 — Define Your Career Goal First</h3>
      <p>The biggest mistake learners make on Udemy is picking a course before picking a goal. Start with: <strong class="text-white">"What job or skill do I want in 12 months?"</strong> Then use our learning paths above to find the exact topic sequence. Each path is ordered by prerequisite — you always learn the right thing at the right time.</p>

      <h3 class="text-white font-bold text-xl">Step 2 — Use Topics, Not Just Categories</h3>
      <p>The <a href="/category" class="text-[#10b981] hover:underline">Category page</a> is great for quick browsing. But for structured learning, go deeper into specific topics. Instead of browsing "Development," go to the <a href="/topics/best-udemy-courses/python" class="text-[#10b981] hover:underline">Python topic</a> or <a href="/topics/best-udemy-courses/react" class="text-[#10b981] hover:underline">React topic</a> for curated, depth-first course lists.</p>

      <h3 class="text-white font-bold text-xl">Step 3 — Check Rating and Recency</h3>
      <p>On each topic page, CoursesWyn sorts by rating. Prioritise courses with <strong class="text-white">4.4 stars or above</strong>, updated within the last year, with at least 1,000 reviews. These signals indicate the instructor actively maintains content and students get real value.</p>

      <div class="bg-[#28323d] border border-[#10b981]/30 rounded-xl p-6">
        <p class="text-[#10b981] font-bold mb-2">💡 /topics vs /category — what's the difference?</p>
        <p class="text-gray-400 text-sm">The <a href="/category" class="text-[#10b981] hover:underline">/category page</a> is a fast, compact navigator for browsing all courses in a subject area. This <strong class="text-white">/topics hub</strong> is your starting point when you want structured guidance — learning paths, career context, and sub-topic breakdowns to help you learn with direction.</p>
      </div>

      <p class="text-xs pt-6 border-t border-[#2d3748] text-center text-gray-500">
        <em><strong>Disclaimer:</strong> CoursesWyn is not affiliated with Udemy.com. All trademarks belong to their respective owners. We aggregate publicly available promotional coupon codes to help students access quality education at no cost.</em>
      </p>
    </div>
  </section>

</div>
</MainLayout>