---
/**
 * src/pages/blog/[...page].astro  (atau path blog listing kamu)
 *
 * TARGET KEYWORD : "udemy course reviews", "udemy course guide 2026", "best udemy course review"
 * BEDA DARI      : /topics → learning hub (roadmaps, per-kategori)
 *                  /category → navigasi kursus
 *                  homepage → "best free udemy courses"
 *
 * ANGLE UNIK     : Editorial reviews & guides — konten jurnalistik,
 *                  bukan directory kursus
 */

import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const allPosts  = await getCollection('blog');
  const sorted    = allPosts.sort(
    (a: any, b: any) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
  );
  return paginate(sorted, { pageSize: 12 });
}

const { page } = Astro.props as { page: any };

const now         = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.toLocaleDateString('en-US', { month: 'long' });

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('en-US', { month:'long', day:'numeric', year:'numeric' });
}

// Estimated read time from description word count
function readTime(text: string = '') {
  const words = text.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 200)) + ' min read';
}

// ── SEO ───────────────────────────────────────────────────────────────────────
// Keyword angle: "udemy course reviews" — editorial, bukan directory
const isFirstPage  = page.currentPage === 1;
const pageTitle    = isFirstPage
  ? `Udemy Course Reviews & Guides ${currentYear} — Expert Analysis | CoursesWyn`
  : `Udemy Course Reviews & Guides — Page ${page.currentPage} | CoursesWyn`;
const pageDescription = `Expert reviews and in-depth guides for the best Udemy courses in ${currentYear}. Honest analysis of course quality, instructor credibility, and real-world applicability — updated daily.`;
const canonical    = isFirstPage
  ? 'https://courseswyn.com/blog/'
  : `https://courseswyn.com/blog/${page.currentPage}/`;

// ── FAQ — keyword angle: "are udemy reviews reliable" ────────────────────────
// Sengaja berbeda dari FAQ di /topics dan /category
const faqs = [
  {
    q: `How does CoursesWyn review Udemy courses in ${currentYear}?`,
    a: `Our review process evaluates: (1) Course curriculum depth and accuracy. (2) Instructor credentials and teaching quality. (3) Student outcome data — completion rates and rating trends. (4) Content recency — courses updated in the last 12 months score higher. (5) Real-world applicability of the skills taught.`,
  },
  {
    q: 'What is the difference between a CoursesWyn review and a Udemy rating?',
    a: `Udemy ratings are aggregated student reviews — helpful but subject to rating inflation. CoursesWyn editorial reviews go deeper: we evaluate curriculum structure, prerequisite clarity, project quality, and career relevance. A course with 4.3★ on Udemy may score differently on our editorial criteria.`,
  },
  {
    q: 'Do you only review free Udemy courses?',
    a: `Our guides and reviews cover both free (100% OFF coupon) and paid Udemy courses. For free course reviews, we verify that a working coupon exists at time of publication. We flag when a reviewed course transitions from free to paid so our readers always know what to expect.`,
  },
  {
    q: 'How often are CoursesWyn course guides updated?',
    a: `Course guides are reviewed and updated when: (1) A course receives a major content update from the instructor. (2) New comparable courses launch in the same topic. (3) Industry standards change and the course content may be outdated. Our team publishes new guides and updates daily.`,
  },
];

// ── Structured data ───────────────────────────────────────────────────────────
const breadcrumbSchema = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type':'ListItem', position:1, name:'Home',            item:'https://courseswyn.com/' },
    { '@type':'ListItem', position:2, name:'Course Reviews',  item:'https://courseswyn.com/blog/' },
    ...(page.currentPage > 1 ? [{ '@type':'ListItem', position:3, name:`Page ${page.currentPage}`, item:canonical }] : []),
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org', '@type': 'ItemList',
  name: `Udemy Course Reviews & Guides ${currentYear}`,
  description: pageDescription,
  numberOfItems: page.data.length,
  itemListElement: page.data.map((post: any, i: number) => ({
    '@type': 'ListItem', position: i + 1,
    url: `https://courseswyn.com/${post.slug}/`,
    name: post.data.title,
    description: post.data.description,
  })),
};

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type':'Question', name:f.q, acceptedAnswer:{ '@type':'Answer', text:f.a } })),
};

// Only add FAQ schema on first page to avoid duplicate schema across paginated pages
const combinedSchema = isFirstPage
  ? [breadcrumbSchema, itemListSchema, faqSchema]
  : [breadcrumbSchema, itemListSchema];
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  structuredData={combinedSchema}
>
<div class="bg-[#1c252e] min-h-screen pb-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8 flex items-center gap-2 text-sm text-gray-500">
      <a href="/" class="hover:text-indigo-400 transition-colors">Home</a>
      <span aria-hidden="true">›</span>
      <span class="text-gray-300" aria-current="page">Course Reviews & Guides</span>
    </nav>

    <!-- Header -->
    <header class="text-center mb-16">
      {isFirstPage && (
        <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/30 rounded-full px-4 py-1.5 mb-6">
          <span class="w-2 h-2 bg-indigo-500 rounded-full animate-pulse"></span>
          <span class="text-indigo-500 text-xs font-bold uppercase tracking-widest">
            Updated {currentMonth} {currentYear} · New Reviews Daily
          </span>
        </div>
      )}
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-6 leading-tight">
        Udemy Course Reviews &<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 to-purple-500">
          Expert Guides {currentYear}
        </span>
      </h1>
      <p class="text-xl text-gray-400 max-w-3xl mx-auto leading-relaxed">
        Honest, in-depth analysis of the best Udemy courses — not just ratings, but curriculum breakdowns,
        instructor credibility checks, and real career outcome data.
        {page.currentPage > 1 && <span class="text-gray-500"> · Page {page.currentPage} of {page.lastPage}</span>}
      </p>
    </header>

    <!-- Editorial callout — unique to this page, not on /topics or /category -->
    {isFirstPage && (
      <div class="bg-[#28323d] border border-[#2d3748] rounded-2xl p-6 mb-12 grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { icon:'🔍', title:'Curriculum Analysis',    body:'We assess course structure, depth, and accuracy — not just student star ratings.' },
          { icon:'👨‍🏫', title:'Instructor Vetting',    body:'We check instructor credentials, industry experience, and Q&A responsiveness.' },
          { icon:'📅', title:'Recency Check',           body:'Courses are flagged if content is outdated. We prioritise courses updated in the last 12 months.' },
        ].map(item => (
          <div class="flex items-start gap-4">
            <span class="text-2xl flex-shrink-0">{item.icon}</span>
            <div>
              <p class="text-white font-bold text-sm mb-1">{item.title}</p>
              <p class="text-gray-400 text-xs leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    )}

    <!-- Articles grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
      {page.data.map((post: any) => (
        <article>
          <a
            href={`/${post.slug}/`}
            class="group block bg-[#1c252e] rounded-2xl overflow-hidden hover:-translate-y-1 transition-all duration-300 shadow-lg border border-[#2d3748] hover:border-indigo-500/50 flex flex-col h-full"
          >
            <div class="relative aspect-[16/9] overflow-hidden">
              <img
                src={post.data.image?.src || post.data.image || 'https://images.unsplash.com/photo-1526379095098-d400fd0bf935?w=800&h=400&fit=crop'}
                alt={post.data.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                width="800"
                height="450"
              />
              <div class="absolute top-4 left-4 flex gap-2">
                {post.data.tags?.[0] && (
                  <span class="bg-[#1c252e]/80 backdrop-blur-md text-indigo-400 text-[10px] font-bold px-2 py-1 rounded-md border border-indigo-500/30 uppercase tracking-wider">
                    {post.data.tags[0]}
                  </span>
                )}
                <!-- "Review" or "Guide" label based on tag -->
                <span class="bg-indigo-500/80 backdrop-blur-md text-white text-[10px] font-bold px-2 py-1 rounded-md uppercase tracking-wider">
                  {post.data.tags?.includes('review') ? 'Review' : 'Guide'}
                </span>
              </div>
            </div>

            <div class="p-6 flex flex-col flex-grow">
              <h2 class="font-bold text-xl text-white mb-3 group-hover:text-indigo-400 transition-colors line-clamp-2 leading-tight">
                {post.data.title}
              </h2>
              <p class="text-gray-400 text-sm line-clamp-3 mb-4 flex-grow">
                {post.data.description}
              </p>

              <div class="pt-4 border-t border-[#2d3748] flex items-center justify-between text-xs text-gray-500">
                <div class="flex items-center gap-3">
                  <span class="flex items-center gap-1.5 text-white font-medium">
                    <img src="/assets/authors/andrew-derek.png" alt="Andrew Derek"
                         class="w-5 h-5 rounded-full object-cover border border-indigo-500/30" />
                    Andrew Derek
                  </span>
                  <span aria-hidden="true">·</span>
                  <time datetime={new Date(post.data.pubDate).toISOString()} class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    {formatDate(post.data.pubDate)}
                  </time>
                </div>
                <span class="text-indigo-500 font-bold group-hover:translate-x-1 transition-transform" aria-hidden="true">
                  Read →
                </span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    <!-- Pagination -->
    <nav aria-label="Pagination" class="flex justify-center mt-12 mb-20">
      <div class="flex items-center gap-2 bg-[#1c252e] p-2 rounded-xl border border-[#2d3748]">
        {page.url.prev && (
          <a href={page.url.prev}
             class="px-4 h-10 flex items-center gap-2 rounded-lg text-gray-400 hover:text-white hover:bg-[#28323d] transition-all text-sm font-bold">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Previous
          </a>
        )}
        <span class="px-4 py-2 font-bold text-indigo-400 bg-[#28323d] rounded-lg border border-[#2d3748] text-sm" aria-current="page">
          Page {page.currentPage} of {page.lastPage}
        </span>
        {page.url.next && (
          <a href={page.url.next}
             class="px-4 h-10 flex items-center gap-2 rounded-lg text-gray-400 hover:text-white hover:bg-[#28323d] transition-all text-sm font-bold">
            Next
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        )}
      </div>
    </nav>

    <!-- Cross-link to /topics -->
    <div class="bg-[#28323d] border border-[#2d3748] rounded-2xl p-8 mb-16 flex flex-col md:flex-row items-center gap-6 justify-between">
      <div>
        <h2 class="text-white font-bold text-xl mb-2">Want a structured learning roadmap?</h2>
        <p class="text-gray-400 text-sm">
          These reviews help you evaluate individual courses. For a full career path using free Udemy courses,
          visit our <strong class="text-white">Topics & Learning Paths</strong> hub.
        </p>
      </div>
      <a href="/topics"
         class="flex-shrink-0 px-6 py-3 bg-indigo-500 hover:bg-indigo-600 text-white font-bold rounded-xl transition-all whitespace-nowrap">
        View Learning Paths →
      </a>
    </div>

    <!-- FAQ — first page only -->
    {isFirstPage && (
      <section class="border-t border-[#2d3748] pt-20 mb-16">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-white mb-3">About Our Udemy Course Reviews</h2>
          <p class="text-gray-400">How we evaluate and rate Udemy courses</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {faqs.map(f => (
            <div class="bg-[#1c252e] border border-[#2d3748] p-8 rounded-2xl hover:border-indigo-500/40 transition-colors">
              <h3 class="text-indigo-500 text-lg font-bold mb-4">{f.q}</h3>
              <p class="text-gray-400 leading-relaxed text-sm">{f.a}</p>
            </div>
          ))}
        </div>
      </section>
    )}

  </div>
</div>
</MainLayout>