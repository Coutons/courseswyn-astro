---
/**
 * src/pages/topics/best-udemy-courses/[category].astro
 *
 * TARGET KEYWORD : "best udemy [category] courses", "free [category] courses udemy"
 * BEDA DARI      : /topics/index → hub overview semua topik
 *                  /category     → navigasi cepat semua kategori
 *
 * ANGLE UNIK     : Deep-dive per kategori — konten editorial spesifik,
 *                  skill roadmap, career paths, FAQ per-kategori
 */

import MainLayout from '../../../layouts/MainLayout.astro';
import CourseCard from '../../../components/CourseCard.astro';
import coupons from '../../../data/coupons.json';

export async function getStaticPaths() {
  const slugify = (text: string) =>
    text.toString().toLowerCase().trim()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)/g, '');

  const data = await import('../../../data/coupons.json');
  const categories    = [...new Set(data.default.map((c: any) => c.category).filter(Boolean))];
  const subcategories = [...new Set(data.default.map((c: any) => c.subcategory).filter(Boolean))];
  const allTopics     = [...new Set([...categories, ...subcategories])];

  return allTopics.map(topic => ({
    params: { category: slugify(String(topic)) },
    props:  { category: topic, slug: slugify(String(topic)) },
  }));
}

const { category, slug } = Astro.props as { category: string; slug: string };

const formatName = (s: string) =>
  s.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());

const displayName = formatName(category);

// ── Filter courses ────────────────────────────────────────────────────────────
const matched = coupons.filter((c: any) => {
  const cat = c.category?.toLowerCase() || '';
  const sub = c.subcategory?.toLowerCase() || '';
  const q   = category.toLowerCase().replace(/-/g, ' ');
  return cat.includes(q) || sub.includes(q) ||
         cat.includes(category.toLowerCase()) ||
         sub.includes(category.toLowerCase());
});

const topCourses = [...matched]
  .sort((a: any, b: any) => (b.rating || 0) - (a.rating || 0))
  .slice(0, 24);

// ── Stats ─────────────────────────────────────────────────────────────────────
const now          = new Date();
const currentMonth = now.toLocaleDateString('en-US', { month: 'long' });
const currentYear  = now.getFullYear();
const totalCourses = matched.length;
const rated        = matched.filter((c: any) => c.rating > 0);
const avgRating    = rated.length
  ? (rated.reduce((s: number, c: any) => s + c.rating, 0) / rated.length).toFixed(1)
  : '0';

// ── Editorial data per-kategori ───────────────────────────────────────────────
const categoryEditorial: Record<string, {
  intro:       string;
  skills:      string[];
  careerPaths: string[];
  salaryRange: string;
  timeToLearn: string;
  whyNow:      string;
}> = {
  'Python': {
    intro:       'Python is the world\'s most popular programming language for 2024–2026. From data science to web development and AI, Python skills open doors across every technology sector.',
    skills:      ['Data Analysis','Web Development','Machine Learning','Automation','Django','Flask','Data Science','APIs'],
    careerPaths: ['Data Scientist','Backend Developer','ML Engineer','Automation Engineer','Data Analyst'],
    salaryRange: '$80,000 – $150,000/year',
    timeToLearn: '3–6 months to job-ready',
    whyNow:      'Python is the primary language of the AI and data science revolution. Every major tech company uses Python for automation, ML pipelines, and backend services.',
  },
  'JavaScript': {
    intro:       'JavaScript is the only language that runs natively in every web browser. It\'s essential for frontend development, and with Node.js, it powers the backend too.',
    skills:      ['ES6+','Async Programming','DOM Manipulation','REST APIs','Node.js','TypeScript','React','Testing'],
    careerPaths: ['Frontend Developer','Full-Stack Developer','Node.js Developer','React Developer'],
    salaryRange: '$75,000 – $140,000/year',
    timeToLearn: '4–8 months to job-ready',
    whyNow:      'JavaScript developer demand has never been higher. The rise of web apps, PWAs, and serverless functions means JavaScript skills are needed everywhere.',
  },
  'React': {
    intro:       'React is the most widely-used JavaScript library for building modern user interfaces. Used by Facebook, Netflix, Airbnb, and thousands of startups worldwide.',
    skills:      ['Components','Hooks','Context API','Redux','React Router','Next.js','TypeScript','Testing'],
    careerPaths: ['React Developer','Frontend Engineer','Full-Stack Developer','UI Engineer'],
    salaryRange: '$85,000 – $150,000/year',
    timeToLearn: '2–4 months (after JavaScript basics)',
    whyNow:      'React job postings consistently rank in the top 3 most-requested frontend skills. Next.js has made React the default choice for modern web applications.',
  },
  'Data Science': {
    intro:       'Data Science combines statistics, programming, and domain expertise to extract meaningful insights from data. One of the highest-paying career paths in technology.',
    skills:      ['Python','Statistics','Machine Learning','Data Visualization','SQL','Pandas','Tableau','Power BI'],
    careerPaths: ['Data Scientist','Data Analyst','Business Intelligence Analyst','ML Engineer'],
    salaryRange: '$90,000 – $160,000/year',
    timeToLearn: '6–12 months to job-ready',
    whyNow:      'Every company is now a data company. Data Scientists are among the top 5 most in-demand roles globally, with a projected 35% job growth over the next decade.',
  },
  'Machine Learning': {
    intro:       'Machine Learning and AI are reshaping every industry. From recommendation systems to computer vision, ML skills are the most in-demand technical competency of the decade.',
    skills:      ['Neural Networks','Deep Learning','TensorFlow','PyTorch','Computer Vision','NLP','Scikit-learn','Transformers'],
    careerPaths: ['ML Engineer','AI Researcher','Data Scientist','Computer Vision Engineer','NLP Engineer'],
    salaryRange: '$110,000 – $200,000/year',
    timeToLearn: '6–12 months (after Python & statistics)',
    whyNow:      'Generative AI has created an explosion in ML engineer demand. Companies are hiring ML practitioners at rates 3x higher than just two years ago.',
  },
  'Web Development': {
    intro:       'Web development encompasses everything needed to build websites and web applications — from HTML/CSS to full-stack frameworks. The foundational career path for most software developers.',
    skills:      ['HTML/CSS','JavaScript','React','Node.js','Databases','REST APIs','Git','Deployment'],
    careerPaths: ['Full-Stack Developer','Frontend Developer','Backend Developer','Web Designer'],
    salaryRange: '$65,000 – $130,000/year',
    timeToLearn: '6–12 months for full-stack',
    whyNow:      'Web development is the most accessible path into tech. The barrier to entry is low, resources are abundant, and the job market remains consistently strong.',
  },
};

// Fallback editorial for categories without explicit config
const defaultEditorial = {
  intro:       `Master ${displayName} with our curated selection of the highest-rated free Udemy courses. All taught by industry experts with real-world experience.`,
  skills:      ['Professional Skills','Best Practices','Practical Projects','Industry Knowledge','Portfolio Building'],
  careerPaths: ['Professional Practitioner','Specialist','Consultant','Team Lead'],
  salaryRange: 'Varies by role and experience',
  timeToLearn: 'Self-paced — typically 2–6 months',
  whyNow:      `${displayName} skills are increasingly valued across industries. Starting with free Udemy courses lets you assess your interest before investing in advanced education.`,
};

const editorial = categoryEditorial[category as keyof typeof categoryEditorial] || defaultEditorial;

// ── Related topics for internal linking ───────────────────────────────────────
const relatedTopicsMap: Record<string, string[]> = {
  'Python':          ['data-science','machine-learning','django','flask','automation'],
  'JavaScript':      ['react','node-js','typescript','vue-js','angular'],
  'React':           ['javascript','typescript','next-js','node-js','redux'],
  'Data Science':    ['python','machine-learning','sql','tableau','statistics'],
  'Machine Learning':['python','data-science','tensorflow','pytorch','deep-learning'],
  'Web Development': ['javascript','react','node-js','html-css','sql'],
  'Java':            ['spring-boot','android','kotlin','microservices','maven'],
  'SQL':             ['data-science','python','mysql','postgresql','database-design'],
  'AWS':             ['docker','kubernetes','devops','linux','cloud-computing'],
  'Docker':          ['kubernetes','aws','devops','linux','ci-cd'],
};
const relatedSlugs = relatedTopicsMap[category] || [];

// ── FAQ per-kategori ──────────────────────────────────────────────────────────
const faqs = [
  {
    q: `Are these free ${displayName} Udemy courses really free?`,
    a: `Yes. All ${displayName} courses on CoursesWyn come with a verified 100% OFF Udemy coupon code. You get full lifetime access, all course materials, instructor Q&A, and a Udemy Certificate of Completion — at zero cost.`,
  },
  {
    q: `What skill level are these ${displayName} courses?`,
    a: `We list ${displayName} courses for all skill levels — Beginner, Intermediate, and Advanced. Each course card shows the level, so you can filter by what's right for you. Complete beginners should start with foundational ${displayName} courses before moving to advanced topics.`,
  },
  {
    q: `How long does it take to learn ${displayName} on Udemy?`,
    a: `${editorial.timeToLearn}. The exact time depends on your starting point and how many hours per week you commit. Most Udemy ${displayName} courses are 10–30 hours of content, which you can complete at your own pace.`,
  },
  {
    q: `Can I get a job after completing free ${displayName} Udemy courses?`,
    a: `Free Udemy courses provide the same knowledge as paid ones. To maximise your job prospects, combine courses with portfolio projects, GitHub contributions, and networking. Many developers and data professionals have landed their first roles using Udemy-only skill stacks.`,
  },
  {
    q: `How quickly do ${displayName} Udemy coupons expire?`,
    a: `Udemy promotional coupons typically expire in 1–3 days. CoursesWyn updates ${displayName} coupons daily and removes expired ones automatically. If a course appears on this page, the coupon is currently active.`,
  },
  {
    q: `Is a Udemy ${displayName} certificate recognised by employers?`,
    a: `Udemy certificates are recognised as evidence of skill acquisition and self-initiative. They're especially valued in tech, marketing, and design roles. For maximum impact, list your Udemy ${displayName} certificate on LinkedIn alongside a portfolio project that demonstrates what you built with the skill.`,
  },
];

// ── SEO ───────────────────────────────────────────────────────────────────────
// Keyword angle: "best udemy [category] courses" + year — per-kategori, bukan homepage
const pageTitle       = `Best ${displayName} Udemy Courses ${currentYear} — ${totalCourses}+ Free with Certificate`;
const pageDescription = `Discover ${totalCourses}+ free ${displayName} Udemy courses for ${currentYear}. Verified 100% OFF coupons, ${avgRating}★ average rating, expert instructors. Learn ${displayName} online and earn a free certificate.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type':'ListItem', position:1, name:'Home',                                    item:'https://courseswyn.com/' },
    { '@type':'ListItem', position:2, name:'Udemy Topics',                            item:'https://courseswyn.com/topics/' },
    { '@type':'ListItem', position:3, name:`Best ${displayName} Udemy Courses`,       item:Astro.url.href },
  ],
};

const collectionSchema = {
  '@context': 'https://schema.org', '@type': 'CollectionPage',
  name: pageTitle, description: pageDescription, url: Astro.url.href,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: topCourses.length,
    itemListElement: topCourses.map((c: any, i: number) => ({
      '@type':'ListItem', position:i+1,
      url:`https://courseswyn.com/coupon/${c.slug}`, name:c.title,
    })),
  },
};

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type':'Question', name:f.q, acceptedAnswer:{ '@type':'Answer', text:f.a } })),
};

const combinedSchema = [breadcrumbSchema, collectionSchema, faqSchema];
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://courseswyn.com/topics/best-udemy-courses/${slug}`}
  structuredData={combinedSchema}
>
<div class="bg-[#1c252e] min-h-screen pb-20">

  <!-- HERO -->
  <header class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8 flex items-center gap-2 text-sm text-gray-500 flex-wrap">
      <a href="/" class="hover:text-indigo-400 transition-colors">Home</a>
      <span aria-hidden="true">›</span>
      <a href="/topics" class="hover:text-indigo-400 transition-colors">Udemy Topics</a>
      <span aria-hidden="true">›</span>
      <span class="text-gray-300" aria-current="page">{displayName}</span>
    </nav>

    <div class="text-center">
      <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/30 rounded-full px-4 py-1.5 mb-6">
        <span class="w-2 h-2 bg-indigo-500 rounded-full animate-pulse"></span>
        <span class="text-indigo-400 text-xs font-bold uppercase tracking-widest">
          Updated {currentMonth} {currentYear} · Verified Coupons
        </span>
      </div>

      <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">
        Best <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">{displayName}</span><br/>
        Udemy Courses {currentYear}
      </h1>
      <p class="text-xl text-gray-300 font-medium mb-6">
        {totalCourses}+ Free {displayName} Courses · Free Certificate · Expert Instructors
      </p>
      <p class="text-gray-400 max-w-3xl mx-auto leading-relaxed mb-10 text-lg">
        {editorial.intro}
      </p>

      <!-- Stats -->
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12 max-w-3xl mx-auto border-t border-b border-[#2d3748] py-8">
        {[
          { v:`${totalCourses}+`,   l:'Free Courses' },
          { v:`${avgRating}★`,     l:'Average Rating' },
          { v:editorial.timeToLearn.split('–')[0].trim().replace(/[^0-9–]/g,'').split(/\s/)[0] + ' mo', l:'Avg. Time to Learn' },
          { v:'100%',               l:'Free Access' },
        ].map(s => (
          <div>
            <dt class="text-3xl font-black text-indigo-400">{s.v}</dt>
            <dd class="text-gray-500 text-xs font-bold uppercase tracking-wider mt-1">{s.l}</dd>
          </div>
        ))}
      </dl>

      <a href="#courses"
         class="inline-block px-8 py-4 bg-indigo-500 hover:bg-indigo-600 text-white rounded-xl font-bold text-lg shadow-lg hover:shadow-xl transition-all hover:-translate-y-1">
        Browse {displayName} Courses ↓
      </a>
    </div>
  </header>

  <!-- WHAT YOU'LL LEARN -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="bg-[#28323d] border border-[#2d3748] rounded-2xl p-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Skills -->
        <div>
          <h2 class="text-white font-bold text-lg mb-4">🎯 Skills You'll Learn</h2>
          <div class="flex flex-wrap gap-2">
            {editorial.skills.map((skill: string) => (
              <span class="bg-[#1c252e] border border-[#2d3748] px-3 py-1 rounded-full text-sm text-gray-300 hover:text-indigo-400 hover:border-indigo-400 transition-all">
                {skill}
              </span>
            ))}
          </div>
        </div>
        <!-- Career paths -->
        <div>
          <h2 class="text-white font-bold text-lg mb-4">💼 Career Paths</h2>
          <ul class="space-y-2">
            {editorial.careerPaths.map((cp: string) => (
              <li class="flex items-center gap-2 text-sm text-gray-400">
                <span class="text-indigo-400">→</span> {cp}
              </li>
            ))}
          </ul>
        </div>
        <!-- Salary & time -->
        <div class="space-y-5">
          <div>
            <h2 class="text-white font-bold text-lg mb-2">💰 Salary Range</h2>
            <p class="text-indigo-400 font-bold text-xl">{editorial.salaryRange}</p>
          </div>
          <div>
            <h2 class="text-white font-bold text-lg mb-2">⏱️ Time to Learn</h2>
            <p class="text-gray-400 text-sm">{editorial.timeToLearn}</p>
          </div>
          <div>
            <h2 class="text-white font-bold text-lg mb-2">📈 Why Learn Now</h2>
            <p class="text-gray-400 text-sm leading-relaxed">{editorial.whyNow}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COURSES -->
  <section id="courses" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-1.5 h-8 bg-indigo-500 rounded-full"></span>
      <h2 class="text-2xl font-bold text-white">
        Top Free {displayName} Udemy Courses — {currentYear}
      </h2>
    </div>

    {topCourses.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-12">
        {topCourses.map((course: any) => (
          <CourseCard course={course} />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-400 text-lg mb-4">No courses found for {displayName} right now.</p>
        <p class="text-gray-500 text-sm mb-6">New coupons are added daily — check back soon, or browse a related topic.</p>
        <a href="/topics" class="inline-block px-6 py-3 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 transition-colors">
          Browse All Topics
        </a>
      </div>
    )}

    {topCourses.length >= 24 && (
      <div class="text-center">
        <a href="/courses" class="inline-block px-8 py-4 bg-[#28323d] border border-[#2d3748] text-white rounded-xl hover:border-indigo-400 transition-all">
          View All {displayName} Courses →
        </a>
      </div>
    )}
  </section>

  <!-- RELATED TOPICS -->
  {relatedSlugs.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-1.5 h-7 bg-indigo-500 rounded-full"></span>
        <h2 class="text-xl font-bold text-white">Related Topics to Explore</h2>
      </div>
      <div class="flex flex-wrap gap-3">
        {relatedSlugs.map((s: string) => (
          <a href={`/topics/best-udemy-courses/${s}`}
             class="bg-[#28323d] border border-[#2d3748] px-4 py-2 rounded-full text-sm text-gray-300 hover:text-white hover:border-indigo-400 hover:bg-indigo-500/10 transition-all font-medium capitalize">
            {s.replace(/-/g, ' ')}
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- WHY LEARN HERE -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="bg-[#28323d] border border-[#2d3748] rounded-2xl p-8 md:p-12">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-white mb-3">Why Learn {displayName} with Free Udemy Courses?</h2>
        <p class="text-gray-400">Everything included — at zero cost</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { icon:'🎓', title:'Same as Paid Enrollment', body:`Free coupon enrollments give you identical access to paid students. Same ${displayName} lectures, resources, and the same certificate.` },
          { icon:'🛠️', title:'Hands-on Projects',        body:`The best ${displayName} Udemy courses include real projects you can add to your portfolio to prove your skills to employers.` },
          { icon:'📜', title:'Verified Certificate',      body:`Earn a Udemy Certificate of Completion for every ${displayName} course you finish. Add it to LinkedIn or your resume immediately.` },
        ].map(item => (
          <div class="text-center">
            <div class="w-16 h-16 bg-indigo-500/20 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl">
              {item.icon}
            </div>
            <h3 class="text-xl font-bold text-white mb-2">{item.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-3">
        Free {displayName} Udemy Course — FAQs
      </h2>
      <p class="text-gray-400">Everything you need to know before enrolling</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {faqs.map((faq) => (
        <div class="bg-[#28323d] border border-[#2d3748] p-6 rounded-xl hover:border-indigo-500/40 transition-colors">
          <h3 class="text-indigo-400 font-bold text-base mb-3 leading-snug">{faq.q}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{faq.a}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- SEO PROSE -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="space-y-6 text-gray-400 leading-relaxed text-base">
      <h2 class="text-3xl font-bold text-white text-center mb-2">
        Master {displayName} with Free Udemy Courses in {currentYear}
      </h2>

      <p>
        This page curates the <strong class="text-white">best free {displayName} Udemy courses</strong> available right now,
        sorted by student rating. Every course comes with a verified 100% OFF coupon — you pay nothing and receive
        full lifetime access plus a Udemy Certificate of Completion.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-6">
        {[
          { title:'Quality Filter',    body:`Only ${displayName} courses rated 4.0+ with proven student outcomes.` },
          { title:'Expert Instructors', body:`Courses taught by practitioners with real-world ${displayName} experience.` },
          { title:'Updated Coupons',   body:`Every ${displayName} coupon is verified and refreshed daily.` },
          { title:'All Levels',         body:`${displayName} courses for beginners through to advanced practitioners.` },
        ].map(item => (
          <div class="bg-[#28323d] border border-[#2d3748] rounded-xl p-5">
            <p class="text-indigo-400 font-bold text-sm mb-1">{item.title}</p>
            <p class="text-gray-400 text-sm">{item.body}</p>
          </div>
        ))}
      </div>

      <h3 class="text-white font-bold text-xl">How to Start Learning {displayName} Today</h3>
      <ol class="space-y-2 text-sm">
        <li><strong class="text-white">1.</strong> Pick a course above that matches your current skill level.</li>
        <li><strong class="text-white">2.</strong> Click "Enroll Free" — the 100% OFF coupon is pre-applied.</li>
        <li><strong class="text-white">3.</strong> Create a free Udemy account if you don't have one.</li>
        <li><strong class="text-white">4.</strong> Complete the course and download your certificate.</li>
        <li><strong class="text-white">5.</strong> Build a portfolio project using what you learned.</li>
      </ol>

      <!-- Cross-links back to hub -->
      <div class="bg-[#28323d] border border-[#2d3748] rounded-xl p-5 flex flex-wrap gap-4 items-center justify-between">
        <div>
          <p class="text-white font-bold text-sm mb-1">Looking for a full learning roadmap?</p>
          <p class="text-gray-400 text-xs">Visit our topics hub for structured career paths using free Udemy courses.</p>
        </div>
        <a href="/topics" class="flex-shrink-0 px-5 py-2 bg-indigo-500 hover:bg-indigo-600 text-white text-sm font-bold rounded-lg transition-all">
          View Learning Paths →
        </a>
      </div>

      <p class="text-xs pt-6 border-t border-[#2d3748] text-center text-gray-500">
        <em><strong>Disclaimer:</strong> CoursesWyn is not affiliated with Udemy.com. All trademarks belong to their respective owners. We aggregate publicly available promotional coupon codes to help students access quality education at no cost.</em>
      </p>
    </div>
  </section>

</div>
</MainLayout>