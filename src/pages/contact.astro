---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Contact CoursesWyn | Get Support & Customer Service"
    description="Contact CoursesWyn for support, questions about Udemy coupons, partnership inquiries, or feedback. Our team responds within 24 hours."
>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "ContactPage",
          "@id": "https://courseswyn.com/contact",
          "url": "https://courseswyn.com/contact",
          "name": "Contact CoursesWyn - Support & Customer Service",
          "description": "Get in touch with CoursesWyn for support, Udemy coupon questions, partnerships, or feedback. Fast response within 24 hours.",
          "isPartOf": { "@id": "https://courseswyn.com" },
          "primaryImageOfPage": {
            "@type": "ImageObject",
            "url": "https://courseswyn.com/logo.svg"
          },
          "datePublished": "2023-01-01",
          "dateModified": "2026-01-15",
          "inLanguage": "en-US",
          "breadcrumb": {
            "@type": "BreadcrumbList",
            "itemListElement": [
              { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" },
              { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://courseswyn.com/contact" }
            ]
          },
          "mainEntity": {
            "@type": "Organization",
            "name": "CoursesWyn",
            "contactPoint": {
              "@type": "ContactPoint",
              "contactType": "customer service",
              "email": "contact@courseswyn.com",
              "availableLanguage": "English",
              "hoursAvailable": {
                "@type": "OpeningHoursSpecification",
                "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
                "opens": "09:00",
                "closes": "18:00"
              }
            }
          }
        }
      ]
    })} />

    <main style="background: var(--bg); color: var(--text);">
        
        {/* ── HERO ── */}
        <section style="padding: 100px 0 80px; border-bottom: 2px solid var(--border); background: var(--card);">
            <div class="container">
                <h1 style={{ 
                    fontSize: "clamp(2.5rem, 7vw, 4.5rem)", 
                    fontWeight: 900, 
                    lineHeight: 1.05, 
                    letterSpacing: "-0.04em",
                    marginBottom: "32px"
                }}>
                    Get in<br/>
                    <span style={{ background: "var(--accent)", color: "white", padding: "0 10px" }}>Touch.</span>
                </h1>
                
                <p style={{ 
                    fontSize: "clamp(1.1rem, 3vw, 1.3rem)", 
                    color: "var(--muted)", 
                    maxWidth: "800px", 
                    lineHeight: 1.6,
                    fontWeight: 500,
                    marginBottom: "48px"
                }}>
                    Have questions about Udemy coupons, need support, or want to discuss partnerships? Our team is ready to assist you.
                </p>
            </div>
        </section>

        {/* ── CONTACT OPTIONS ── */}
        <section style="padding: 80px 0; background: white; border-bottom: 2px solid var(--border);">
            <div class="container">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 32px;">
                    {[
                        { 
                            t: "General Support", 
                            d: "Questions about Udemy coupons, course deals, or how our platform works? We're here to help!",
                            b: "Ask a Question",
                            e: "Support Question",
                            c: "var(--accent)"
                        },
                        { 
                            t: "Partnerships", 
                            d: "Interested in collaborating with CoursesWyn? We work with instructors, platforms, and educational partners.",
                            b: "Discuss Partnership",
                            e: "Partnership Inquiry",
                            c: "var(--text)"
                        },
                        { 
                            t: "Share Feedback", 
                            d: "Love CoursesWyn or have suggestions? We value your feedback and use it to improve our platform.",
                            b: "Send Feedback",
                            e: "Feedback",
                            c: "var(--muted)"
                        }
                    ].map(opt => (
                        <div class="neo-contact-card">
                            <h2 style={{ fontSize: "1.5rem", fontWeight: 900, marginBottom: "16px" }}>{opt.t}</h2>
                            <p style={{ color: "var(--muted)", fontSize: "1rem", lineHeight: 1.6, fontWeight: 500, marginBottom: "32px" }}>
                                {opt.d}
                            </p>
                            <a 
                                href={`mailto:contact@courseswyn.com?subject=${opt.e}`} 
                                class="btn" 
                                style={{ width: "100%", textAlign: "center", background: opt.c, color: "white", borderColor: opt.c }}
                            >
                                {opt.b}
                            </a>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        {/* ── RESPONSE TIME ── */}
        <section style="padding: 80px 0; background: var(--bg);">
            <div class="container" style="max-width: 800px; text-align: center;">
                <div style="background: white; border: 2px solid var(--border); padding: 48px; box-shadow: 8px 8px 0 var(--border); border-radius: 8px;">
                    <h2 style="font-size: 2.5rem; font-weight: 900; margin-bottom: 24px; letter-spacing: -0.02em;">Fast Response.</h2>
                    <p style="color: var(--muted); font-size: 1.1rem; line-height: 1.7, font-weight: 500; margin-bottom: 40px;">
                        We respond to all inquiries within 24 hours during business days. For urgent coupon issues, check our troubleshooting guides first.
                    </p>
                    
                    <div style="display: flex; justify-content: center; gap: 24px; flex-wrap: wrap;">
                        <a href="https://x.com/CoursesGift" target="_blank" class="pill" style="padding: 12px 24px; font-weight: 800; border-width: 2px;">TWITTER / X</a>
                        <a href="https://www.facebook.com/BestCouponPromo/" target="_blank" class="pill" style="padding: 12px 24px; font-weight: 800; border-width: 2px;">FACEBOOK</a>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <style>
        .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
        .neo-contact-card {
            background: white; border: 2px solid var(--border); border-radius: 8px; padding: 40px;
            transition: all 0.2s; box-shadow: 6px 6px 0 var(--border);
        }
        .neo-contact-card:hover { transform: translate(-4px, -4px); box-shadow: 10px 10px 0 var(--border); }
    </style>
</Layout>
