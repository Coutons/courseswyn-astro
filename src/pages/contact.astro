---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Contact CoursesWyn | Get Support & Customer Service"
    description="Contact CoursesWyn for support, questions about Udemy coupons, partnership inquiries, or feedback. Our team responds within 24 hours."
>
    <!-- Contact Page Enhanced Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "ContactPage",
          "@id": "https://courseswyn.com/contact",
          "url": "https://courseswyn.com/contact",
          "name": "Contact CoursesWyn - Support & Customer Service",
          "description": "Get in touch with CoursesWyn for support, Udemy coupon questions, partnerships, or feedback. Fast response within 24 hours.",
          "isPartOf": {
            "@id": "https://courseswyn.com"
          },
          "primaryImageOfPage": {
            "@type": "ImageObject",
            "url": "https://courseswyn.com/logo.svg"
          },
          "datePublished": "2023-01-01",
          "dateModified": "2026-01-15",
          "inLanguage": "en-US",
          "breadcrumb": {
            "@type": "BreadcrumbList",
            "itemListElement": [
              {
                "@type": "ListItem",
                "position": 1,
                "name": "Home",
                "item": "https://courseswyn.com"
              },
              {
                "@type": "ListItem",
                "position": 2,
                "name": "Contact",
                "item": "https://courseswyn.com/contact"
              }
            ]
          },
          "mainEntity": {
            "@type": "Organization",
            "name": "CoursesWyn",
            "contactPoint": {
              "@type": "ContactPoint",
              "contactType": "customer service",
              "email": "contact@courseswyn.com",
              "availableLanguage": "English",
              "hoursAvailable": {
                "@type": "OpeningHoursSpecification",
                "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
                "opens": "09:00",
                "closes": "18:00"
              }
            }
          }
        },
        {
          "@type": "Organization",
          "@id": "https://courseswyn.com/#organization",
          "name": "CoursesWyn",
          "url": "https://courseswyn.com",
          "logo": "https://courseswyn.com/logo.svg",
          "description": "Free Udemy coupons platform providing customer support",
          "foundingDate": "2023",
          "contactPoint": {
            "@type": "ContactPoint",
            "contactType": "customer support",
            "email": "contact@courseswyn.com",
            "url": "https://courseswyn.com/contact"
          },
          "sameAs": [
            "https://x.com/courses_peak",
            "https://www.facebook.com/CoursesWynOfficial/"
          ]
        }
      ]
    }
    </script>
    <div class="hero-gradient" style={{ minHeight: "100vh", color: "var(--text)" }}>
        <main>
            {/* Hero Section */}
            <section
                class="hero-gradient"
                style={{
                    position: "relative",
                    padding: "8rem 1rem 4rem",
                    textAlign: "center",
                    overflow: "hidden",
                }}
            >
                <div class="container" style={{ position: "relative", zIndex: 10 }}>
                    <div style={{
                        display: "inline-flex",
                        alignItems: "center",
                        gap: "0.5rem",
                        background: "var(--brand-soft)",
                        padding: "0.5rem 1rem",
                        borderRadius: "9999px",
                        marginBottom: "2rem",
                        fontSize: "0.9rem",
                        color: "var(--brand)",
                        fontWeight: 600
                    }}>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.89 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                        </svg>
                        Get in Touch
                    </div>

                    <h1
                        style={{
                            fontSize: "clamp(2.5rem, 5vw, 4rem)",
                            fontWeight: 800,
                            lineHeight: 1.1,
                            marginBottom: "1.5rem",
                            maxWidth: "1200px",
                            margin: "0 auto 1.5rem"
                        }}
                    >
                        <span style={{
                            background: "linear-gradient(135deg, var(--brand) 0%, hsl(35, 90%, 68%) 100%)",
                            WebkitBackgroundClip: "text",
                            WebkitTextFillColor: "transparent",
                            backgroundClip: "text"
                        }}>
                            Contact CoursesWyn
                        </span>
                        <br/>
                        <span style={{
                            background: "linear-gradient(135deg, var(--text) 0%, var(--muted) 100%)",
                            WebkitBackgroundClip: "text",
                            WebkitTextFillColor: "transparent",
                            backgroundClip: "text"
                        }}>
                            We're Here to Help
                        </span>
                    </h1>
                    <p
                        style={{
                            fontSize: "clamp(1.1rem, 2.5vw, 1.4rem)",
                            color: "var(--muted)",
                            maxWidth: "700px",
                            margin: "0 auto 3rem",
                            lineHeight: 1.6,
                            fontWeight: 400
                        }}
                    >
                        Have questions about Udemy coupons, need support, or want to discuss partnerships? Our team is ready to assist you.
                    </p>
                </div>

                {/* Decorative elements */}
                <div style={{
                    position: "absolute",
                    top: "20%",
                    left: "10%",
                    width: "300px",
                    height: "300px",
                    background: "var(--brand)",
                    filter: "blur(120px)",
                    opacity: 0.1,
                    borderRadius: "50%",
                }}></div>
                <div style={{
                    position: "absolute",
                    bottom: "10%",
                    right: "10%",
                    width: "250px",
                    height: "250px",
                    background: "var(--accent)",
                    filter: "blur(100px)",
                    opacity: 0.1,
                    borderRadius: "50%",
                }}></div>
            </section>

            {/* Contact Options */}
            <section class="card-gradient" style={{ padding: "4rem 1rem" }}>
                <div class="container" style={{ maxWidth: "1200px" }}>
                    <div style={{ display: "grid", gap: "2rem" }}>
                        {/* Support Questions */}
                        <div
                            style={{
                                background: "var(--card)",
                                padding: "3rem",
                                borderRadius: "20px",
                                border: "1px solid var(--border)",
                                textAlign: "center"
                            }}
                        >
                            <div style={{
                                width: "80px",
                                height: "80px",
                                background: "var(--brand)",
                                borderRadius: "20px",
                                display: "flex",
                                alignItems: "center",
                                justifyContent: "center",
                                margin: "0 auto 2rem"
                            }}>
                                <svg width="40" height="40" viewBox="0 0 24 24" fill="white">
                                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/>
                                </svg>
                            </div>
                            <h2 style={{ color: "var(--text)", fontSize: "2rem", marginBottom: "1rem", fontWeight: 700 }}>
                                General Support
                            </h2>
                            <p style={{ color: "var(--muted)", fontSize: "1.1rem", marginBottom: "2rem", lineHeight: 1.6 }}>
                                Questions about Udemy coupons, course deals, or how our platform works? We're here to help!
                            </p>
                            <a
                                href="mailto:contact@courseswyn.com?subject=Support Question"
                                style={{
                                    display: "inline-flex",
                                    alignItems: "center",
                                    gap: "0.5rem",
                                    padding: "1rem 2rem",
                                    background: "var(--brand)",
                                    color: "var(--bg)",
                                    textDecoration: "none",
                                    borderRadius: "12px",
                                    fontSize: "1.1rem",
                                    fontWeight: 600,
                                    transition: "all 0.3s ease"
                                }}
                            >
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.89 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                                </svg>
                                Ask a Question
                            </a>
                        </div>

                        {/* Partnership Inquiries */}
                        <div
                            style={{
                                background: "var(--card)",
                                padding: "3rem",
                                borderRadius: "20px",
                                border: "1px solid var(--border)",
                                textAlign: "center"
                            }}
                        >
                            <div style={{
                                width: "80px",
                                height: "80px",
                                background: "var(--accent)",
                                borderRadius: "20px",
                                display: "flex",
                                alignItems: "center",
                                justifyContent: "center",
                                margin: "0 auto 2rem"
                            }}>
                                <svg width="40" height="40" viewBox="0 0 24 24" fill="white">
                                    <path d="M16 4c0-1.11.89-2 2-2s2 .89 2 2-.89 2-2 2-2-.89-2-2zm4 18v-6h2.5l-2.54-7.63C19.68 7.55 18.92 7 18.09 7h-.25c-.34 0-.68.16-.92.45L14.5 10H12v2h2.47l.93 5H10v2h6v4h2zM10 4c0-1.11-.89-2-2-2s-2 .89-2 2 .89 2 2 2 2-.89 2-2zm4 18v-6H9.5l2.54-7.63C12.32 7.55 13.08 7 13.91 7h.25c.34 0 .68.16.92.45L17.5 10H20v2h-2.47l-.93 5H14v2h-6v4H8z"/>
                                </svg>
                            </div>
                            <h2 style={{ color: "var(--text)", fontSize: "2rem", marginBottom: "1rem", fontWeight: 700 }}>
                                Partnership Opportunities
                            </h2>
                            <p style={{ color: "var(--muted)", fontSize: "1.1rem", marginBottom: "2rem", lineHeight: 1.6 }}>
                                Interested in collaborating with CoursesWyn? We work with instructors, platforms, and educational partners.
                            </p>
                            <a
                                href="mailto:contact@courseswyn.com?subject=Partnership Inquiry"
                                style={{
                                    display: "inline-flex",
                                    alignItems: "center",
                                    gap: "0.5rem",
                                    padding: "1rem 2rem",
                                    background: "var(--accent)",
                                    color: "var(--bg)",
                                    textDecoration: "none",
                                    borderRadius: "12px",
                                    fontSize: "1.1rem",
                                    fontWeight: 600,
                                    transition: "all 0.3s ease"
                                }}
                            >
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M16 4c0-1.11.89-2 2-2s2 .89 2 2-.89 2-2 2-2-.89-2-2zm4 18v-6h2.5l-2.54-7.63C19.68 7.55 18.92 7 18.09 7h-.25c-.34 0-.68.16-.92.45L14.5 10H12v2h2.47l.93 5H10v2h6v4h2zM10 4c0-1.11-.89-2-2-2s-2 .89-2 2 .89 2 2 2 2-.89 2-2zm4 18v-6H9.5l2.54-7.63C12.32 7.55 13.08 7 13.91 7h.25c.34 0 .68.16.92.45L17.5 10H20v2h-2.47l-.93 5H14v2h-6v4H8z"/>
                                </svg>
                                Discuss Partnership
                            </a>
                        </div>

                        {/* Feedback */}
                        <div
                            style={{
                                background: "var(--card)",
                                padding: "3rem",
                                borderRadius: "20px",
                                border: "1px solid var(--border)",
                                textAlign: "center"
                            }}
                        >
                            <div style={{
                                width: "80px",
                                height: "80px",
                                background: "hsl(180, 50%, 40%)",
                                borderRadius: "20px",
                                display: "flex",
                                alignItems: "center",
                                justifyContent: "center",
                                margin: "0 auto 2rem"
                            }}>
                                <svg width="40" height="40" viewBox="0 0 24 24" fill="white">
                                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                                </svg>
                            </div>
                            <h2 style={{ color: "var(--text)", fontSize: "2rem", marginBottom: "1rem", fontWeight: 700 }}>
                                Share Your Feedback
                            </h2>
                            <p style={{ color: "var(--muted)", fontSize: "1.1rem", marginBottom: "2rem", lineHeight: 1.6 }}>
                                Love CoursesWyn or have suggestions? We value your feedback and use it to improve our platform.
                            </p>
                            <a
                                href="mailto:contact@courseswyn.com?subject=Feedback"
                                style={{
                                    display: "inline-flex",
                                    alignItems: "center",
                                    gap: "0.5rem",
                                    padding: "1rem 2rem",
                                    background: "hsl(180, 50%, 40%)",
                                    color: "var(--bg)",
                                    textDecoration: "none",
                                    borderRadius: "12px",
                                    fontSize: "1.1rem",
                                    fontWeight: 600,
                                    transition: "all 0.3s ease"
                                }}
                            >
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                                </svg>
                                Send Feedback
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            {/* Response Time & Social Links */}
            <section class="hero-gradient" style={{ padding: "4rem 1rem" }}>
                <div class="container" style={{ maxWidth: "800px", textAlign: "center" }}>
                    <h2 style={{
                        fontSize: "clamp(1.8rem, 4vw, 2.5rem)",
                        fontWeight: 800,
                        color: "var(--text)",
                        marginBottom: "1rem"
                    }}>
                        Fast Response Guarantee
                    </h2>
                    <p style={{
                        color: "var(--muted)",
                        fontSize: "1.1rem",
                        maxWidth: "600px",
                        margin: "0 auto 2rem",
                        lineHeight: 1.6
                    }}>
                        We respond to all inquiries within 24 hours during business days. For urgent coupon issues, check our troubleshooting guides first.
                    </p>

                    <div style={{
                        background: "var(--card)",
                        padding: "3rem",
                        borderRadius: "24px",
                        border: "1px solid var(--border)",
                        marginBottom: "3rem"
                    }}>
                        <h3 style={{ color: "var(--text)", fontSize: "1.5rem", marginBottom: "2rem", fontWeight: 700 }}>
                            Stay Connected
                        </h3>
                        <p style={{ color: "var(--muted)", marginBottom: "2rem" }}>
                            Follow us for the latest Udemy deals and educational updates.
                        </p>
                        <div style={{ display: "flex", justifyContent: "center", gap: "2rem", flexWrap: "wrap" }}>
                            <a
                                href="https://x.com/courses_peak"
                                target="_blank"
                                rel="noopener noreferrer"
                                style={{
                                    display: "flex",
                                    alignItems: "center",
                                    gap: "0.5rem",
                                    padding: "1rem 1.5rem",
                                    background: "var(--card)",
                                    border: "1px solid var(--border)",
                                    borderRadius: "12px",
                                    textDecoration: "none",
                                    color: "var(--text)",
                                    transition: "all 0.3s ease"
                                }}
                            >
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                                </svg>
                                Twitter / X
                            </a>
                            <a
                                href="https://www.facebook.com/CoursesWynOfficial/"
                                target="_blank"
                                rel="noopener noreferrer"
                                style={{
                                    display: "flex",
                                    alignItems: "center",
                                    gap: "0.5rem",
                                    padding: "1rem 1.5rem",
                                    background: "var(--card)",
                                    border: "1px solid var(--border)",
                                    borderRadius: "12px",
                                    textDecoration: "none",
                                    color: "var(--text)",
                                    transition: "all 0.3s ease"
                                }}
                            >
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                                </svg>
                                Facebook
                            </a>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <style>
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .hero-gradient {
            background: linear-gradient(135deg, hsl(222, 47%, 7%) 0%, hsl(222, 43%, 10%) 100%);
        }

        .card-gradient {
            background: var(--bg);
        }
    </style>
</Layout>
