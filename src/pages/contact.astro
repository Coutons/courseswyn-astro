---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Contact CoursesWyn | Get Support & Customer Service"
    description="Contact CoursesWyn for support, questions about Udemy coupons, partnership inquiries, or feedback. Our team responds within 24 hours."
>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "ContactPage",
          "@id": "https://courseswyn.com/contact",
          "url": "https://courseswyn.com/contact",
          "name": "Contact CoursesWyn - Support & Customer Service",
          "description": "Get in touch with CoursesWyn for support, Udemy coupon questions, partnerships, or feedback. Fast response within 24 hours.",
          "isPartOf": { "@id": "https://courseswyn.com" },
          "primaryImageOfPage": {
            "@type": "ImageObject",
            "url": "https://courseswyn.com/logo.svg"
          },
          "datePublished": "2023-01-01",
          "dateModified": "2026-01-15",
          "inLanguage": "en-US",
          "breadcrumb": {
            "@type": "BreadcrumbList",
            "itemListElement": [
              { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" },
              { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://courseswyn.com/contact" }
            ]
          },
          "mainEntity": {
            "@type": "Organization",
            "name": "CoursesWyn"
          }
        }
      ]
    })} />

    <main>
        <section class="c-hero">
            <div class="c-container">
                <div class="c-badge">Contact Us</div>
                <h1 class="c-title">Get in <span class="c-grad">Touch.</span></h1>
                <p class="c-desc">
                    Have questions about Udemy coupons, need support, or want to discuss partnerships? Our team is ready to assist you.
                </p>
            </div>
        </section>

        <section class="c-section">
            <div class="c-container">
                <div class="c-grid">
                    {[
                        {
                            t: "General Support",
                            d: "Questions about Udemy coupons, course deals, or how our platform works? We're here to help!",
                            b: "Ask a Question",
                            e: "Support Question"
                        },
                        {
                            t: "Partnerships",
                            d: "Interested in collaborating with CoursesWyn? We work with instructors, platforms, and educational partners.",
                            b: "Discuss Partnership",
                            e: "Partnership Inquiry"
                        },
                        {
                            t: "Share Feedback",
                            d: "Love CoursesWyn or have suggestions? We value your feedback and use it to improve our platform.",
                            b: "Send Feedback",
                            e: "Feedback"
                        }
                    ].map(opt => (
                        <div class="c-card">
                            <h2 class="c-card-title">{opt.t}</h2>
                            <p class="c-card-desc">{opt.d}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <section class="c-section c-section-last">
            <div class="c-container c-container-narrow">
                <div class="c-response">
                    <h2 class="c-response-title">Fast Response.</h2>
                    <p class="c-response-desc">
                        We respond to all inquiries within 24 hours during business days. For urgent coupon issues, check our <a href="/how-to-redeem-coupon">troubleshooting guides</a> first.
                    </p>
                    <div class="c-social">
                        <a href="https://x.com/CoursesGift" target="_blank" rel="noopener noreferrer" class="c-social-btn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                            X / Twitter
                        </a>
                        <a href="https://www.facebook.com/BestCouponPromo/" target="_blank" rel="noopener noreferrer" class="c-social-btn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                            Facebook
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <style>
        .c-container { max-width: 1024px; margin: 0 auto; padding: 0 1.5rem; }
        .c-container-narrow { max-width: 700px; }

        .c-hero { padding: 80px 0 60px; text-align: center; border-bottom: 1px solid var(--border); }
        .c-badge { display: inline-flex; align-items: center; gap: 6px; background: var(--brand-soft); color: var(--brand); padding: 6px 14px; border-radius: 999px; font-size: 0.82rem; font-weight: 700; margin-bottom: 24px; }
        .c-title { font-size: clamp(2.2rem, 6vw, 3.5rem); font-weight: 900; line-height: 1.1; margin: 0 0 16px; letter-spacing: -0.03em; }
        .c-grad { background: linear-gradient(135deg, var(--brand), hsl(200, 80%, 55%)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .c-desc { font-size: 1.1rem; color: var(--text-secondary); max-width: 650px; margin: 0 auto; line-height: 1.6; font-weight: 500; }

        .c-section { padding: 60px 0; }
        .c-section-last { padding-bottom: 80px; }
        .c-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }

        .c-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 32px; transition: border-color 0.15s; }
        .c-card:hover { border-color: var(--brand); }
        .c-card-title { font-size: 1.3rem; font-weight: 800; color: var(--text); margin: 0 0 12px; }
        .c-card-desc { font-size: 0.92rem; color: var(--text-secondary); line-height: 1.6; margin: 0 0 24px; font-weight: 500; }

        .c-btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: var(--brand); color: white; border-radius: var(--radius-sm); font-size: 0.9rem; font-weight: 700; text-decoration: none; transition: opacity 0.15s; width: 100%; justify-content: center; }
        .c-btn:hover { opacity: 0.9; }
        .c-btn svg { flex-shrink: 0; }

        .c-response { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 48px; text-align: center; }
        .c-response-title { font-size: 1.8rem; font-weight: 900; color: var(--text); margin: 0 0 16px; }
        .c-response-desc { font-size: 1rem; color: var(--text-secondary); line-height: 1.6; margin: 0 0 32px; font-weight: 500; }
        .c-response-desc a { color: var(--brand); }

        .c-social { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; }
        .c-social-btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text); text-decoration: none; font-size: 0.85rem; font-weight: 700; transition: border-color 0.15s; }
        .c-social-btn:hover { border-color: var(--brand); }
        .c-social-btn svg { width: 18px; height: 18px; }
    </style>
</Layout>
