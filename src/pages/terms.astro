---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Terms of Service | Legal Terms & Conditions"
    description="CoursesWyn Terms of Service. Legal terms and conditions for using our Udemy coupon platform, including user conduct, intellectual property, and service usage guidelines."
>
    <!-- Terms Page Enhanced Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "@id": "https://courseswyn.com/terms",
          "url": "https://courseswyn.com/terms",
          "name": "Terms of Service - CoursesWyn Legal Terms and Conditions",
          "description": "Comprehensive Terms of Service for CoursesWyn. Legal terms covering Udemy coupon usage, user conduct, intellectual property rights, and service conditions.",
          "isPartOf": {
            "@id": "https://courseswyn.com"
          },
          "primaryImageOfPage": {
            "@type": "ImageObject",
            "url": "https://courseswyn.com/logo.svg"
          },
          "datePublished": "2023-01-01",
          "dateModified": "2026-01-15",
          "inLanguage": "en-US",
          "breadcrumb": {
            "@type": "BreadcrumbList",
            "itemListElement": [
              {
                "@type": "ListItem",
                "position": 1,
                "name": "Home",
                "item": "https://courseswyn.com"
              },
              {
                "@type": "ListItem",
                "position": 2,
                "name": "Terms of Service",
                "item": "https://courseswyn.com/terms"
              }
            ]
          },
          "mainEntity": {
            "@type": "WebPage",
            "name": "Terms of Service",
            "description": "Legal terms and conditions for using CoursesWyn services"
          }
        },
        {
          "@type": "Organization",
          "@id": "https://courseswyn.com/#organization",
          "name": "CoursesWyn",
          "url": "https://courseswyn.com",
          "logo": "https://courseswyn.com/logo.svg",
          "description": "Free Udemy coupons platform with legal terms of service",
          "foundingDate": "2023",
          "sameAs": [
            "https://x.com/courses_peak",
            "https://www.facebook.com/CoursesWynOfficial/"
          ]
        }
      ]
    }
    </script>
    <div class="hero-gradient" style={{ minHeight: "100vh", color: "var(--text)" }}>
        <main>
            {/* Hero Section */}
            <section
                class="hero-gradient"
                style={{
                    position: "relative",
                    padding: "8rem 1rem 4rem",
                    textAlign: "center",
                    overflow: "hidden",
                }}
            >
                <div class="container" style={{ position: "relative", zIndex: 10 }}>
                    <div style={{
                        display: "inline-flex",
                        alignItems: "center",
                        gap: "0.5rem",
                        background: "var(--brand-soft)",
                        padding: "0.5rem 1rem",
                        borderRadius: "9999px",
                        marginBottom: "2rem",
                        fontSize: "0.9rem",
                        color: "var(--brand)",
                        fontWeight: 600
                    }}>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
                        </svg>
                        Legal Terms
                    </div>

                    <h1
                        style={{
                            fontSize: "clamp(2.5rem, 5vw, 4rem)",
                            fontWeight: 800,
                            lineHeight: 1.1,
                            marginBottom: "1.5rem",
                            maxWidth: "1200px",
                            margin: "0 auto 1.5rem"
                        }}
                    >
                        <span style={{
                            background: "linear-gradient(135deg, var(--brand) 0%, hsl(35, 90%, 68%) 100%)",
                            WebkitBackgroundClip: "text",
                            WebkitTextFillColor: "transparent",
                            backgroundClip: "text"
                        }}>
                            Terms of Service
                        </span>
                        <br/>
                        <span style={{
                            background: "linear-gradient(135deg, var(--text) 0%, var(--muted) 100%)",
                            WebkitBackgroundClip: "text",
                            WebkitTextFillColor: "transparent",
                            backgroundClip: "text"
                        }}>
                            Legal Terms & Conditions
                        </span>
                    </h1>
                    <p
                        style={{
                            fontSize: "clamp(1.1rem, 2.5vw, 1.4rem)",
                            color: "var(--muted)",
                            maxWidth: "700px",
                            margin: "0 auto 3rem",
                            lineHeight: 1.6,
                            fontWeight: 400
                        }}
                    >
                        Please read these terms carefully before using CoursesWyn. By accessing our services, you agree to be bound by these conditions.
                    </p>
                </div>

                {/* Decorative elements */}
                <div style={{
                    position: "absolute",
                    top: "20%",
                    left: "10%",
                    width: "300px",
                    height: "300px",
                    background: "var(--brand)",
                    filter: "blur(120px)",
                    opacity: 0.1,
                    borderRadius: "50%",
                }}></div>
                <div style={{
                    position: "absolute",
                    bottom: "10%",
                    right: "10%",
                    width: "250px",
                    height: "250px",
                    background: "hsl(0, 84%, 60%)",
                    filter: "blur(100px)",
                    opacity: 0.1,
                    borderRadius: "50%",
                }}></div>
            </section>

            {/* Key Terms Overview */}
            <section class="card-gradient" style={{ padding: "4rem 1rem" }}>
                <div class="container">
                    <div style={{
                        textAlign: "center",
                        marginBottom: "3rem"
                    }}>
                        <h2 style={{
                            fontSize: "clamp(1.8rem, 4vw, 2.5rem)",
                            fontWeight: 800,
                            color: "var(--text)",
                            marginBottom: "1rem"
                        }}>
                            Service Overview
                        </h2>
                        <p style={{
                            color: "var(--muted)",
                            fontSize: "1.1rem",
                            maxWidth: "600px",
                            margin: "0 auto",
                            lineHeight: 1.6
                        }}>
                            Understanding what CoursesWyn offers and how our terms protect both users and our platform
                        </p>
                    </div>

                    <div style={{
                        display: "grid",
                        gridTemplateColumns: "repeat(auto-fit, minmax(300px, 1fr))",
                        gap: "2rem"
                    }}>
                        <div style={{
                            background: "var(--card)",
                            padding: "2rem",
                            borderRadius: "20px",
                            border: "1px solid var(--border)",
                            transition: "all 0.3s ease"
                        }}>
                            <div style={{
                                width: "60px",
                                height: "60px",
                                background: "var(--brand)",
                                borderRadius: "16px",
                                display: "flex",
                                alignItems: "center",
                                justifyContent: "center",
                                marginBottom: "1.5rem"
                            }}>
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="white">
                                    <path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.41l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.41zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z"/>
                                </svg>
                            </div>
                            <h3 style={{ color: "var(--brand)", fontSize: "1.3rem", marginBottom: "1rem", fontWeight: 700 }}>
                                Free Coupon Service
                            </h3>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, fontSize: "0.95rem" }}>
                                CoursesWyn provides verified Udemy coupon links completely free of charge. No registration or payment required to access deals.
                            </p>
                        </div>

                        <div style={{
                            background: "var(--card)",
                            padding: "2rem",
                            borderRadius: "20px",
                            border: "1px solid var(--border)",
                            transition: "all 0.3s ease"
                        }}>
                            <div style={{
                                width: "60px",
                                height: "60px",
                                background: "var(--accent)",
                                borderRadius: "16px",
                                display: "flex",
                                alignItems: "center",
                                justifyContent: "center",
                                marginBottom: "1.5rem"
                            }}>
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="white">
                                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                                </svg>
                            </div>
                            <h3 style={{ color: "var(--accent)", fontSize: "1.3rem", marginBottom: "1rem", fontWeight: 700 }}>
                                No Purchase Required
                            </h3>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, fontSize: "0.95rem" }}>
                                All CoursesWyn services are provided at no cost. We earn through affiliate partnerships, not from user fees.
                            </p>
                        </div>

                        <div style={{
                            background: "var(--card)",
                            padding: "2rem",
                            borderRadius: "20px",
                            border: "1px solid var(--border)",
                            transition: "all 0.3s ease"
                        }}>
                            <div style={{
                                width: "60px",
                                height: "60px",
                                background: "hsl(180, 50%, 40%)",
                                borderRadius: "16px",
                                display: "flex",
                                alignItems: "center",
                                justifyContent: "center",
                                marginBottom: "1.5rem"
                            }}>
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="white">
                                    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm0 12H6V10h12v10z"/>
                                </svg>
                            </div>
                            <h3 style={{ color: "hsl(180, 50%, 40%)", fontSize: "1.3rem", marginBottom: "1rem", fontWeight: 700 }}>
                                Third-Party Purchases
                            </h3>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, fontSize: "0.95rem" }}>
                                Any purchases are made directly on Udemy or other platforms. CoursesWyn facilitates access but doesn't process payments.
                            </p>
                        </div>

                        <div style={{
                            background: "var(--card)",
                            padding: "2rem",
                            borderRadius: "20px",
                            border: "1px solid var(--border)",
                            transition: "all 0.3s ease"
                        }}>
                            <div style={{
                                width: "60px",
                                height: "60px",
                                background: "hsl(0, 84%, 60%)",
                                borderRadius: "16px",
                                display: "flex",
                                alignItems: "center",
                                justifyContent: "center",
                                marginBottom: "1.5rem"
                            }}>
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="white">
                                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                </svg>
                            </div>
                            <h3 style={{ color: "hsl(0, 84%, 60%)", fontSize: "1.3rem", marginBottom: "1rem", fontWeight: 700 }}>
                                Community Guidelines
                            </h3>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, fontSize: "0.95rem" }}>
                                Use our services responsibly and respect intellectual property rights. Help maintain a positive learning community.
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            {/* Detailed Terms Sections */}
            <section class="hero-gradient" style={{ padding: "4rem 1rem" }}>
                <div class="container" style={{ maxWidth: "1200px" }}>
                    <div style={{ display: "grid", gap: "2rem" }}>
                        {/* 1. Acceptance of Terms */}
                        <div
                            style={{
                                background: "var(--card)",
                                padding: "2rem",
                                borderRadius: "20px",
                                border: "1px solid var(--border)",
                                transition: "all 0.3s ease"
                            }}
                        >
                            <h2 style={{
                                fontSize: "1.5rem",
                                fontWeight: 700,
                                color: "var(--text)",
                                marginBottom: "1rem",
                            }}>
                                1. Acceptance of Terms
                            </h2>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, marginBottom: "1rem" }}>
                                By accessing and using CoursesWyn, you accept and agree to be bound by the terms and provision of this agreement.
                                If you do not agree to abide by the above, please do not use this service.
                            </p>
                        </div>

                        {/* 2. Description of Service */}
                        <div
                            style={{
                                background: "var(--card)",
                                padding: "2rem",
                                borderRadius: "20px",
                                border: "1px solid var(--border)",
                                transition: "all 0.3s ease"
                            }}
                        >
                            <h2 style={{
                                fontSize: "1.5rem",
                                fontWeight: 700,
                                color: "var(--text)",
                                marginBottom: "1rem",
                            }}>
                                2. Description of Service
                            </h2>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, marginBottom: "1rem" }}>
                                CoursesWyn is an educational resource platform that provides links to discounted and free courses on third-party learning platforms,
                                primarily Udemy. We aggregate and share coupon codes to help users access quality education at reduced costs.
                            </p>
                            <div style={{
                                background: "hsl(222, 47%, 12%)",
                                padding: "1rem",
                                borderRadius: "12px",
                                borderLeft: "4px solid var(--brand)"
                            }}>
                                <strong style={{ color: "var(--brand)" }}>⚠️ Important:</strong> CoursesWyn does not host or provide courses directly. All course content and transactions occur on third-party platforms.
                            </div>
                        </div>

                        {/* 3. Coupon and Deal Information */}
                        <div
                            style={{
                                background: "var(--card)",
                                padding: "2rem",
                                borderRadius: "20px",
                                border: "1px solid var(--border)",
                                transition: "all 0.3s ease"
                            }}
                        >
                            <h2 style={{
                                fontSize: "1.5rem",
                                fontWeight: 700,
                                color: "var(--text)",
                                marginBottom: "1rem",
                            }}>
                                3. Coupon and Deal Information
                            </h2>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, marginBottom: "1rem" }}>
                                While we strive to provide accurate and up-to-date coupon information, CoursesWyn cannot guarantee the validity or availability
                                of any specific coupon or deal. Coupons may expire, be discontinued, or have limited quantities.
                            </p>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6 }}>
                                We are not responsible for any purchases made on third-party websites, including billing disputes, refunds, or customer service issues.
                            </p>
                        </div>

                        {/* 4. User Conduct and Responsibilities */}
                        <div
                            style={{
                                background: "var(--card)",
                                padding: "2rem",
                                borderRadius: "20px",
                                border: "1px solid var(--border)",
                                transition: "all 0.3s ease"
                            }}
                        >
                            <h2 style={{
                                fontSize: "1.5rem",
                                fontWeight: 700,
                                color: "var(--text)",
                                marginBottom: "1rem",
                            }}>
                                4. User Conduct and Responsibilities
                            </h2>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, marginBottom: "1rem" }}>
                                You agree to use CoursesWyn only for lawful purposes and in accordance with these Terms of Service. Prohibited activities include:
                            </p>
                            <ul style={{ color: "var(--muted)", paddingLeft: "2rem", lineHeight: 1.6 }}>
                                <li style={{ marginBottom: "0.5rem" }}>Attempting to access or use the service through unauthorized means</li>
                                <li style={{ marginBottom: "0.5rem" }}>Interfering with or disrupting the service or servers</li>
                                <li style={{ marginBottom: "0.5rem" }}>Using automated tools to scrape or collect data</li>
                                <li style={{ marginBottom: "0.5rem" }}>Violating any applicable laws or regulations</li>
                                <li style={{ marginBottom: "0.5rem" }}>Misrepresenting your identity or affiliation</li>
                            </ul>
                        </div>

                        {/* 5. Intellectual Property */}
                        <div
                            style={{
                                background: "var(--card)",
                                padding: "2rem",
                                borderRadius: "20px",
                                border: "1px solid var(--border)",
                                transition: "all 0.3s ease"
                            }}
                        >
                            <h2 style={{
                                fontSize: "1.5rem",
                                fontWeight: 700,
                                color: "var(--text)",
                                marginBottom: "1rem",
                            }}>
                                5. Intellectual Property
                            </h2>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, marginBottom: "1rem" }}>
                                All content, features, and functionality on CoursesWyn, including but not limited to text, graphics, logos, and software,
                                are owned by CoursesWyn or its licensors and are protected by copyright, trademark, and other intellectual property laws.
                            </p>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6 }}>
                                Third-party trademarks, service marks, and trade names that appear on CoursesWyn are the property of their respective owners.
                            </p>
                        </div>

                        {/* 6. Privacy and Data */}
                        <div
                            style={{
                                background: "var(--card)",
                                padding: "2rem",
                                borderRadius: "20px",
                                border: "1px solid var(--border)",
                                transition: "all 0.3s ease"
                            }}
                        >
                            <h2 style={{
                                fontSize: "1.5rem",
                                fontWeight: 700,
                                color: "var(--text)",
                                marginBottom: "1rem",
                            }}>
                                6. Privacy and Data Protection
                            </h2>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, marginBottom: "1rem" }}>
                                Your privacy is important to us. Our collection and use of personal information is governed by our Privacy Policy,
                                which forms part of these Terms of Service.
                            </p>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6 }}>
                                By using CoursesWyn, you consent to the collection and use of information as outlined in our Privacy Policy.
                            </p>
                        </div>

                        {/* 7. Disclaimers and Limitations */}
                        <div
                            style={{
                                background: "var(--card)",
                                padding: "2rem",
                                borderRadius: "20px",
                                border: "1px solid var(--border)",
                                transition: "all 0.3s ease"
                            }}
                        >
                            <h2 style={{
                                fontSize: "1.5rem",
                                fontWeight: 700,
                                color: "var(--text)",
                                marginBottom: "1rem",
                            }}>
                                7. Disclaimers and Limitations of Liability
                            </h2>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, marginBottom: "1rem" }}>
                                CoursesWyn is provided on an "as is" and "as available" basis. We make no warranties, expressed or implied,
                                and hereby disclaim all warranties including merchantability, fitness for a particular purpose, and non-infringement.
                            </p>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, marginBottom: "1rem" }}>
                                In no event shall CoursesWyn be liable for any direct, indirect, incidental, special, or consequential damages
                                arising out of or in any way connected with your use of our service.
                            </p>
                        </div>

                        {/* 8. Termination */}
                        <div
                            style={{
                                background: "var(--card)",
                                padding: "2rem",
                                borderRadius: "20px",
                                border: "1px solid var(--border)",
                                transition: "all 0.3s ease"
                            }}
                        >
                            <h2 style={{
                                fontSize: "1.5rem",
                                fontWeight: 700,
                                color: "var(--text)",
                                marginBottom: "1rem",
                            }}>
                                8. Termination
                            </h2>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, marginBottom: "1rem" }}>
                                We reserve the right to terminate or suspend your access to CoursesWyn immediately, without prior notice,
                                for any reason including breach of these Terms of Service.
                            </p>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6 }}>
                                Upon termination, your right to use the service will cease immediately.
                            </p>
                        </div>

                        {/* 9. Changes to Terms */}
                        <div
                            style={{
                                background: "var(--card)",
                                padding: "2rem",
                                borderRadius: "20px",
                                border: "1px solid var(--border)",
                                transition: "all 0.3s ease"
                            }}
                        >
                            <h2 style={{
                                fontSize: "1.5rem",
                                fontWeight: 700,
                                color: "var(--text)",
                                marginBottom: "1rem",
                            }}>
                                9. Changes to Terms
                            </h2>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6, marginBottom: "1rem" }}>
                                We reserve the right to modify these Terms of Service at any time. Changes will be effective immediately
                                upon posting on this page. Your continued use of CoursesWyn after changes constitutes acceptance of the new terms.
                            </p>
                            <p style={{ color: "var(--muted)", lineHeight: 1.6 }}>
                                Last updated: January 15, 2026
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            {/* Contact for Legal Questions */}
            <section class="card-gradient" style={{ padding: "4rem 1rem" }}>
                <div class="container" style={{ maxWidth: "800px", textAlign: "center" }}>
                    <h2 style={{
                        fontSize: "clamp(1.8rem, 4vw, 2.5rem)",
                        fontWeight: 800,
                        color: "var(--text)",
                        marginBottom: "1rem"
                    }}>
                        Questions About These Terms?
                    </h2>
                    <p style={{
                        color: "var(--muted)",
                        fontSize: "1.1rem",
                        maxWidth: "600px",
                        margin: "0 auto 3rem",
                        lineHeight: 1.6
                    }}>
                        If you have any questions about our Terms of Service or need clarification on any section, please don't hesitate to contact us.
                    </p>

                    <div style={{
                        background: "var(--card)",
                        padding: "3rem",
                        borderRadius: "24px",
                        border: "1px solid var(--border)",
                        textAlign: "center",
                        position: "relative",
                        overflow: "hidden"
                    }}>
                        <div style={{
                            position: "absolute",
                            top: "-50px",
                            right: "-50px",
                            width: "150px",
                            height: "150px",
                            background: "hsl(0, 84%, 60%)",
                            borderRadius: "50%",
                            opacity: 0.1
                        }}></div>
                        <h3 style={{
                            color: "var(--text)",
                            fontSize: "1.5rem",
                            fontWeight: 700,
                            marginBottom: "1.5rem",
                            textAlign: "center"
                        }}>
                            Contact Legal Team
                        </h3>
                        <p style={{ color: "var(--muted)", marginBottom: "2rem" }}>
                            For legal inquiries, terms clarification, or partnership discussions.
                        </p>
                        <a
                            href="mailto:contact@courseswyn.com?subject=Legal Inquiry"
                            style={{
                                display: "inline-flex",
                                alignItems: "center",
                                gap: "0.5rem",
                                padding: "1rem 2rem",
                                background: "var(--brand)",
                                color: "var(--bg)",
                                textDecoration: "none",
                                borderRadius: "12px",
                                fontSize: "1.1rem",
                                fontWeight: 600,
                                transition: "all 0.3s ease"
                            }}
                        >
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.89 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                            </svg>
                            Email Legal Team
                        </a>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <style>
        .container {
            max-width: 1200px;
            margin: 0 auto;
