---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Terms of Service | Legal Terms & Conditions"
    description="CoursesWyn Terms of Service. Legal terms and conditions for using our Udemy coupon platform, including user conduct, intellectual property, and service usage guidelines."
>
    <!-- Terms Page Enhanced Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "@id": "https://courseswyn.com/terms",
          "url": "https://courseswyn.com/terms",
          "name": "Terms of Service - CoursesWyn Legal Terms and Conditions",
          "description": "Comprehensive Terms of Service for CoursesWyn. Legal terms covering Udemy coupon usage, user conduct, intellectual property rights, and service conditions.",
          "isPartOf": {
            "@id": "https://courseswyn.com"
          },
          "primaryImageOfPage": {
            "@type": "ImageObject",
            "url": "https://courseswyn.com/logo.svg"
          },
          "datePublished": "2023-01-01",
          "dateModified": "2026-01-15",
          "inLanguage": "en-US",
          "breadcrumb": {
            "@type": "BreadcrumbList",
            "itemListElement": [
              {
                "@type": "ListItem",
                "position": 1,
                "name": "Home",
                "item": "https://courseswyn.com"
              },
              {
                "@type": "ListItem",
                "position": 2,
                "name": "Terms of Service",
                "item": "https://courseswyn.com/terms"
              }
            ]
          },
          "mainEntity": {
            "@type": "WebPage",
            "name": "Terms of Service",
            "description": "Legal terms and conditions for using CoursesWyn services"
          }
        },
        {
          "@type": "Organization",
          "@id": "https://courseswyn.com/#organization",
          "name": "CoursesWyn",
          "url": "https://courseswyn.com",
          "logo": "https://courseswyn.com/logo.svg",
          "description": "Free Udemy coupons platform with legal terms of service",
          "foundingDate": "2023",
          "sameAs": [
            "https://x.com/courseswyn",
            "https://www.facebook.com/BestCouponPromo/"
          ]
        }
      ]
    }
    </script>

    <main>
        <section class="t-hero">
            <div class="t-container">
                <div class="t-badge">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
                    </svg>
                    Legal Terms
                </div>
                <h1 class="t-title">
                    <span class="t-grad">Terms of Service</span>
                    <br/>
                    <span class="t-grad">Legal Terms & Conditions</span>
                </h1>
                <p class="t-desc">
                    Please read these terms carefully before using CoursesWyn. By accessing our services, you agree to be bound by these conditions.
                </p>
            </div>
        </section>

        <section class="t-section">
            <div class="t-container">
                <div class="t-section-header">
                    <h2 class="t-section-title">Service Overview</h2>
                    <p class="t-section-desc">Understanding what CoursesWyn offers and how our terms protect both users and our platform</p>
                </div>

                <div class="t-grid">
                    <div class="t-card">
                        <div class="t-card-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="white">
                                <path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.41l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.41zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z"/>
                            </svg>
                        </div>
                        <h3 class="t-card-title">Free Coupon Service</h3>
                        <p class="t-card-desc">CoursesWyn provides verified Udemy coupon links completely free of charge. No registration or payment required to access deals.</p>
                    </div>

                    <div class="t-card">
                        <div class="t-card-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="white">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                            </svg>
                        </div>
                        <h3 class="t-card-title">No Purchase Required</h3>
                        <p class="t-card-desc">All CoursesWyn services are provided at no cost. We earn through affiliate partnerships, not from user fees.</p>
                    </div>

                    <div class="t-card">
                        <div class="t-card-icon t-card-icon-alt">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="white">
                                <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm0 12H6V10h12v10z"/>
                            </svg>
                        </div>
                        <h3 class="t-card-title">Third-Party Purchases</h3>
                        <p class="t-card-desc">Any purchases are made directly on Udemy or other platforms. CoursesWyn facilitates access but doesn't process payments.</p>
                    </div>

                    <div class="t-card">
                        <div class="t-card-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="white">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                            </svg>
                        </div>
                        <h3 class="t-card-title">Community Guidelines</h3>
                        <p class="t-card-desc">Use our services responsibly and respect intellectual property rights. Help maintain a positive learning community.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="t-section">
            <div class="t-container t-container-narrow">
                <div class="t-detail-list">
                    <div class="t-detail-card">
                        <h2 class="t-detail-title">1. Acceptance of Terms</h2>
                        <p class="t-text">By accessing and using CoursesWyn, you accept and agree to be bound by the terms and provision of this agreement. If you do not agree to abide by the above, please do not use this service.</p>
                    </div>

                    <div class="t-detail-card">
                        <h2 class="t-detail-title">2. Description of Service</h2>
                        <p class="t-text">CoursesWyn is an educational resource platform that provides links to discounted and free courses on third-party learning platforms, primarily Udemy. We aggregate and share coupon codes to help users access quality education at reduced costs.</p>
                        <div class="t-note">
                            <strong class="t-note-label">⚠️ Important:</strong> CoursesWyn does not host or provide courses directly. All course content and transactions occur on third-party platforms.
                        </div>
                    </div>

                    <div class="t-detail-card">
                        <h2 class="t-detail-title">3. Coupon and Deal Information</h2>
                        <p class="t-text">While we strive to provide accurate and up-to-date coupon information, CoursesWyn cannot guarantee the validity or availability of any specific coupon or deal. Coupons may expire, be discontinued, or have limited quantities.</p>
                        <p class="t-text">We are not responsible for any purchases made on third-party websites, including billing disputes, refunds, or customer service issues.</p>
                    </div>

                    <div class="t-detail-card">
                        <h2 class="t-detail-title">4. User Conduct and Responsibilities</h2>
                        <p class="t-text">You agree to use CoursesWyn only for lawful purposes and in accordance with these Terms of Service. Prohibited activities include:</p>
                        <ul class="t-list">
                            <li>Attempting to access or use the service through unauthorized means</li>
                            <li>Interfering with or disrupting the service or servers</li>
                            <li>Using automated tools to scrape or collect data</li>
                            <li>Violating any applicable laws or regulations</li>
                            <li>Misrepresenting your identity or affiliation</li>
                        </ul>
                    </div>

                    <div class="t-detail-card">
                        <h2 class="t-detail-title">5. Intellectual Property</h2>
                        <p class="t-text">All content, features, and functionality on CoursesWyn, including but not limited to text, graphics, logos, and software, are owned by CoursesWyn or its licensors and are protected by copyright, trademark, and other intellectual property laws.</p>
                        <p class="t-text">Third-party trademarks, service marks, and trade names that appear on CoursesWyn are the property of their respective owners.</p>
                    </div>

                    <div class="t-detail-card">
                        <h2 class="t-detail-title">6. Privacy and Data Protection</h2>
                        <p class="t-text">Your privacy is important to us. Our collection and use of personal information is governed by our Privacy Policy, which forms part of these Terms of Service.</p>
                        <p class="t-text">By using CoursesWyn, you consent to the collection and use of information as outlined in our Privacy Policy.</p>
                    </div>

                    <div class="t-detail-card">
                        <h2 class="t-detail-title">7. Disclaimers and Limitations of Liability</h2>
                        <p class="t-text">CoursesWyn is provided on an "as is" and "as available" basis. We make no warranties, expressed or implied, and hereby disclaim all warranties including merchantability, fitness for a particular purpose, and non-infringement.</p>
                        <p class="t-text">In no event shall CoursesWyn be liable for any direct, indirect, incidental, special, or consequential damages arising out of or in any way connected with your use of our service.</p>
                    </div>

                    <div class="t-detail-card">
                        <h2 class="t-detail-title">8. Termination</h2>
                        <p class="t-text">We reserve the right to terminate or suspend your access to CoursesWyn immediately, without prior notice, for any reason including breach of these Terms of Service.</p>
                        <p class="t-text">Upon termination, your right to use the service will cease immediately.</p>
                    </div>

                    <div class="t-detail-card">
                        <h2 class="t-detail-title">9. Changes to Terms</h2>
                        <p class="t-text">We reserve the right to modify these Terms of Service at any time. Changes will be effective immediately upon posting on this page. Your continued use of CoursesWyn after changes constitutes acceptance of the new terms.</p>
                        <p class="t-text">Last updated: January 15, 2026</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="t-section t-section-last">
            <div class="t-container t-container-narrow">
                <div class="t-cta">
                    <h2 class="t-cta-title">Questions About These Terms?</h2>
                    <p class="t-cta-desc">If you have any questions about our Terms of Service or need clarification on any section, please don't hesitate to contact us.</p>
                    <div class="t-cta-card">
                        <h3 class="t-cta-card-title">Contact Legal Team</h3>
                        <p class="t-cta-card-desc">For legal inquiries, terms clarification, or partnership discussions, please visit our <a href="/contact" style="color:var(--brand);">contact page</a>.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <style>
        .t-container { max-width: 1024px; margin: 0 auto; padding: 0 1.5rem; }
        .t-container-narrow { max-width: 860px; }

        .t-hero { padding: 80px 0 60px; text-align: center; border-bottom: 1px solid var(--border); }
        .t-badge { display: inline-flex; align-items: center; gap: 6px; background: var(--brand-soft); color: var(--brand); padding: 6px 14px; border-radius: 999px; font-size: 0.82rem; font-weight: 700; margin-bottom: 24px; }
        .t-title { font-size: clamp(2.2rem, 6vw, 3.5rem); font-weight: 900; line-height: 1.1; margin: 0 0 16px; letter-spacing: -0.03em; }
        .t-grad { background: linear-gradient(135deg, var(--brand), hsl(200, 80%, 55%)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .t-desc { font-size: 1.1rem; color: var(--text-secondary); max-width: 650px; margin: 0 auto; line-height: 1.6; font-weight: 500; }

        .t-section { padding: 60px 0; }
        .t-section-last { padding-bottom: 80px; }
        .t-section-header { text-align: center; margin-bottom: 40px; }
        .t-section-title { font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 900; color: var(--text); margin: 0 0 12px; letter-spacing: -0.02em; }
        .t-section-desc { font-size: 1.05rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto; line-height: 1.6; font-weight: 500; }

        .t-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }

        .t-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 32px; transition: border-color 0.15s; }
        .t-card:hover { border-color: var(--brand); }
        .t-card-icon { width: 56px; height: 56px; background: var(--brand); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; }
        .t-card-icon-alt { background: var(--bg-secondary); }
        .t-card-title { font-size: 1.2rem; font-weight: 800; color: var(--text); margin: 0 0 10px; }
        .t-card-desc { font-size: 0.92rem; color: var(--text-secondary); line-height: 1.6; margin: 0; font-weight: 500; }

        .t-detail-list { display: grid; gap: 20px; }
        .t-detail-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 32px; }
        .t-detail-title { font-size: 1.35rem; font-weight: 800; color: var(--text); margin: 0 0 14px; }

        .t-text { color: var(--text-secondary); line-height: 1.7; margin: 0 0 14px; font-weight: 500; }
        .t-text:last-child { margin-bottom: 0; }

        .t-list { color: var(--text-secondary); padding-left: 1.5rem; line-height: 1.7; margin: 0 0 0; font-weight: 500; }
        .t-list li { margin-bottom: 6px; }
        .t-list li:last-child { margin-bottom: 0; }

        .t-note { background: var(--bg-secondary); padding: 16px; border-radius: var(--radius-sm); border-left: 4px solid var(--brand); margin-top: 16px; }
        .t-note-label { color: var(--brand); font-weight: 700; }

        .t-cta { text-align: center; }
        .t-cta-title { font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 900; color: var(--text); margin: 0 0 12px; letter-spacing: -0.02em; }
        .t-cta-desc { font-size: 1.05rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto 32px; line-height: 1.6; font-weight: 500; }
        .t-cta-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 48px; text-align: center; }
        .t-cta-card-title { font-size: 1.4rem; font-weight: 800; color: var(--text); margin: 0 0 12px; }
        .t-cta-card-desc { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.6; margin: 0 0 28px; font-weight: 500; }

        .t-btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; background: var(--brand); color: white; border-radius: var(--radius-sm); font-size: 0.95rem; font-weight: 700; text-decoration: none; transition: opacity 0.15s; }
        .t-btn:hover { opacity: 0.9; }
        .t-btn svg { flex-shrink: 0; }
    </style>
</Layout>
