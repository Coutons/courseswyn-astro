// SEO metadata
const pageTitle = "Success Stories | Real Career Transformations with Free Udemy Courses";
const pageDescription = "Read inspiring success stories from learners who transformed their careers using free Udemy courses from CoursesWyn. Real people, real results, zero cost.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main style="background: var(--bg); color: var(--text);">
    
    {/* ── HERO ── */}
    <section style="padding: 100px 0 80px; border-bottom: 2px solid var(--border); background: var(--card);">
      <div class="container">
        <h1 style={{ 
          fontSize: "clamp(2.5rem, 7vw, 4.5rem)", 
          fontWeight: 900, 
          lineHeight: 1.05, 
          letterSpacing: "-0.04em",
          marginBottom: "32px"
        }}>
          Success<br/>
          <span style={{ background: "var(--accent)", color: "white", padding: "0 10px" }}>Stories.</span>
        </h1>
        
        <p style={{ 
          fontSize: "clamp(1.1rem, 3vw, 1.3rem)", 
          color: "var(--muted)", 
          maxWidth: "800px", 
          lineHeight: 1.6,
          fontWeight: 500,
          marginBottom: "48px"
        }}>
          Real people, real results. Thousands of learners have transformed their careers using verified Udemy coupons from CoursesWyn.
        </p>

        <div style="display: flex; gap: 16px; flex-wrap: wrap;">
          {[
            { v: "50K+", l: "Milestones" },
            { v: "85%", l: "Career Growth" },
            { v: "$0", l: "Course Cost" }
          ].map(s => (
            <div style="background: white; border: 2px solid var(--border); padding: 12px 24px; border-radius: 4px; box-shadow: 4px 4px 0 var(--border); display: flex; flex-direction: column; align-items: center;">
              <span style="font-size: 1.5rem; font-weight: 900; color: var(--accent);">{s.v}</span>
              <span style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--muted);">{s.l}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── STORIES GRID ── */}
    <section style="padding: 80px 0;">
      <div class="container">
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 32px;">
          {successStories.map((story) => (
            <div class="neo-story-card">
              <div style="position: absolute; top: 12px; right: 12px; background: var(--accent); color: white; padding: 4px 12px; font-weight: 900; font-size: 0.7rem; border: 2px solid var(--border); box-shadow: 2px 2px 0 var(--border);">
                +{story.salaryIncrease} SALARY
              </div>
              
              <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 24px;">
                <img 
                  src={story.avatar} 
                  alt={story.name}
                  style="width: 64px; height: 64px; border-radius: 4px; border: 2px solid var(--border); object-fit: cover;"
                />
                <div>
                  <h3 style="font-size: 1.2rem; font-weight: 900; margin: 0;">{story.name}</h3>
                  <div style="font-size: 0.8rem; font-weight: 800; color: var(--accent); text-transform: uppercase;">{story.role}</div>
                  <div style="font-size: 0.75rem; font-weight: 700; color: var(--muted);">{story.achievement}</div>
                </div>
              </div>

              <div style="display: flex; gap: 4px; margin-bottom: 16px;">
                {[...Array(5)].map(() => (
                  <span style="color: var(--accent); font-size: 1.2rem;">★</span>
                ))}
              </div>

              <p style="margin: 0 0 24px; color: var(--muted); font-size: 1rem; line-height: 1.6; font-weight: 500; font-style: italic;">
                "{story.review}"
              </p>

              <div style="background: var(--card); border: 2px solid var(--border); padding: 12px; font-size: 0.85rem; font-weight: 800; text-align: center; text-transform: uppercase;">
                {story.course}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── CTA ── */}
    <section style="padding: 80px 0; border-top: 2px solid var(--border); background: var(--accent);">
      <div class="container" style="text-align: center; color: white;">
        <h2 style="font-size: 3rem; font-weight: 900; margin-bottom: 24px;">Start Your Story.</h2>
        <p style="font-size: 1.2rem; font-weight: 500; max-width: 600px; margin: 0 auto 40px; opacity: 0.9;">
          Join thousands of learners who transformed their careers with verified Udemy courses.
        </p>
        <a href="/udemy-coupon-code" class="btn" style="background: white; color: var(--accent); border-color: white; padding: 16px 40px; font-size: 1.1rem; box-shadow: 6px 6px 0 var(--border);">
          Get Free Promo Codes
        </a>
      </div>
    </section>

  </main>

  <style>
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .neo-story-card {
      background: white; border: 2px solid var(--border); border-radius: 4px; padding: 32px;
      position: relative; transition: all 0.2s;
      box-shadow: 6px 6px 0 var(--border);
    }
    .neo-story-card:hover { transform: translate(-4px, -4px); box-shadow: 10px 10px 0 var(--border); }
  </style>
</Layout>
