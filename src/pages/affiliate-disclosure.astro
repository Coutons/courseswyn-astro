---
import Layout from "../layouts/Layout.astro";

const siteUrl = "https://courseswyn.com";
const currentDate = new Date();
const formattedDate = currentDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const faqs = [
  {
    q: "Does using CoursesWyn cost me extra money?",
    a: "No, using CoursesWyn does not cost you anything extra. When you click on our affiliate links and make a purchase, you pay the same price (or often less with our exclusive discounts) as if you went directly to the platform."
  },
  {
    q: "How does CoursesWyn make money?",
    a: "We earn small commissions from qualifying purchases made through our affiliate links. This helps us maintain and improve Courses Wyn at no cost to you. Our affiliate relationships do not influence which courses we recommend."
  },
  {
    q: "Are your course recommendations unbiased?",
    a: "Yes, absolutely. Our editorial independence is paramount. We only recommend courses and platforms we genuinely believe offer value to our users. We feature courses based on quality, relevance, and value—not commission rates."
  },
  {
    q: "Which platforms does CoursesWyn partner with?",
    a: "We partner with major online learning platforms including Udemy, Coursera, edX, Pluralsight, Skillshare, LinkedIn Learning, Udacity, and Codecademy. All partnerships are clearly disclosed on this page."
  },
  {
    q: "Do I need to create an account to use CoursesWyn?",
    a: "No, you do not need to create an account to browse and access our free course coupons. You only need a free account on the respective platform (like Udemy) to enroll in courses."
  }
];
---

<Layout
  title="Affiliate Disclosure | CoursesWyn"
  description="CoursesWyn is an affiliate marketing platform. We earn commissions when you purchase courses through our links, but this doesn't affect our recommendations or pricing."
  canonical={`${siteUrl}/affiliate-disclosure`}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Affiliate Disclosure",
    "description": "CourseWyn is an affiliate marketing platform. We earn commissions when you purchase courses through our links.",
    "url": `${siteUrl}/affiliate-disclosure`,
    "datePublished": "2024-01-01",
    "dateModified": currentDate.toISOString().split('T')[0],
    "publisher": {
      "@type": "Organization",
      "name": "CourseWyn",
      "url": siteUrl
    },
    "mainEntity": {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.a
        }
      }))
    }
  })} />

  <div class="container" style={{
    maxWidth: "1400px",
    margin: "0 auto",
    padding: "4rem 1.5rem"
  }}>
    {/* Header Section */}
    <div style={{
      textAlign: "center",
      marginBottom: "3rem"
    }}>
      <div style={{
        display: "inline-flex",
        alignItems: "center",
        gap: "0.75rem",
        background: "var(--bg-secondary)",
        padding: "0.5rem 1rem",
        borderRadius: "20px",
        border: "1px solid var(--border)",
        marginBottom: "1.5rem"
      }}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--bg-secondary)" style={{ flexShrink: 0 }}>
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        <span style={{ color: "var(--bg-secondary)", fontWeight: 600, fontSize: "0.85rem" }}>Transparency First</span>
      </div>
      <h1 style={{
        fontSize: "clamp(2rem, 5vw, 3rem)",
        fontWeight: 800,
        marginBottom: "1rem",
        background: "linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-secondary) 100%)",
        WebkitBackgroundClip: "text",
        WebkitTextFillColor: "transparent",
        backgroundClip: "text"
      }}>
        Affiliate Disclosure
      </h1>
      <p style={{
        color: "var(--muted)",
        fontSize: "1.1rem",
        maxWidth: "700px",
        margin: "0 auto",
        lineHeight: 1.7
      }}>
        CoursesWyn is an affiliate marketing platform. We earn commissions when you purchase courses through our links, but this does not affect our recommendations or pricing.
      </p>
    </div>

    <div style={{
      background: "var(--card)",
      border: "1px solid var(--border)",
      borderRadius: "16px",
      padding: "3rem",
      boxShadow: "0 4px 24px rgba(0,0,0,0.08)"
    }}>

      <p style={{
        color: "var(--muted)",
        fontSize: "1rem",
        lineHeight: 1.7,
        marginBottom: "2rem"
      }}>
        Last updated: <strong style={{ color: "var(--text)" }}>{formattedDate}</strong>
      </p>

      <div style={{
        background: "var(--brand-soft)",
        border: "1px solid var(--border)",
        borderRadius: "12px",
        padding: "1.5rem",
        marginBottom: "2rem"
      }}>
        <p style={{
          color: "var(--text)",
          fontSize: "1rem",
          fontWeight: 600,
          margin: 0,
          lineHeight: 1.6
        }}>
          CoursesWyn is a participant in various affiliate advertising programs designed to provide a means for sites to earn advertising fees by advertising and linking to partner platforms.
        </p>
      </div>

      <h2 style={{
        fontSize: "1.5rem",
        fontWeight: 700,
        color: "var(--text)",
        marginBottom: "1rem",
        marginTop: "2rem"
      }}>
        What This Means for You
      </h2>

      <ul style={{
        color: "var(--muted)",
        fontSize: "1rem",
        lineHeight: 1.8,
        paddingLeft: "1.5rem",
        marginBottom: "2rem"
      }}>
        <li style={{ marginBottom: "0.75rem" }}>
          <strong style={{ color: "var(--text)" }}>No Extra Cost:</strong> When you click on our coupon links and make a purchase, you pay the same price (or often less with our exclusive discounts) as if you went directly to the platform.
        </li>
        <li style={{ marginBottom: "0.75rem" }}>
          <strong style={{ color: "var(--text)" }}>We Earn Commissions:</strong> We may earn a small commission from qualifying purchases made through our affiliate links. This helps us maintain and improve CoursesWyn at no cost to you.
        </li>
        <li style={{ marginBottom: "0.75rem" }}>
          <strong style={{ color: "var(--text)" }}>Unbiased Recommendations:</strong> Our editorial independence is paramount. We only recommend courses and platforms we genuinely believe offer value to our users.
        </li>
        <li style={{ marginBottom: "0.75rem" }}>
          <strong style={{ color: "var(--text)" }}>Transparent Pricing:</strong> All prices, discounts, and coupon codes displayed on CoursesWyn are accurate and verified at the time of publication.
        </li>
      </ul>

      <h2 style={{
        fontSize: "1.5rem",
        fontWeight: 700,
        color: "var(--text)",
        marginBottom: "1rem",
        marginTop: "2rem"
      }}>
        Our Affiliate Partners
      </h2>

      <p style={{
        color: "var(--muted)",
        fontSize: "1rem",
        lineHeight: 1.7,
        marginBottom: "1.5rem"
      }}>
        CoursesWyn participates in affiliate programs with the following platforms:
      </p>

      <div style={{
        display: "grid",
        gridTemplateColumns: "repeat(auto-fit, minmax(250px, 1fr))",
        gap: "1.5rem",
        marginBottom: "2rem"
      }}>
        {[
          { name: "Udemy", url: "https://www.udemy.com", icon: "A435F0" },
          { name: "Coursera", url: "https://www.coursera.org", icon: "0056D2" },
          { name: "edX", url: "https://www.edx.org", icon: "02262B" },
          { name: "Pluralsight", url: "https://www.pluralsight.com", icon: "F05A28" },
          { name: "Skillshare", url: "https://www.skillshare.com", icon: "00FF84" },
          { name: "LinkedIn Learning", url: "https://www.linkedin.com/learning", icon: "0A66C2" },
          { name: "Udacity", url: "https://www.udacity.com", icon: "02B3E4" },
          { name: "Codecademy", url: "https://www.codecademy.com", icon: "091D42" }
        ].map((partner) => (
          <a
            href={partner.url}
            target="_blank"
            rel="noopener noreferrer"
            style={{
              display: "flex",
              alignItems: "center",
              gap: "0.75rem",
              padding: "1rem 1.25rem",
              background: "var(--card)",
              border: "1px solid var(--border)",
              borderRadius: "12px",
              textDecoration: "none",
              color: "var(--text)",
              fontSize: "1rem",
              fontWeight: 600,
              transition: "all 0.3s ease",
              boxShadow: "0 2px 8px rgba(0,0,0,0.06)"
            }}
            onmouseover="this.style.borderColor='var(--brand)'; this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 24px rgba(16,185,129,0.15)'"
            onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'"
          >
            <div style={{
              width: "40px",
              height: "40px",
              background: `#${partner.icon}`,
              borderRadius: "8px",
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              flexShrink: 0,
              color: "white",
              fontSize: "0.9rem",
              fontWeight: 700
            }}>
              {partner.name.charAt(0)}
            </div>
            <div>
              <div style={{ fontSize: "1rem", fontWeight: 600 }}>{partner.name}</div>
              <div style={{ fontSize: "0.8rem", color: "var(--muted)" }}>Official Partner</div>
            </div>
          </a>
        ))}
      </div>

      <h2 style={{
        fontSize: "1.5rem",
        fontWeight: 700,
        color: "var(--text)",
        marginBottom: "1rem",
        marginTop: "2rem"
      }}>
        Our Commitment to You
      </h2>

      <p style={{
        color: "var(--muted)",
        fontSize: "1rem",
        lineHeight: 1.7,
        marginBottom: "1.5rem"
      }}>
        We are committed to maintaining the highest standards of integrity and transparency. Our affiliate relationships do not influence:
      </p>

      <ul style={{
        color: "var(--muted)",
        fontSize: "1rem",
        lineHeight: 1.8,
        paddingLeft: "1.5rem",
        marginBottom: "2rem"
      }}>
        <li style={{ marginBottom: "0.75rem" }}>
          <strong style={{ color: "var(--text)" }}>Course Selection:</strong> We feature courses based on quality, relevance, and value—not commission rates.
        </li>
        <li style={{ marginBottom: "0.75rem" }}>
          <strong style={{ color: "var(--text)" }}>Review Process:</strong> Our editorial team independently evaluates and verifies all coupons before publication.
        </li>
        <li style={{ marginBottom: "0.75rem" }}>
          <strong style={{ color: "var(--text)" }}>User Experience:</strong> We prioritize your learning journey and provide honest, helpful information to help you make informed decisions.
        </li>
      </ul>

      <h2 style={{
        fontSize: "1.5rem",
        fontWeight: 700,
        color: "var(--text)",
        marginBottom: "1rem",
        marginTop: "2rem"
      }}>
        Questions or Concerns?
      </h2>

      <p style={{
        color: "var(--muted)",
        fontSize: "1rem",
        lineHeight: 1.7,
        marginBottom: "1.5rem"
      }}>
        If you have any questions about our affiliate relationships or this disclosure, please do not hesitate to contact us. We are happy to provide additional information or clarification.
      </p>

      <a
        href="/contact"
        style={{
          display: "inline-flex",
          alignItems: "center",
          gap: "0.5rem",
          padding: "0.75rem 1.5rem",
          background: "var(--brand)",
          color: "var(--bg)",
          textDecoration: "none",
          borderRadius: "8px",
          fontSize: "1rem",
          fontWeight: 600,
          transition: "all 0.2s ease"
        }}
        onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px var(--brand-soft)'"
        onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'"
      >
        Contact Us
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
        </svg>
      </a>

      {/* FAQ Section */}
      <h2 style={{
        fontSize: "1.5rem",
        fontWeight: 700,
        color: "var(--text)",
        marginBottom: "1rem",
        marginTop: "3rem"
      }}>
        Frequently Asked Questions
      </h2>

      <div style={{
        display: "flex",
        flexDirection: "column",
        gap: "1rem"
      }}>
        {faqs.map((faq, index) => (
          <details
            itemscope
            itemtype="https://schema.org/Question"
            style={{
              background: "var(--card)",
              border: "1px solid var(--border)",
              borderRadius: "12px",
              overflow: "hidden"
            }}
          >
            <summary
              itemprop="name"
              style={{
                padding: "1.25rem 1.5rem",
                cursor: "pointer",
                fontSize: "1rem",
                fontWeight: 600,
                color: "var(--text)",
                display: "flex",
                alignItems: "center",
                justifyContent: "space-between",
                gap: "1rem",
                listStyle: "none",
                transition: "all 0.2s ease"
              }}
              onmouseover="this.style.background='var(--card-hover)'"
              onmouseout="this.style.background='var(--card)'"
            >
              <span>{faq.q}</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--muted)" style={{ flexShrink: 0, transition: "transform 0.2s ease" }}>
                <path d="M7 10l5 5 5-5z"/>
              </svg>
            </summary>
            <div
              itemscope
              itemtype="https://schema.org/Answer"
              itemprop="acceptedAnswer"
              style={{
                padding: "0 1.5rem 1.5rem 1.5rem",
                color: "var(--muted)",
                fontSize: "1rem",
                lineHeight: 1.7,
                borderTop: "1px solid var(--border)"
              }}
            >
              <span itemprop="text">{faq.a}</span>
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  .container {
    min-height: 60vh;
  }
</style>
