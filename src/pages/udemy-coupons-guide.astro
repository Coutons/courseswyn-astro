---
import Layout from "../layouts/Layout.astro";

const canonicalUrl = "https://courseswyn.com/udemy-coupons-guide";
const pageTitle = "Udemy Coupons Guide 2026 — How to Get Free Udemy Courses (100% Off Codes) | CoursesWyn";
const pageDescription = "Master Udemy coupon codes in 2026. Learn how to find and redeem 100% free Udemy courses, discover legitimate discount codes up to 90% off, and avoid common coupon mistakes. Complete step-by-step guide with verified working codes updated daily.";

const currentYear = new Date().getFullYear();
const lastModified = new Date().toISOString().split('T')[0];
---
<Layout title={pageTitle} description={pageDescription}>
  <link rel="canonical" href={canonicalUrl} slot="head" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Article",
        "@id": `${canonicalUrl}#article`,
        "url": canonicalUrl,
        "headline": `Udemy Coupons Guide ${currentYear} — How to Get 100% Off Udemy Courses`,
        "description": pageDescription,
        "datePublished": "2024-01-01",
        "dateModified": lastModified,
        "inLanguage": "en-US",
        "author": {
          "@type": "Organization",
          "name": "CoursesWyn",
          "url": "https://courseswyn.com"
        },
        "publisher": {
          "@type": "Organization",
          "@id": "https://courseswyn.com/#organization",
          "name": "CoursesWyn",
          "url": "https://courseswyn.com",
          "logo": {
            "@type": "ImageObject",
            "url": "https://courseswyn.com/logo.svg"
          }
        },
        "isPartOf": { "@id": "https://courseswyn.com" },
        "breadcrumb": {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" },
            { "@type": "ListItem", "position": 2, "name": "Udemy Coupons Guide", "item": canonicalUrl }
          ]
        }
      },
      {
        "@type": "HowTo",
        "@id": `${canonicalUrl}#howto`,
        "name": "How to Get 100% Off Udemy Courses Using Coupons",
        "description": "Step-by-step instructions to find, verify, and redeem Udemy coupon codes for free or discounted courses.",
        "totalTime": "PT5M",
        "step": [
          {
            "@type": "HowToStep",
            "position": 1,
            "name": "Find a verified Udemy coupon",
            "text": "Visit CoursesWyn's deals page and browse courses by category or topic. All listed coupons are verified and updated daily."
          },
          {
            "@type": "HowToStep",
            "position": 2,
            "name": "Click 'Redeem Coupon'",
            "text": "On the CoursesWyn deal page, click the 'Redeem Coupon' or 'Get Deal' button to open the Udemy course page with the discount pre-applied."
          },
          {
            "@type": "HowToStep",
            "position": 3,
            "name": "Log in or create a Udemy account",
            "text": "If you're not already logged in, create a free Udemy account or log in with your existing credentials."
          },
          {
            "@type": "HowToStep",
            "position": 4,
            "name": "Confirm the discounted price",
            "text": "On the Udemy checkout page, verify the price shows $0.00 (or the discounted amount) before proceeding."
          },
          {
            "@type": "HowToStep",
            "position": 5,
            "name": "Enroll and access the course",
            "text": "Complete checkout. The course is now in your Udemy library with lifetime access — start learning immediately."
          }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Are Udemy coupons legitimate and safe to use?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Udemy coupons are official promotional codes issued directly by Udemy or course instructors. They are not hacks or exploits — they're a standard marketing tool. CoursesWyn only lists coupons from official Udemy affiliate and instructor sources."
            }
          },
          {
            "@type": "Question",
            "name": "How long do Udemy coupons last?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Udemy coupon validity varies. 100% off coupons are typically valid for 3–7 days and have a limited redemption count — often 1,000 uses. Once the limit is reached, the coupon stops working even before its expiry date. Instructor discount coupons (80–95% off) can last longer, sometimes several weeks."
            }
          },
          {
            "@type": "Question",
            "name": "Do free Udemy courses give completion certificates?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. All Udemy courses — whether accessed free via coupon or purchased at full price — include a certificate of completion. You can download it as a PDF or share it directly to your LinkedIn profile."
            }
          },
          {
            "@type": "Question",
            "name": "Can I use more than one coupon on a Udemy course?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No. Udemy only allows one coupon code per course enrollment. You cannot stack coupons. If multiple coupons are available for the same course, use the one with the highest discount (ideally 100% off)."
            }
          },
          {
            "@type": "Question",
            "name": "What happens if a Udemy coupon has expired?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Expired coupons redirect you to the full-price course page. The discount is not applied. Return to CoursesWyn to check if a new coupon for the same course has been listed — instructors sometimes re-issue coupons periodically."
            }
          },
          {
            "@type": "Question",
            "name": "Is there a limit to how many free Udemy courses I can get?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Udemy does not cap the number of free courses you can enroll in using coupons. Each coupon gives you lifetime access to that course, so you can accumulate as many as you like — though Udemy may limit total free enrollments per account in some regions."
            }
          }
        ]
      }
    ]
  })} />

  <main style="background: var(--bg); color: var(--text);">
    
    {/* ── HERO ── */}
    <section style="padding: 80px 0 60px; border-bottom: 2px solid var(--border); background: var(--card);">
      <div class="container">
        {/* Breadcrumb */}
        <nav aria-label="Breadcrumb" style={{ marginBottom: "32px" }}>
          <ol style={{ display: "flex", listStyle: "none", padding: 0, margin: 0, gap: "10px", fontSize: "0.85rem", fontWeight: 800, color: "var(--muted)", textTransform: "uppercase", letterSpacing: "0.05em" }} itemscope itemtype="https://schema.org/BreadcrumbList">
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a href="/" style={{ color: "inherit", textDecoration: "none" }} itemprop="item">
                <span itemprop="name">Home</span>
              </a>
              <meta itemprop="position" content="1" />
            </li>
            <li style={{ color: "var(--border)" }}>/</li>
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a href="/blog" style={{ color: "inherit", textDecoration: "none" }} itemprop="item">
                <span itemprop="name">Guides</span>
              </a>
              <meta itemprop="position" content="2" />
            </li>
            <li style={{ color: "var(--border)" }}>/</li>
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" style={{ color: "var(--text)" }}>
              <span itemprop="name">Udemy Coupons Guide</span>
              <meta itemprop="position" content="3" />
            </li>
          </ol>
        </nav>

        <div style="display: inline-block; background: var(--accent); color: white; padding: 4px 14px; border: 2px solid var(--border); box-shadow: 3px 3px 0 var(--border); border-radius: 4px; fontSize: 0.75rem; fontWeight: 800; marginBottom: 32px; textTransform: uppercase;">
          Complete Guide · Updated {currentYear}
        </div>

        <h1 style={{ 
          fontSize: "clamp(2.2rem, 5vw, 3.5rem)", 
          fontWeight: 900, 
          lineHeight: 1.1, 
          letterSpacing: "-0.04em",
          marginBottom: "24px"
        }}>
          Complete Guide: How to Get <span style={{ background: "var(--accent)", color: "white", padding: "0 8px" }}>Free Udemy Courses</span> with Coupons
        </h1>
        
        <p style={{ 
          fontSize: "clamp(1.1rem, 3vw, 1.3rem)", 
          color: "var(--muted)", 
          maxWidth: "800px", 
          lineHeight: 1.6,
          fontWeight: 500,
          marginBottom: "24px"
        }}>
          Everything you need to know about Udemy coupons: where to find them, how they work, 
          how to redeem them, and how to avoid expired codes — explained clearly and honestly.
        </p>
        <p style={{ 
          fontSize: "1rem", 
          color: "var(--muted)", 
          maxWidth: "800px", 
          lineHeight: 1.6,
          fontWeight: 500,
          marginBottom: "48px"
        }}>
          <strong style="color:var(--text)">Why read this guide?</strong> Udemy offers thousands of free courses through promotional codes, 
          but finding legitimate, working coupons can be frustrating. This guide reveals insider strategies 
          from our team who verify 100+ coupons daily, helping you save hundreds on professional development 
          without falling for expired codes or fake deals.
        </p>

        <div style="display:flex; align-items:center; gap:24px; font-weight:700; font-size:0.9rem; color:var(--muted);">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style={{ width: "32px", height: "32px", background: "var(--accent)", border: "2px solid var(--border)", borderRadius: "4px", display: "flex", alignItems: "center", justifyContent: "center", color: "white", fontWeight: 900, fontSize: "0.9rem" }}>CW</div>
            <span>By <strong style="color:var(--text)">Andrew Derek</strong>, Lead Course Analyst</span>
          </div>
          <span style={{ color: "var(--border)" }}>|</span>
          <span>⏱️ 6 min read</span>
          <span style={{ color: "var(--border)" }}>|</span>
          <span>📅 Updated {lastModified}</span>
        </div>
      </div>
    </section>

    {/* ── TOC ── */}
    <nav style="padding: 40px 0; border-bottom: 2px solid var(--border); background: white;">
      <div class="container">
        <h2 style="font-size: 1.1rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 24px;">Contents</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px;">
          {[
            ["#what-are-udemy-coupons", "What are Udemy coupons?"],
            ["#how-coupons-work", "How do Udemy coupons work?"],
            ["#types-of-coupons", "Types of Udemy coupons"],
            ["#how-to-find", "Where to find valid coupons"],
            ["#how-to-redeem", "How to redeem (step by step)"],
            ["#tips", "Pro tips for maximum savings"],
            ["#faq", "Frequently asked questions"],
          ].map(([href, label], i) => (
            <a href={href} style="display: flex; align-items: center; gap: 12px; text-decoration: none; color: var(--text); font-weight: 700; font-size: 0.9rem;">
              <span style="color: var(--accent); font-weight: 900;">0{i+1}</span>
              {label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    {/* ── CONTENT ── */}
    <article style="padding: 80px 0;">
      <div class="container" style="max-width: 860px;">
        
        <section id="what-are-udemy-coupons" style="margin-bottom: 64px;">
          <h2 class="section-heading">01. What Are Udemy Coupons?</h2>
          <div class="prose">
            <p>Udemy coupons are <strong>time-limited promotional codes</strong> that reduce the price of a Udemy course — sometimes to <strong>$0.00 (completely free)</strong>. They work like standard e-commerce promo codes: a unique alphanumeric string is applied at checkout, and the course price is discounted instantly.</p>
            <p>These discount codes are a marketing strategy used by course creators to:</p>
            <ul>
              <li><strong>Build student base quickly</strong> — New instructors offer free enrollments to generate reviews and social proof</li>
              <li><strong>Promote course launches</strong> — 100% off codes drive initial momentum for new releases</li>
              <li><strong>Clear older inventory</strong> — Discounts refresh interest in courses that haven't sold recently</li>
              <li><strong>Platform-wide sales</strong> — Udemy itself runs seasonal promotions with sitewide discounts</li>
            </ul>
            <p>Coupons are issued by two sources:</p>
            <ul>
              <li><strong>Udemy itself</strong> — for platform-wide sales events.</li>
              <li><strong>Individual instructors</strong> — to attract new students. These are the most common source of 100% off coupons.</li>
            </ul>
            <div class="neo-callout">
              <strong>Key insight:</strong> When you enroll in a course using a 100% off coupon, you get the <strong>exact same course</strong> as paying students — lifetime access, all video content, downloadable resources, Q&A forums, and a certificate of completion. The only difference is you paid $0.00.
            </div>
          </div>
        </section>

        <section id="how-coupons-work" style="margin-bottom: 64px;">
          <h2 class="section-heading">02. How Do Udemy Coupons Actually Work?</h2>
          <div class="prose">
            <p>Understanding the mechanics of Udemy's coupon system helps you use them more effectively. Here's what happens behind the scenes:</p>
            
            <h3 style="font-size: 1.2rem; font-weight: 900; margin: 32px 0 16px; color: var(--text);">The Technical Process</h3>
            <p>When an instructor creates a coupon, they set three key parameters:</p>
            <ul>
              <li><strong>Discount percentage</strong> — Can range from 10% to 100% off the list price</li>
              <li><strong>Redemption limit</strong> — Maximum number of students who can use the code (typically 50–1,000)</li>
              <li><strong>Expiration date</strong> — When the coupon automatically stops working</li>
            </ul>

            <h3 style="font-size: 1.2rem; font-weight: 900; margin: 32px 0 16px; color: var(--text);">Why 100% Off Coupons Exist</h3>
            <p>It might seem counterintuitive for instructors to give away courses for free, but there are strategic reasons:</p>
            <ul>
              <li><strong>Algorithm boost</strong> — Udemy's recommendation algorithm favors courses with high enrollment numbers</li>
              <li><strong>Review generation</strong> — Free students often leave reviews, which increases course visibility</li>
              <li><strong>Upsell opportunities</strong> — Instructors may offer paid consulting or advanced courses to free students</li>
              <li><strong>Affiliate earnings</strong> — Some instructors earn from Udemy's affiliate program even on free enrollments</li>
            </ul>

            <div class="neo-callout">
              <strong>Important:</strong> A coupon can stop working for two reasons: hitting the redemption limit OR reaching the expiration date. Always check both when a code doesn't work.
            </div>
          </div>
        </section>

        <section id="types-of-coupons" style="margin-bottom: 64px;">
          <h2 class="section-heading">03. Types of Udemy Coupons Explained</h2>
          <div class="prose">
            <p>Not all Udemy coupons are equal. Here's a breakdown of the main types you'll encounter:</p>
            <div class="neo-table-container">
              <table class="neo-table">
                <thead>
                  <tr>
                    <th>Type</th>
                    <th>Discount</th>
                    <th>Duration</th>
                  </tr>
                </thead>
                <tbody>
                  <tr><td><strong>100% Off</strong></td><td>Free ($0.00)</td><td>3–7 days</td></tr>
                  <tr><td><strong>High-Discount</strong></td><td>80–95% off</td><td>Weeks</td></tr>
                  <tr><td><strong>Udemy Sale</strong></td><td>~$9.99–$14.99</td><td>2–7 days</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <section id="how-to-find" style="margin-bottom: 64px;">
          <h2 class="section-heading">04. Where to Find Valid Coupons (Legitimate Sources)</h2>
          <div style="display: flex; flex-direction: column; gap: 24px;">
            {[
              { t: "CoursesWyn", d: "We list instructor-issued Udemy coupons verified daily. Filter by category to find deals in your area." },
              { t: "Udemy Promotions", d: "Sign up for Udemy's newsletter or check their home page for active sales banners." },
              { t: "Instructor Sites", d: "Many instructors publish coupon links on their personal websites or YouTube channels." }
            ].map(src => (
              <div class="neo-card">
                <h3 style="font-size: 1.1rem; font-weight: 900; margin-bottom: 8px;">{src.t}</h3>
                <p style="margin: 0; color: var(--muted); font-size: 0.9rem; font-weight: 600;">{src.d}</p>
              </div>
            ))}
          </div>
        </section>

        <section id="how-to-redeem" style="margin-bottom: 64px;">
          <h2 class="section-heading">05. How to Redeem — Complete Step-by-Step Guide</h2>
          <div class="steps">
            {[
              ["Find a deal on CoursesWyn", "Browse the Deals page or search by topic. Each listing shows the discount and expiry."],
              ["Click 'Redeem Coupon'", "This opens Udemy with the code pre-applied. The price appears automatically."],
              ["Log in or create account", "Creating an account is free and takes 30 seconds. You can also sign in with Google."],
              ["Verify price at checkout", "Confirm the price shows $0.00 (for free coupons) before clicking 'Enroll Now'."],
              ["Enroll and start learning", "The course is immediately added to your library with lifetime access."]
            ].map(([title, desc], i) => (
              <div style="display: flex; gap: 24px; align-items: flex-start; margin-bottom: 32px;">
                <div style="background: var(--accent); color: white; width: 32px; height: 32px; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-weight: 900; border: 2px solid var(--border); box-shadow: 2px 2px 0 var(--border); flex-shrink: 0;">{i+1}</div>
                <div>
                  <h3 style="font-size: 1.1rem; font-weight: 900; margin-bottom: 8px;">{title}</h3>
                  <p style="margin: 0; color: var(--muted); line-height: 1.6; font-weight: 500;">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section id="tips" style="margin-bottom: 64px;">
          <h2 class="section-heading">06. Pro Tips for Maximum Savings</h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 24px;">
            {[
              { icon: "⚡", t: "Act fast", d: "100% off coupons are capped at 1,000 uses. Popular courses can expire in hours." },
              { icon: "📋", t: "Quality over quantity", d: "Only enroll in courses you genuinely plan to start. Don't clutter your library." },
              { icon: "💳", t: "30-day refund", d: "Udemy offers a money-back guarantee for any paid course purchase." }
            ].map(tip => (
              <div class="neo-card">
                <div style="font-size: 1.5rem; margin-bottom: 12px;">{tip.icon}</div>
                <h3 style="font-size: 1rem; font-weight: 900; margin-bottom: 8px;">{tip.t}</h3>
                <p style="margin: 0; color: var(--muted); font-size: 0.85rem; font-weight: 600; line-height: 1.6;">{tip.d}</p>
              </div>
            ))}
          </div>
        </section>

        <section id="faq">
          <h2 class="section-heading">07. Frequently Asked Questions About Udemy Coupons</h2>
          <div style="display: flex; flex-direction: column; gap: 16px;">
            {[
              { q: "Are Udemy coupons legitimate and safe to use?", a: "Yes, absolutely. Udemy coupons are official promotional codes issued directly by Udemy or course instructors. They are legitimate marketing tools, not hacks or exploits. CoursesWyn only lists coupons from verified official sources including Udemy's affiliate program and instructor promotions." },
              { q: "Can you get Udemy courses for free with coupons?", a: "Yes. Many instructors offer 100% off coupons that make courses completely free ($0.00). These are most common for new course launches or when instructors want to build initial student numbers and reviews. The course content, certificate, and lifetime access are identical to paid enrollments." },
              { q: "How long do Udemy coupons last?", a: "Coupon duration varies by type. 100% off coupons typically last 3–7 days OR until 1,000 redemptions are reached. High-discount coupons (80–95% off) can last several weeks. Platform-wide sales usually run 2–7 days. Always check the specific expiry on each coupon listing." },
              { q: "Why do some Udemy coupon codes not work?", a: "Coupons fail for three main reasons: (1) Redemption limit reached — the 1,000 student cap was hit, (2) Expiration date passed — the time window closed, or (3) Geographic restrictions — some coupons only work in specific countries. If a code doesn't work, check CoursesWyn for a fresh replacement coupon." },
              { q: "Do free Udemy courses give certificates?", a: "Yes. All Udemy courses accessed via coupon include the same certificate of completion as full-price purchases. You can download it as a PDF or add it directly to your LinkedIn profile. The certificate does not indicate you got the course for free." },
              { q: "Can I use more than one coupon on a Udemy course?", a: "No. Udemy only allows one coupon code per course enrollment. You cannot stack or combine coupons. If multiple coupons exist for the same course, use the one with the highest discount percentage (ideally 100% off for free access)." },
              { q: "Is there a limit to how many free Udemy courses I can enroll in?", a: "Udemy does not publish a strict limit on free course enrollments. You can theoretically accumulate hundreds of free courses. However, Udemy may flag accounts showing unusual enrollment patterns (like thousands of courses in a single day). We recommend enrolling only in courses you genuinely intend to study." },
              { q: "What's the best way to find working Udemy coupon codes?", a: "The most reliable method is using curated coupon sites like CoursesWyn that verify codes daily. Other sources include instructor email newsletters, Udemy's official promotional emails, and instructor social media channels. Avoid random code generator websites — they almost never work." },
              { q: "Do Udemy coupons work worldwide?", a: "Most coupons work globally, but some are region-restricted. Udemy's pricing varies by country, so a 100% off coupon might show a different (but still heavily discounted) price in some regions. The discount is always applied relative to your local pricing tier." },
              { q: "Can I share Udemy coupons with friends?", a: "Yes. Udemy coupons are designed to be shared. When you find a working coupon link, it can be used by multiple people until the redemption limit or expiry date is reached. Sharing legitimate coupons with friends or colleagues is completely acceptable." }
            ].map(faq => (
              <details class="neo-details">
                <summary style="padding: 16px 24px; font-weight: 800; cursor: pointer; display: flex; justify-content: space-between; align-items: center;">
                  {faq.q}
                  <span style="color: var(--accent); font-size: 1.2rem;">+</span>
                </summary>
                <div style="padding: 0 24px 16px; color: var(--muted); font-weight: 500; line-height: 1.6;">{faq.a}</div>
              </details>
            ))}
          </div>
        </section>

        {/* ── RELATED RESOURCES ── */}
        <section style="margin-top: 80px; padding-top: 64px; border-top: 2px solid var(--border);">
          <h2 class="section-heading">Start Learning with Free AI Courses</h2>
          <p style="font-size: 1rem; color: var(--muted); margin-bottom: 32px; line-height: 1.6;">
            Now that you know how to use Udemy coupons, explore the hottest AI and tech courses with verified 100% off codes:
          </p>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
            {[
              { title: "ChatGPT & AI Writing", desc: "Master prompt engineering and AI content creation", link: "/blog/best-chatgpt-courses-udemy-2026", icon: "🤖" },
              { title: "AI Agent Development", desc: "Build autonomous agents with LangChain & CrewAI", link: "/blog/best-udemy-agentic-ai-courses-2026", icon: "🧠" },
              { title: "Cursor AI Coding", desc: "Code 10x faster with AI-powered development tools", link: "/blog/best-cursor-ai-courses-udemy", icon: "⚡" },
              { title: "LangChain & RAG", desc: "Create AI apps with retrieval-augmented generation", link: "/blog/best-langchain-langgraph-courses-udemy-2026-rag-agents-production", icon: "�" },
              { title: "Generative AI Mastery", desc: "Complete GPT, image gen & AI tools guide", link: "/blog/top-10-best-generative-ai-courses-udemy", icon: "✨" },
              { title: "Browse All Free Deals", desc: "Find 100% off coupons across all categories", link: "/udemy-coupon-code", icon: "🎫" }
            ].map(resource => (
              <a href={resource.link} style="text-decoration: none; color: inherit;">
                <div class="neo-card" style="height: 100%;">
                  <div style="font-size: 2rem; margin-bottom: 12px;">{resource.icon}</div>
                  <h3 style="font-size: 1.1rem; font-weight: 900; margin-bottom: 8px; color: var(--text);">{resource.title}</h3>
                  <p style="margin: 0; color: var(--muted); font-size: 0.9rem; font-weight: 500; line-height: 1.5;">{resource.desc}</p>
                </div>
              </a>
            ))}
          </div>
        </section>

      </div>
    </article>
  </main>

  <style>
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .section-heading {
      font-size: 2rem; font-weight: 900; margin-bottom: 32px; color: var(--text);
      display: flex; align-items: center; gap: 16px;
      letter-spacing: -0.02em;
    }
    .prose p { margin-bottom: 24px; line-height: 1.7; font-size: 1.05rem; font-weight: 500; color: var(--muted); }
    .prose strong { color: var(--text); font-weight: 700; }
