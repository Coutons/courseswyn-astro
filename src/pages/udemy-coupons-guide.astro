---
import MainLayout from '../layouts/MainLayout.astro';

const currentMonth = new Date().toLocaleDateString('en-US', { month: 'long' });
const currentYear = new Date().getFullYear();

const pageTitle = `Udemy Coupons Guide ${currentYear} — How to Get 100% Off Udemy Courses`;
const pageDescription = "The complete guide to finding and using Udemy coupon codes in 2026. Learn how to get 100% off Udemy courses, where to find verified coupons, and how to redeem them step by step.";
---

<MainLayout title={pageTitle} description={pageDescription}>
  <div class="bg-[#1c252e] min-h-screen py-16 px-4">
    <div class="max-w-4xl mx-auto space-y-16">
      
      <!-- HEADER -->
      <header class="space-y-6 border-b border-[#2d3748] pb-12">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-[10px] font-black uppercase tracking-widest bg-green-500/10 border border-green-500/20 text-green-500">
          <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
          Official 2026 Strategy Guide
        </div>
        <h1 class="text-4xl md:text-6xl font-black text-white leading-tight">
          Udemy Coupons Guide <span class="text-green-500">{currentYear}</span>: How to Get 100% Off
        </h1>
        <p class="text-gray-400 text-lg md:text-xl leading-relaxed">
          Everything you need to know about Udemy coupons: where to find them, how they work, how to redeem them, and how to avoid expired codes — explained clearly and honestly.
        </p>
      </header>

      <!-- TABLE OF CONTENTS -->
      <nav class="bg-[#111820] border border-[#2d3748] rounded-3xl p-8 shadow-xl">
        <h2 class="text-white font-black text-xs uppercase tracking-widest mb-6">In This Guide:</h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
          <li><a href="#what-are-coupons" class="text-gray-400 hover:text-green-500 transition-colors flex items-center gap-2"><span>1.</span> What Are Udemy Coupons?</a></li>
          <li><a href="#types-of-coupons" class="text-gray-400 hover:text-green-500 transition-colors flex items-center gap-2"><span>2.</span> Types of Udemy Coupons</a></li>
          <li><a href="#where-to-find" class="text-gray-400 hover:text-green-500 transition-colors flex items-center gap-2"><span>3.</span> Where to Find Valid Coupons</a></li>
          <li><a href="#how-to-redeem" class="text-gray-400 hover:text-green-500 transition-colors flex items-center gap-2"><span>4.</span> How to Redeem (Step-by-Step)</a></li>
          <li><a href="#pro-tips" class="text-gray-400 hover:text-green-500 transition-colors flex items-center gap-2"><span>5.</span> Pro Tips to Maximize Savings</a></li>
          <li><a href="#faq" class="text-gray-400 hover:text-green-500 transition-colors flex items-center gap-2"><span>6.</span> Frequently Asked Questions</a></li>
        </ul>
      </nav>

      <!-- CONTENT SECTIONS -->
      <div class="space-y-24">
        
        <!-- 1. WHAT ARE COUPONS -->
        <section id="what-are-coupons" class="space-y-6">
          <h2 class="text-3xl font-black text-white flex items-center gap-4">
            <span class="text-green-500">01.</span> What Are Udemy Coupons?
          </h2>
          <div class="prose prose-invert prose-lg max-w-none text-gray-400 leading-relaxed space-y-4">
            <p>
              Udemy coupons are time-limited promotional codes that reduce the price of a Udemy course — sometimes to <strong>$0.00 (completely free)</strong>. They work like standard e-commerce promo codes: a unique alphanumeric string is applied at checkout, and the course price is discounted instantly.
            </p>
            <p>
              Coupons are generally issued by two main sources:
            </p>
            <ul class="list-none space-y-4 pt-4">
              <li class="flex items-start gap-4">
                <span class="w-8 h-8 rounded-xl bg-green-500/10 flex items-center justify-center text-green-500 shrink-0 font-black">U</span>
                <div>
                  <strong class="text-white block mb-1">Udemy Itself</strong>
                  For platform-wide sales events like Black Friday or New Year promotions.
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="w-8 h-8 rounded-xl bg-green-500/10 flex items-center justify-center text-green-500 shrink-0 font-black">I</span>
                <div>
                  <strong class="text-white block mb-1">Individual Instructors</strong>
                  Used to attract new students or reward their community. These are the most common source of <strong>100% OFF</strong> coupons.
                </div>
              </li>
            </ul>
          </div>
        </section>

        <!-- 2. TYPES OF COUPONS -->
        <section id="types-of-coupons" class="space-y-6">
          <h2 class="text-3xl font-black text-white flex items-center gap-4">
            <span class="text-green-500">02.</span> Types of Udemy Coupons
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-[#111820] border border-[#2d3748] rounded-3xl p-8 space-y-4">
              <h3 class="text-green-500 font-black text-xs uppercase tracking-widest">The Holy Grail</h3>
              <h4 class="text-white text-xl font-black">100% OFF Instructor Coupons</h4>
              <p class="text-gray-400 text-sm leading-relaxed">
                These give you a fully paid course at zero cost, but they expire incredibly fast. A popular course can exhaust 1,000 redemptions within hours of a coupon being shared.
              </p>
            </div>
            <div class="bg-[#111820] border border-[#2d3748] rounded-3xl p-8 space-y-4">
              <h3 class="text-green-500 font-black text-xs uppercase tracking-widest">High Value</h3>
              <h4 class="text-white text-xl font-black">Limited Discount (80-95% OFF)</h4>
              <p class="text-gray-400 text-sm leading-relaxed">
                Generally valid for longer periods (3-30 days). These often set the course price to a flat $9.99 - $14.99 regardless of the original price.
              </p>
            </div>
          </div>
        </section>

        <!-- 3. WHERE TO FIND -->
        <section id="where-to-find" class="space-y-6">
          <h2 class="text-3xl font-black text-white flex items-center gap-4">
            <span class="text-green-500">03.</span> Where to Find Valid Coupons
          </h2>
          <div class="space-y-6">
            <div class="p-8 bg-gradient-to-br from-[#1c252e] to-[#111820] border border-[#2d3748] rounded-[2.5rem] shadow-2xl relative overflow-hidden group">
              <div class="absolute top-0 right-0 w-32 h-32 bg-green-500/5 rounded-full blur-3xl"></div>
              <h4 class="text-white text-xl font-black mb-4">Verification is Key</h4>
              <p class="text-gray-400 leading-relaxed mb-6">
                The biggest challenge is that most codes found online are expired. At <strong>CoursesWyn</strong>, we list instructor-issued coupons verified daily. Each deal shows the verification date to ensure you don't waste time on broken links.
              </p>
              <div class="flex flex-wrap gap-4">
                <a href="/udemy-coupon-code" class="px-8 py-4 bg-[#2d3748] hover:bg-green-500 text-white text-xs font-black uppercase tracking-widest rounded-2xl transition-all shadow-xl shadow-black/20">Browse Verified Deals</a>
                <a href="#how-to-redeem" class="px-8 py-4 bg-[#1c252e] border border-[#2d3748] text-white text-xs font-black uppercase tracking-widest rounded-2xl hover:border-green-500 transition-all">Redemption Guide</a>
              </div>
            </div>
          </div>
        </section>

        <!-- 4. HOW TO REDEEM -->
        <section id="how-to-redeem" class="scroll-mt-24 space-y-12">
           <div class="text-center space-y-4">
              <h2 class="text-4xl font-black text-white">How to Redeem a Udemy Coupon</h2>
              <p class="text-gray-500 max-w-2xl mx-auto">Redeeming a verified coupon via CoursesWyn takes under 2 minutes. Follow this official 5-step process.</p>
           </div>
           
           <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
              {[
                { n: '01', t: 'Find a Deal', d: 'Browse our latest verified 100% OFF coupons by category.' },
                { n: '02', t: 'Click Redeem', d: 'Clicking "Redeem Coupon" opens Udemy with the code pre-applied.' },
                { n: '03', t: 'Verify Price', d: 'Always confirm the price shows $0.00 at the Udemy checkout.' },
                { n: '04', t: 'Log In', d: 'Sign in to your free Udemy account to claim the course.' },
                { n: '05', t: 'Lifetime Access', d: 'Enroll once and keep the course in your library forever.' }
              ].map(step => (
                <div class="bg-[#111820] border border-[#2d3748] p-6 rounded-3xl space-y-4 hover:border-green-500 transition-all group">
                   <span class="text-green-500 font-black text-2xl group-hover:scale-110 transition-transform block">{step.n}</span>
                   <h5 class="text-white font-black text-sm">{step.t}</h5>
                   <p class="text-gray-500 text-xs leading-relaxed">{step.d}</p>
                </div>
              ))}
           </div>
           
           <div class="text-center">
              <a href="/how-to-redeem-coupon" class="inline-flex items-center gap-2 text-green-500 font-black uppercase tracking-[0.2em] text-[10px] hover:underline">
                 Full Detailed Redemption Guide ↗
              </a>
           </div>
        </section>

        <!-- 5. PRO TIPS -->
        <section id="pro-tips" class="space-y-8">
          <h2 class="text-3xl font-black text-white">Pro Tips to Maximize Savings</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-3">
              <h4 class="text-white font-black flex items-center gap-2">
                <span class="w-2 h-2 bg-amber-500 rounded-full"></span>
                Act within hours, not days
              </h4>
              <p class="text-gray-400 text-sm leading-relaxed">
                100% OFF coupons are usually capped at 1,000 uses. Popular courses can exhaust this limit in under 6 hours. Check CoursesWyn daily for the freshest drops.
              </p>
            </div>
            <div class="space-y-3">
              <h4 class="text-white font-black flex items-center gap-2">
                <span class="w-2 h-2 bg-amber-500 rounded-full"></span>
                Wishlist first, filter later
              </h4>
              <p class="text-gray-400 text-sm leading-relaxed">
                Don't enroll in every free course. Only claim what you genuinely plan to start within 30 days to avoid cluttering your library.
              </p>
            </div>
            <div class="space-y-3">
              <h4 class="text-white font-black flex items-center gap-2">
                <span class="w-2 h-2 bg-amber-500 rounded-full"></span>
                Check the "Last Updated" date
              </h4>
              <p class="text-gray-400 text-sm leading-relaxed">
                For tech topics like AI or Web Frameworks, prefer courses updated within the last 12 months for the most relevant content.
              </p>
            </div>
            <div class="space-y-3">
              <h4 class="text-white font-black flex items-center gap-2">
                <span class="w-2 h-2 bg-amber-500 rounded-full"></span>
                Certificate of Completion
              </h4>
              <p class="text-gray-400 text-sm leading-relaxed">
                Enrolling via a free coupon still grants you a full certificate of completion that you can share on LinkedIn or your resume.
              </p>
            </div>
          </div>
        </section>

        <!-- 6. FAQ -->
        <section id="faq" class="space-y-12">
          <h2 class="text-3xl font-black text-white">Frequently Asked Questions</h2>
          <div class="divide-y divide-[#2d3748]">
            {[
              { q: 'Are Udemy coupons safe and legal?', a: 'Yes. These are official promotional codes issued by instructors or Udemy themselves. CoursesWyn only lists verified links.' },
              { q: 'Why did the coupon show full price?', a: 'This means the coupon has either expired or hit its maximum redemption limit (usually 1,000 uses).' },
              { q: 'Can I use multiple coupons on one course?', a: 'No, Udemy only allows one coupon per course enrollment. Choose the highest discount available.' },
              { q: 'Do I get lifetime access with a free coupon?', a: 'Yes! Once enrolled, the course is yours forever, including all future updates and the certificate.' }
            ].map(item => (
              <div class="py-8 first:pt-0">
                <h4 class="text-white font-black text-lg mb-4">{item.q}</h4>
                <p class="text-gray-400 leading-relaxed">{item.a}</p>
              </div>
            ))}
          </div>
        </section>

      </div>

      <!-- FOOTER CTA -->
      <footer class="bg-[#111820] border border-[#2d3748] rounded-[3rem] p-12 text-center space-y-6 shadow-2xl">
        <h2 class="text-3xl md:text-5xl font-black text-white">Ready to start learning?</h2>
        <p class="text-gray-400 text-lg max-w-xl mx-auto">Browse thousands of verified 100% OFF coupons updated every single day.</p>
        <div class="pt-4">
          <a href="/udemy-coupon-code" class="inline-block px-12 py-5 bg-[#2d3748] hover:bg-green-500 text-white font-black rounded-full transition-all shadow-xl shadow-black/20 text-lg uppercase tracking-widest">Explore All Deals</a>
        </div>
      </footer>

    </div>
  </div>
</MainLayout>
