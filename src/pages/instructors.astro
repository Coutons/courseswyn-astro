    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    font-size: 0.78rem; font-weight: 500;
    text-decoration: none;
    transition: background 0.15s;
  }

  .cat-tag:hover { background: hsla(45, 95%, 58%, 0.15); }

  /* Deal preview rows */
  .deal-preview-row {
    display: flex; align-items: center; gap: 0.55rem;
    padding: 0.6rem 0.75rem;
    background: var(--bg, hsl(222, 47%, 5%));
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .deal-preview-row:hover { border-color: var(--brand); }

  .deal-disc-pill {
    flex-shrink: 0;
    background: hsla(0, 80%, 55%, 0.14);
    border: 1px solid hsla(0, 80%, 55%, 0.28);
    color: hsl(0, 80%, 75%);
    font-size: 0.68rem; font-weight: 700;
    padding: 0.12rem 0.4rem; border-radius: 5px;
  }

  .deal-preview-title {
    flex: 1;
    font-size: 0.82rem; color: var(--text); font-weight: 500;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .deal-price-current {
    flex-shrink: 0;
    font-size: 0.85rem; font-weight: 700;
    color: hsl(120, 60%, 55%);
  }

  /* CTA button — same style as /deals primary button */
  .cta-btn {
    display: flex; align-items: center; gap: 0.5rem;
    width: 100%; padding: 0.85rem 1.25rem;
    background: var(--brand);
    color: var(--bg);
    font-weight: 700; font-size: 0.95rem;
    text-decoration: none; border-radius: 10px;
    transition: filter 0.2s, transform 0.15s;
    box-shadow: 0 4px 20px -4px hsla(45, 95%, 58%, 0.3);
  }

  .cta-btn:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }

  /* FAQ */
  .faq-item:hover {
    border-color: var(--brand) !important;
    transition: border-color 0.2s ease;
  }

  /* Responsive */
  @media (max-width: 768px) {
    h1 { font-size: 1.75rem !important; }
    #instructorGrid { grid-template-columns: 1fr !important; }
  }

  @media (max-width: 480px) {
    h1 { font-size: 1.4rem !important; }
  }
</style>

<script>
  // ─────────────────────────────────────────────
  // FILTER + SORT
  // ─────────────────────────────────────────────
  interface CardEl extends HTMLElement {
    dataset: {
      categories: string;
      rating: string;
      students: string;
      courses: string;
      name: string;
    };
  }

  const categoryFilter = document.getElementById('categoryFilter') as HTMLSelectElement | null;
  const ratingFilter   = document.getElementById('ratingFilter')   as HTMLSelectElement | null;
  const sortByEl       = document.getElementById('sortBy')         as HTMLSelectElement | null;
  const grid           = document.getElementById('instructorGrid');
  const noResults      = document.getElementById('noResults');
  const resultCount    = document.getElementById('resultCount');

  function filterAndSort(): void {
    if (!grid || !categoryFilter || !ratingFilter || !sortByEl) return;

    const category  = categoryFilter.value.toLowerCase();
    const minRating = parseFloat(ratingFilter.value) || 0;
    const sort      = sortByEl.value;

    const cards = Array.from(grid.querySelectorAll<CardEl>('.inst-card'));

    const visible = cards.filter((card) => {
      const cats   = card.dataset.categories.toLowerCase();
      const rating = parseFloat(card.dataset.rating) || 0;
      return (!category || cats.includes(category)) && rating >= minRating;
    });

    visible.sort((a, b) => {
      switch (sort) {
        case 'students': return parseInt(b.dataset.students) - parseInt(a.dataset.students);
        case 'courses':  return parseInt(b.dataset.courses)  - parseInt(a.dataset.courses);
        case 'rating':   return parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating);
        case 'name':     return a.dataset.name.localeCompare(b.dataset.name);
        default:         return 0;
      }
    });

    // Hide all, re-insert visible in sorted order
    cards.forEach((c) => (c.style.display = 'none'));

    if (visible.length === 0) {
      if (grid)      grid.style.display      = 'none';
      if (noResults) noResults.style.display = 'block';
    } else {
      if (grid)      grid.style.display      = 'grid';
      if (noResults) noResults.style.display = 'none';
      visible.forEach((c) => { c.style.display = ''; grid!.appendChild(c); });
    }

    if (resultCount) {
      resultCount.textContent = `${visible.length} instructor${visible.length !== 1 ? 's' : ''} found`;
    }
  }

  categoryFilter?.addEventListener('change', filterAndSort);
  ratingFilter?.addEventListener('change', filterAndSort);
  sortByEl?.addEventListener('change', filterAndSort);

  // ─────────────────────────────────────────────
  // GEO AI PERSONALISATION
  // Detects visitor country via ipapi.co (free tier, no key needed)
  // and shows a localised banner + appends country hint to subtitle.
  // Fails silently — no impact on page if API is unavailable.
  // ─────────────────────────────────────────────
  interface GeoResponse {
    country_code?: string;
    country_name?: string;
    city?: string;
  }

  const GEO_COPY: Record<string, string> = {
    US: '🇺🇸 Popular in the United States — Top Udemy instructors with verified English-language coupons.',
    GB: '🇬🇧 Trending in the UK — Expert Udemy instructors with exclusive discount codes for UK learners.',
    IN: '🇮🇳 Top picks for India — Thousands of Indian learners save daily with these Udemy instructor coupons.',
    AU: '🇦🇺 Trending in Australia — Verified Udemy instructor coupons available to you right now.',
    CA: '🇨🇦 Popular in Canada — Get free and discounted Udemy courses from top instructors.',
    DE: '🇩🇪 Beliebt in Deutschland — Verifizierte Udemy-Coupons von Top-Instruktoren, täglich aktualisiert.',
    BR: '🇧🇷 Popular no Brasil — Cupons Udemy verificados dos melhores instrutores, atualizados diariamente.',
    NG: '🇳🇬 Trending in Nigeria — Access world-class Udemy courses free with verified instructor coupons.',
    PH: '🇵🇭 Popular in the Philippines — Free and discounted Udemy courses from expert instructors.',
    ID: '🇮🇩 Populer di Indonesia — Kupon Udemy terverifikasi dari instruktur terbaik, diperbarui harian.',
    PK: '🇵🇰 Trending in Pakistan — Get free Udemy courses from top instructors, verified every day.',
    EG: '🇪🇬 Popular in Egypt — Verified Udemy instructor coupons updated daily.',
    MX: '🇲🇽 Popular en México — Cupones Udemy verificados de los mejores instructores.',
    FR: '🇫🇷 Populaire en France — Coupons Udemy vérifiés auprès des meilleurs formateurs.',
    TR: '🇹🇷 Türkiye\'de popüler — En iyi Udemy eğitmenlerinden doğrulanmış kuponlar.',
    AR: '🇦🇷 Popular en Argentina — Cupones Udemy verificados de los mejores instructores.',
    SA: '🇸🇦 رائج في المملكة العربية السعودية — كوبونات Udemy موثقة من أفضل المدربين.',
    NL: '🇳🇱 Populair in Nederland — Geverifieerde Udemy-coupons van topinstructeurs.',
    ES: '🇪🇸 Popular en España — Cupones Udemy verificados de los mejores instructores.',
    IT: '🇮🇹 Popolare in Italia — Coupon Udemy verificati dai migliori istruttori.',
  };

  async function initGeo(): Promise<void> {
    const banner  = document.getElementById('geo-banner');
    const geoText = document.getElementById('geo-text');
    if (!banner || !geoText) return;

    try {
      // Use session cache to avoid repeated API calls on navigation
      const cached = sessionStorage.getItem('cs_geo');
      let geo: GeoResponse;

      if (cached) {
        geo = JSON.parse(cached) as GeoResponse;
      } else {
        const res = await fetch('https://ipapi.co/json/', {
          signal: AbortSignal.timeout(4000),
        });
        if (!res.ok) return;
        geo = (await res.json()) as GeoResponse;
        sessionStorage.setItem('cs_geo', JSON.stringify(geo));
      }

      const code = (geo.country_code ?? '').toUpperCase();
      const msg  = GEO_COPY[code]
        ?? `📍 Browsing from ${geo.country_name ?? 'your region'} — Verified Udemy instructor coupons available now.`;

      geoText.textContent = msg;
      banner.style.display = 'block';

      // Append country hint to the results subtitle for soft personalisation
      const sub = document.getElementById('resultCount');
      if (sub && geo.country_name && !sub.textContent?.includes(geo.country_name)) {
        sub.textContent = (sub.textContent ?? '').trimEnd() + ` · Popular in ${geo.country_name}`;
      }
    } catch {
      // Geo is a progressive enhancement — never block page load
    }
  }

  // ─────────────────────────────────────────────
  // FAQ ACCORDION — identical logic to /deals
  // ─────────────────────────────────────────────
  function initFaq(): void {
    document.querySelectorAll('.faq-item').forEach((item) => {
      const btn    = item.querySelector('.faq-question') as HTMLButtonElement | null;
      const answer = item.querySelector('.faq-answer')   as HTMLElement | null;
      const icon   = item.querySelector('.faq-icon')     as SVGElement | null;
      if (!btn || !answer || !icon) return;

      btn.addEventListener('click', () => {
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        // Close all items first
        document.querySelectorAll('.faq-item').forEach((other) => {
          const ob = other.querySelector('.faq-question') as HTMLButtonElement | null;
          const oa = other.querySelector('.faq-answer')   as HTMLElement | null;
          const oi = other.querySelector('.faq-icon')     as SVGElement | null;
          if (ob) ob.setAttribute('aria-expanded', 'false');
          if (oa) oa.style.maxHeight = '0';
          if (oi) oi.style.transform = 'rotate(0deg)';
        });

        // Re-open if it was closed
        if (!isOpen) {
          btn.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = `${answer.scrollHeight}px`;
          icon.style.transform   = 'rotate(180deg)';
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initFaq();
    initGeo();
  });
</script>