    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  /* Match /deals page global backgrounds */
  .hero-gradient {
    background: linear-gradient(135deg, hsl(222, 47%, 7%) 0%, hsl(222, 43%, 10%) 100%);
  }

  .card-gradient {
    background: var(--bg);
  }

  /* ── FILTERS ── */
