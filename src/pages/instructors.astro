---
import Layout from '../layouts/Layout.astro';
import { readDeals } from '../lib/store';
import type { Deal } from '../types/deal.d';
import { parseInstructors, createInstructorSlug } from '../lib/instructors';
import { formatDateWIB } from '../lib/date';

interface Instructor {
  name: string;
  courses: Deal[];
  totalStudents: number;
  avgRating: number;
  categories: string[];
  totalReviews: number;
  provider: string;
  courseCount: number;
  totalCoupons: number;
}

const deals: Deal[] = await readDeals();
const instructorMap = new Map<string, Instructor>();

deals.forEach((deal: Deal) => {
  if (!deal.instructor) return;
  const instructorNames = parseInstructors(deal.instructor);
  instructorNames.forEach((instructorName) => {
    const clean = instructorName.replace(/[^\x20-\x7E]/g, '').trim() || instructorName.trim();
    if (!instructorMap.has(clean)) {
      instructorMap.set(clean, {
        name: clean,
        courses: [],
        totalStudents: 0,
        avgRating: 0,
        categories: [],
        totalReviews: 0,
        provider: deal.provider || 'Udemy',
        courseCount: 0,
        totalCoupons: 0,
      });
    }
    const inst = instructorMap.get(clean)!;
    inst.courses.push(deal);
    inst.totalCoupons += 1;
    if (deal.students) inst.totalStudents += deal.students;
    if (deal.rating) {
      const count = inst.courses.length;
      inst.avgRating = (inst.avgRating * (count - 1) + deal.rating) / count;
      inst.totalReviews += deal.students || 0;
    }
    if (deal.category && !inst.categories.includes(deal.category)) {
      inst.categories.push(deal.category);
    }
  });
});

const instructors = Array.from(instructorMap.values())
  .map((inst) => ({
    name: inst.name,
    courses: inst.courses,
    totalStudents: inst.totalStudents,
    avgRating: Number(inst.avgRating.toFixed(1)),
    categories: inst.categories,
    totalReviews: inst.totalReviews,
    provider: inst.provider,
    courseCount: inst.courses.length,
    totalCoupons: inst.totalCoupons
  }))
  .sort((a, b) => b.totalStudents - a.totalStudents);

function getMaxDiscount(courses: Deal[]): number {
  return Math.max(
    0,
    ...courses.map((c) => {
      if (!c.originalPrice || !c.price || c.price >= c.originalPrice) return 0;
      return Math.round(100 - (c.price / c.originalPrice) * 100);
    })
  );
}

function hasFree(courses: Deal[]): boolean {
  return courses.some((c) => c.price === 0);
}

function getInitials(name: string): string {
  return name.split(' ').map((n) => n[0]).join('').toUpperCase().slice(0, 2);
}

function getTopDeals(courses: Deal[]): Deal[] {
  return courses
    .filter((c) => c.originalPrice && c.price !== undefined && c.price < c.originalPrice)
    .sort((a, b) => {
      const da = Math.round(100 - ((a.price ?? 0) / (a.originalPrice ?? 1)) * 100);
      const db = Math.round(100 - ((b.price ?? 0) / (b.originalPrice ?? 1)) * 100);
      return db - da;
    })
    .slice(0, 2);
}

const totalCoupons = deals.length;
const totalFree = instructors.reduce((s, i) => s + (hasFree(i.courses) ? 1 : 0), 0);

const currentMonth = new Date().toLocaleDateString('en-US', { month: 'long', timeZone: 'Asia/Jakarta' });
const currentYear = Number(new Date().toLocaleString('en-US', { year: 'numeric', timeZone: 'Asia/Jakarta' }));

const siteUrl = 'https://courseswyn.com';
const canonicalUrl = `${siteUrl}/instructors`;
const title = `Top Udemy Instructors with Free Coupons & Promo Codes ${currentMonth} ${currentYear} | CoursesWyn`;
const description = `Discover ${instructors.length} top Udemy instructors offering ${totalCoupons.toLocaleString()}+ verified free coupons and promo codes. Updated daily in ${currentMonth} ${currentYear}.`;
---

<Layout title={title} description={description} canonical={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      { "@type": "BreadcrumbList", "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Instructors", "item": canonicalUrl }
      ]},
      { "@type": "CollectionPage", "url": canonicalUrl, "name": title, "description": description, "mainEntity": { "@type": "ItemList", "numberOfItems": instructors.length }}
    ]
  })} />

  <style>
    .hero-gradient-text {
      background: linear-gradient(135deg, var(--brand), #60a5fa, #3b82f6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .inst-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
      transition: all 0.3s ease;
    }
    .inst-card:hover {
      border-color: var(--brand);
      transform: translateY(-2px);
    }
    .faq-grid { display: grid; gap: 0.75rem; }
    .faq-item { background: transparent; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .faq-item summary { padding: 1.25rem; font-weight: 700; cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-size: 1rem; color: var(--text); list-style: none; }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item[open] summary { border-bottom: 1px solid var(--border); }
    .faq-item .fi { transition: transform 0.3s; flex-shrink: 0; }
    .faq-item[open] .fi { transform: rotate(180deg); }
    .faq-answer { padding: 0 1.25rem 1.25rem; color: var(--muted); line-height: 1.7; font-size: 0.9rem; }
  </style>

  <main>
    <section class="hero">
      <div class="container">
        <div class="hero-content anim-up">
          <h1>
            <span style="display:block">Top</span>
            <span class="hero-gradient-text" style="display:block;font-size:clamp(2.5rem,6vw,4.5rem)">Instructors</span>
            <span style="display:block">with Verified Coupons</span>
          </h1>
          <p>Exclusive discount codes from <strong>{instructors.length} expert instructors</strong>. Browse <strong>{totalCoupons.toLocaleString()} active coupons</strong> with up to <strong>100% off</strong>.</p>
        </div>
      </div>
    </section>

    <section style="padding-bottom:2rem">
      <div class="container">
        <div class="stat-grid">
          <div class="stat-box">
            <div class="stat-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
              {instructors.length}
            </div>
            <div class="stat-label">Instructors</div>
          </div>
          <div class="stat-box">
            <div class="stat-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
              {totalCoupons.toLocaleString()}+
            </div>
            <div class="stat-label">Coupons</div>
          </div>
          <div class="stat-box">
            <div class="stat-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {totalFree} Free
            </div>
            <div class="stat-label">Offer Free Deals</div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <span class="section-title">Expert Instructors</span>
        <h2 class="section-heading" style="margin:0 0 2.5rem;">Top Instructors with Verified Coupons</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1.25rem;">
          {instructors.map((instructor) => {
            const maxDisc = getMaxDiscount(instructor.courses);
            const free = hasFree(instructor.courses);
            const topDeals = getTopDeals(instructor.courses);
            const instructorSlug = createInstructorSlug(instructor.name);

            return (
              <article class="inst-card">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1rem;">
                  <div style="width:48px;height:48px;border-radius:10px;background:var(--brand);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:900;font-size:1.25rem;flex-shrink:0;">{getInitials(instructor.name)}</div>
                  {free && <span style="background:var(--brand-soft);color:var(--brand);padding:2px 10px;border-radius:999px;font-size:0.65rem;font-weight:800;border:1px solid var(--brand-soft);">FREE</span>}
                </div>
                <h3 style="font-size:1.1rem;font-weight:800;margin:0 0 2px;color:var(--text);">{instructor.name}</h3>
                <p style="font-size:0.8rem;color:var(--muted);font-weight:600;margin:0 0 1rem;">{instructor.provider} &middot; {instructor.totalCoupons} Coupon{instructor.totalCoupons === 1 ? '' : 's'}</p>
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:1rem;">
                  {[
                    { l: "Students", v: instructor.totalStudents > 1000 ? (instructor.totalStudents/1000).toFixed(1) + 'k' : instructor.totalStudents },
                    { l: "Rating", v: instructor.avgRating + "★" },
                    { l: "Max Off", v: maxDisc + "%" }
                  ].map(s => (
                    <div style="background:var(--bg-secondary);padding:10px 8px;border-radius:10px;text-align:center;">
                      <div style="font-size:0.9rem;font-weight:800;color:var(--text);">{s.v}</div>
                      <div style="font-size:0.6rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;">{s.l}</div>
                    </div>
                  ))}
                </div>
                {topDeals.length > 0 && (
                  <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:1rem;">
                    {topDeals.map(deal => (
                      <a href={`/coupon/${deal.slug || deal.id}`} style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:var(--bg-secondary);border:1px solid var(--border);border-radius:10px;text-decoration:none;color:var(--text);font-size:0.82rem;font-weight:600;">
                        <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{deal.title}</span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                      </a>
                    ))}
                  </div>
                )}
                <a href={`/instructor/${instructorSlug}`} class="btn btn-primary" style="width:100%;text-align:center;display:block;padding:12px;border-radius:10px;font-size:0.85rem;">
                  View All {instructor.totalCoupons} Coupon{instructor.totalCoupons === 1 ? '' : 's'}
                </a>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section class="section" style="padding-top:0;">
      <div class="container" style="max-width:800px;">
        <span class="section-title">FAQ</span>
        <h2 class="section-heading" style="margin:0 0 2rem;">Common Questions</h2>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {[
            { q: 'Who are the top Udemy instructors with free coupons?', a: `CoursesWyn features ${instructors.length} verified Udemy instructors who regularly share free and discounted coupons.` },
            { q: 'How do I get a free course from a Udemy instructor?', a: 'Click on any instructor card to see their latest verified deals. All coupons are checked daily.' },
            { q: 'Are the instructor coupons verified?', a: 'Yes. Every coupon is manually verified before listing. Expired coupons are removed within hours.' }
          ].map(faq => (
            <details class="faq-item">
              <summary>
                {faq.q}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="3" class="fi"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-answer">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
