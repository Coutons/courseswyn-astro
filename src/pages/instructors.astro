  .inst-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px -8px rgba(0, 0, 0, 0.45);
    border-color: var(--brand);
  }

  /* Top gradient bar appears on hover */
  .card-accent-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--brand), var(--secondary));
    opacity: 0;
    transition: opacity 0.25s;
  }

  .inst-card:hover .card-accent-bar {
    opacity: 1;
  }

  /* Badge */
  .card-badge {
    position: absolute;
    top: 1rem; right: 1rem;
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .badge-hot {
    background: hsla(0, 80%, 55%, 0.12);
    border: 1px solid hsla(0, 80%, 55%, 0.35);
    color: hsl(0, 80%, 75%);
  }

  .badge-free {
    background: hsla(120, 70%, 45%, 0.12);
    border: 1px solid hsla(120, 70%, 45%, 0.3);
    color: hsl(120, 60%, 65%);
  }

  /* Avatar */
  .inst-avatar {
    flex-shrink: 0;
    width: 54px; height: 54px;
    border-radius: 50%;
    background: linear-gradient(135deg, hsl(222, 47%, 13%), hsl(222, 40%, 19%));
    border: 2px solid var(--brand-soft);
    display: flex; align-items: center; justify-content: center;
    color: var(--brand);
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
  }

  .inst-name {
    color: var(--text);
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.3rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* 3-column stats panel */
  .inst-stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: var(--bg, hsl(222, 47%, 5%));
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 1.25rem;
  }

  .inst-stat {
    display: flex; flex-direction: column;
    align-items: center;
    padding: 0.75rem 0.4rem;
    position: relative;
  }

  .inst-stat:not(:last-child)::after {
    content: '';
    position: absolute; right: 0; top: 20%; height: 60%;
    width: 1px; background: var(--border);
  }

  .stat-val {
    font-size: 1rem; font-weight: 700;
    margin-bottom: 0.2rem;
  }

  .stat-lbl {
    font-size: 0.72rem; color: var(--muted); font-weight: 500;
  }

  /* Category tags */
  .section-label {
    font-size: 0.7rem; font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin: 0 0 0.5rem;
