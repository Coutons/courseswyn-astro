---
import MainLayout from '../../../../layouts/MainLayout.astro';
import coupons from '../../../../data/coupons.json';
import CourseCard from '../../../../components/CourseCard.astro';

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const categories = [...new Set(coupons.map(c => c.category))];
  
  return categories.flatMap(category => {
    const filteredCourses = coupons.filter(c => c.category === category);
    filteredCourses.sort((a, b) => new Date(b.updatedAt || new Date()).getTime() - new Date(a.updatedAt || new Date()).getTime());
    
    const safeCategorySlug = category ? String(category).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') : 'uncategorized';

    return paginate(filteredCourses, {
      params: { category: safeCategorySlug },
      props: { originalCategory: category },
      pageSize: 16
    });
  });
}

const { page, originalCategory: category } = Astro.props;
const allCourses = page.data;
const pageTitle = `Free ${category} Courses - Coupon Codes${page.currentPage > 1 ? ` - Page ${page.currentPage}` : ''}`;
const pageDescription = `Get the best ${category} courses for free or 90% off. Verified Udemy coupons for ${category}, programming, and design. Start learning ${category} today without breaking the bank.`;

// SEO & Schema
const schemaData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": Astro.url.href,
  "mainEntity": {
     "@type": "ItemList",
     "itemListElement": allCourses.map((course: any, index: number) => ({
      "@type": "ListItem",
      "position": index + 1,
      "url": `https://courseswyn.com/coupon/${course.slug}`,
      "name": course.title
    }))
  }
};

const topCategories = ["Development", "Business", "IT & Software", "Design", "Marketing"];
---

<MainLayout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  
  <!-- Fixed Background & Glows -->
  <div class="fixed inset-0 bg-[#0a0f16] -z-50"></div>
  <div class="fixed top-0 left-[-10%] w-[700px] h-[700px] bg-emerald-500/10 rounded-full blur-[180px] mix-blend-screen pointer-events-none -z-40"></div>
  <div class="fixed bottom-0 right-[-10%] w-[600px] h-[600px] bg-blue-600/8 rounded-full blur-[180px] mix-blend-screen pointer-events-none -z-40"></div>

  <div class="min-h-screen pb-20 relative">
    
    <!-- Header / Filter Section -->
    <div class="border-b border-white/5 pt-12 pb-8 relative z-30">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
         <!-- Top Tabs -->
         <div class="flex justify-center mb-10">
            <div class="flex items-center bg-white/5 backdrop-blur-xl rounded-2xl p-1.5 gap-1.5 border border-white/10 shadow-2xl">
                <a href="/topics" class="flex items-center gap-2.5 px-6 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all text-sm font-bold group">
                   <svg class="w-4 h-4 text-emerald-400 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                   My Interests
                </a>
                <a href="/udemy-coupon-code" class="flex items-center gap-2.5 px-6 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all text-sm font-bold group">
                    <svg class="w-4 h-4 text-emerald-400 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    All Courses
                 </a>
                <div class="flex items-center gap-2.5 px-6 py-2.5 rounded-xl bg-emerald-500 text-white shadow-xl shadow-emerald-500/20 text-sm font-black border border-emerald-400/20">
                    {category}
                </div>
                <a href="/categories" class="flex items-center gap-2.5 px-6 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all text-sm font-bold group">
                   <svg class="w-4 h-4 text-emerald-400 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                   Free Courses
                </a>
            </div>
         </div>

         <!-- Controls Row -->
         <div class="flex flex-col md:flex-row items-center justify-between gap-6">
             
             <!-- Search Bar -->
             <div class="relative w-full md:w-96 group">
                <form action="/search" method="GET">
                    <input 
                    type="text" 
                    name="q"
                    placeholder={`Search in ${category}...`}
                    class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-emerald-500/50 transition-all font-sans text-sm shadow-inner backdrop-blur-md" 
                    />
                    <button type="submit" class="absolute right-3 top-3 text-emerald-400 hover:text-emerald-300 transition-colors bg-transparent border-none p-0 cursor-pointer">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    </button>
                </form>
             </div>

             <!-- Right Controls -->
             <div class="flex items-center gap-6">
                <!-- Grid/List Toggle -->
                <div class="flex items-center bg-white/5 rounded-xl p-1 border border-white/10 shadow-inner backdrop-blur-md">
                   <button class="p-2.5 rounded-lg bg-emerald-500 text-white shadow-lg shadow-emerald-500/20">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                   </button>
                   <button class="p-2.5 rounded-lg text-gray-400 hover:text-white transition-colors">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"/></svg>
                   </button>
                </div>

                <!-- Filters & Sort -->
                <div class="flex items-center gap-4">
                   <button class="flex items-center gap-2 text-white font-black text-xs uppercase tracking-widest bg-transparent hover:text-emerald-400 transition-colors">
                      Filters
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
                   </button>
                   <div class="h-4 w-px bg-white/10"></div>
                   <button class="flex items-center gap-2 text-white font-black text-xs uppercase tracking-widest bg-transparent hover:text-emerald-400 transition-colors">
                      Sort: Date
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                   </button>
                </div>
             </div>
         </div>

      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
      
      <!-- Course Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {allCourses.map((course: any) => (
           <CourseCard course={course} />
        ))}
      </div>

      <!-- Pagination -->
      <div class="flex justify-center mt-16 mb-20 relative z-10">
        <div class="flex items-center gap-2 bg-white/5 backdrop-blur-xl p-2 rounded-2xl border border-white/10 shadow-2xl">
             {page.url.prev ? (
                <a href={page.url.prev} class="px-6 h-12 flex items-center gap-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/10 transition-all text-sm font-black uppercase tracking-widest">
                    <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
                    Prev
                </a>
            ) : null}

             <span class="px-6 h-12 flex items-center font-black text-emerald-400 bg-white/5 rounded-xl border border-white/10 text-xs uppercase tracking-[0.2em] shadow-inner">
                Page {page.currentPage}
             </span>

            {page.url.next ? (
                <a href={page.url.next} class="px-6 h-12 flex items-center gap-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/10 transition-all text-sm font-black uppercase tracking-widest">
                    Next
                    <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7-7"/></svg>
                </a>
            ) : null}
        </div>
      </div>

    </div>
  </div>
</MainLayout>
