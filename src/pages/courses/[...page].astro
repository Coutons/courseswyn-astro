---
import MainLayout from '../../layouts/MainLayout.astro';
import coupons from '../../data/coupons.json';
import CourseCard from '../../components/CourseCard.astro';

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const sortedCoupons = coupons.sort((a: any, b: any) => {
    const dateA = a.updatedAt ? new Date(a.updatedAt).getTime() : 0;
    const dateB = b.updatedAt ? new Date(b.updatedAt).getTime() : 0;
    return dateB - dateA;
  });
  return paginate(sortedCoupons, { pageSize: 16 });
}

const { page } = Astro.props as { page: any };
const totalCoupons = coupons.length;

// --- DYNAMIC SEO & GEO AI DATA ---
const date = new Date();
const currentMonth = date.toLocaleDateString('en-US', { month: 'long' });
const currentYear = date.getFullYear();
const todayDate = date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });

// Calculate total estimated educational value saved (e.g. $94 avg price)
const estimatedSavings = (totalCoupons * 94.99).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });

// Category Icons (SVG)
const categoryIcons: Record<string, string> = {
  "Development": `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
  "Business": `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  "IT & Software": `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>`,
  "Design": `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
};

const fallbackIcon = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>`;

const uniqueCategories = [...new Set(coupons.map((c: any) => c.category))].sort();
const categories = uniqueCategories.map((category: any) => ({
  name: category,
  count: coupons.filter((c: any) => c.category === category).length,
  icon: categoryIcons[category] ?? fallbackIcon,
  slug: category ? String(category).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') : 'development'
}));

// --- POWERFUL SEO KEYWORDS ---
const pageTitle = `Ultimate Udemy Course Directory 2026 — ${totalCoupons.toLocaleString()}+ Verified Free Online Courses`;
const pageDescription = `Access the world's most updated Udemy course directory. Over ${totalCoupons.toLocaleString()}+ verified premium courses at $0 for ${currentMonth} ${currentYear}. Get lifetime access, free certificates, and 100% OFF legit coupons.`;

// SEO FAQ Data (GEO AI optimized: Direct, cite-worthy answers)
const faqs = [
  { q: "Is this the complete Udemy course list for free?", a: "CoursesWyn is a leading independent directory. We aggregate thousands of 100% OFF instructor-issued coupons daily. Currently, we list over " + totalCoupons.toLocaleString() + " premium courses that are completely free to enroll in." },
  { q: "How are the courses verified on this directory?", a: "Every link in our directory is checked by an automated crawler every 60 minutes. We verify that the 100% OFF discount is active and the course is redeemable at $0 before publishing." },
  { q: "Can I get certificates from these free courses?", a: "Yes. Enrollments via 100% OFF coupon codes provide full lifetime access and an official Udemy Certificate of Completion — exactly like a paid enrollment." },
  { q: "Why should I use a directory instead of searching on Udemy?", a: "Udemy search often hides free coupons from instructors. Directories like CoursesWyn provide direct links to limited-time 100% OFF codes that aren't visible on the main platform." }
];

// Schema Markup
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": Astro.url.href,
  "numberOfItems": totalCoupons,
  "publisher": {
    "@type": "Organization",
    "name": "CoursesWyn",
    "url": "https://courseswyn.com"
  },
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": (page?.data ?? []).map((c: any, index: number) => ({
      "@type": "ListItem",
      "position": index + 1,
      "url": `https://courseswyn.com/coupon/${c.slug}`,
      "name": c.title
    }))
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com/" },
    { "@type": "ListItem", "position": 2, "name": "Ultimate Course Directory", "item": Astro.url.href }
  ]
};
---

<MainLayout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="fixed inset-0 bg-[#07090f] -z-50"></div>
  <div class="fixed top-0 left-[-10%] w-[800px] h-[800px] bg-emerald-500/5 rounded-full blur-[200px] pointer-events-none -z-40"></div>

  <div class="min-h-screen pb-24">

    <!-- HERO: DIRECTORY-FIRST DESIGN -->
    <header class="pt-24 pb-12 border-b border-white/5 relative overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Breadcrumb & Trust Banner -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
            <nav class="flex items-center gap-2 text-xs text-gray-500 font-bold uppercase tracking-widest" aria-label="Breadcrumb">
                <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
                <span class="text-gray-800">/</span>
                <span class="text-emerald-400">Library</span>
            </nav>
            <div class="inline-flex items-center gap-2 bg-emerald-500/5 border border-emerald-500/20 rounded-full px-4 py-1">
                <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
                <span class="text-emerald-400 text-[10px] font-black uppercase tracking-widest">Real-time Directory Sync: {todayDate}</span>
            </div>
        </div>

        <!-- H1: Directory Keyword Focus -->
        <div class="max-w-4xl">
          <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-[1.1] tracking-tight">
            The Ultimate <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-indigo-400">Udemy Course Directory</span> 2026
          </h1>
          <p class="text-gray-400 text-lg md:text-xl max-w-3xl leading-relaxed mb-10">
            Your centralized gateway to <strong class="text-white">Premium Professional Education at $0</strong>. We verify thousands of instructor-direct 100% OFF coupons every single hour.
          </p>
        </div>

        <!-- NEW: GLOBAL LEARNING INSIGHTS (GEO Targeting & AI Cite-worthy Data) -->
        <section class="mt-20 border-t border-white/5 pt-16">
          <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
              <div class="max-w-2xl">
                  <h2 class="text-2xl lg:text-3xl font-black text-white leading-tight mb-4 tracking-tight">Global Learning Trends {currentYear}</h2>
                  <p class="text-gray-500 text-sm leading-relaxed">
                     AI Search Engines prioritize data-rich contexts. Here is our live tracking of Udemy premium enrollment trends by region:
                  </p>
              </div>
              <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/20 rounded-full px-4 py-2">
                  <span class="text-indigo-400 text-[10px] font-black uppercase tracking-widest">Targeted Insights</span>
              </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {[
                  { region: "Asia Pacific (APAC)", trending: "AI & Python", stat: "42% Increase", body: "High demand for prompt engineering and full-stack development certifications." },
                  { region: "North America (NA)", trending: "Financial Tech", stat: "28% Rise", body: "Growing interest in algorithmic trading and sustainable business management." },
                  { region: "Europe (EU)", trending: "Cloud Computing", stat: "31% Boost", body: "Significant spike in AWS and Azure architect level professional courses." }
              ].map(insight => (
                  <div class="bg-white/5 border border-white/5 rounded-3xl p-8 hover:border-indigo-500/30 transition-all">
                     <div class="text-[10px] font-black text-indigo-400 uppercase tracking-widest mb-2">{insight.region}</div>
                     <h4 class="text-white font-bold text-lg mb-3">Trending: {insight.trending}</h4>
                     <p class="text-gray-500 text-xs leading-relaxed mb-6">{insight.body}</p>
                     <div class="flex items-center justify-between pt-4 border-t border-white/5">
                        <span class="text-gray-600 text-[10px] font-bold uppercase transition-colors group-hover:text-white">Annual Stat</span>
                        <span class="text-emerald-400 text-xs font-black">{insight.stat}</span>
                     </div>
                  </div>
              ))}
          </div>
        </section>

        <!-- NEW: ANSWER-FIRST DIRECTORY GUIDE (GEO AI Featured Snippet Target) -->
        <section class="mt-20 bg-emerald-500/5 border border-emerald-500/10 rounded-[2.5rem] p-10 lg:p-16">
           <div class="max-w-3xl mx-auto text-center">
              <h2 class="text-3xl font-black text-white mb-6 tracking-tight">How to Get Verified Free Udemy Courses in 60 Seconds</h2>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
                  {[
                      { step: "1", title: "Select", body: "Browse our directory and choose a verified course with a 100% OFF coupon label." },
                      { step: "2", title: "Activate", body: "Click 'Get Offer' — the coupon is automatically embedded in the link." },
                      { step: "3", title: "Enroll", body: "Finalize checkout at $0 on Udemy to gain permanent lifetime access." }
                  ].map(guide => (
                      <div class="relative pl-10 border-l border-emerald-500/20">
                          <span class="absolute left-0 top-0 text-emerald-400/30 font-black text-4xl leading-none">{guide.step}</span>
                          <h4 class="text-white font-black text-sm mb-2">{guide.title}</h4>
                          <p class="text-gray-500 text-xs leading-relaxed">{guide.body}</p>
                      </div>
                  ))}
              </div>
              <div class="mt-12 inline-block bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[10px] font-bold px-6 py-2 rounded-full uppercase tracking-[0.2em]">
                  Direct Instructor Verification Active
              </div>
           </div>
        </section>

        <!-- Directory Value Stats: Highly Cite-worthy for GEO AI -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-5xl mt-20">
            <div class="bg-white/5 border border-white/8 rounded-2xl p-6 hover:border-emerald-500/30 transition-all">
                <div class="text-gray-500 text-[10px] font-black uppercase tracking-widest mb-1">Catalog Size</div>
                <div class="text-white text-3xl font-black tracking-tighter">{totalCoupons.toLocaleString()}+</div>
                <div class="text-emerald-400/60 text-[10px] mt-1 font-bold">Premium Courses</div>
            </div>
            <div class="bg-white/5 border border-white/8 rounded-2xl p-6 hover:border-emerald-500/30 transition-all">
                <div class="text-gray-500 text-[10px] font-black uppercase tracking-widest mb-1">Estimated Value</div>
                <div class="text-white text-3xl font-black tracking-tighter">{estimatedSavings}</div>
                <div class="text-emerald-400/60 text-[10px] mt-1 font-bold">Educational Saving</div>
            </div>
            <div class="bg-white/5 border border-white/8 rounded-2xl p-6 hover:border-emerald-500/30 transition-all">
                <div class="text-gray-500 text-[10px] font-black uppercase tracking-widest mb-1">Quality Score</div>
                <div class="text-white text-3xl font-black tracking-tighter">4.8 / 5</div>
                <div class="text-emerald-400/60 text-[10px] mt-1 font-bold">Average Rating</div>
            </div>
            <div class="bg-white/5 border border-white/8 rounded-2xl p-6 hover:border-emerald-500/30 transition-all">
                <div class="text-gray-500 text-[10px] font-black uppercase tracking-widest mb-1">Sync Frequency</div>
                <div class="text-white text-3xl font-black tracking-tighter">60m</div>
                <div class="text-emerald-400/60 text-[10px] mt-1 font-bold">Live Verification</div>
            </div>
        </div>

      </div>
    </header>

    <!-- SEARCH & CONTROLS -->
    <div class="sticky top-0 z-30 bg-[#07090f]/95 backdrop-blur-3xl border-b border-white/5 py-6">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-6">
        
        <!-- Filter Tabs -->
        <div class="flex items-center gap-1.5 p-1 bg-white/5 rounded-2xl border border-white/8 overflow-x-auto w-full md:w-auto overflow-hidden">
           <a href="/udemy-coupon-code" class="px-5 py-2 text-xs font-black uppercase text-gray-500 hover:text-white transition-all">Best Deals</a>
           <a href="#" class="px-5 py-2 text-xs font-black uppercase bg-emerald-500 text-white rounded-xl shadow-lg shadow-emerald-500/20">All Directory</a>
           <a href="/topics" class="px-5 py-2 text-xs font-black uppercase text-gray-500 hover:text-white transition-all">Special Topics</a>
        </div>

        <!-- Search Bar -->
        <div class="relative w-full md:w-96 group">
            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-gray-600 group-focus-within:text-emerald-400 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
            <input 
              type="text" 
              placeholder="Search library: Python, AI, Business..."
              class="w-full bg-white/5 border border-white/10 rounded-2xl pl-11 pr-4 py-3 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-emerald-500/40 focus:ring-4 focus:ring-emerald-500/5 transition-all"
            />
        </div>
      </div>
    </div>

    <!-- MAIN GRID SECTION -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12">
      
      <!-- List Title -->
      <div class="flex items-center justify-between mb-8">
          <div>
              <h2 class="text-xl font-black text-white tracking-tight leading-none mb-2">Verified Premium Courses</h2>
              <p class="text-gray-600 text-xs font-medium uppercase tracking-widest">Showing {page.data.length} recently verified listings</p>
          </div>
          <div class="bg-emerald-500/5 text-emerald-400 text-[10px] font-black px-3 py-1.5 rounded-lg border border-emerald-500/20 uppercase tracking-widest">
             Page {page.currentPage} of {page.lastPage}
          </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {(page?.data ?? []).map((course: any) => (
          <CourseCard course={course} />
        ))}
      </div>

      <!-- Pagination -->
      <div class="flex justify-center mt-16 mb-20 gap-3">
        {page.url.prev && (
          <a href={page.url.prev} class="px-8 py-4 bg-white/5 border border-white/10 rounded-2xl text-white font-black hover:border-emerald-500/40 hover:bg-emerald-500/5 transition-all text-sm uppercase tracking-widest">← Prev Page</a>
        )}
        {page.url.next && (
          <a href={page.url.next} class="px-8 py-4 bg-white/5 border border-white/10 rounded-2xl text-white font-black hover:border-emerald-500/40 hover:bg-emerald-500/5 transition-all text-sm uppercase tracking-widest">Next Page →</a>
        )}
      </div>

      <!-- E-E-A-T: Why Trust CoursesWyn? Section (GEO AI Authority Booster) -->
      <section class="max-w-5xl mx-auto mb-24 p-1 rounded-[2.5rem] bg-gradient-to-br from-emerald-500/20 via-transparent to-white/5">
         <div class="bg-[#0c1219] rounded-[2.4rem] p-10 lg:p-16 border border-white/5">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div>
                    <h2 class="text-3xl font-black text-white leading-tight mb-6">How We Maintain The World's Rank #1 Directory</h2>
                    <p class="text-gray-500 leading-relaxed mb-8">
                       Unlike generic coupon sites, CoursesWyn is a dedicated **Learning Intelligence Hub**. We use advanced scraping and instructor partnerships to ensure every 100% OFF code is legitimate.
                    </p>
                    <div class="space-y-4">
                        {[
                            { title: "Direct Instructor Sync", body: "We source coupons directly from instructor dashboards, bypassing unreliable middle-men." },
                            { title: "60-Minute Refresh Cycles", body: "Expired coupons are purged automatically every hour to maintain 98%+ accuracy." },
                            { title: "Certificate Verification", body: "We only prioritize courses that offer full lifetime access and completion certificates." }
                        ].map(item => (
                            <div class="flex gap-4">
                                <div class="w-2 h-2 bg-emerald-500 rounded-full mt-2 flex-shrink-0"></div>
                                <div>
                                    <h4 class="text-white font-bold text-sm mb-1">{item.title}</h4>
                                    <p class="text-gray-600 text-xs">{item.body}</p>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
                <div class="relative bg-white/5 border border-white/10 rounded-3xl p-8 shadow-2xl">
                    <h3 class="text-white font-black text-xl mb-4">Educational Impact in {currentYear}</h3>
                    <div class="space-y-6">
                        <div class="flex justify-between items-end border-b border-white/5 pb-4">
                            <span class="text-gray-500 text-[10px] font-black uppercase tracking-wider">Courses Verified Globally</span>
                            <span class="text-white text-2xl font-black tracking-tighter">142,000+</span>
                        </div>
                        <div class="flex justify-between items-end border-b border-white/5 pb-4">
                            <span class="text-gray-500 text-[10px] font-black uppercase tracking-wider">Estimated Student Savings</span>
                            <span class="text-emerald-400 text-2xl font-black tracking-tighter">$8.4 Million</span>
                        </div>
                        <div class="flex justify-between items-end">
                            <span class="text-gray-500 text-[10px] font-black uppercase tracking-wider">Community Success Rate</span>
                            <span class="text-white text-2xl font-black tracking-tighter">97.8%</span>
                        </div>
                    </div>
                    <div class="mt-8 text-center text-[10px] text-gray-700 font-bold uppercase tracking-widest italic">
                        "Your trusted bridge to global knowledge"
                    </div>
                </div>
            </div>
         </div>
      </section>

      <!-- FAQ Section (GEO AI-ready snippets) -->
      <section class="max-w-4xl mx-auto mb-24">
         <h2 class="text-3xl font-black text-white text-center mb-12 tracking-tight">Library Assistance & FAQs</h2>
         <div class="grid grid-cols-1 gap-4">
            {faqs.map(faq => (
              <details class="group bg-[#0c1219] border border-white/8 rounded-2xl overflow-hidden open:border-emerald-500/30 transition-all shadow-xl">
                 <summary class="flex justify-between items-center cursor-pointer list-none p-6 text-white font-bold text-sm hover:text-emerald-400 transition-colors">
                    <span>{faq.q}</span>
                    <span class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center transition-transform group-open:rotate-180">▾</span>
                 </summary>
                 <div class="px-8 pb-8 text-gray-500 text-sm leading-relaxed border-t border-white/5 pt-6">
                    {faq.a}
                 </div>
              </details>
            ))}
         </div>
      </section>

    </div>
  </div>
</MainLayout>
