---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getDeals } from '../../lib/store.js';
import { formatDateWIB } from '../../lib/date';

const allDeals = await getDeals();
const now = new Date();
const activeDeals = allDeals.filter(d => !d.expiresAt || new Date(d.expiresAt) > now);

function timeLeft(expiresAt: string): string {
  const diff = new Date(expiresAt).getTime() - now.getTime();
  if (diff <= 0) return 'Expired';
  const hours = Math.floor(diff / 3600000);
  const days = Math.floor(hours / 24);
  if (days > 0) return `${days}d left`;
  if (hours > 0) return `${hours}h left`;
  return '&lt;1h left';
}

const paidDeals = activeDeals.filter(d => d.price > 0 || d.price == null).slice(0, 48);
const freeDeals = activeDeals.filter(d => d.price === 0);
const totalCoupons = allDeals.length;
const totalActive = activeDeals.length;
const totalFree = freeDeals.length;

const dateFull = formatDateWIB(now, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

const latestUpdate = allDeals.reduce((latest, d) => {
  const t = new Date(d.updatedAt || d.createdAt || 0).getTime();
  return t > latest ? t : latest;
}, 0);
const diffMs = now.getTime() - latestUpdate;
const diffMin = Math.floor(diffMs / 60000);
let lastVerified;
if (diffMin < 1) lastVerified = 'Just now';
else if (diffMin < 60) lastVerified = `${diffMin}m ago`;
else {
  const diffHr = Math.floor(diffMin / 60);
  lastVerified = diffHr < 24 ? `${diffHr}h ago` : `${Math.floor(diffHr / 24)}d ago`;
}

const almostGone = allDeals
  .filter(d => d.expiresAt)
  .filter(d => {
    const diff = new Date(d.expiresAt!).getTime() - now.getTime();
    return diff > 0 && diff < 7 * 24 * 3600000;
  })
  .sort((a, b) => new Date(a.expiresAt!).getTime() - new Date(b.expiresAt!).getTime())
  .slice(0, 4);

const popularDeals = allDeals
  .filter(d => (d.rating ?? 0) >= 4.5)
  .slice(0, 8);

function mapCard(d: typeof allDeals[0]) {
  const students = d.students ? d.students.toLocaleString() : null;
  const instructor = d.instructor || null;
  const expiry = d.expiresAt ? timeLeft(d.expiresAt) : null;
  let discount: string;
  if (d.price === 0) {
    discount = 'FREE';
  } else if (d.originalPrice && d.originalPrice > 0 && d.price != null) {
    const pct = Math.round((1 - d.price / d.originalPrice) * 100);
    discount = `${pct}% OFF`;
  } else {
    discount = null as any;
  }
  return {
    slug: d.slug || d.id,
    image: d.image,
    title: d.title,
    students,
    instructor: typeof instructor === 'string' ? instructor.split(',')[0].trim() : null,
    expiry,
    discount
  };
}

const goneCards = almostGone.map(mapCard);
const paidCards = paidDeals.map(mapCard);
const popularCards = popularDeals.map(mapCard);

const paidCount = paidDeals.length;

const siteUrl = "https://courseswyn.com";
const pageUrl = `${siteUrl}/udemy-coupons-today/`;
const monthYear = formatDateWIB(now, { month: 'long', year: 'numeric' });
const pageTitle = `100% Off Udemy Coupons Today - ${monthYear} | CoursesWyn`;
const metaDescription = `${totalActive} verified 100% off Udemy coupons for ${dateFull}. ${totalFree} new free courses added today in Development, Design, Business & more. Updated in real time.`;

const topicCounts: Record<string, number> = {};
for (const d of allDeals) {
  topicCounts[d.category || 'Other'] = (topicCounts[d.category || 'Other'] || 0) + 1;
}
const trendingTopics = Object.entries(topicCounts).sort((a, b) => b[1] - a[1]).slice(0, 12);

function slugify(s: string) {
  return s.toLowerCase().replace(/\s+&\s+/g, '-and-').replace(/['\s]+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
}

const faqs = [
  { q: "Are these Udemy coupons really free?", a: "Yes. Every coupon listed gives 100% off the course price. We verify each code before publishing. No credit card or subscription required — click through to Udemy and enroll for free." },
  { q: "How long do these Udemy coupons last?", a: "Udemy coupons typically expire within a few days or run out of redemptions. We recommend enrolling as soon as you find a course you want. If a code has expired, check our main deals page for the latest listings." },
  { q: "How do I redeem a Udemy coupon?", a: "Click the course card to open its deal page on CoursesWyn, then click the coupon or 'Get deal' button. You'll be taken to Udemy with the discount applied. Complete enrollment there — no payment required for 100% off coupons." },
  { q: "What categories are available today?", a: `This page lists coupons across multiple categories including ${trendingTopics.slice(0, 3).map(([t]) => t).join(', ')} and more. Courses are grouped so you can quickly find deals in your area of interest.` },
  { q: "Do I get a certificate with free Udemy courses?", a: "Yes. Courses enrolled via our coupons include lifetime access, downloadable resources, and an official Udemy completion certificate when you finish the course." },
  { q: "How often are new coupons added?", a: "New coupons are added throughout the day as instructors publish them. We check Udemy in near real time and update this list automatically, so checking back every few hours will show fresh deals." },
  { q: "Why did Udemy change its coupon policy?", a: `In 2025 Udemy updated its free coupon policy to improve course quality. Most coupons are now limited to 10-100 redemptions. Read more on <a href="https://teach.udemy.com/update-for-instructors-improving-free-coupons-better-targeting-higher-quality-learning/" rel="noopener" target="_blank">Udemy's instructor blog</a>.` },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": pageTitle,
      "description": metaDescription,
      "dateModified": new Date(latestUpdate).toISOString(),
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Today's Coupons", "item": pageUrl },
      ],
    },
    {
      "@type": "ItemList",
      "name": "Today's 100% Off Udemy Coupons",
      "description": metaDescription,
      "numberOfItems": totalActive,
      "itemListElement": allDeals.slice(0, 20).map((d, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": `${siteUrl}/coupon/${d.slug || d.id}`,
        "name": d.title,
      })),
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    },
  ],
};
---

<Layout title={pageTitle} description={metaDescription} canonical={pageUrl} hideBreadcrumbs={true}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <main class="daily-root">
    <div class="daily-container">

      <nav class="daily-breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li aria-hidden="true">/</li>
          <li>Today's Coupons</li>
        </ol>
      </nav>

      <header class="daily-header">
        <div class="daily-header-text">
          <h1 class="daily-title">Today's 100% Off Udemy Coupons</h1>
          <p class="daily-subtitle">{dateFull} &mdash; every coupon below was added in the last 24 hours and is re-verified in near real time. Coupons usually expire within a day or run out of redemptions, so the freshest ones are listed first.</p>
        </div>
        <div class="daily-stats">
          <div class="stat-item">
            <span class="stat-label">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
              Coupons added (24h)
            </span>
            <span class="stat-value">{totalCoupons}</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
              Still active now
            </span>
            <span class="stat-value">{totalActive}</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v14"/><path d="M20 11v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8"/><path d="M7.5 7a1 1 0 0 1 0-5A4.8 8 0 0 1 12 7a4.8 8 0 0 1 4.5-5 1 1 0 0 1 0 5"/><rect x="3" y="7" width="18" height="4" rx="1"/></svg>
              New free courses (24h)
            </span>
            <span class="stat-value">{totalFree}</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              Last verification
            </span>
            <span class="stat-value">{lastVerified}</span>
          </div>
        </div>
      </header>

      {goneCards.length > 0 && (
        <section class="daily-section">
          <h2 class="section-title">
            <svg class="section-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Almost gone
          </h2>
          <p class="section-desc">These coupons expire soon &mdash; enroll now before they run out.</p>
          <div class="card-grid card-grid-4">
            {goneCards.map(deal => (
              <a href={`/coupon/${deal.slug}`} class="deal-card">
                <div class="deal-img">
                  <Image src={deal.image} alt={deal.title} width={400} height={225} loading="eager" inferSize={false} />
                  <div class="deal-badges">
                    {deal.discount && <span class="badge-off">{deal.discount}</span>}
                  </div>
                  {deal.expiry && <div class="deal-badges-right"><span class="badge-expiry"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>{deal.expiry}</span></div>}
                </div>
                <div class="deal-body">
                  <h3 class="deal-title">{deal.title}</h3>
                  <p class="deal-instructor">{deal.instructor}</p>
                  <p class="deal-students">{deal.students} enrolled</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <section class="daily-section">
        <h2 class="section-title">
          <svg class="section-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          Latest coupons
        </h2>
        <p class="section-desc">The most recent {paidCount} verified 100% off deals.</p>
        <div class="card-grid card-grid-4">
          {paidCards.map(deal => (
            <a href={`/coupon/${deal.slug}`} class="deal-card">
              <div class="deal-img">
                <Image src={deal.image} alt={deal.title} width={400} height={225} loading="lazy" inferSize={false} />
                <div class="deal-badges">
                  {deal.discount && <span class="badge-off">{deal.discount}</span>}
                </div>
                {deal.expiry && <div class="deal-badges-right"><span class="badge-expiry"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>{deal.expiry}</span></div>}
              </div>
              <div class="deal-body">
                <h3 class="deal-title">{deal.title}</h3>
                {deal.instructor && <p class="deal-instructor">{deal.instructor}</p>}
              </div>
            </a>
          ))}
        </div>
        <p class="browse-all">Showing the {paidCount} most recent of {totalActive} active coupons &mdash; <a href="/udemy-coupon-code">browse them all</a>.</p>
      </section>

      {popularCards.length > 0 && (
        <section class="daily-section">
          <h2 class="section-title">
            <svg class="section-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            Popular deals
          </h2>
          <p class="section-desc">Top-rated courses with the highest student reviews.</p>
          <div class="card-grid card-grid-4">
            {popularCards.map(deal => (
              <a href={`/coupon/${deal.slug}`} class="deal-card">
                <div class="deal-img">
                  <Image src={deal.image} alt={deal.title} width={400} height={225} loading="lazy" inferSize={false} />
                  <div class="deal-badges">
                    {deal.discount && <span class="badge-off">{deal.discount}</span>}
                  </div>
                  {deal.expiry && <div class="deal-badges-right"><span class="badge-expiry"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>{deal.expiry}</span></div>}
                </div>
                <div class="deal-body">
                  <h3 class="deal-title">{deal.title}</h3>
                  <p class="deal-instructor">{deal.instructor}</p>
                  <p class="deal-students">{deal.students} enrolled</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <section class="daily-section">
        <h2 class="section-title">
          <svg class="section-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
          Trending topics
        </h2>
        <p class="section-desc">Most popular categories among today's coupons.</p>
        <div class="topic-list">
          {trendingTopics.map(([topic, count]) => (
            <a href={`/categories/${slugify(topic)}/`} class="topic-tag">
              <span>{topic}</span>
              <span class="topic-count">{count}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="seo-section">
        <h2>How CoursesWyn verifies Udemy coupons</h2>
        <p>Since <a href="https://teach.udemy.com/update-for-instructors-improving-free-coupons-better-targeting-higher-quality-learning/" rel="noopener" target="_blank">Udemy's free coupon policy update</a>, most coupons are limited to about 10 to 100 redemptions or expire within days, which is why so many coupon sites list codes that no longer work. CoursesWyn checks every coupon against Udemy in near real time. When a coupon runs out, it disappears from this list automatically.</p>
        <p>New coupons are added throughout the day. Browse <a href="/udemy-coupon-code">all verified coupons</a> or explore <a href="/udemy-coupons-today">today's latest deals</a>.</p>
      </section>

      <section class="daily-faq">
        <h2 class="section-title">
          <svg class="section-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Frequently asked questions
        </h2>
        {faqs.map(faq => (
          <details class="faq-item">
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </section>

    </div>
  </main>
</Layout>

<style>
  .daily-root { background: var(--bg); padding: 2rem 1rem 4rem; }
  .daily-container { max-width: 960px; margin: 0 auto; }

  .daily-header { display: grid; grid-template-columns: 1fr 260px; gap: 2rem; margin-bottom: 2rem; align-items: start; }
  .daily-header-text { padding-top: 0.25rem; }
  .daily-title { font-size: 2rem; font-weight: 900; color: var(--text); margin: 0 0 0.75rem; letter-spacing: -0.03em; }
  .daily-subtitle { font-size: 0.92rem; color: var(--muted); line-height: 1.65; }

  .daily-breadcrumb { display: flex; justify-content: center; margin-bottom: 1rem; }
  .daily-breadcrumb ol { list-style: none; display: flex; align-items: center; gap: 0.5rem; padding: 0; margin: 0; font-size: 0.8rem; color: var(--muted); }
  .daily-breadcrumb li:not(:last-child)::after { content: '/'; margin-left: 0.5rem; color: var(--border); }
  .daily-breadcrumb a { color: var(--brand); text-decoration: none; }
  .daily-breadcrumb a:hover { text-decoration: underline; }

  .daily-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
  .stat-item { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.35rem; min-height: 74px; border: 1px solid var(--border); border-radius: 10px; background: var(--card); padding: 0.75rem 1rem; text-align: center; }
  .stat-label { display: flex; align-items: center; justify-content: center; gap: 0.35rem; font-size: 0.7rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.03em; }
  .stat-label svg { width: 14px; height: 14px; flex-shrink: 0; }
  .stat-value { font-size: 1.1rem; font-weight: 700; color: var(--text); }

  .daily-section { margin-bottom: 2.5rem; }
  .section-title { font-size: 1.2rem; font-weight: 800; color: var(--text); margin: 0 0 0.25rem; display: flex; align-items: center; gap: 0.65rem; }
  .section-icon { color: var(--brand); flex-shrink: 0; }
  .section-desc { font-size: 0.85rem; color: var(--muted); margin: 0 0 1rem; }

  .card-grid { display: grid; gap: 0.85rem; }
  .card-grid-4 { grid-template-columns: repeat(4, 1fr); }

  .deal-card { display: block; background: var(--card); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; text-decoration: none; transition: all 0.2s; }
  .deal-card:hover { border-color: var(--brand); transform: translateY(-2px); }
  .deal-img { position: relative; width: 100%; aspect-ratio: 16/9; overflow: hidden; background: var(--border); }
  .deal-img img { width: 100%; height: 100%; object-fit: cover; }
  .deal-badges { position: absolute; top: 6px; left: 6px; display: flex; gap: 3px; }
  .deal-badges-right { position: absolute; top: 6px; right: 6px; display: flex; gap: 3px; }
  .badge-off { background: linear-gradient(135deg, var(--brand), #1d4ed8); color: white; font-size: 0.65rem; font-weight: 800; padding: 2px 7px; border-radius: 3px; }
  .badge-expiry { background: rgba(220,38,38,0.85); backdrop-filter: blur(4px); color: white; font-size: 0.6rem; font-weight: 700; padding: 2px 7px; border-radius: 3px; display: inline-flex; align-items: center; gap: 3px; }
  .deal-body { padding: 0.65rem; }
  .deal-title { font-size: 0.82rem; font-weight: 600; color: var(--text); margin: 0 0 0.15rem; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .deal-card:hover .deal-title { color: var(--brand); }
  .deal-instructor { font-size: 0.7rem; color: var(--muted); margin: 0 0 0.2rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .deal-students { font-size: 0.7rem; color: var(--muted); margin: 0; }

  .topic-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .topic-tag { display: inline-flex; align-items: center; gap: 6px; padding: 7px 16px; border-radius: 100px; border: 1px solid var(--border); font-size: 0.85rem; font-weight: 600; color: var(--text); text-decoration: none; transition: all 0.2s; background: var(--card); }
  .topic-tag:hover { border-color: var(--brand); color: var(--brand); background: color-mix(in srgb, var(--brand) 6%, var(--card)); }
  .topic-count { font-size: 0.7rem; font-weight: 700; color: white; background: var(--brand); padding: 1px 7px; border-radius: 100px; min-width: 20px; text-align: center; line-height: 1.5; }

  .seo-section { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; }
  .seo-section h2 { font-size: 1.1rem; font-weight: 700; color: var(--text); margin: 0 0 0.75rem; }
  .seo-section p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; margin: 0 0 0.75rem; }
  .seo-section p:last-child { margin-bottom: 0; }
  .seo-section a { color: var(--brand); text-decoration: none; font-weight: 600; }
  .seo-section a:hover { text-decoration: underline; }

  .browse-all { margin-top: 1rem; font-size: 0.85rem; color: var(--muted); text-align: center; }
  .browse-all a { color: var(--brand); text-decoration: none; font-weight: 600; }
  .browse-all a:hover { text-decoration: underline; }

  .daily-faq { margin-bottom: 2rem; }
  .daily-faq .faq-item {
    background: var(--card); border: 1px solid var(--border); border-radius: 10px;
    padding: 0.85rem 1rem; margin-bottom: 0.5rem;
  }
  .daily-faq .faq-item summary {
    font-size: 0.9rem; font-weight: 600; color: var(--text); cursor: pointer;
  }
  .daily-faq .faq-item p {
    font-size: 0.85rem; color: var(--muted); line-height: 1.5; margin: 0.5rem 0 0;
  }
  .daily-faq .faq-item a { color: var(--brand); text-decoration: none; font-weight: 600; }
  .daily-faq .faq-item a:hover { text-decoration: underline; }

  @media (max-width: 768px) {
    .daily-title { font-size: 1.5rem; }
    .daily-container { max-width: 100%; }
    .daily-header { grid-template-columns: 1fr; gap: 1rem; }
    .daily-stats { max-width: 280px; }
    .card-grid-4 { grid-template-columns: repeat(2, 1fr); gap: 0.65rem; }
    .stat-item { min-width: 100px; padding: 0.75rem 1rem; }
    .stat-value { font-size: 1.25rem; }
  }
</style>