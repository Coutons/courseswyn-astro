---
import Layout from '../../layouts/Layout.astro';
import { getDeals, getAvailableDates } from '../../lib/store.js';
import { formatDateWIB } from '../../lib/date';

const dates = await getAvailableDates();
const latestDate = dates[0]?.date;
const latestDeals = await getDeals({ date: latestDate, sortBy: 'rating' });
const latestCount = latestDeals.length;

const siteUrl = "https://courseswyn.com";
const pageUrl = `${siteUrl}/udemy-coupons-today/`;

const pageTitle = "Udemy Coupons Today - Daily Verified Discount Codes | CoursesWyn";
const metaDescription = "Browse daily updated Udemy coupons. Get 100% off deals and verified free courses updated every single day. Professional development, design, and business courses.";

function formatDateLabel(dateStr: string) {
  const dateObj = new Date(`${dateStr}T00:00:00.000Z`);
  return formatDateWIB(dateObj, { year: 'numeric', month: 'long', day: 'numeric' });
}

function slugifyCat(cat: string) {
  return cat.toLowerCase().replace(/\s+&\s+/g, '-and-').replace(/\s+/g, '-');
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": pageTitle,
      "description": metaDescription,
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` }
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Udemy Coupons Today", "item": pageUrl }
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={metaDescription} canonical={pageUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <main class="archive-root">
    <div class="container">
      <header class="archive-header">
        <h1 class="archive-title">Udemy Coupons Today</h1>
        <p class="archive-desc">
          We track and verify 100% off Udemy coupons every single day. 
          Browse our daily updates below to find premium courses for free.
        </p>
      </header>

      {latestDate && (
        <section class="latest-section">
          <div class="latest-banner">
            <div class="latest-banner-body">
              <span class="latest-badge">New Update</span>
              <h2 class="latest-heading">Latest Update: {formatDateLabel(latestDate)}</h2>
              <p class="latest-sub">
                {latestCount} verified free Udemy coupons added today. 
                Hand-picked and tested — grab them before they expire.
              </p>
              <div class="latest-meta">
                <span>{latestCount} Free Courses</span>
                <span>100% Off</span>
                <span>Verified</span>
              </div>
              <a href={`/udemy-coupon-today/${latestDate}/`} class="latest-btn">
                Browse All {formatDateLabel(latestDate)} Deals →
              </a>
            </div>
          </div>
        </section>
      )}

      <section class="history-section">
        <h2>Daily Coupon Archives</h2>
        <p class="history-desc">Browse verified coupons from previous days. Most coupons remain valid for 2-3 days.</p>
        
        <div class="date-grid">
          {dates.map((item, index) => (
            <div class={`date-card ${index === 0 ? 'date-card-new' : ''}`}>
              <div class="date-image">
                {item.image ? (
                  <img src={item.image} alt={`Udemy Coupons for ${item.date}`} loading="lazy" />
                ) : (
                  <div class="date-placeholder">📅</div>
                )}
                <div class="date-badge">{item.date}</div>
                {index === 0 && <span class="new-tag">New Update</span>}
              </div>
              <div class="date-body">
                <h3 class="date-title">Udemy Coupons Today: {formatDateLabel(item.date)}</h3>
                <p class="date-desc">
                  Browse verified 100% off Udemy courses for {formatDateLabel(item.date)}. Verified and ready to redeem.
                </p>
                <a href={`/udemy-coupons-today/${item.date}/`} class="date-btn">
                  View Coupons →
                </a>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="info-section">
        <div class="info-card">
          <h3>How Our Daily Updates Work</h3>
          <p>
            Every day, our team scours instructor networks and official Udemy channels to find the latest 100% off coupons. 
            These coupons are official promotions used by instructors to build their student base. 
            We verify each one manually before adding it to our daily archive.
          </p>
          <div class="info-grid">
            <div class="info-item">
              <span class="info-icon">🕒</span>
              <h4>Updated 24/7</h4>
              <p>We add new courses as soon as they become available.</p>
            </div>
            <div class="info-item">
              <span class="info-icon">✅</span>
              <h4>100% Verified</h4>
              <p>All coupons are tested to ensure they provide a full discount.</p>
            </div>
            <div class="info-item">
              <span class="info-icon">🎓</span>
              <h4>Full Access</h4>
              <p>Get lifetime access and certificates of completion for free.</p>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .archive-root { background: var(--bg); padding: 4rem 0; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  
  .archive-header { text-align: center; margin-bottom: 4rem; }
  .archive-title { font-size: 3rem; font-weight: 900; color: var(--text); letter-spacing: -0.05em; margin-bottom: 1rem; }
  .archive-desc { font-size: 1.25rem; color: var(--muted); max-width: 700px; margin: 0 auto; line-height: 1.6; }

  .latest-section { margin-bottom: 5rem; }
  .latest-banner { background: linear-gradient(135deg, var(--brand) 0%, #ea580c 100%); border-radius: 24px; overflow: hidden; position: relative; }
  .latest-banner::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 80% 20%, rgba(255,255,255,0.15) 0%, transparent 60%); }
  .latest-banner-body { position: relative; padding: 3rem; text-align: center; }
  .latest-badge { display: inline-block; background: rgba(255,255,255,0.2); color: white; font-size: 0.7rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.08em; padding: 4px 14px; border-radius: 99px; margin-bottom: 1rem; backdrop-filter: blur(4px); }
  .latest-heading { font-size: 2rem; font-weight: 900; color: white; margin: 0 0 0.75rem; letter-spacing: -0.02em; }
  .latest-sub { color: rgba(255,255,255,0.85); font-size: 1.05rem; line-height: 1.6; max-width: 600px; margin: 0 auto 1.5rem; }
  .latest-meta { display: flex; justify-content: center; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 2rem; }
  .latest-meta span { color: rgba(255,255,255,0.9); font-size: 0.85rem; font-weight: 700; background: rgba(255,255,255,0.1); padding: 4px 14px; border-radius: 99px; backdrop-filter: blur(4px); }
  .latest-btn { display: inline-flex; align-items: center; gap: 0.5rem; background: white; color: var(--brand); text-decoration: none; font-weight: 800; font-size: 1rem; padding: 1rem 2rem; border-radius: 16px; transition: all 0.3s; box-shadow: 0 4px 16px rgba(0,0,0,0.15); }
  .latest-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); }

  .history-section { margin-bottom: 5rem; }
  .history-section h2 { font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem; }
  .history-desc { color: var(--muted); margin-bottom: 2rem; font-size: 1.125rem; }

  .date-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 2.5rem; }
  .date-card { background: var(--card); border: 1px solid var(--border); border-radius: 28px; overflow: hidden; display: flex; flex-direction: column; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }
  .date-card:hover { border-color: var(--brand); transform: translateY(-12px); box-shadow: 0 25px 50px -12px var(--brand-soft); }
  .date-card-new { border: 2.5px solid var(--brand); }
  .date-image { height: 210px; width: 100%; position: relative; background: var(--border); overflow: hidden; }
  .date-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
  .date-card:hover .date-image img { transform: scale(1.1); }
  .date-badge { position: absolute; bottom: 12px; right: 12px; background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(8px); color: white; padding: 4px 12px; border-radius: 99px; font-size: 0.75rem; font-weight: 700; border: 1px solid rgba(255, 255, 255, 0.2); }
  .date-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 4rem; background: var(--bg); }
  .date-body { padding: 2rem; display: flex; flex-direction: column; flex: 1; text-align: center; }
  .date-title { font-size: 1.5rem; font-weight: 900; color: var(--text); margin: 0 0 1rem; line-height: 1.2; letter-spacing: -0.02em; }
  .date-desc { font-size: 0.9375rem; color: var(--muted); line-height: 1.5; margin: 0 0 1.5rem; flex: 1; }
  .date-btn { display: block; text-align: center; background: var(--brand); color: var(--bg); text-decoration: none; font-weight: 800; font-size: 1rem; padding: 1rem; border-radius: 16px; transition: all 0.3s; box-shadow: 0 4px 12px var(--brand-soft); }
  .date-btn:hover { filter: brightness(1.1); transform: scale(1.02); }
  .new-tag { position: absolute; top: 12px; left: 12px; background: #ef4444; color: #fff; font-size: 0.7rem; font-weight: 900; text-transform: uppercase; padding: 4px 12px; border-radius: 8px; z-index: 10; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4); }

  .info-section { margin-top: 6rem; }
  .info-card { background: var(--bg-secondary); color: var(--text); padding: 3rem; border-radius: 32px; text-align: center; }
  .info-card h3 { font-size: 2rem; font-weight: 800; margin-bottom: 1rem; }
  .info-card p { font-size: 1.125rem; color: var(--muted); max-width: 800px; margin: 0 auto 3rem; line-height: 1.6; }
  .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; }
  .info-item { display: flex; flex-direction: column; align-items: center; }
  .info-icon { font-size: 2rem; margin-bottom: 1rem; }
  .info-item h4 { font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem; }
  .info-item p { font-size: 0.875rem; color: var(--muted); margin: 0; }

  @media (max-width: 768px) {
    .archive-title { font-size: 2.25rem; }
    .archive-desc { font-size: 1.125rem; }
    .latest-section { padding: 1.5rem; }
    .info-card { padding: 2rem 1.5rem; }
  }
</style>
