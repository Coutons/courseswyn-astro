      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════
       CLIENT-SIDE SCRIPTS
       1. Dynamic real countdown timer
       2. Copy coupon with proper visual feedback
  ════════════════════════════════════════ -->
  <script>
    // ── 1. COUNTDOWN TIMER ──────────────────────────────────────
    (function () {
      const el = document.getElementById('countdown-timer');
      if (!el) return;

      const target = new Date((el as HTMLElement).dataset.target as string).getTime();

      function pad(n: number): string { return String(n).padStart(2, '0'); }

      function tick(): void {
        const diff = target - Date.now();
        if (diff <= 0) {
          el.querySelectorAll('[data-unit]').forEach(s => (s.textContent = '00'));
          return;
        }
        const days    = Math.floor(diff / 86_400_000);
        const hours   = Math.floor((diff % 86_400_000) / 3_600_000);
        const minutes = Math.floor((diff % 3_600_000) / 60_000);
        const seconds = Math.floor((diff % 60_000) / 1_000);

        const map: Record<string, string> = {
          days: pad(days), hrs: pad(hours), min: pad(minutes), sec: pad(seconds),
        };
        el.querySelectorAll('[data-unit]').forEach(span => {
          const unit = (span as HTMLElement).dataset.unit as string;
          if (map[unit] !== undefined) span.textContent = map[unit];
        });
      }

      tick();
      setInterval(tick, 1000);
    })();

    // ── 2. COPY COUPON WITH VISUAL FEEDBACK ─────────────────────
    (function () {
      const btn = document.getElementById('copy-coupon-btn') as HTMLButtonElement | null;
      if (!btn) return;

      btn.addEventListener('click', async () => {
        const code = btn.dataset.coupon ?? '';
        try {
          await navigator.clipboard.writeText(code);
          btn.textContent = 'Copied!';
          btn.classList.replace('text-indigo-400', 'text-green-400');
          setTimeout(() => {
            btn.textContent = 'Copy';
            btn.classList.replace('text-green-400', 'text-indigo-400');
          }, 2000);
        } catch {
          btn.textContent = 'Failed';
          setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
        }
      });
    })();
  </script>

</MainLayout>