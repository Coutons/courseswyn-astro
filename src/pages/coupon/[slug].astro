---
import MainLayout from "../../layouts/MainLayout.astro";
import courses from "../../data/coupons.json";
import CourseCard from "../../components/CourseCard.astro";
import AuthorBox from "../../components/AuthorBox.astro";

export async function getStaticPaths() {
  return courses.filter((c: any) => c.slug).map((course: any) => ({
    params: { slug: course.slug },
    props: { course },
  }));
}

const { course } = Astro.props;

// ─────────────────────────────────────────────
// RELATED COURSES
// ─────────────────────────────────────────────
const relatedCourses = courses
  .filter((c: any) => c.category === course.category && c.slug !== course.slug)
  .sort(() => 0.5 - Math.random())
  .slice(0, 4);

// ─────────────────────────────────────────────
// SHARED DATA
// ─────────────────────────────────────────────
const date = new Date();
const currentMonth = date.toLocaleDateString('en-US', { month: 'long' });
const currentYear = date.getFullYear();
const isFree = course.price === 0 || course.price === "Free";

// --- TIMESTAMP LOGIC ---
// Use updatedAt for current coupon data relevance, fallback to createdAt.
function getRelativeTime(dateStr: string): string {
  if (!dateStr) return "Newly Added";
  const now = new Date();
  const past = new Date(dateStr);
  const diffMs = now.getTime() - past.getTime();
  const diffMins = Math.floor(diffMs / 60000);
  const diffHours = Math.floor(diffMins / 60);
  const diffDays = Math.floor(diffHours / 24);
  if (diffMins < 1)   return "Just now";
  if (diffMins < 60)  return `${diffMins} minute${diffMins > 1 ? 's' : ''} ago`;
  if (diffHours < 24) return `${diffHours} hour${diffHours > 1 ? 's' : ''} ago`;
  if (diffDays < 7)   return `${diffDays} day${diffDays > 1 ? 's' : ''} ago`;
  return past.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
// updatedAt = date when coupon/data was last updated
const timeAgo = getRelativeTime(course.updatedAt || course.createdAt);

// --- PRICE LOGIC ---
// originalPrice: base Udemy price
// currentPrice: price after coupon application
// savedAmount: total savings for the user
const originalPrice = Number(course.originalPrice || 84.99);
const currentPrice  = isFree ? 0 : Number(course.price || 0);
const savedAmount   = (originalPrice - currentPrice).toFixed(2);   // e.g. "99.00"
const discountPct   = Math.round(((originalPrice - currentPrice) / originalPrice) * 100); // e.g. 90

// --- TAGS LOGIC ---
// Derived from category, subcategory, and course tags.
const rawTags: string[] = [
  course.category,
  course.subcategory || course.subCategory,
  ...(Array.isArray(course.tags) ? course.tags : []),
].filter((t): t is string => Boolean(t) && t.trim().length > 0);
const uniqueTags = [...new Set(rawTags)];

// ─────────────────────────────────────────────
// FAQs
// ─────────────────────────────────────────────
const faqs = isFree ? [
  {
    q: `Is ${course.title} really free?`,
    a: `Yes! ${course.title} is completely free with our exclusive 100% OFF coupon code. You can enroll for $0 and get lifetime access including all future updates.`
  },
  {
    q: "How do I get this course for free?",
    a: `Click the "Get Udemy Coupon" button on this page. The 100% OFF discount is applied automatically — no manual copy-paste needed. You'll be redirected to Udemy checkout with $0 price.`
  },
  {
    q: `How long is the ${course.category} free course?`,
    a: `${course.title} is approximately ${course.duration || 'a few hours'} long. Once enrolled with the free coupon, you get lifetime access to learn at your own pace.`
  }
] : [
  {
    q: `Is there a discount for ${course.title}?`,
    a: `Yes! Instead of paying $${originalPrice}, you can get ${course.title} for just $${currentPrice} with our verified coupon — saving you $${savedAmount} (${discountPct}% OFF) today.`
  },
  {
    q: "How do I apply the coupon code?",
    a: `Simply click the "Get Udemy Coupon" button on this page. The discount is applied automatically to your checkout link — no manual entry needed.`
  },
  {
    q: `How long is ${course.title}?`,
    a: `${course.title} is approximately ${course.duration || 'a few hours'} long. Udemy gives you lifetime access so you can learn at your own pace and revisit content anytime.`
  }
];

// Enrich FAQ data from course learning objectives
const learnSummary = course.learn?.slice(0, 3)
  .map((l: string) => l.replace(/^[✓✅•\-*]\s*/, ''))
  .join('; ')
  || `key skills in ${course.category}`;

faqs.push({
  q: `What will I learn in ${course.title}?`,
  a: `In ${course.title} by ${course.instructor || 'expert instructors'}, you will learn: ${learnSummary}. The course covers ${course.subcategory || course.category} with ${course.duration} of hands-on content.`
});

// Additional informational FAQ
faqs.push({
  q: `What is ${course.title}?`,
  a: `${course.title} is a ${course.duration} online course on Udemy taught by ${course.instructor || 'an expert instructor'}. It covers ${course.category} with a ${course.rating || '4.5'} star rating from ${course.students?.toLocaleString() || '100+'} enrolled students. Use our verified coupon to access it ${isFree ? 'for free' : `at $${currentPrice} (${discountPct}% OFF)`}.`
});

// --- SEO LOGIC ---
const keywordUtama = course.title.split(/[:\-|()]/)[0].trim();
const pageTitle     = `${keywordUtama} Udemy Coupon - ${isFree ? '100% Off' : `${discountPct}% Off`}`;
const firstLearn    = course.learn?.[0]?.replace(/^[✓✅•\-*]\s*/, '') || '';
const pageDescription = `Get ${course.title} (${course.duration}) ${isFree ? 'for FREE — 100% OFF' : `at $${currentPrice} — ${discountPct}% OFF`} with verified Udemy coupon. ${firstLearn ? `${firstLearn}.` : ''} Updated ${currentMonth} ${currentYear}.`;

// Coupon valid until end of next month
const nextMonthDate = new Date();
nextMonthDate.setMonth(nextMonthDate.getMonth() + 1);
const priceValidUntil = nextMonthDate.toISOString().split('T')[0];

// ─────────────────────────────────────────────
// SCHEMA — Course
// ─────────────────────────────────────────────
const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": course.title,
  "description": course.description,
  "provider": {
    "@type": "Organization",
    "name": "Udemy",
    "sameAs": "https://www.udemy.com"
  },
  "instructor": {
    "@type": "Person",
    "name": course.instructor || "Udemy Instructor"
  },
  "author": {
    "@type": "Person",
    "name": "Andrew Derek",
    "url": "https://courseswyn.com"
  },
  "image": course.image,
  "inLanguage": course.language || "en",
  "offers": {
    "@type": "Offer",
    "price": isFree ? "0" : String(currentPrice),
    "priceCurrency": "USD",
    "priceValidUntil": priceValidUntil,
    "availability": "https://schema.org/InStock",
    "url": Astro.url.href,
    "category": course.category
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": course.rating || 4.5,
    "ratingCount": course.students || 100,
    "bestRating": "5",
    "worstRating": "1"
  }
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",             "item": Astro.site },
    { "@type": "ListItem", "position": 2, "name": "Udemy Coupon Code","item": `${Astro.site}udemy-coupon-code` },
    { "@type": "ListItem", "position": 3, "name": course.category,    "item": `${Astro.site}courses/category/${encodeURIComponent(course.category)}` },
    { "@type": "ListItem", "position": 4, "name": course.title,       "item": Astro.url.href }
  ]
};

// ─────────────────────────────────────────────
// SCHEMA — FAQ
// ─────────────────────────────────────────────
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<MainLayout title={pageTitle} description={pageDescription}>
  <!-- JSON-LD Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="bg-[#1c252e] min-h-screen pb-20 pt-6 px-4">
    <div class="max-w-7xl mx-auto">
      <!-- SECTION: BREADCRUMBS - Navigation path for the current course -->
      <nav class="flex flex-wrap items-center gap-2 text-xs text-gray-500 mb-6 pb-2">
        <a href="/" class="hover:text-green-500 transition-colors">Home</a>
        <span>/</span>
        <a href="/udemy-coupon-code" class="hover:text-green-500 transition-colors">Coupons</a>
        <span>/</span>
        <a href={`/courses/category/${encodeURIComponent(course.category)}`} class="hover:text-green-500 transition-colors">{course.category}</a>
        <span>/</span>
        <span class="text-gray-300">{course.title}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <!-- MAIN CONTENT (Left) -->
        <div class="lg:col-span-8 space-y-10">
          
          <!-- SECTION: HEADER - Course Title, Short Description, and Quick Meta Badges -->
          <header class="space-y-6">
            <h1 class="text-3xl md:text-5xl font-black text-white leading-tight">
              {course.title} 
            </h1>
            
            <p class="text-gray-400 text-lg md:text-xl leading-relaxed">
              {course.description.split('.')[0]}. {course.description.split('.')[1] ? course.description.split('.')[1] + '.' : ''}
            </p>

            <div class="flex flex-wrap items-center gap-y-4 gap-x-8 pt-2">
              <div class="flex items-center gap-2">
                <div class="flex items-center gap-1 text-yellow-500">
                  <span class="text-sm">★</span>
                  <span class="text-white font-black text-sm">{course.rating || "5.0"}</span>
                </div>
                <span class="text-gray-500 text-[10px] font-black uppercase tracking-widest">({course.students?.toLocaleString() || "1k+"} students)</span>
              </div>
              
              <div class="flex items-center gap-2">
                <span class="text-gray-500 text-[10px] font-bold">Instructor:</span>
                <span class="text-green-500 font-black text-sm">{course.instructor || "Udemy Instructor"}</span>
              </div>

              <div class="flex items-center gap-2">
                <span class="text-gray-500 text-[10px] font-bold">Last Update:</span>
                <span class="text-white font-black text-sm">{currentMonth} {currentYear}</span>
              </div>

              <div class="flex items-center gap-2">
                <span class="text-gray-500 text-[10px] font-bold">Language:</span>
                <span class="text-white font-black text-sm">{course.language || "English"}</span>
              </div>
            </div>
          </header>

          <!-- SECTION: COURSE OVERVIEW - Detailed list of course metadata, outcomes, and prerequisites -->
          <section class="bg-[#1c252e] border border-[#2d3748] rounded-[2.5rem] overflow-hidden group shadow-2xl">
             <div class="bg-[#2d3748]/30 px-8 py-5 border-b border-[#2d3748] flex items-center justify-between">
                <h2 class="text-sm font-black text-white tracking-widest">Course Overview — Key Details</h2>
                <span class="text-green-500 text-[10px] font-black tracking-tighter">Verified Official Data</span>
             </div>
             <div class="p-8 md:p-10 space-y-6">
                <p class="text-gray-400 text-sm leading-relaxed">
                   A quick-reference summary of the most important course details: provider, instructor, difficulty, duration, and what the coupon covers.
                </p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4 text-sm">
                   <div class="flex items-start gap-3">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Course Title:</strong> {course.title}</p>
                   </div>
                   <div class="flex items-start gap-3">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Provider:</strong> Udemy (listed via CoursesWyn)</p>
                   </div>
                   <div class="flex items-start gap-3">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Instructor:</strong> {course.instructor || "Udemy Instructor"}</p>
                   </div>
                   <div class="flex items-start gap-3">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Coupon Verified:</strong> {currentMonth} {date.getDate()}, {currentYear}</p>
                   </div>
                   <div class="flex items-start gap-3">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Difficulty Level:</strong> All Levels</p>
                   </div>
                   <div class="flex items-start gap-3">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Category:</strong> {course.category}</p>
                   </div>
                   <div class="flex items-start gap-3">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Subcategory:</strong> {course.subcategory || "General"}</p>
                   </div>
                   <div class="flex items-start gap-3">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Duration:</strong> {course.duration || "N/A"} of on-demand video</p>
                   </div>
                   <div class="flex items-start gap-3">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Language:</strong> {course.language || "English"}</p>
                   </div>
                   <div class="flex items-start gap-3">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Access:</strong> Lifetime · Mobile & TV Compatible</p>
                   </div>
                   <div class="flex items-start gap-3 md:col-span-2">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Certificate:</strong> Official certificate of completion included</p>
                   </div>
                   <div class="flex items-start gap-3 md:col-span-2">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Top Learning Outcomes:</strong> {course.learn?.slice(0, 3).join(' · ')}</p>
                   </div>
                   <div class="flex items-start gap-3 md:col-span-2">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Prerequisites:</strong> {course.requirements?.[0] || 'None'}</p>
                   </div>
                   <div class="flex items-start gap-3 md:col-span-2">
                      <span class="text-green-500 mt-1">•</span>
                      <p class="text-gray-300"><strong class="text-white">Price:</strong> <span class="text-green-500 font-black">{isFree ? 'FREE (With Coupon)' : `$${currentPrice}`}</span> / <span class="line-through">${originalPrice} (Reg. Price)</span></p>
                   </div>
                </div>

                <div class="mt-8 bg-amber-500/10 border border-amber-500/20 rounded-2xl p-6 space-y-3">
                   <div class="flex items-center gap-2 text-amber-500 font-black uppercase tracking-widest text-xs">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                      Important:
                   </div>
                   <p class="text-gray-400 text-xs leading-relaxed">
                      This coupon may not function properly in private/incognito browsing mode. Please use a standard browser window and consider temporarily disabling any ad blockers or VPN services for optimal performance.
                   </p>
                </div>
             </div>
          </section>


          <!-- SECTION: WHAT YOU'LL LEARN - Grid of specific learning objectives and skills -->
          {course.learn && course.learn.length > 0 && (
            <section class="bg-[#1c252e] border border-[#2d3748] rounded-[2.5rem] p-8 md:p-10 shadow-xl overflow-hidden relative group">
              <div class="absolute top-0 right-0 w-32 h-32 bg-green-500/5 rounded-full blur-3xl"></div>
              <div class="mb-8">
                <h2 class="text-2xl font-black text-white mb-2 flex items-center gap-3 tracking-tight">
                  <span class="w-1.5 h-8 bg-green-500 rounded-full"></span>
                  What You'll Learn
                </h2>
                <p class="text-gray-500 text-[10px] font-bold ml-[1.875rem]">Skills and competencies you'll gain from this course</p>
              </div>
              <ul class="space-y-2 text-sm text-gray-300">
                {course.learn.map((item: string) => (
                  <li class="flex items-start gap-3">
                    <span class="text-green-500 mt-1">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <!-- SECTION: REQUIREMENTS - List of prerequisites and necessary tools/knowledge -->
          {course.requirements && course.requirements.length > 0 && (
            <section class="p-2 space-y-6">
              <div>
                <h2 class="text-2xl font-bold text-white mb-2 flex items-center gap-3">
                  <span class="w-1.5 h-8 bg-green-500 rounded-full"></span>
                  Requirements
                </h2>
                <p class="text-gray-500 text-[10px] font-bold ml-[1.875rem]">Background knowledge or tools recommended before starting</p>
              </div>
              <ul class="space-y-3">
                {course.requirements.map((req: string) => (
                  <li class="flex items-center gap-3 text-gray-300 text-sm">
                    <span class="w-1.5 h-1.5 bg-gray-600 rounded-full flex-shrink-0"></span>
                    {req}
                  </li>
                ))}
              </ul>
            </section>
          )}

          <!-- SECTION: ABOUT COURSE - Full HTML description and curriculum details -->
          <section class="space-y-6">
            <div>
              <h2 class="text-2xl font-bold text-white mb-2 flex items-center gap-3">
                <span class="w-1.5 h-8 bg-green-500 rounded-full"></span>
                About This Udemy Course
              </h2>
              <p class="text-gray-500 text-[10px] font-bold ml-[1.875rem]">Full course description including curriculum and methodology</p>
            </div>
            <div class="bg-[#1c252e] border border-[#2d3748] rounded-3xl p-6 md:p-8 relative">
              <style>
                .prose-custom * { color: rgb(209 213 219) !important; }
                .prose-custom strong, .prose-custom b { color: white !important; font-weight: 700 !important; }
                .prose-custom h1, .prose-custom h2, .prose-custom h3 { color: white !important; font-weight: 800 !important; margin-bottom: 1.5rem !important; margin-top: 2rem !important; }
                .prose-custom h1 { font-size: 1.5rem !important; }
                .prose-custom h2 { font-size: 1.25rem !important; }
                .prose-custom a { color: #10b981 !important; text-decoration: none !important; }
                .prose-custom a:hover { text-decoration: underline !important; }
                .prose-custom p { line-height: 1.8 !important; margin-bottom: 1.25rem !important; }
                .prose-custom ul { list-style-type: disc !important; padding-left: 1.5rem !important; margin-bottom: 1.5rem !important; }
                .prose-custom li { margin-bottom: 0.5rem !important; }
              </style>
              <div
                class="prose prose-invert prose-lg max-w-none prose-custom"
                set:html={course.content || course.description}
              />
            </div>
          </section>

          <!-- SECTION: INTERNAL GUIDE - Udemy Coupons Guide -->
          <section class="bg-[#1c252e] border border-[#2d3748] rounded-3xl p-6 md:p-8 flex items-center justify-between group">
             <div>
                <h3 class="text-white font-black text-xs uppercase tracking-widest mb-1">Udemy Coupons Guide</h3>
                <p class="text-gray-500 text-[10px] font-bold">Learn the secrets to finding 100% OFF coupons every time</p>
             </div>
             <a href="/udemy-coupons-guide" class="text-green-500 text-[10px] font-black uppercase tracking-widest hover:underline flex items-center gap-2">
                Read Guide ↗
             </a>
          </section>

          <!-- SECTION: COMPARISON (Relocated here) -->
          <section class="space-y-6">
             <div class="flex flex-col md:flex-row md:items-end justify-between gap-2">
                <div>
                   <h2 class="text-xl font-bold text-white tracking-tight">Compare Similar Courses</h2>
                   <p class="text-gray-500 text-[10px] font-bold mt-1">Check out these alternative {course.category} courses to find the perfect fit for your learning goals.</p>
                </div>
                <a href={`/courses/category/${encodeURIComponent(course.category)}`} class="text-green-500 text-[10px] font-black hover:underline whitespace-nowrap">View all →</a>
             </div>
             <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {courses
                  .filter((c: any) => (c.subcategory || c.category) === (course.subcategory || course.category) && c.slug !== course.slug)
                  .sort((a: any, b: any) => (b.rating || 0) - (a.rating || 0))
                  .slice(0, 2)
                  .map((comp: any) => (
                    <a href={`/coupon/${comp.slug}`} class="bg-[#1c252e] border border-[#2d3748] rounded-2xl p-4 flex gap-4 hover:border-green-500 transition-all block group">
                       <img src={comp.image} alt="" class="w-16 h-16 rounded-xl object-cover transition-all flex-shrink-0" />
                       <div class="space-y-1 min-w-0">
                          <p class="text-white font-bold text-[11px] leading-tight line-clamp-2">{comp.title}</p>
                          <div class="flex items-center justify-between border-t border-[#2d3748] pt-1">
                             <span class="text-green-500 font-black text-[10px]">{comp.price === 0 || comp.price === "Free" ? 'FREE' : `$${comp.price}`}</span>
                             <span class="text-gray-500 text-[10px]">★ {comp.rating || "4.5"}</span>
                          </div>
                       </div>
                    </a>
                  ))
                }
             </div>
          </section>

          <!-- SECTION: REVIEW VERDICT (Balanced Review Style) -->
          <section class="bg-gradient-to-br from-[#1c252e] to-[#111820] border border-[#2d3748] rounded-[2.5rem] p-8 md:p-12 relative overflow-hidden shadow-2xl group">
             <!-- SUBTLE DECORATION -->
             <div class="absolute top-0 right-0 w-48 h-48 bg-green-500/5 rounded-full blur-3xl pointer-events-none"></div>

             <div class="relative z-10 space-y-8">
                <div>
                   <h2 class="text-2xl md:text-3xl font-black text-white tracking-tight leading-tight">
                      Is {course.title} Worth It?
                   </h2>
                   <p class="text-gray-500 text-[10px] font-bold mt-2 flex items-center gap-2">
                      <span class="w-1.5 h-8 bg-green-500 rounded-full"></span>
                      Expert Review Verdict • Updated {currentMonth} {currentYear}
                   </p>
                </div>

                <p class="text-gray-400 leading-relaxed text-base md:text-lg">
                   After analyzing the curriculum and student engagement, we've determined that <strong class="text-white">{course.title}</strong> is a high-value resource for anyone looking to master <strong class="text-green-500">{course.category}</strong>. 
                   Taught by {course.instructor || 'expert faculty'}, the {course.duration} course provides a comprehensive roadmap from basics to advanced concepts.
                </p>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                   <!-- PROS -->
                   <div class="space-y-4">
                      <h3 class="text-white text-xs font-black tracking-widest flex items-center gap-2">
                         <span class="w-4 h-4 rounded-full bg-green-500/10 flex items-center justify-center text-green-500">✓</span>
                         What We Like (Pros)
                      </h3>
                      <ul class="space-y-3 text-sm text-gray-400">
                         <li class="flex items-start gap-2">Verified {discountPct}% price drop makes this extremely accessible.</li>
                         <li class="flex items-start gap-2">High aggregate student score of {course.rating || "4.5"}/5.</li>
                         <li class="flex items-start gap-2">Includes official completion certificate and lifetime updates.</li>
                      </ul>
                   </div>

                   <!-- CONS -->
                   <div class="space-y-4">
                      <h3 class="text-white text-xs font-black tracking-widest flex items-center gap-2">
                         <span class="w-4 h-4 rounded-full bg-red-500/10 flex items-center justify-center text-red-500">!</span>
                         Keep in Mind (Cons)
                      </h3>
                      <ul class="space-y-3 text-sm text-gray-400">
                         <li class="flex items-start gap-2">Heavy focus on {course.subcategory || course.category} might feel intense for absolute beginners.</li>
                         <li class="flex items-start gap-2">Lifetime access is only guaranteed as long as the Udemy platform exists.</li>
                         <li class="flex items-start gap-2">Quizzes and hands-on projects may require significant time outside of videos.</li>
                      </ul>
                   </div>
                </div>

                <!-- VERDICT CALLOUT -->
                <div class="pt-6 border-t border-[#2d3748]">
                   <div class="bg-indigo-500/5 border border-indigo-500/10 p-6 rounded-2xl flex flex-col md:flex-row items-center gap-6">
                      <div class="shrink-0 flex items-center gap-3">
                         <div class="w-10 h-10 rounded-full bg-indigo-500 flex items-center justify-center text-[10px] font-black shadow-lg">AD</div>
                         <div>
                            <p class="text-white font-bold text-xs leading-none">Andrew Derek</p>
                            <p class="text-gray-500 text-[9px] font-black tracking-widest mt-1">Lead Reviewer</p>
                         </div>
                      </div>
                      <p class="text-gray-400 text-sm italic leading-relaxed flex-1 text-center md:text-left">
                         "A definitive 'Must-Enroll' for {course.category} enthusiasts. Grab it while the coupon is verified and active for the best value."
                      </p>
                      <div class="shrink-0 px-6 py-2 bg-green-500 text-white text-[10px] font-black tracking-widest rounded-full shadow-lg shadow-green-500/20">
                         Final Verdict: Worth It
                      </div>
                   </div>
                </div>
             </div>
          </section>
 


          <!-- SECTION: RATING SUMMARY - Visual breakdown of student ratings and aggregate score -->
          <section class="bg-[#1c252e] border border-[#2d3748] rounded-3xl p-8 shadow-2xl overflow-hidden">
             <div class="mb-10">
                <h2 class="text-2xl font-bold text-white mb-2 flex items-center gap-3">
                   <span class="w-1.5 h-8 bg-green-500 rounded-full"></span>
                   Course Rating Summary
                </h2>
                <p class="text-gray-500 text-[10px] font-bold ml-[1.875rem]">Aggregate student feedback and score distribution</p>
             </div>
             <div class="flex flex-col md:flex-row items-center gap-12">
                <div class="text-center md:text-left space-y-2 shrink-0">
                   <h2 class="text-gray-500 text-xs font-black tracking-widest mb-4">Course Rating Summary</h2>
                   <p class="text-7xl font-black text-white">{course.rating || "5.0"}</p>
                   <div class="flex items-center justify-center md:justify-start gap-1 text-yellow-500 text-2xl">
                      <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
                   </div>
                   <p class="text-gray-500 text-[10px] font-black tracking-widest mt-2">{course.students?.toLocaleString() || "226"} Ratings</p>
                </div>
                <div class="flex-1 w-full space-y-3">
                   {[
                      { s: '5 stars', p: '75%', color: 'from-green-500 to-green-600' },
                      { s: '4 stars', p: '15%', color: 'from-emerald-500 to-emerald-600' },
                      { s: '3 stars', p: '6%', color: 'from-amber-400 to-amber-500' },
                      { s: '2 stars', p: '2%', color: 'from-orange-500 to-orange-600' },
                      { s: '1 star', p: '2%', color: 'from-red-500 to-red-600' }
                   ].map((bar) => (
                      <div class="flex items-center gap-4 group/bar">
                         <span class="text-[10px] text-gray-500 font-bold w-12 text-right uppercase shrink-0">{bar.s}</span>
                         <div class="flex-1 h-3 bg-[#2d3748] rounded-full overflow-hidden">
                            <div class={`h-full bg-gradient-to-r ${bar.color} transition-all duration-1000 group-hover/bar:brightness-125`} style={`width: ${bar.p}`}></div>
                         </div>
                         <span class="text-[10px] text-white font-black w-10 shrink-0">{bar.p}</span>
                      </div>
                   ))}
                </div>
             </div>
             <p class="text-gray-600 text-[9px] mt-8 italic text-center md:text-left">* Aggregate rating data sourced from Udemy as of {currentMonth} {currentYear}.</p>
          </section>

          {course.instructor && (
            <div class="space-y-6">
               <h2 class="text-2xl font-bold text-white mb-2 flex items-center gap-3">
                  <span class="w-1.5 h-8 bg-green-500 rounded-full"></span>
                  Instructor Profile
               </h2>
               <section class="bg-[#1c252e] border border-[#2d3748] rounded-3xl p-8 space-y-6 shadow-xl">
                  <div class="space-y-4">
                  <p class="text-gray-300 text-sm leading-relaxed">
                     This course is taught by <strong class="text-white">{course.instructor}</strong>. For full instructor bio, credentials, and other courses they teach, visit the instructor profile on Udemy.
                  </p>
                  <ul class="space-y-2 border-t border-[#2d3748] pt-4">
                     <li class="flex items-start gap-3 text-sm">
                        <span class="text-green-500 font-bold">•</span>
                        <p class="text-gray-300"><strong class="text-white">Instructor:</strong> {course.instructor}</p>
                     </li>
                     <li class="flex items-start gap-3 text-sm">
                        <span class="text-green-500 font-bold">•</span>
                        <p class="text-gray-300"><strong class="text-white">Field:</strong> {course.category}</p>
                     </li>
                     <li class="flex items-start gap-3 text-sm">
                        <span class="text-green-500 font-bold">•</span>
                        <p class="text-gray-300"><strong class="text-white">Teaching Style:</strong> Practical, project-based learning (as described in course curriculum)</p>
                     </li>
                  </ul>
                  <div class="pt-2">
                     <a 
                       href={course.url} 
                       target="_blank" 
                       rel="nofollow noopener" 
                       class="inline-flex items-center gap-2 text-green-500 text-[10px] font-black hover:underline"
                     >
                        View Full Instructor Profile ↗
                     </a>
                  </div>
               </section>
            </div>
          )}

        </div>

        <!-- SIDEBAR: Sticky container for CTA and main course features -->
        <aside class="lg:col-span-4 lg:sticky lg:top-6 space-y-6 h-fit">
          
          <div class="bg-[#1c252e] rounded-3xl border border-[#2d3748] overflow-hidden shadow-2xl">
            <!-- SIDEBAR PART: THUMBNAIL -->
            <div class="relative aspect-video">
              <img
                src={course.image}
                alt={course.title}
                class="w-full h-full object-cover"
              />
              <div class="absolute inset-0 bg-black/10"></div>
              <div class="absolute inset-0 flex items-center justify-center opacity-0 hover:opacity-100 transition-opacity bg-black/40 cursor-pointer group">
                  <div class="w-12 h-12 bg-green-500 rounded-full flex items-center justify-center text-white scale-90 group-hover:scale-100 transition-transform">
                      <svg class="w-6 h-6 ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  </div>
              </div>
            </div>

            <div class="p-5 space-y-4">
              <!-- 2. PRICE ROW (COMPACT) -->
              <div class="flex items-center justify-between">
                 <div class="flex items-baseline gap-2">
                    <span class="text-white text-3xl font-black">{isFree ? 'FREE' : `$${currentPrice}`}</span>
                    {originalPrice > currentPrice && (
                       <span class="text-gray-500 line-through text-xs font-bold">${originalPrice}</span>
                    )}
                 </div>
                 {originalPrice > currentPrice && (
                    <span class="bg-[#ff4d4d]/10 text-[#ff4d4d] text-[10px] font-black uppercase px-2 py-1 rounded-md tracking-tighter">{discountPct}% OFF</span>
                 )}
              </div>

              <!-- 3. EXPIRY TIMER (COMPACT) -->
              <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-3">
                 <div class="flex items-center justify-between text-[#ff4d4d] mb-2">
                    <div class="flex items-center gap-2">
                       <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                       <span class="text-[8px] font-black tracking-[0.2em]">Expires In</span>
                    </div>
                    <span class="text-[8px] font-black">Ending soon</span>
                 </div>
                 <div class="grid grid-cols-4 gap-1.5 text-center">
                    {[
                       { v: '26', l: 'Days' }, { v: '09', l: 'Hrs' }, { v: '23', l: 'Min' }, { v: '55', l: 'Sec' }
                    ].map(t => (
                       <div class="bg-white/5 rounded-lg p-1.5">
                          <span class="block text-white font-black text-sm">{t.v}</span>
                          <span class="block text-[6px] text-gray-500 font-bold">{t.l}</span>
                       </div>
                    ))}
                 </div>
              </div>

              <!-- 4. COUPON BOX (COMPACT) -->
              <div class="border border-[#2d3748] rounded-xl overflow-hidden">
                  <div class="p-3 flex items-center justify-between gap-3">
                     <div class="flex-1 font-mono text-white font-black tracking-widest text-sm truncate">
                        {course.coupon ? `${course.coupon.slice(0, 5)}***` : 'ST10M...'}
                     </div>
                    <button 
                      onclick={`navigator.clipboard.writeText('${course.coupon || "ST10MT30324"}'); console.log('Copied!');`}
                      class="text-indigo-400 text-[8px] font-black uppercase hover:text-white transition-colors underline"
                    >
                       Copy
                    </button>
                 </div>
              </div>

              <!-- 5. CTA BUTTON -->
              <a
                href={course.url}
                target="_blank"
                rel="nofollow noopener"
                class="block w-full text-center bg-[#2d3748] hover:bg-green-500 text-white font-black py-4 rounded-xl transition-all shadow-xl shadow-black/20 text-lg uppercase tracking-widest hover:-translate-y-1 active:scale-95"
              >
                Redeem Coupon
              </a>

              <p class="text-[10px] text-gray-500 text-center font-bold">30-Day Money-Back Guarantee via Udemy</p>

              <!-- 6. FEATURES LIST -->
              <div class="pt-6 border-t border-[#2d3748] space-y-4">
                 <h3 class="text-white font-black text-xs tracking-widest">This Course Includes:</h3>
                 <div class="space-y-3">
                    <div class="flex items-center justify-between text-sm">
                       <div class="flex items-center gap-3 text-gray-400">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                          <span class="font-bold">Duration</span>
                       </div>
                       <span class="text-white font-black">{course.duration || "Full Access"}</span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                       <div class="flex items-center gap-3 text-gray-400">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                          <span class="font-bold">Access</span>
                       </div>
                       <span class="text-white font-black">Lifetime - Mobile & TV</span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                       <div class="flex items-center gap-3 text-gray-400">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                          <span class="font-bold">Certificate</span>
                       </div>
                       <span class="text-white font-black">Yes (Official)</span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                       <div class="flex items-center gap-3 text-gray-400">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5a18.022 18.022 0 01-3.827-5.802M13.882 12c.382 1.053.844 2.1 1.382 3.111M7.948 4.605a18.022 18.022 0 003.827 5.802m0 0a18.022 18.022 0 01-3.827 5.802m3.827-5.802a18.022 18.022 0 003.827-5.802"/></svg>
                          <span class="font-bold">Language</span>
                       </div>
                       <span class="text-white font-black">{course.language || "English"}</span>
                    </div>
                 </div>
              </div>

              <!-- SHARE BUTTONS -->
              <div class="flex gap-2 pt-2">
                 <button class="flex-1 bg-[#2d3748] hover:bg-[#374151] text-gray-400 hover:text-white py-2.5 rounded-xl text-[10px] font-black tracking-widest transition-colors flex items-center justify-center gap-2">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"/></svg>
                    Share
                 </button>
                 <button class="flex-1 bg-[#2d3748] hover:bg-[#374151] text-gray-400 hover:text-white py-2.5 rounded-xl text-[10px] font-black tracking-widest transition-colors">
                    Wishlist
                 </button>
              </div>
            </div>
          </div>

          <!-- TRUST BADGE -->
          <div class="bg-gradient-to-br from-[#1c252e] to-[#12181d] border border-[#2d3748] p-6 rounded-3xl flex items-center gap-4">
             <div class="w-12 h-12 bg-green-500/10 text-green-500 rounded-2xl flex items-center justify-center">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
             </div>
              <div>
                 <p class="text-white font-black text-xs tracking-widest">Verified Merchant</p>
                 <p class="text-gray-500 text-[10px] font-bold">100% Secure Checkout</p>
              </div>
          </div>

        </aside>

      </div>

      <!-- ══════════════════════════════════════
           EXTENDED SECTIONS (Bottom)
      ══════════════════════════════════════ -->
      <div class="mt-16 space-y-16">
        


       <!-- SECTION: INTERNAL GUIDE - How to Redeem -->
       <section class="bg-[#1c252e] border border-[#2d3748] rounded-3xl p-6 md:p-8 flex items-center justify-between group">
          <div>
             <h3 class="text-white font-black text-xs uppercase tracking-widest mb-1">Coupon Help Center</h3>
             <p class="text-gray-500 text-[10px] font-bold">Step-by-step instructions on how to redeem your discount</p>
          </div>
          <a href="/how-to-redeem-coupon" class="text-indigo-400 text-[10px] font-black uppercase tracking-widest hover:underline flex items-center gap-2">
             How to Redeem ↗
          </a>
       </section>

      <!-- SECTION: FAQ - Frequently Asked Questions about the course and coupon -->
       <section class="bg-[#1c252e] border border-[#2d3748] rounded-[2.5rem] p-8 md:p-12 shadow-2xl overflow-hidden">
         <h2 class="text-3xl font-black text-white mb-2 tracking-tight">Frequently Asked Questions</h2>
         <p class="text-gray-500 text-sm font-bold tracking-widest mb-10">Everything you need to know about this deal</p>

        <div class="divide-y divide-[#2d3748]/50 mb-12">
          {faqs.map(faq => (
            <details class="group py-6 first:pt-0 last:pb-0">
              <summary class="flex items-center justify-between cursor-pointer list-none">
                <h3 class="text-white font-black text-lg pr-8 group-hover:text-green-500 transition-colors">{faq.q}</h3>
                <span class="text-green-500 transform group-open:rotate-180 transition-transform flex-shrink-0">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </span>
              </summary>
              <div class="mt-4 text-gray-400 leading-relaxed text-sm md:text-base pr-8">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </section>

      <!-- AUTHOR BOX -->
      <section class="mt-16">
        <AuthorBox />
      </section>

      <!-- SECTION: RECENT DEALS - Grid of other recently updated/featured course deals -->
      <section class="pb-12">
        <div class="flex items-center justify-between mb-8">
           <div>
              <h2 class="text-3xl font-black text-white tracking-tight">Recent Deals</h2>
              <p class="text-gray-500 text-[10px] font-black mt-1">Other amazing offers you might like</p>
           </div>
          <a href="/udemy-coupon-code" class="bg-[#2d3748] hover:bg-green-500 text-white font-black text-[10px] uppercase tracking-widest px-6 py-3 rounded-xl transition-all">View All</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {relatedCourses.map((c: any) => <CourseCard course={c} />)}
        </div>
      </section>

      </div>
    </div>
  </div>
</MainLayout>