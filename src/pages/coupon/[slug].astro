---
import Layout from "../../layouts/Layout.astro";
import { getDealById, readDeals } from "../../lib/store";
import DealPage from "../../components/DealPage";
import type { Deal } from "../../types/deal.d.ts";

// Dynamic rendering in dev mode, static in production

// In production, pre-generate static paths
export async function getStaticPaths() {
  const allDeals = await readDeals();
  const paths = [];
  const generated = new Set();

  for (const deal of allDeals) {
    // Generate path for ID (fallback)
    if (!deal.id.endsWith('.amp') && !generated.has(deal.id)) {
      generated.add(deal.id);
      paths.push({
        params: { slug: deal.id },
        props: { deal, allDeals }
      });
    }

    // Generate path for slug
    if (deal.slug && deal.slug !== deal.id && !deal.slug.endsWith('.amp') && !generated.has(deal.slug)) {
      generated.add(deal.slug);
      paths.push({
        params: { slug: deal.slug },
        props: { deal, allDeals }
      });
    }
  }

  return paths;
}

// Get deal data - different logic for static vs server mode
const { deal: propDeal, allDeals: propAllDeals } = Astro.props as {
  deal?: Deal;
  allDeals?: Deal[];
};

let deal: Deal;
let allDeals: Deal[];

if (import.meta.env.PROD) {
  // Production: Use props from static generation
  if (!propDeal || !propAllDeals) {
    throw new Error('Missing props in production mode');
  }
  deal = propDeal;
  allDeals = propAllDeals;
} else {
  // Development: Dynamic loading
  const { slug } = Astro.params;
  allDeals = await readDeals();
  const foundDeal = allDeals.find((d) => d.id === slug || d.slug === slug);

  if (!foundDeal) {
    return new Response(null, {
      status: 302,
      headers: { 'Location': '/' }
    });
  }

  deal = foundDeal;
}

// Get related deals - prioritize subcategory matching for better relevance
const relatedDeals = allDeals
  .filter((d) => {
    // Exclude current deal
    if (d.id === deal.id) return false;

    // If both deals have subcategories, match by subcategory
    if (deal.subcategory && d.subcategory) {
      return d.subcategory === deal.subcategory;
    }

    // Fallback: match by category
    return d.category === deal.category;
  })
  .slice(0, 4);

// Calculate discount percentage
const discountPercentage = deal.originalPrice && deal.price && deal.originalPrice > deal.price
  ? Math.round(((deal.originalPrice - deal.price) / deal.originalPrice) * 100)
  : 0;
---

<Layout
    title={`${deal.title} - ${discountPercentage}% OFF Udemy Coupon`}
    description={(deal.seoDescription || deal.description)?.slice(0, 155) + ((deal.seoDescription || deal.description)?.length > 155 ? '...' : '')}
    image={deal.seoOgImage || deal.image}
    canonical={`https://courseswyn.com/coupon/${deal.slug || deal.id}`}
>
    <!-- Enhanced Structured Data for SEO - Based on CoursesWyn Pattern -->
    <script type="application/ld+json" set:html={
        JSON.stringify({
            "@context": "https://schema.org",
            "@graph": [
                {
                    "@type": "Course",
                    "@id": `https://courseswyn.com/coupon/${deal.slug}#course`,
                    "name": deal.title,
                    "description": deal.seoDescription || deal.description || `${deal.title} - Learn from expert instructors with verified coupons`,
                    "url": `https://courseswyn.com/coupon/${deal.slug}`,
                    "image": deal.seoOgImage || deal.image || `https://courseswyn.com/logo.png`,
                    "provider": {
                        "@type": "Organization",
                        "name": deal.provider || "Udemy",
                        "url": deal.provider === "Udemy" ? "https://www.udemy.com" : `https://courseswyn.com`
                    },
                    "instructor": deal.instructor ? {
                        "@type": "Person",
                        "name": deal.instructor,
                        "jobTitle": "Course Instructor",
                        "affiliation": {
                            "@type": "Organization",
                            "name": deal.provider || "Udemy"
                        }
                    } : undefined,
                    "offers": [
                        {
                            "@type": "Offer",
                            "price": deal.price || 0,
                            "priceCurrency": "USD",
                            "availability": "https://schema.org/InStock",
                            "validThrough": deal.expiresAt || undefined,
                            "url": deal.url || `https://courseswyn.com/coupon/${deal.slug}`,
                            "seller": {
                                "@type": "Organization",
                                "name": deal.provider || "Udemy"
                            }
                        },
                        deal.coupon ? {
                            "@type": "Offer",
                            "name": `${deal.title} - Coupon Deal`,
                            "price": Math.max(0, (deal.price || 0) - ((deal.originalPrice || 0) - (deal.price || 0))),
                            "priceCurrency": "USD",
                            "availability": "https://schema.org/LimitedAvailability",
                            "validThrough": deal.expiresAt || undefined,
                            "url": deal.url || `https://courseswyn.com/coupon/${deal.slug}`,
                            "description": `Use coupon code ${deal.coupon} for discount on ${deal.title}`,
                            "seller": {
                                "@type": "Organization",
                                "name": deal.provider || "Udemy"
                            }
                        } : null
                    ].filter(Boolean),
                    "aggregateRating": deal.rating ? {
                        "@type": "AggregateRating",
                        "ratingValue": deal.rating,
                        "ratingCount": deal.students || 1,
                        "bestRating": 5,
                        "worstRating": 1
                    } : undefined,
                    "timeRequired": deal.duration ? `PT${deal.duration.replace(/[^\d]/g, '')}H` : undefined,
                    "inLanguage": deal.language || "en",
                    "teaches": deal.learn ? deal.learn.join(", ") : (deal.skills && deal.skills.length > 0 ? deal.skills.join(", ") : undefined),
                    "educationalLevel": deal.level || "Beginner to Advanced",
                    "educationalUse": "Professional Development",
                    "datePublished": deal.createdAt ? new Date(deal.createdAt).toISOString() : new Date().toISOString(),
                    "dateModified": deal.updatedAt ? new Date(deal.updatedAt).toISOString() : new Date().toISOString(),
                    "expires": deal.expiresAt || undefined,
                    "hasCourseInstance": {
                        "@type": "CourseInstance",
                        "courseMode": "online",
                        "instructor": deal.instructor ? {
                            "@type": "Person",
                            "name": deal.instructor
                        } : undefined
                    }
                },
                {
                    "@type": "BreadcrumbList",
                    "itemListElement": [
                        {
                            "@type": "ListItem",
                            "position": 1,
                            "name": "Home",
                            "item": "https://courseswyn.com"
                        },
                        {
                            "@type": "ListItem",
                            "position": 2,
                            "name": "Deals",
                            "item": "https://courseswyn.com"
                        },
                        deal.category ? {
                            "@type": "ListItem",
                            "position": 3,
                            "name": deal.category,
                            "item": `https://courseswyn.com/categories/${deal.category.toLowerCase().replace(/\s+/g, '-')}`
                        } : null,
                        {
                            "@type": "ListItem",
                            "position": deal.category ? 4 : 3,
                            "name": deal.title,
                            "item": `https://courseswyn.com/coupon/${deal.slug}`
                        }
                    ].filter(Boolean)
                },
                ...(deal.faqs && deal.faqs.length > 0 ? [{
                    "@type": "FAQPage",
                    "@id": `https://courseswyn.com/coupon/${deal.slug}#faq`,
                    "mainEntity": deal.faqs.slice(0, 5).map((faq: any) => ({
                        "@type": "Question",
                        "name": faq.q,
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": faq.a.replace(/<[^>]*>/g, '').trim()
                        }
                    }))
                }] : []),
                {
                    "@type": "WebPage",
                    "@id": `https://courseswyn.com/coupon/${deal.slug}#webpage`,
                    "url": `https://courseswyn.com/coupon/${deal.slug}`,
                    "name": `${deal.title} - Udemy Coupon & Discount Code`,
                    "description": `Get ${deal.title} with ${discountPercentage > 0 ? discountPercentage + '% off' : 'free access'} using verified coupon code. ${deal.students ? deal.students.toLocaleString() + ' students enrolled.' : ''} Limited time offer.`,
                    "inLanguage": "en-US",
                    "isPartOf": {
                        "@type": "WebSite",
                        "name": "CoursesWyn",
                        "url": "https://courseswyn.com"
                    },
                    "datePublished": deal.createdAt ? new Date(deal.createdAt).toISOString() : new Date().toISOString(),
                    "dateModified": deal.updatedAt ? new Date(deal.updatedAt).toISOString() : new Date().toISOString(),
                    "publisher": {
                        "@type": "Organization",
                        "name": "CoursesWyn",
                        "url": "https://courseswyn.com",
                        "logo": {
                            "@type": "ImageObject",
                            "url": "https://courseswyn.com/logo.png"
                        },
                        "sameAs": [
                            "https://www.facebook.com/courseswyn",
                            "https://twitter.com/courseswyn"
                        ]
                    }
                },
                {
                    "@type": "Organization",
                    "@id": "https://courseswyn.com#organization",
                    "name": "CoursesWyn",
                    "url": "https://courseswyn.com",
                    "logo": "https://courseswyn.com/logo.png",
                    "description": "CoursesWyn provides verified Udemy coupons and discount codes for premium online courses. We help learners worldwide access quality education at affordable prices.",
                    "foundingDate": "2024",
                    "sameAs": [
                        "https://www.facebook.com/courseswyn",
                        "https://twitter.com/courseswyn"
                    ],
                    "contactPoint": {
                        "@type": "ContactPoint",
                        "contactType": "customer service",
                        "availableLanguage": "English"
                    }
                }
            ]
        })
    } />

    {
        /* We pass client:load to ensure interactivity (tabs, hydration) works immediately */
    }
    <DealPage client:load deal={deal} relatedDeals={relatedDeals} />

</Layout>
