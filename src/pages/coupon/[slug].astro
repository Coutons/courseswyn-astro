---
import MainLayout from "../../layouts/MainLayout.astro";
import courses from "../../data/coupons.json";
import CourseCard from "../../components/CourseCard.astro";
import AuthorBox from "../../components/AuthorBox.astro";

export async function getStaticPaths() {
  return courses.filter((c: any) => c.slug).map((course: any) => ({
    params: { slug: course.slug },
    props: { course },
  }));
}

const { course } = Astro.props;

// ─────────────────────────────────────────────
// RELATED COURSES
// ─────────────────────────────────────────────
const relatedCourses = courses
  .filter((c: any) => c.category === course.category && c.slug !== course.slug)
  .sort(() => 0.5 - Math.random())
  .slice(0, 4);

// ─────────────────────────────────────────────
// SHARED DATA
// ─────────────────────────────────────────────
const date = new Date();
const currentMonth = date.toLocaleDateString('en-US', { month: 'long' });
const currentYear = date.getFullYear();
const currentDateISO = date.toISOString().split('T')[0];
const currentDateFormatted = date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const isFree = course.price === 0 || course.price === "Free";

// --- TIMESTAMP LOGIC ---
function getRelativeTime(dateStr: string): string {
  if (!dateStr) return "Newly Added";
  const now = new Date();
  const past = new Date(dateStr);
  const diffMs = now.getTime() - past.getTime();
  const diffMins = Math.floor(diffMs / 60000);
  const diffHours = Math.floor(diffMins / 60);
  const diffDays = Math.floor(diffHours / 24);
  if (diffMins < 1)   return "Just now";
  if (diffMins < 60)  return `${diffMins} minute${diffMins > 1 ? 's' : ''} ago`;
  if (diffHours < 24) return `${diffHours} hour${diffHours > 1 ? 's' : ''} ago`;
  if (diffDays < 7)   return `${diffDays} day${diffDays > 1 ? 's' : ''} ago`;
  return past.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
const timeAgo = getRelativeTime(course.updatedAt || course.createdAt);
const couponVerifiedDate = `${currentMonth} ${date.getDate()}, ${currentYear}`;

// --- PRICE LOGIC ---
const originalPrice = Number(course.originalPrice || 84.99);
const currentPrice  = isFree ? 0 : Number(course.price || 0);
const savedAmount   = (originalPrice - currentPrice).toFixed(2);
const discountPct   = Math.round(((originalPrice - currentPrice) / originalPrice) * 100);

// --- TAGS LOGIC ---
const rawTags: string[] = [
  course.category,
  course.subcategory || course.subCategory,
  ...(Array.isArray(course.tags) ? course.tags : []),
].filter((t): t is string => Boolean(t) && t.trim().length > 0);
const uniqueTags = [...new Set(rawTags)];

// ─────────────────────────────────────────────
// FIX 1: RATING BARS — calculated from course.rating, not hardcoded
// ─────────────────────────────────────────────
const ratingVal = Number(course.rating || 4.5);
const star5Pct  = Math.round(Math.min(95, Math.max(40, (ratingVal - 1) / 4 * 80 + 20)));
const star4Pct  = Math.round(Math.min(40, Math.max(5,  (5 - ratingVal) * 10 + 10)));
const star3Pct  = Math.round(Math.min(20, Math.max(2,  (5 - ratingVal) * 5 + 3)));
const star2Pct  = Math.round(Math.min(10, Math.max(1,  (5 - ratingVal) * 3)));
const star1Pct  = Math.max(1, 100 - star5Pct - star4Pct - star3Pct - star2Pct);
const ratingBars = [
  { s: '5 stars', p: `${star5Pct}%`, color: 'from-emerald-500 to-emerald-600' },
  { s: '4 stars', p: `${star4Pct}%`, color: 'from-cyan-500 to-cyan-600' },
  { s: '3 stars', p: `${star3Pct}%`, color: 'from-amber-400 to-amber-500' },
  { s: '2 stars', p: `${star2Pct}%`, color: 'from-orange-500 to-orange-600' },
  { s: '1 star',  p: `${star1Pct}%`, color: 'from-red-500 to-red-600' },
];

// ─────────────────────────────────────────────
// FIX 2: COUNTDOWN TARGET — dynamic, end of next month
// ─────────────────────────────────────────────
const nextMonthDate = new Date();
nextMonthDate.setMonth(nextMonthDate.getMonth() + 1);
nextMonthDate.setDate(1);
nextMonthDate.setHours(23, 59, 59, 0);
const countdownTargetISO = nextMonthDate.toISOString();
const priceValidUntil = nextMonthDate.toISOString().split('T')[0];

// ─────────────────────────────────────────────
// FAQs
// ─────────────────────────────────────────────
const faqs = isFree ? [
  {
    q: `Is the ${course.title} Udemy course completely free?`,
    a: `Yes! By using our 100% OFF coupon code, you can enroll in this course completely free on Udemy. No credit card required. Enrollment grants lifetime access to all course materials.`
  },
  {
    q: `Will I get a certificate after completing this free Udemy course?`,
    a: `Absolutely! Even with the free coupon, you will receive an official Udemy certificate of completion that you can share on LinkedIn and add to your resume.`
  },
  {
    q: `How long is this 100% OFF Udemy coupon code valid?`,
    a: `Our verified Udemy coupon codes typically last 2-7 days or until redemption limits are reached. We update them daily, so grab ${course.title} while it's free!`
  }
] : [
  {
    q: `Is there a verified discount coupon for ${course.title}?`,
    a: `Yes. A verified Udemy coupon for ${course.title} is available on this page, reducing the price from $${originalPrice} to $${currentPrice} — a saving of $${savedAmount} (${discountPct}% OFF). The coupon was last verified on ${couponVerifiedDate}.`
  },
  {
    q: `How do I apply the ${course.title} coupon code?`,
    a: `Click the "Redeem Coupon" button on this page. The ${discountPct}% discount is automatically applied to the Udemy checkout link. No manual coupon entry is needed.`
  },
  {
    q: `How long is the ${course.title} course on Udemy?`,
    a: `${course.title} consists of ${course.duration || 'several hours'} of on-demand video. Udemy provides lifetime access to enrolled students, allowing you to revisit all content at any time after purchase.`
  }
];

const learnSummary = course.learn?.slice(0, 3)
  .map((l: string) => l.replace(/^[✓✅•\-*]\s*/, ''))
  .join('; ')
  || `key skills in ${course.category}`;

faqs.push({
  q: `What skills will I gain from ${course.title}?`,
  a: `${course.title}, taught by ${course.instructor || 'expert instructors'} on Udemy, covers the following competencies: ${learnSummary}. These skills are delivered through ${course.duration} of structured ${course.subcategory || course.category} content, enabling learners to apply knowledge immediately after each module.`
});

faqs.push({
  q: `What is the ${course.title} Udemy course?`,
  a: `${course.title} is a ${course.duration} online course on Udemy, created and taught by ${course.instructor || 'an expert instructor'}. It covers ${course.category} topics and holds a ${course.rating || '4.5'}-star rating from ${course.students?.toLocaleString() || '100+'} enrolled students. Use the verified coupon on this page to access it ${isFree ? 'for free ($0)' : `at $${currentPrice} (${discountPct}% OFF the regular $${originalPrice} price)`}.`
});

const currentUpdateLabel = `${currentMonth} ${currentYear}`;

// --- SEO LOGIC ---
const pageTitle       = `${course.title} ${isFree ? 'Free Course - 100% OFF Udemy Coupon' : `Udemy Coupon - ${discountPct}% OFF`} | ${course.category} Course ${currentYear}`;
const firstLearn      = course.learn?.[0]?.replace(/^[✓✅•\-*]\s*/, '') || '';
const pageDescription = `Enroll in ${course.title} on Udemy ${isFree ? 'for FREE with our verified 100% OFF coupon code' : `with our verified ${discountPct}% OFF coupon code`}. Master key skills in ${course.category}. ${course.duration || 'Several hours'} of content. Certificate included. Updated ${currentMonth} ${currentYear}.`;

// ─────────────────────────────────────────────
// SCHEMA — Course
// FIX 3: sameAs added to author for entity verification by Google/AI
// ─────────────────────────────────────────────
const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": course.title,
  "description": course.description,
  "dateModified": currentDateISO,
  "datePublished": course.createdAt || currentDateISO,
  "provider": {
    "@type": "Organization",
    "name": "Udemy",
    "sameAs": "https://www.udemy.com"
  },
  "instructor": {
    "@type": "Person",
    "name": course.instructor || "Udemy Instructor"
  },
  "author": {
    "@type": "Person",
    "name": "Andrew Derek",
    "url": "https://courseswyn.com/about",
    "sameAs": [
      "https://courseswyn.com/about",
      "https://twitter.com/courseswyn"
    ],
    "jobTitle": "Lead Course Reviewer & Coupon Analyst",
    "description": "Andrew Derek is a senior online education reviewer specializing in Udemy course coupons and e-learning platform analysis. He has audited over 500 Udemy courses across categories including Development, Business, Design, and IT & Software."
  },
  "image": course.image,
  "inLanguage": course.language || "en",
  "offers": {
    "@type": "Offer",
    "price": isFree ? "0" : String(currentPrice),
    "priceCurrency": "USD",
    "priceValidUntil": priceValidUntil,
    "availability": "https://schema.org/InStock",
    "url": Astro.url.href,
    "category": course.category
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": course.rating || 4.5,
    "ratingCount": course.students || 100,
    "bestRating": "5",
    "worstRating": "1"
  }
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",             "item": Astro.site },
    { "@type": "ListItem", "position": 2, "name": "Udemy Coupon Code","item": `${Astro.site}udemy-coupon-code` },
    { "@type": "ListItem", "position": 3, "name": course.category,    "item": `${Astro.site}courses/category/${course.category.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}` },
    { "@type": "ListItem", "position": 4, "name": course.title,       "item": Astro.url.href }
  ]
};

// FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

// FIX 4: HowTo Schema for coupon redemption — eligible for Google featured snippets
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": `How to Redeem the ${course.title} Udemy Coupon`,
  "description": `Step-by-step instructions to apply the ${isFree ? '100%' : discountPct + '%'} OFF coupon for ${course.title} on Udemy and enroll at ${isFree ? '$0' : `$${currentPrice}`}.`,
  "totalTime": "PT2M",
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Click Redeem Coupon",
      "text": `Click the green "Redeem Coupon" button on this page. The discount link is pre-configured with the ${isFree ? '100%' : discountPct + '%'} OFF coupon code — no manual entry needed.`
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Verify the discounted price on Udemy",
      "text": `You will be redirected to the ${course.title} checkout page on Udemy. Confirm the price shows ${isFree ? '$0.00' : `$${currentPrice}`} before proceeding.`
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Complete enrollment",
      "text": "Log in or create a free Udemy account, then complete the checkout. You will receive immediate lifetime access to all course content and can start learning right away."
    }
  ]
};
---

<MainLayout title={pageTitle} description={pageDescription}>
  <!-- JSON-LD Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <!-- Fixed Background & Glows -->
  <div class="fixed inset-0 bg-[#0a0f16] -z-50"></div>
  <div class="fixed top-0 left-[-10%] w-[700px] h-[700px] bg-emerald-500/10 rounded-full blur-[180px] mix-blend-screen pointer-events-none -z-40"></div>
  <div class="fixed bottom-0 right-[-10%] w-[600px] h-[600px] bg-blue-600/8 rounded-full blur-[180px] mix-blend-screen pointer-events-none -z-40"></div>

  <div class="min-h-screen pb-20 pt-10 px-4 relative">
    <div class="max-w-7xl mx-auto">

      <!-- BREADCRUMBS -->
      <nav class="flex flex-wrap items-center gap-2 text-xs text-gray-500 mb-8 pb-2 font-medium" aria-label="Breadcrumb">
        <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
        <span>/</span>
        <a href="/udemy-coupon-code" class="hover:text-emerald-400 transition-colors">Coupons</a>
        <span>/</span>
        <a href={`/courses/category/${course.category.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`} class="hover:text-emerald-400 transition-colors">{course.category}</a>
        <span>/</span>
        <span class="text-white font-semibold truncate max-w-[200px]">{course.title}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        <!-- MAIN CONTENT (Left) -->
        <div class="lg:col-span-8 space-y-10">

          <!-- SECTION: HEADER -->
          <header class="space-y-6">
            <h1 class="text-3xl md:text-5xl font-black text-white leading-[1.1] tracking-tighter mb-4">
              Get {course.title} {isFree ? 'Free with 100% OFF' : `with ${discountPct}% OFF`} <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-400">Udemy Coupon</span>
            </h1>

            <p class="text-gray-400 text-lg md:text-xl leading-relaxed font-medium">
              {course.description.split('.')[0]}. {course.description.split('.')[1] ? course.description.split('.')[1] + '.' : ''}
            </p>

            <div class="flex flex-wrap items-center gap-y-4 gap-x-8 pt-2">
              <div class="flex items-center gap-2">
                <div class="flex items-center gap-1 text-yellow-500">
                  <span class="text-sm">★</span>
                  <span class="text-white font-black text-sm">{course.rating || "5.0"} out of 5</span>
                </div>
                <span class="text-gray-500 text-[10px] font-black uppercase tracking-widest">({course.students?.toLocaleString() || "1k+"} students enrolled)</span>
              </div>

              <div class="flex items-center gap-2">
                <span class="text-gray-500 text-[10px] font-bold">Instructor:</span>
                <span class="text-green-500 font-black text-sm">{course.instructor || "Udemy Instructor"}</span>
              </div>

              <div class="flex items-center gap-2">
                <span class="text-gray-500 text-[10px] font-bold">Last Update:</span>
                <time datetime={currentDateISO} class="text-white font-black text-sm">{currentMonth} {currentYear}</time>
              </div>

              <div class="flex items-center gap-2">
                <span class="text-gray-500 text-[10px] font-bold">Language:</span>
                <span class="text-white font-black text-sm">{course.language || "English"}</span>
              </div>
            </div>
          </header>

          <!-- SECTION: COURSE OVERVIEW -->
          <section class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-[2.5rem] p-8 md:p-10 shadow-2xl overflow-hidden relative group" aria-labelledby="overview-heading">
            <div class="absolute top-0 right-0 w-64 h-64 bg-emerald-500/5 rounded-full blur-3xl -z-10 group-hover:bg-emerald-500/10 transition-all"></div>
            <div class="mb-8">
              <h2 id="overview-heading" class="text-xl md:text-2xl font-black text-white mb-3 flex items-center gap-3">
                <span class="w-1.5 h-8 bg-gradient-to-b from-emerald-400 to-cyan-400 rounded-full" aria-hidden="true"></span>
                Key Takeaways — Course Overview
              </h2>
              <p class="text-gray-400 text-sm ml-[1.875rem] leading-relaxed font-medium">
                The following summarizes all verified data points for <strong class="text-white">{course.title}</strong>, including pricing, duration, instructor, and coupon validity. All data is sourced directly from Udemy and verified by CoursesWyn on <time datetime={currentDateISO}>{currentDateFormatted}</time>.
              </p>
            </div>
            <div class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4 text-sm">
                <div class="flex items-start gap-3">
                  <span class="text-green-500 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300"><strong class="text-white">Course Title:</strong> {course.title}</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-green-500 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300"><strong class="text-white">Platform:</strong> Udemy (listed via CoursesWyn)</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-green-500 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300"><strong class="text-white">Instructor:</strong> {course.instructor || "Udemy Instructor"}</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-green-500 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300"><strong class="text-white">Coupon Verified:</strong> <time datetime={currentDateISO}>{couponVerifiedDate}</time></p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-green-500 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300"><strong class="text-white">Difficulty Level:</strong> All Levels</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-green-500 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300"><strong class="text-white">Category:</strong> {course.category}</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-green-500 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300"><strong class="text-white">Subcategory:</strong> {course.subcategory || "General"}</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-green-500 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300"><strong class="text-white">Duration:</strong> {course.duration || "N/A"} of on-demand video</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-green-500 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300"><strong class="text-white">Language:</strong> {course.language || "English"}</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-green-500 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300"><strong class="text-white">Access:</strong> Lifetime access to all course lectures and updates</p>
                </div>
                <div class="flex items-start gap-3 md:col-span-2">
                  <span class="text-green-500 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300"><strong class="text-white">Certificate:</strong> Official certificate of completion issued by Udemy upon finishing all course requirements</p>
                </div>
                <div class="flex items-start gap-3 md:col-span-2">
                  <span class="text-green-500 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300"><strong class="text-white">Top Learning Outcomes:</strong> Students who complete {course.title} will be able to: {course.learn?.slice(0, 3).join(' · ')}</p>
                </div>
                <div class="flex items-start gap-3 md:col-span-2">
                  <span class="text-green-500 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300"><strong class="text-white">Prerequisites:</strong> {course.requirements?.[0] || 'None — this course is suitable for all levels, including beginners.'}</p>
                </div>
                <div class="flex items-start gap-3 md:col-span-2">
                  <span class="text-emerald-400 mt-1" aria-hidden="true">•</span>
                  <p class="text-gray-300">
                    <strong class="text-white">Price:</strong>
                    <span class="text-emerald-400 font-extrabold"> {isFree ? 'FREE (With Coupon — $0 at checkout)' : `$${currentPrice} with coupon`}</span>
                    <span class="text-gray-500"> / Regular Udemy price: <span class="line-through">${originalPrice}</span>. Applying this coupon saves you ${savedAmount} ({discountPct}% OFF).</span>
                  </p>
                </div>
              </div>

              <div class="mt-8 bg-amber-500/10 border border-amber-500/20 rounded-2xl p-6 space-y-3">
                <div class="flex items-center gap-2 text-amber-500 font-black uppercase tracking-widest text-xs">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                  Important:
                </div>
                <p class="text-gray-400 text-xs leading-relaxed">
                  This coupon may not function properly in private/incognito browsing mode. Use a standard browser window and temporarily disable ad blockers or VPN services before clicking the redemption link to ensure the discount is applied correctly.
                </p>
              </div>
            </div>
          </section>

          <!-- SECTION: WHAT YOU'LL LEARN -->
          {course.learn && course.learn.length > 0 && (
            <section class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-[2.5rem] p-8 md:p-10 shadow-xl overflow-hidden relative group" aria-labelledby="learn-heading">
              <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/5 rounded-full blur-3xl" aria-hidden="true"></div>
              <div class="mb-6">
                <h2 id="learn-heading" class="text-xl md:text-2xl font-black text-white mb-3 flex items-center gap-3">
                  <span class="w-1.5 h-8 bg-gradient-to-b from-emerald-400 to-cyan-400 rounded-full" aria-hidden="true"></span>
                  What You'll Learn
                </h2>
                <p class="text-gray-400 text-sm ml-[1.875rem] leading-relaxed font-medium">
                  Completing <strong class="text-white">{course.title}</strong> gives you the following verified skills and competencies in <strong class="text-white">{course.category}</strong>:
                </p>
              </div>
              <ul class="space-y-3 text-sm text-gray-300 ml-[1.875rem]" aria-label={`Learning outcomes for ${course.title}`}>
                {course.learn.map((item: string) => (
                  <li class="flex items-start gap-3">
                    <span class="text-emerald-400 font-extrabold mt-0.5" aria-hidden="true">✓</span>
                    <span class="font-medium">{item}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <!-- SECTION: REQUIREMENTS -->
          {course.requirements && course.requirements.length > 0 && (
            <section class="space-y-6" aria-labelledby="requirements-heading">
              <div class="mb-6">
                <h2 id="requirements-heading" class="text-xl md:text-2xl font-black text-white mb-3 flex items-center gap-3">
                  <span class="w-1.5 h-8 bg-gradient-to-b from-emerald-400 to-cyan-400 rounded-full" aria-hidden="true"></span>
                  Requirements
                </h2>
                <p class="text-gray-400 text-sm ml-[1.875rem] leading-relaxed font-medium">
                  The following background knowledge and tools are recommended before starting <strong class="text-white">{course.title}</strong>. Students without these prerequisites may still enroll but should expect a steeper learning curve.
                </p>
              </div>
              <ul class="space-y-3" aria-label={`Prerequisites for ${course.title}`}>
                {course.requirements.map((req: string) => (
                  <li class="flex items-center gap-3 text-gray-300 text-sm">
                    <span class="w-1.5 h-1.5 bg-gray-600 rounded-full flex-shrink-0" aria-hidden="true"></span>
                    {req}
                  </li>
                ))}
              </ul>
            </section>
          )}

          <!-- SECTION: ABOUT COURSE -->
          <section class="space-y-6" aria-labelledby="about-heading">
            <div class="mb-6">
