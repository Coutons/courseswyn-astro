---
import Layout from "../../layouts/Layout.astro";
import { getDealById, readDeals } from "../../lib/store";
import DealPage from "../../components/DealPage";
import type { Deal } from "../../types/deal";

// Dynamic rendering in dev mode, static in production

// In production, pre-generate static paths
export async function getStaticPaths() {
  const allDeals = await readDeals();
  const paths = [];
  for (const deal of allDeals) {
    // Generate path for ID (fallback)
    paths.push({
      params: { slug: deal.id },
      props: { deal, allDeals }
    });
    // Generate path for slug
    if (deal.slug && deal.slug !== deal.id) {
      paths.push({
        params: { slug: deal.slug },
        props: { deal, allDeals }
      });
    }
  }
  return paths;
}

// Get deal data - different logic for static vs server mode
const { deal: propDeal, allDeals: propAllDeals } = Astro.props as {
  deal?: Deal;
  allDeals?: Deal[];
};

let deal: Deal;
let allDeals: Deal[];

if (import.meta.env.PROD) {
  // Production: Use props from static generation
  if (!propDeal || !propAllDeals) {
    throw new Error('Missing props in production mode');
  }
  deal = propDeal;
  allDeals = propAllDeals;
} else {
  // Development: Dynamic loading
  const { slug } = Astro.params;
  allDeals = await readDeals();
  const foundDeal = allDeals.find((d) => d.id === slug || d.slug === slug);

  if (!foundDeal) {
    return new Response(null, {
      status: 302,
      headers: { 'Location': '/' }
    });
  }

  deal = foundDeal;
}

// Get related deals - prioritize subcategory matching for better relevance
const relatedDeals = allDeals
  .filter((d) => {
    // Exclude current deal
    if (d.id === deal.id) return false;

    // If both deals have subcategories, match by subcategory
    if (deal.subcategory && d.subcategory) {
      return d.subcategory === deal.subcategory;
    }

    // Fallback: match by category
    return d.category === deal.category;
  })
  .slice(0, 4);

// Calculate discount percentage
const discountPercentage = deal.originalPrice && deal.price && deal.originalPrice > deal.price
  ? Math.round(((deal.originalPrice - deal.price) / deal.originalPrice) * 100)
  : 0;
---

<Layout
    title={`${deal.title} - ${discountPercentage}% OFF Udemy Coupon`}
    description={(deal.seoDescription || deal.description)?.slice(0, 155) + ((deal.seoDescription || deal.description)?.length > 155 ? '...' : '')}
    image={deal.seoOgImage || deal.image}
    canonical={`https://courseswyn.com/coupon/${deal.slug || deal.id}`}
>
    <!-- Enhanced Structured Data for SEO -->
    <script type="application/ld+json" set:html={
        JSON.stringify({
            "@context": "https://schema.org",
            "@type": "Course",
            "name": deal.title,
            "description": deal.seoDescription || deal.description,
            "image": deal.seoOgImage || deal.image,
            "thumbnailUrl": deal.seoOgImage || deal.image,
            "provider": {
                "@type": "Organization",
                "name": deal.provider,
                "url": deal.provider === "Udemy" ? "https://www.udemy.com" : deal.provider === "Coursera" ? "https://www.coursera.org" : undefined
            },
            "offers": {
                "@type": "Offer",
                "price": deal.price.toString(),
                "priceCurrency": "USD",
                "availability": "https://schema.org/InStock",
                "url": deal.url,
                "priceValidUntil": deal.expiresAt ? new Date(deal.expiresAt).toISOString().split('T')[0] : undefined,
                "seller": {
                    "@type": "Organization",
                    "name": deal.provider
                }
            },
            "aggregateRating": deal.rating ? {
                "@type": "AggregateRating",
                "ratingValue": deal.rating.toString(),
                "reviewCount": Math.max(1, Math.round(deal.students ?? 0)),
                "bestRating": "5",
                "worstRating": "1"
            } : undefined,
            "creator": deal.instructor ? {
                "@type": "Person",
                "name": deal.instructor
            } : undefined,
            "educationalLevel": deal.level || "All Levels",
            "teaches": (() => {
                if (deal.skills && deal.skills.length > 0) return deal.skills.join(", ");
                const extractedSkills = new Set<string>();
                if (deal.category) extractedSkills.add(deal.category);
                if (deal.subcategory) extractedSkills.add(deal.subcategory);
                if (deal.learn && deal.learn.length > 0) {
                    deal.learn.slice(0, 5).forEach(item => {
                        const words = item.toLowerCase().split(' ');
                        if (words.includes('python')) extractedSkills.add('Python');
                        if (words.includes('javascript') || words.includes('js')) extractedSkills.add('JavaScript');
                        if (words.includes('react')) extractedSkills.add('React');
                        if (words.includes('html')) extractedSkills.add('HTML');
                        if (words.includes('css')) extractedSkills.add('CSS');
                        if (words.includes('data') && words.includes('analysis')) extractedSkills.add('Data Analysis');
                        if (words.includes('machine') && words.includes('learning')) extractedSkills.add('Machine Learning');
                        if (words.includes('web') && words.includes('development')) extractedSkills.add('Web Development');
                        if (words.includes('mobile') && words.includes('development')) extractedSkills.add('Mobile Development');
                    });
                }
                return Array.from(extractedSkills).slice(0, 10).join(", ") || deal.learn?.join(", ") || "";
            })(),
            "inLanguage": deal.language || "English",
            "url": `https://courseswyn.com/coupon/${deal.slug || deal.id}`,
            "datePublished": deal.createdAt ? new Date(deal.createdAt).toISOString().split('T')[0] : undefined,
            "dateModified": deal.updatedAt ? new Date(deal.updatedAt).toISOString().split('T')[0] : undefined,
            "timeRequired": deal.duration ? `PT${deal.duration.replace(/[^\d]/g, '')}H` : undefined,
            "hasCourseInstance": {
                "@type": "CourseInstance",
                "courseMode": "online",
                "instructor": deal.instructor ? {
                    "@type": "Person",
                    "name": deal.instructor
                } : undefined
            },
            "about": [
                deal.category ? {
                    "@type": "Thing",
                    "name": deal.category
                } : null,
                deal.subcategory ? {
                    "@type": "Thing",
                    "name": deal.subcategory
                } : null
            ].filter(Boolean),
            "educationalCredentialAwarded": deal.category ? `${deal.category} Certificate` : undefined,
            "occupationalCredentialAwarded": deal.category ? {
                "@type": "EducationalOccupationalCredential",
                "name": `${deal.category} Certification`,
                "educationalLevel": "Professional Certificate"
            } : undefined
        })
    } />

    <!-- Breadcrumb Structured Data -->
    <script type="application/ld+json" set:html={
        JSON.stringify({
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://courseswyn.com"
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "Udemy Coupon Code",
                    "item": "https://courseswyn.com/udemy-coupon-code"
                },
                deal.category ? {
                    "@type": "ListItem",
                    "position": 3,
                    "name": deal.category,
                    "item": `https://courseswyn.com/categories/${deal.category.toLowerCase().replace(/\s+/g, '-')}`
                } : null,
                {
                    "@type": "ListItem",
                    "position": deal.category ? 4 : 3,
                    "name": deal.title,
                    "item": `https://courseswyn.com/coupon/${deal.slug || deal.id}`
                }
            ].filter(Boolean)
        })
    } />

    <!-- Enhanced FAQ Structured Data for Featured Snippets -->
    {(deal.faqs && deal.faqs.length > 0) && (
        <script type="application/ld+json" set:html={
            JSON.stringify({
                "@context": "https://schema.org",
                "@type": "FAQPage",
                "mainEntity": deal.faqs.slice(0, 8).map((faq: any) => ({
                    "@type": "Question",
                    "name": faq.q,
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": faq.a.replace(/<[^>]*>/g, '').trim()
                    }
                })),
                "publisher": {
                    "@type": "Organization",
                    "name": "CoursesWyn",
                    "url": "https://courseswyn.com"
                },
                "about": {
                    "@type": "Course",
                    "name": deal.title,
                    "url": `https://courseswyn.com/coupon/${deal.slug || deal.id}`
                }
            })
        } />
    )}

    {
        /* We pass client:load to ensure interactivity (tabs, hydration) works immediately */
    }
    <DealPage client:load deal={deal} relatedDeals={relatedDeals} />

</Layout>
