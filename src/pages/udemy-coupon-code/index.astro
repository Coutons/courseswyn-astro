---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import DealCard from "../../components/DealCard.astro";
import { readDeals } from "../../lib/store";

const allDeals = await readDeals();

const PAGE_SIZE = 12;

// Get current page and language from URL params
const currentPage = Math.max(1, parseInt(Astro.params.page || '1', 10));
const selectedLanguage = Astro.url.searchParams.get('language');

// Filter deals by language if selected
let filteredDeals = allDeals;
if (selectedLanguage) {
  filteredDeals = allDeals.filter((d: any) => 
    d.language && d.language.toLowerCase() === selectedLanguage.toLowerCase()
  );
}

// Pagination calculation
const totalPages = Math.ceil(filteredDeals.length / PAGE_SIZE);
const startIndex = (currentPage - 1) * PAGE_SIZE;
const endIndex = startIndex + PAGE_SIZE;
const currentItems = filteredDeals.slice(startIndex, endIndex);

// Pagination URLs
const siteUrl = "https://courseswyn.com";
const baseDealsUrl = `${siteUrl}/udemy-coupon-code`;
const langQuery = selectedLanguage ? `?language=${encodeURIComponent(selectedLanguage)}` : "";
const currentUrl = currentPage === 1 ? `${baseDealsUrl}${langQuery}` : `${baseDealsUrl}/${currentPage}${langQuery}`;
const prevUrl = currentPage > 1
  ? (currentPage === 2 ? `${baseDealsUrl}${langQuery}` : `${baseDealsUrl}/${currentPage - 1}${langQuery}`)
  : null;
const nextUrl = currentPage < totalPages ? `${baseDealsUrl}/${currentPage + 1}${langQuery}` : null;

// Dynamic SEO
const currentDate = new Date();
const monthNames = ["January","February","March","April","May","June",
  "July","August","September","October","November","December"];
const currentMonth = monthNames[currentDate.getMonth()];
const currentYear = currentDate.getFullYear();

// Real stats from data
const totalDeals = allDeals.length;
const freeDeals = allDeals.filter((d: any) => d.price === 0 || d.price === null).length;
const avgSavings = (() => {
  const valid = allDeals.filter((d: any) => d.originalPrice && d.price !== undefined && d.originalPrice > 0);
  if (valid.length === 0) return 90;
  const total = valid.reduce((sum: number, d: any) =>
    sum + ((d.originalPrice - (d.price ?? 0)) / d.originalPrice) * 100, 0);
  return Math.round(total / valid.length);
})();

// Page-aware title & description - SEO optimized
const langSuffix = selectedLanguage ? ` in ${selectedLanguage}` : "";
const pageTitle = currentPage === 1
  ? `${totalDeals}+ Free Udemy Coupons${langSuffix} & 100% Off Deals [${currentMonth} ${currentYear}] | CoursesWyn`
  : `Udemy Coupon Codes${langSuffix} Page ${currentPage} of ${totalPages} | 100% Free Courses`;

const pageDescription = currentPage === 1
  ? `Find ${totalDeals}+ verified free Udemy courses${langSuffix} and 100% off coupon codes for ${currentMonth} ${currentYear}. Get ${freeDeals}+ completely free programming, Python, JavaScript, AWS certification courses. Save up to ${avgSavings}% with daily verified deals. No payment required for free coupons.`
  : `Browse page ${currentPage} of verified Udemy coupon codes${langSuffix}. Discover ${totalDeals}+ free courses and 100% off deals updated daily on CoursesWyn. Get instant access to premium courses at zero cost.`;

// FAQ data - SEO optimized with long-tail keywords
const faqs = [
  {
    q: "Are these Udemy coupon codes legitimate and safe?",
    a: "Yes! All Udemy coupons listed on CoursesWyn are 100% legitimate. We source codes directly from Udemy's official affiliate program and verified course instructors. Each coupon is manually tested by our team before listing. These are official promotional codes — not hacks or exploits. You get the exact same course content, certificates, and lifetime access as paying students."
  },
  {
    q: "How do I get Udemy courses for free with 100% off coupons?",
    a: "Getting free Udemy courses is simple: (1) Browse our deals page and find a course you want, (2) Click the 'Get Coupon' or 'Redeem Deal' button, (3) You'll be redirected to Udemy with the discount pre-applied, (4) Verify the price shows $0.00 at checkout, (5) Click 'Enroll Now' — no payment needed. The course is instantly added to your library with lifetime access."
  },
  {
    q: "How often are new free Udemy courses added?",
    a: "We update our database every single day with fresh Udemy coupons. New 100% off courses are added as soon as instructors release them — sometimes multiple times per day. Our team monitors Udemy daily to catch the best free course opportunities before redemption limits are reached. Bookmark this page and check back regularly."
  },
  {
    q: "Do free Udemy courses give certificates of completion?",
    a: "Absolutely! When you enroll in a free Udemy course using our 100% off coupons, you receive the exact same certificate as students who paid full price. You can download your certificate as a PDF or share it directly to LinkedIn. The certificate does not indicate that you got the course for free — it looks identical to paid certificates."
  },
  {
    q: "Why do some Udemy coupons say 'This coupon has expired'?",
    a: "Udemy coupons have two expiration triggers: time limit (usually 3-7 days) OR redemption limit (typically 1,000 students). Once either limit is hit, the coupon stops working. If you see an expired message, return to CoursesWyn — we refresh our listings multiple times daily and likely have a working replacement coupon for that course."
  },
  {
    q: "Can I use these Udemy coupons if I'm not in the United States?",
    a: "Yes! Most Udemy coupons work worldwide. However, pricing varies by country due to Udemy's regional pricing. A 100% off coupon might show a different (but still heavily discounted) price in some regions. The discount is always applied relative to your local pricing tier. Coupons sourced directly from instructors typically work globally."
  },
  {
    q: "Is there a catch? Why are these courses free?",
    a: "No catch! Instructors offer free coupons for strategic marketing reasons: building initial student numbers, generating reviews for new courses, boosting algorithm rankings, or attracting students to their paid course portfolios. You get premium education at zero cost — the instructor gets social proof and potential future customers. It's a win-win."
  }
];

// Pagination items
type PageItem = { type: 'page'; value: number } | { type: 'ellipsis', id: string };
const pageItems: PageItem[] = [];
const windowSize = 2;
let lastAdded = 0;
for (let p = 1; p <= totalPages; p++) {
  const inWindow = p >= currentPage - windowSize && p <= currentPage + windowSize;
  if (p === 1 || p === totalPages || inWindow) {
    if (lastAdded > 0 && p - lastAdded > 1) {
      pageItems.push({ type: 'ellipsis', id: `gap-${p}` });
    }
    pageItems.push({ type: 'page', value: p });
    lastAdded = p;
  }
}

// JSON-LD
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${currentUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Udemy Deals & Coupons", "item": baseDealsUrl },
        ...(currentPage > 1 ? [{ "@type": "ListItem", "position": 3, "name": `Page ${currentPage}`, "item": currentUrl }] : [])
      ]
    },
    {
      "@type": "CollectionPage",
      "@id": currentUrl,
      "url": currentUrl,
      "name": pageTitle,
      "description": pageDescription,
      "isPartOf": { "@id": siteUrl },
      "breadcrumb": { "@id": `${currentUrl}#breadcrumb` },
      "dateModified": currentDate.toISOString().split('T')[0],
      "inLanguage": "en-US",
      "mainEntity": {
        "@type": "ItemList",
        "name": `Udemy Deals & Free Coupons — ${currentMonth} ${currentYear}`,
        "description": `${totalDeals}+ verified Udemy course deals with ${freeDeals}+ free options`,
        "numberOfItems": allDeals.length,
        "itemListElement": currentItems.map((deal: any, index: number) => ({
          "@type": "ListItem",
          "position": startIndex + index + 1,
          "item": {
            "@type": "Course",
            "name": deal.title,
            "description": deal.description || `Get ${deal.title} free with a verified 100% off coupon on CoursesWyn.`,
            "url": `${siteUrl}/coupon/${deal.slug}`,
            "image": deal.image,
            "provider": {
              "@type": "Organization",
              "name": deal.provider || "Udemy",
              "url": "https://www.udemy.com"
            },
            "offers": {
              "@type": "Offer",
              "price": String(deal.price ?? "0"),
              "priceCurrency": "USD",
              "availability": "https://schema.org/InStock",
              "priceValidUntil": deal.expiresAt || new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
              "seller": { "@type": "Organization", "name": "CoursesWyn", "url": siteUrl }
            },
            ...(deal.rating ? {
              "aggregateRating": {
                "@type": "AggregateRating",
                "ratingValue": deal.rating.toString(),
                "bestRating": "5",
                "worstRating": "1",
                "ratingCount": Math.max(1, Math.round(deal.students ?? 1000))
              }
            } : {})
          }
        }))
      }
    },
    ...(currentPage === 1 ? [{
      "@type": "FAQPage",
      "@id": `${baseDealsUrl}#faq`,
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": { "@type": "Answer", "text": faq.a }
      }))
    }] : [])
  ]
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={currentUrl}
>
  <Fragment slot="head">
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
  </Fragment>

  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <main style="background: var(--bg); color: var(--text);">

    {/* ── HERO — page 1 only ── */}
    {currentPage === 1 && (
      <section style="padding: 100px 0 80px; border-bottom: 2px solid var(--border); background: var(--card);">
        <div class="container">
          <div style="display: inline-flex; align-items: center; gap: 8px; background: var(--accent); color: white; padding: 6px 16px; border: 2px solid var(--border); box-shadow: 3px 3px 0 var(--border); border-radius: 4px; font-weight: 900; font-size: 0.75rem; text-transform: uppercase; margin-bottom: 32px;">
            Updated Daily — {currentMonth} {currentYear}
          </div>

          <h1 style={{ 
            fontSize: "clamp(2.2rem, 5vw, 3.5rem)", 
            fontWeight: 900, 
            lineHeight: 1.1, 
            letterSpacing: "-0.04em",
            marginBottom: "20px"
          }}>
            {totalDeals}+ Free Udemy Coupons {selectedLanguage && <span style={{ color: "var(--brand)" }}>in {selectedLanguage}</span>} & <span style={{ background: "var(--brand)", color: "white", padding: "0 8px" }}>100% Off Deals</span>
          </h1>

          <p style={{ 
            fontSize: "clamp(1rem, 2.5vw, 1.15rem)", 
            color: "var(--muted)", 
            maxWidth: "800px", 
            lineHeight: 1.5,
            fontWeight: 500,
            marginBottom: "16px"
          }}>
            Verified working coupon codes for {currentMonth} {currentYear}. Get {freeDeals}+ completely free courses — programming, Python, JavaScript, AWS certification, data science & more.
          </p>
          <p style={{ 
            fontSize: "0.95rem", 
            color: "var(--muted)", 
            maxWidth: "800px", 
            lineHeight: 1.5,
            fontWeight: 500,
            marginBottom: "32px"
          }}>
            <strong style="color:var(--text)">How it works:</strong> Click any course below, the discount auto-applies at checkout. No credit card needed for free coupons. Updated daily by our team.
          </p>

          <div style="display: flex; gap: 16px; flex-wrap: wrap;">
            {[
              { v: `${totalDeals}+`, l: "Courses" },
              { v: `${freeDeals}+`, l: "100% Free" },
              { v: `${avgSavings}%`, l: "Avg Savings" }
            ].map(s => (
              <div style={{ background: "white", border: "2px solid var(--border)", padding: "12px 24px", borderRadius: "4px", boxShadow: "4px 4px 0 var(--border)", display: "flex", flexDirection: "column", alignItems: "center" }}>
                <span style="font-size: 1.5rem; font-weight: 900; color: var(--accent);">{s.v}</span>
                <span style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--muted);">{s.l}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* Page 2+ header */}
    {currentPage > 1 && (
      <section style="padding: 64px 0 48px; border-bottom: 2px solid var(--border); background: var(--card);">
        <div class="container">
            <h1 style={{ fontSize: "2.5rem", fontWeight: 900, letterSpacing: "-0.04em", marginBottom: "8px" }}>
            {selectedLanguage ? `${selectedLanguage} Courses` : 'Deals'} — Page {currentPage}
          </h1>
          <p style={{ color: "var(--muted)", fontWeight: 800, textTransform: "uppercase", fontSize: "0.8rem", letterSpacing: "0.1em" }}>
            Showing {startIndex + 1}–${Math.min(endIndex, filteredDeals.length)} of {filteredDeals.length} courses
          </p>
        </div>
      </section>
    )}

    {/* ── DEALS GRID ── */}
    <section style="padding: 80px 0;">
      <div class="container">

        {/* SEO Description Block */}
        {currentPage === 1 && (
          <div style="margin-bottom: 48px; padding: 32px; background: white; border: 2px solid var(--border); border-radius: 8px; box-shadow: 4px 4px 0 var(--border);">
            <h2 style="font-size: 1.5rem; font-weight: 900; margin: 0 0 16px 0; letter-spacing: -0.02em; color: var(--text);">
              What Are Udemy 100% Off Coupons?
            </h2>
            <p style="color: var(--muted); font-weight: 500; line-height: 1.7; margin-bottom: 16px;">
              Udemy 100% off coupons are promotional codes issued by course instructors that reduce the price of a course to 
              <strong style="color:var(--text)">$0.00 — completely free</strong>. These aren't hacks or illegal methods; they're legitimate marketing 
              strategies instructors use to build their student base, generate reviews for new courses, and increase visibility in Udemy's search algorithm.
            </p>
            <p style="color: var(--muted); font-weight: 500; line-height: 1.7; margin: 0;">
              When you enroll using a free coupon, you get <strong style="color:var(--text)">identical benefits</strong> to paying students: 
              full video content, downloadable resources, Q&A access with instructors, and a 
              <strong style="color:var(--text)">certificate of completion</strong> that you can add to your resume or LinkedIn. 
              The only difference? You paid nothing. Browse our verified deals below — updated daily by our team.
            </p>
          </div>
        )}

        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px;">
          <div>
            <h2 style="font-size: 1.75rem; font-weight: 900; margin: 0; letter-spacing: -0.04em;">
              {currentPage === 1 ? `${filteredDeals.length}+ Verified ${selectedLanguage ? selectedLanguage : ''} Free Courses` : `Page ${currentPage} — Free Udemy Courses`}
            </h2>
            <p style="color: var(--muted); font-weight: 500; margin-top: 8px;">
              {currentPage === 1 
                ? `100% off coupon codes for ${currentMonth} ${currentYear} — programming, web development, data science & more`
                : `Showing courses ${startIndex + 1}–${Math.min(endIndex, filteredDeals.length)} of ${filteredDeals.length} total deals`
              }
            </p>
          </div>
          <a href="/categories" class="btn btn-outline" style="padding: 12px 24px; font-size: 0.85rem;">
            BROWSE CATEGORIES
          </a>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; margin-bottom: 64px;">
          {currentItems.length > 0 ? (
            currentItems.map((deal: any) => (
              <DealCard deal={deal} />
            ))
          ) : (
            <div style="grid-column: 1 / -1; text-align: center; padding: 64px 24px; background: white; border: 2px solid var(--border); border-radius: 8px; box-shadow: 4px 4px 0 var(--border);">
              <div style="font-size: 3rem; margin-bottom: 16px;">🔍</div>
              <h3 style="font-size: 1.5rem; font-weight: 900; margin-bottom: 8px;">No {selectedLanguage} Courses Found</h3>
              <p style="color: var(--muted); font-weight: 500; margin-bottom: 24px;">We couldn't find any verified free courses in {selectedLanguage} right now.</p>
              <a href={baseDealsUrl} class="btn" style="padding: 12px 32px;">VIEW ALL LANGUAGES</a>
            </div>
          )}
        </div>

        {/* ── PAGINATION ── */}
        {totalPages > 1 && (
          <nav aria-label="Pagination" style="margin-top: 64px; padding-top: 48px; border-top: 2px solid var(--border);">
            <div style="display: flex; justify-content: center; align-items: center; gap: 16px; flex-wrap: wrap;">
              {prevUrl ? (
                <a href={prevUrl} class="btn btn-outline" style="padding: 12px 24px;">← PREV</a>
              ) : (
                <span class="btn btn-disabled" style="padding: 12px 24px; opacity: 0.5;">← PREV</span>
              )}

              <div style="display: flex; gap: 8px;">
                {pageItems.map((item) => {
                  if (item.type === 'ellipsis') {
                    return <span style="font-weight: 900; color: var(--muted); padding: 0 8px;">...</span>;
                  }
                  const isActive = item.value === currentPage;
                  const href = item.value === 1 ? `${baseDealsUrl}${langQuery}` : `${baseDealsUrl}/${item.value}${langQuery}`;
                  return (
                    <a href={href} class={isActive ? "btn btn-active" : "btn btn-outline"} style="width: 44px; height: 44px; padding: 0; display: flex; align-items: center; justify-content: center; font-size: 0.9rem;">
                      {item.value}
                    </a>
                  );
                })}
              </div>

              {nextUrl ? (
                <a href={nextUrl} class="btn" style="padding: 12px 24px;">NEXT →</a>
              ) : (
                <span class="btn btn-disabled" style="padding: 12px 24px; opacity: 0.5;">NEXT →</span>
              )}
            </div>
            <p style="text-align: center; color: var(--muted); font-weight: 800; font-size: 0.75rem; text-transform: uppercase; margin-top: 24px; letter-spacing: 0.05em;">
              Page {currentPage} of {totalPages}
            </p>
          </nav>
        )}

      </div>
    </section>

    {/* ── FAQ — page 1 only ── */}
    {currentPage === 1 && (
      <section style="padding: 80px 0; background: var(--card); border-top: 2px solid var(--border);">
        <div class="container" style="max-width: 800px;">
          <h2 style="font-size: 2rem; font-weight: 900; margin-bottom: 16px; text-align: center; letter-spacing: -0.02em;">
            Frequently Asked Questions About Free Udemy Coupons
          </h2>
          <p style="text-align: center; color: var(--muted); font-weight: 500; margin-bottom: 48px; line-height: 1.6;">
            Everything you need to know about getting Udemy courses for free with 100% off coupon codes
          </p>
          <div style="display: flex; flex-direction: column; gap: 16px;">
            {faqs.map((faq) => (
              <details class="neo-faq-details">
                <summary style="padding: 24px; font-weight: 900; cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-size: 1.1rem;">
                  {faq.q}
                  <span style="color: var(--accent); font-size: 1.5rem;">+</span>
                </summary>
                <div style="padding: 0 24px 24px; color: var(--muted); font-size: 1rem; line-height: 1.6; font-weight: 500;">
                  {faq.a}
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* ── RELATED RESOURCES — page 1 only ── */}
    {currentPage === 1 && (
      <section style="padding: 80px 0; background: var(--bg); border-top: 2px solid var(--border);">
        <div class="container">
          <h2 style="font-size: 2rem; font-weight: 900; margin-bottom: 16px; letter-spacing: -0.02em; text-align: center;">
            Explore AI & Tech Learning Paths
          </h2>
          <p style="text-align: center; color: var(--muted); font-weight: 500; margin-bottom: 48px; line-height: 1.6; max-width: 700px; margin: 0 auto 48px;">
            Discover the hottest AI courses with verified 100% off coupons. Master ChatGPT, AI agents, machine learning, and automation.
          </p>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">
            {[
              { title: "ChatGPT & Prompt Engineering", desc: "Master AI writing, coding, and automation with ChatGPT", link: "/blog/best-chatgpt-courses-udemy-2026", icon: "🤖" },
              { title: "AI Agent Development", desc: "Build autonomous AI agents with LangChain, CrewAI & AutoGPT", link: "/blog/best-udemy-agentic-ai-courses-2026", icon: "🧠" },
              { title: "Cursor AI Coding", desc: "Code faster with AI-powered IDE assistance", link: "/blog/best-cursor-ai-courses-udemy", icon: "⚡" },
              { title: "LangChain & RAG Systems", desc: "Build AI apps with retrieval-augmented generation", link: "/blog/best-langchain-langgraph-courses-udemy-2026-rag-agents-production", icon: "�" },
              { title: "AI for Web Development", desc: "Create websites and apps with AI assistance", link: "/blog/best-ai-web-development-courses-udemy-2026", icon: "🌐" },
              { title: "Generative AI Mastery", desc: "Complete guide to GPT, image generation & AI tools", link: "/blog/top-10-best-generative-ai-courses-udemy", icon: "✨" }
            ].map(resource => (
              <a href={resource.link} style="text-decoration: none; color: inherit;">
                <div style="background: white; border: 2px solid var(--border); border-radius: 8px; padding: 24px; box-shadow: 4px 4px 0 var(--border); transition: all 0.15s ease; height: 100%;" class="resource-card">
                  <div style="font-size: 2rem; margin-bottom: 12px;">{resource.icon}</div>
                  <h3 style="font-size: 1.1rem; font-weight: 900; margin-bottom: 8px; color: var(--text);">{resource.title}</h3>
                  <p style="margin: 0; color: var(--muted); font-size: 0.9rem; font-weight: 500; line-height: 1.5;">{resource.desc}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>
</Layout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .btn-active { background: var(--accent) !important; color: white !important; border-color: var(--border) !important; }
  .neo-faq-details { background: white; border: 2px solid var(--border); border-radius: 8px; margin-bottom: 16px; box-shadow: 4px 4px 0 var(--border); }
  .neo-faq-details[open] { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--border); }
  summary::-webkit-details-marker { display: none; }
  .resource-card:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--border); }
</style>