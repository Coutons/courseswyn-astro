---
import Layout from "../../layouts/Layout.astro";
import DealCard from "../../components/DealCard.astro";
import { readDeals } from "../../lib/store";

const allDeals = await readDeals();

const PAGE_SIZE = 12;

// Get current page from URL params
const currentPage = Math.max(1, parseInt(Astro.params.page || '1', 10));

// Pagination calculation
const totalPages = Math.ceil(allDeals.length / PAGE_SIZE);
const startIndex = (currentPage - 1) * PAGE_SIZE;
const endIndex = startIndex + PAGE_SIZE;
const currentItems = allDeals.slice(startIndex, endIndex);

// Pagination URLs
const siteUrl = "https://courseswyn.com";
const baseDealsUrl = `${siteUrl}/udemy-coupon-code`;
const currentUrl = currentPage === 1 ? baseDealsUrl : `${baseDealsUrl}/${currentPage}`;
const prevUrl = currentPage > 1
  ? (currentPage === 2 ? baseDealsUrl : `${baseDealsUrl}/${currentPage - 1}`)
  : null;
const nextUrl = currentPage < totalPages ? `${baseDealsUrl}/${currentPage + 1}` : null;

// Dynamic SEO
const currentDate = new Date();
const monthNames = ["January","February","March","April","May","June",
  "July","August","September","October","November","December"];
const currentMonth = monthNames[currentDate.getMonth()];
const currentYear = currentDate.getFullYear();

// Real stats from data
const totalDeals = allDeals.length;
const freeDeals = allDeals.filter((d: any) => d.price === 0 || d.price === null).length;
const avgSavings = (() => {
  const valid = allDeals.filter((d: any) => d.originalPrice && d.price !== undefined && d.originalPrice > 0);
  if (valid.length === 0) return 90;
  const total = valid.reduce((sum: number, d: any) =>
    sum + ((d.originalPrice - (d.price ?? 0)) / d.originalPrice) * 100, 0);
  return Math.round(total / valid.length);
})();

// Page-aware title & description
const pageTitle = currentPage === 1
  ? `Free Udemy Coupons ${currentMonth} ${currentYear} | ${totalDeals}+ 100% Off Deals`
  : `Udemy Deals — Page ${currentPage} of ${totalPages} | CoursesWyn`;

const pageDescription = currentPage === 1
  ? `Browse ${totalDeals}+ verified Udemy coupons with ${freeDeals}+ free courses. Save up to ${avgSavings}% on programming, web development, data science and more. Updated daily.`
  : `Page ${currentPage} of Udemy deals. Browse more verified free courses and 100% off coupons on CoursesWyn.`;

// FAQ data
const faqs = [
  {
    q: "Are Udemy deals on CoursesWyn legitimate?",
    a: "Yes! All deals on CoursesWyn are verified and sourced directly from Udemy or authorized partners. We regularly check and update our listings to ensure every coupon is active and working."
  },
  {
    q: "How often are new Udemy coupons added?",
    a: "We update our coupon database daily with new Udemy courses. New free courses and discounts are added every single day — check back regularly for the latest offers."
  },
  {
    q: "Is CoursesWyn free to use?",
    a: "Yes, CoursesWyn is completely free. We don't charge anything to access deals, coupons, or course information. Our mission is to help learners access premium education for free."
  },
  {
    q: "Do free Udemy courses include certificates?",
    a: "Yes! Free courses obtained through our coupons include full Udemy course benefits — completion certificates, lifetime access, and all course materials — same as paid enrollment."
  },
  {
    q: "How do I redeem a Udemy coupon from CoursesWyn?",
    a: "Click on any deal on this page. You will be redirected to the official Udemy course page with the discount automatically applied. Click 'Enroll Now' and complete checkout — no payment required for 100% off coupons."
  }
];

// Pagination items
type PageItem = { type: 'page'; value: number } | { type: 'ellipsis', id: string };
const pageItems: PageItem[] = [];
const windowSize = 2;
let lastAdded = 0;
for (let p = 1; p <= totalPages; p++) {
  const inWindow = p >= currentPage - windowSize && p <= currentPage + windowSize;
  if (p === 1 || p === totalPages || inWindow) {
    if (lastAdded > 0 && p - lastAdded > 1) {
      pageItems.push({ type: 'ellipsis', id: `gap-${p}` });
    }
    pageItems.push({ type: 'page', value: p });
    lastAdded = p;
  }
}

// JSON-LD
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${currentUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Udemy Deals & Coupons", "item": baseDealsUrl },
        ...(currentPage > 1 ? [{ "@type": "ListItem", "position": 3, "name": `Page ${currentPage}`, "item": currentUrl }] : [])
      ]
    },
    {
      "@type": "CollectionPage",
      "@id": currentUrl,
      "url": currentUrl,
      "name": pageTitle,
      "description": pageDescription,
      "isPartOf": { "@id": siteUrl },
      "breadcrumb": { "@id": `${currentUrl}#breadcrumb` },
      "dateModified": currentDate.toISOString().split('T')[0],
      "inLanguage": "en-US",
      "mainEntity": {
        "@type": "ItemList",
        "name": `Udemy Deals & Free Coupons — ${currentMonth} ${currentYear}`,
        "description": `${totalDeals}+ verified Udemy course deals with ${freeDeals}+ free options`,
        "numberOfItems": allDeals.length,
        "itemListElement": currentItems.map((deal: any, index: number) => ({
          "@type": "ListItem",
          "position": startIndex + index + 1,
          "item": {
            "@type": "Course",
            "name": deal.title,
            "description": deal.description || `Get ${deal.title} free with a verified 100% off coupon on CoursesWyn.`,
            "url": `${siteUrl}/coupon/${deal.slug || deal.id}`,
            "image": deal.image,
            "provider": {
              "@type": "Organization",
              "name": deal.provider || "Udemy",
              "url": "https://www.udemy.com"
            },
            "offers": {
              "@type": "Offer",
              "price": String(deal.price ?? "0"),
              "priceCurrency": "USD",
              "availability": "https://schema.org/InStock",
              "priceValidUntil": deal.expiresAt || new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
              "seller": { "@type": "Organization", "name": "CoursesWyn", "url": siteUrl }
            },
            ...(deal.rating ? {
              "aggregateRating": {
                "@type": "AggregateRating",
                "ratingValue": deal.rating.toString(),
                "bestRating": "5",
                "worstRating": "1",
                "ratingCount": Math.max(1, Math.round(deal.students ?? 1000))
              }
            } : {})
          }
        }))
      }
    },
    ...(currentPage === 1 ? [{
      "@type": "FAQPage",
      "@id": `${baseDealsUrl}#faq`,
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": { "@type": "Answer", "text": faq.a }
      }))
    }] : [])
  ]
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={currentUrl}
>
  <Fragment slot="head">
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
  </Fragment>

  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <main style="background: var(--bg); color: var(--text);">

    {/* ── HERO — page 1 only ── */}
    {currentPage === 1 && (
      <section style="padding: 100px 0 80px; border-bottom: 2px solid var(--border); background: var(--card);">
        <div class="container">
          <div style="display: inline-flex; align-items: center; gap: 8px; background: var(--accent); color: white; padding: 6px 16px; border: 2px solid var(--border); box-shadow: 3px 3px 0 var(--border); border-radius: 4px; font-weight: 900; font-size: 0.75rem; text-transform: uppercase; margin-bottom: 32px;">
            Updated Daily — {currentMonth} {currentYear}
          </div>

          <h1 style={{ 
            fontSize: "clamp(2.5rem, 7vw, 4.5rem)", 
            fontWeight: 900, 
            lineHeight: 1.05, 
            letterSpacing: "-0.04em",
            marginBottom: "32px"
          }}>
            Free Udemy<br/>
            <span style={{ background: "var(--accent)", color: "white", padding: "0 10px" }}>Coupons.</span>
          </h1>

          <p style={{ 
            fontSize: "clamp(1.1rem, 3vw, 1.3rem)", 
            color: "var(--muted)", 
            maxWidth: "800px", 
            lineHeight: 1.6,
            fontWeight: 500,
            marginBottom: "48px"
          }}>
            Browse {totalDeals}+ verified Udemy deals with {freeDeals}+ free courses. Save up to {avgSavings}% on tech and business courses.
          </p>

          <div style="display: flex; gap: 16px; flex-wrap: wrap;">
            {[
              { v: `${totalDeals}+`, l: "Courses" },
              { v: `${freeDeals}+`, l: "100% Free" },
              { v: `${avgSavings}%`, l: "Avg Savings" }
            ].map(s => (
              <div style={{ background: "white", border: "2px solid var(--border)", padding: "12px 24px", borderRadius: "4px", boxShadow: "4px 4px 0 var(--border)", display: "flex", flexDirection: "column", alignItems: "center" }}>
                <span style="font-size: 1.5rem; font-weight: 900; color: var(--accent);">{s.v}</span>
                <span style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--muted);">{s.l}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* Page 2+ header */}
    {currentPage > 1 && (
      <section style="padding: 64px 0 48px; border-bottom: 2px solid var(--border); background: var(--card);">
        <div class="container">
          <h1 style={{ fontSize: "2.5rem", fontWeight: 900, letterSpacing: "-0.04em", marginBottom: "8px" }}>
            Deals — Page {currentPage}
          </h1>
          <p style={{ color: "var(--muted)", fontWeight: 800, textTransform: "uppercase", fontSize: "0.8rem", letterSpacing: "0.1em" }}>
            Showing {startIndex + 1}–{Math.min(endIndex, allDeals.length)} of {allDeals.length} courses
          </p>
        </div>
      </section>
    )}

    {/* ── DEALS GRID ── */}
    <section style="padding: 80px 0;">
      <div class="container">

        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px;">
          <div>
            <h2 style="font-size: 2rem; font-weight: 900; margin: 0; letter-spacing: -0.04em;">Latest Deals.</h2>
            <p style="color: var(--muted); font-weight: 500; margin-top: 8px;">Freshly verified Udemy promo codes</p>
          </div>
          <a href="/categories" class="btn btn-outline" style="padding: 12px 24px; font-size: 0.85rem;">
            BROWSE CATEGORIES
          </a>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; margin-bottom: 64px;">
          {currentItems.map((deal: any) => (
            <DealCard deal={deal} />
          ))}
        </div>

        {/* ── PAGINATION ── */}
        {totalPages > 1 && (
          <nav aria-label="Pagination" style="margin-top: 64px; padding-top: 48px; border-top: 2px solid var(--border);">
            <div style="display: flex; justify-content: center; align-items: center; gap: 16px; flex-wrap: wrap;">
              {prevUrl ? (
                <a href={prevUrl} class="btn btn-outline" style="padding: 12px 24px;">← PREV</a>
              ) : (
                <span class="btn btn-disabled" style="padding: 12px 24px; opacity: 0.5;">← PREV</span>
              )}

              <div style="display: flex; gap: 8px;">
                {pageItems.map((item) => {
                  if (item.type === 'ellipsis') {
                    return <span style="font-weight: 900; color: var(--muted); padding: 0 8px;">...</span>;
                  }
                  const isActive = item.value === currentPage;
                  const href = item.value === 1 ? baseDealsUrl : `${baseDealsUrl}/${item.value}`;
                  return (
                    <a href={href} class={isActive ? "btn btn-active" : "btn btn-outline"} style="width: 44px; height: 44px; padding: 0; display: flex; align-items: center; justify-content: center; font-size: 0.9rem;">
                      {item.value}
                    </a>
                  );
                })}
              </div>

              {nextUrl ? (
                <a href={nextUrl} class="btn" style="padding: 12px 24px;">NEXT →</a>
              ) : (
                <span class="btn btn-disabled" style="padding: 12px 24px; opacity: 0.5;">NEXT →</span>
              )}
            </div>
            <p style="text-align: center; color: var(--muted); font-weight: 800; font-size: 0.75rem; text-transform: uppercase; margin-top: 24px; letter-spacing: 0.05em;">
              Page {currentPage} of {totalPages}
            </p>
          </nav>
        )}

      </div>
    </section>

    {/* ── FAQ — page 1 only ── */}
    {currentPage === 1 && (
      <section style="padding: 80px 0; background: var(--card); border-top: 2px solid var(--border);">
        <div class="container" style="max-width: 800px;">
          <h2 style="font-size: 2.5rem; font-weight: 900; margin-bottom: 48px; text-align: center; letter-spacing: -0.02em;">Common Questions.</h2>
          <div style="display: flex; flex-direction: column; gap: 16px;">
            {faqs.map((faq) => (
              <details class="neo-faq-details">
                <summary style="padding: 24px; font-weight: 900; cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-size: 1.1rem;">
                  {faq.q}
                  <span style="color: var(--accent); font-size: 1.5rem;">+</span>
                </summary>
                <div style="padding: 0 24px 24px; color: var(--muted); font-size: 1rem; line-height: 1.6; font-weight: 500;">
                  {faq.a}
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>
</Layout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .btn-active { background: var(--accent) !important; color: white !important; border-color: var(--border) !important; }
  .neo-faq-details { background: white; border: 2px solid var(--border); border-radius: 8px; margin-bottom: 16px; box-shadow: 4px 4px 0 var(--border); }
  .neo-faq-details[open] { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--border); }
  summary::-webkit-details-marker { display: none; }
</style>