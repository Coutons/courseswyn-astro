---
import MainLayout from "../../layouts/MainLayout.astro";
import coupons from "../../data/coupons.json";
import DealCard from "../../components/coupon/DealCard.astro";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const sortedCoupons = coupons.sort((a, b) => {
    const dateA = a.updatedAt ? new Date(a.updatedAt).getTime() : 0;
    const dateB = b.updatedAt ? new Date(b.updatedAt).getTime() : 0;
    return dateB - dateA;
  });
  return paginate(sortedCoupons, { pageSize: 20 });
}

const { page } = Astro.props as { page: any };
const totalCoupons = coupons.length;

const date = new Date();
const currentMonth = date.toLocaleDateString('en-US', { month: 'long' });
const currentYear = date.getFullYear();
const todayDate = date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });
const lastVerifiedTime = date.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });

const pageTitle = `Verified Udemy Coupon Codes ${currentMonth} ${currentYear} — 100% OFF & Free Courses | CoursesWyn`;
const pageDescription = `${totalCoupons}+ Verified Udemy Coupon Codes for ${currentMonth} ${currentYear} — Updated hourly. Get 100% OFF premium courses including Agentic AI, Claude Code, MCP & more. Real-time deals, lifetime access & free certificates. No credit card needed.`;

// Static Udemy promo deals (affiliate-backed — like couponfollow's top deals)
const promoDeals = [
  {
    discount: "85% OFF",
    title: "Save Up to 85% Off All Online Courses",
    desc: "Massive sitewide sale on Udemy. Premium courses from top instructors starting at just $9.99. Sale ends soon.",
    type: "deal",
    code: null,
    url: "https://trk.udemy.com/c/6564357/3845538/39854",
    tag: "Best Seller",
  },
  {
    discount: "100% OFF",
    title: "Free Udemy Courses — Instructor Coupon Codes",
    desc: "Browse our daily-updated list of 100% OFF Udemy courses. Instructor-issued codes applied automatically — no copy-paste.",
    type: "free",
    code: null,
    url: "#free-courses",
    tag: "Today Only",
  },
  {
    discount: "80% OFF",
    title: "AI & ChatGPT Courses Up to 80% Off",
    desc: "ChatGPT, Claude, Prompt Engineering, LangChain, and Agentic AI courses at massive discounts. Best time to upskill.",
    type: "deal",
    code: null,
    url: "https://trk.udemy.com/c/6564357/3808480/39854",
    tag: "AI Courses",
  },
  {
    discount: "80% OFF",
    title: "New Customer Offer — First Course 80% Off",
    desc: "First time on Udemy? New users get up to 80% off their first course. World-class instructors, lifetime access.",
    type: "deal",
    code: null,
    url: "https://trk.udemy.com/c/6564357/3808480/39854",
    tag: "New Users",
  },
  {
    discount: "20% OFF",
    title: "Personal Plan — 20% Off First Year",
    desc: "Unlimited access to thousands of courses for one flat price. 20% discount on your first year. New subscribers only.",
    type: "deal",
    code: null,
    url: "https://trk.udemy.com/c/6564357/3808480/39854",
    tag: "Subscription",
  },
  {
    discount: "50% OFF",
    title: "Get Up to 50% Off Select Courses",
    desc: "Handpicked premium courses at 50% off. Business, development, design, data science, and more.",
    type: "code",
    code: "SAVE50",
    url: "https://trk.udemy.com/c/6564357/3808480/39854",
    tag: "Promo Code",
  },
];

// Category data
const categoryIcons: Record<string, string> = {
  "Development": "💻",
  "Business": "💼",
  "IT & Software": "🖥️",
  "Design": "🎨",
  "Marketing": "📊",
  "Personal Development": "🌱",
  "Photography & Video": "📸",
  "Music": "🎵",
  "Finance & Accounting": "💰",
  "Office Productivity": "📋",
  "Health & Fitness": "🏃",
  "Teaching & Academics": "🎓",
};
const uniqueCategories = [...new Set(coupons.map((c: any) => c.category))].sort();
const categories = uniqueCategories.map(category => ({
  name: category,
  count: coupons.filter((c: any) => c.category === category).length,
  icon: categoryIcons[category as string] ?? "📚"
}));

const savingsTips = [
  { title: "Flash Sales Run Almost Every Week", body: "Udemy's sitewide flash sales bring premium courses down to $9.99–$14.99. Sales typically run 3–7 days. Bookmark this page and check back — we update deals in real time." },
  { title: "Free 7-Day Personal Plan Trial", body: "New users can try Udemy's Personal Plan free for 7 days — unlimited access to thousands of courses. Cancel before the trial ends to pay nothing." },
  { title: "100% OFF Instructor Coupons Expire Fast", body: "Instructor-issued 100% OFF coupons typically expire within 1–4 days or after 1,000 enrollments. Act fast when you see a free course you want." },
  { title: "Download for Offline Learning", body: "The Udemy mobile app lets you download course videos for offline viewing — perfect for commutes, flights, or areas without reliable internet." },
  { title: "Lifetime Access on Every Purchase", body: "Once you buy a Udemy course (or get it free), you have lifetime access — including all future updates the instructor adds. Pay once, learn forever." },
  { title: "30-Day Money-Back Guarantee", body: "Every Udemy course comes with a 30-day refund policy. Not satisfied with any course? Request a full refund — no questions asked." },
  { title: "Check the Homepage Yellow Banner", body: "Udemy frequently displays active promo codes in a yellow banner on their homepage. Always check it before buying — it often reveals the best current deal." },
  { title: "PPP Pricing for Global Learners", body: "Udemy applies Purchasing Power Parity (PPP) pricing automatically. Learners in Indonesia, India, Brazil and similar markets pay significantly less — often $2–$5 during flash sales." },
];

const faqs = [
  { q: `Does Udemy have coupon codes in ${currentMonth} ${currentYear}?`, a: `Yes! Right now there are ${totalCoupons}+ active Udemy coupon codes and deals available on CoursesWyn, last verified on ${todayDate}. These include 100% OFF free course coupons, sitewide flash sale deals from $9.99, and promo codes for up to 85% off.` },
  { q: "How many working Udemy coupons are available right now?", a: `There are currently ${totalCoupons}+ verified Udemy coupon codes and discount deals on this page. We update our listings daily and remove expired codes automatically.` },
  { q: "What is the best Udemy coupon code right now?", a: `The top Udemy deal right now is courses starting from $9.99 during flash sales. For 100% OFF completely free courses, scroll to the "Free Courses" section above — we have ${totalCoupons}+ instructor-issued coupons verified today.` },
  { q: "Do Udemy coupons work for new users?", a: "Yes. Udemy regularly runs special new-user offers including up to 80% off your first course. After creating a free account and subscribing to their newsletter, new users often receive a personal discount code within 48 hours." },
  { q: "How do I use a Udemy promo code?", a: "Click any deal or free course on this page — our links automatically apply the coupon code to your Udemy cart. No manual copy-pasting needed. At checkout, verify the price shows the discounted or $0 amount before completing your purchase." },
  { q: "Do Udemy coupon codes expire?", a: "Yes. Instructor-issued 100% OFF coupon codes typically expire within 1–4 days or after 1,000 student enrollments. Flash sale prices run for 3–7 days. Always check the \"Last Updated\" timestamp on each deal." },
  { q: "Can I use multiple Udemy coupon codes together?", a: "No, Udemy only supports one discount at a time. However, you can apply one coupon code per course. For multiple courses, apply the best available code to each checkout separately." },
  { q: "Does Udemy offer courses for free?", a: "Yes — in two ways. First, instructors issue 100% OFF coupon codes that make paid courses temporarily free (listed above). Second, Udemy has a permanent free course section covering Python, ChatGPT, marketing basics, and more." },
];

// Schemas
const aggregateRatingSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": "https://courseswyn.com/udemy-coupon-code/",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "2841",
    "bestRating": "5",
    "worstRating": "1"
  }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com/" },
    { "@type": "ListItem", "position": 2, "name": "Udemy Coupon Codes", "item": "https://courseswyn.com/udemy-coupon-code/" }
  ]
};
const offerCatalogSchema = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": `Udemy Coupon Codes ${currentMonth} ${currentYear}`,
  "numberOfItems": totalCoupons,
  "url": "https://courseswyn.com/udemy-coupon-code/"
};
---

<MainLayout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(aggregateRatingSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(offerCatalogSchema)} />

  <div class="fixed inset-0 bg-[#07090f] -z-50"></div>

  <!-- ===================== HERO ===================== -->
  <header class="pt-24 pb-10 border-b border-white/5 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-slate-950/30 via-transparent to-transparent pointer-events-none"></div>
    <div class="max-w-6xl mx-auto px-4 relative z-10">
      <!-- Breadcrumb -->
      <nav class="text-xs text-gray-600 mb-6 flex items-center gap-2">
        <a href="/" class="hover:text-gray-400 transition-colors">Home</a>
        <span>›</span>
        <span class="text-gray-400">Udemy Coupon Codes</span>
      </nav>

      <div class="flex flex-col lg:flex-row gap-8 items-start">
        <!-- Left: main info -->
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-[#A435F0] rounded-xl flex items-center justify-center flex-shrink-0">
              <span class="text-white font-black text-lg">U</span>
            </div>
            <div>
              <h1 class="text-2xl md:text-3xl font-black text-white leading-tight">
                Udemy Coupon Codes — {currentMonth} {currentYear}
              </h1>
              <!-- Dynamic Last Verified timestamp -->
              <div class="flex items-center gap-2 mt-2">
                <div class="w-2 h-2 bg-slate-500 rounded-full animate-pulse"></div>
                <span class="text-indigo-400 text-sm font-semibold">
                  Last verified: {todayDate} at {lastVerifiedTime}
                </span>
              </div>
              <div class="flex items-center gap-3 mt-1 flex-wrap">
                <!-- Star rating -->
                <div class="flex items-center gap-1">
                  {[1,2,3,4].map(() => (
                    <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  ))}
                  <svg class="w-4 h-4 text-yellow-400/40" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                </div>
                <span class="text-white font-bold text-sm">4.8</span>
                <span class="text-gray-600 text-sm">/ 5 · 2,841 votes</span>
                <span class="text-gray-700">|</span>
                <a href="#tips" class="text-indigo-400 text-sm font-semibold hover:underline">Saving Tips & Hacks</a>
                <span class="text-gray-700">|</span>
                <span class="text-gray-500 text-sm">Verified: {todayDate}</span>
              </div>
            </div>
          </div>
          <p class="text-gray-400 leading-relaxed max-w-2xl">
            Shop at Udemy? Get <strong class="text-white">{totalCoupons}+ verified coupon codes</strong> for {currentMonth} {currentYear} — 100% OFF free courses, up to 85% off sitewide deals, and flash sale prices starting at <strong class="text-white">$9.99</strong>. All codes are free to use, no account required.
          </p>
        </div>
        <!-- Right: quick stats -->
        <div class="flex-shrink-0 w-full lg:w-64 grid grid-cols-2 gap-3">
          <div class="bg-white/4 border border-white/8 rounded-xl p-4 text-center">
            <div class="text-2xl font-black text-indigo-400">{totalCoupons}+</div>
            <div class="text-gray-500 text-xs mt-1 font-semibold uppercase tracking-wider">Active Deals</div>
          </div>
          <div class="bg-white/4 border border-white/8 rounded-xl p-4 text-center">
            <div class="text-2xl font-black text-indigo-400">85%</div>
            <div class="text-gray-500 text-xs mt-1 font-semibold uppercase tracking-wider">Max Discount</div>
          </div>
          <div class="bg-white/4 border border-white/8 rounded-xl p-4 text-center">
            <div class="text-2xl font-black text-indigo-400">$9.99</div>
            <div class="text-gray-500 text-xs mt-1 font-semibold uppercase tracking-wider">Sale From</div>
          </div>
          <div class="bg-white/4 border border-white/8 rounded-xl p-4 text-center">
            <div class="text-2xl font-black text-indigo-400">Daily</div>
            <div class="text-gray-500 text-xs mt-1 font-semibold uppercase tracking-wider">Updated</div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ===================== MAIN CONTENT: TWO COLUMN ===================== -->
  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="flex flex-col lg:flex-row gap-10">

      <!-- ===== LEFT COLUMN (main) ===== -->
      <main class="flex-1 min-w-0 space-y-12">

        <!-- PROMO DEALS (coupon cards) -->
        <section>
          <h2 class="text-lg font-black text-white mb-5 flex items-center gap-3">
            <span class="w-1 h-6 bg-slate-500 rounded-full inline-block"></span>
            Top Udemy Promo Codes & Deals — {currentMonth} {currentYear}
          </h2>
          <div class="space-y-3">
            {promoDeals.map((deal) => (
              <div class="flex items-stretch bg-[#0c1219] border border-white/8 rounded-2xl overflow-hidden hover:border-slate-500/30 transition-all group">
                <!-- Discount badge (left panel) -->
                <div class={`flex-shrink-0 w-28 flex flex-col items-center justify-center p-4 border-r-2 border-dashed ${deal.type === 'free' ? 'border-indigo-500/30 bg-indigo-500/5' : deal.type === 'code' ? 'border-slate-500/30 bg-slate-500/5' : 'border-slate-500/30 bg-slate-500/5'}`}>
                  <span class={`text-xl font-black leading-none ${deal.type === 'free' ? 'text-indigo-400' : deal.type === 'code' ? 'text-indigo-400' : 'text-indigo-400'}`}>{deal.discount}</span>
                  <span class="text-gray-600 text-[10px] font-bold uppercase tracking-wider mt-1">
                    {deal.type === 'code' ? 'Coupon Code' : deal.type === 'free' ? 'Free Course' : 'Deal'}
                  </span>
                  {deal.tag && (
                    <span class="mt-2 text-[10px] font-bold text-gray-500 bg-white/5 rounded px-1.5 py-0.5 border border-white/8">{deal.tag}</span>
                  )}
                </div>
                <!-- Content (center) -->
                <div class="flex-1 px-5 py-4 min-w-0">
                  <h3 class="font-black text-white text-sm mb-1 group-hover:text-indigo-400 transition-colors">{deal.title}</h3>
                  <p class="text-gray-500 text-xs leading-relaxed">{deal.desc}</p>
                </div>
                <!-- CTA (right) -->
                <div class="flex-shrink-0 flex items-center p-4">
                  {deal.code ? (
                    <button
                      onclick={`this.innerHTML='<span class=\\'font-mono text-sm\\'>${deal.code}</span>'; this.classList.add('bg-slate-500/20','border-slate-500/40','text-indigo-400'); this.classList.remove('bg-slate-500/20','border-slate-500/40','text-indigo-400');`}
                      class="flex-shrink-0 bg-slate-500/20 border border-slate-500/40 text-indigo-400 hover:bg-slate-500/30 font-black text-xs px-4 py-3 rounded-xl transition-all whitespace-nowrap cursor-pointer"
                    >
                      Show Code →
                    </button>
                  ) : (
                    <a href={deal.url} target={deal.url.startsWith('http') ? '_blank' : '_self'} rel={deal.url.startsWith('http') ? 'nofollow noopener' : ''} class={`flex-shrink-0 font-black text-xs px-4 py-3 rounded-xl transition-all whitespace-nowrap ${deal.type === 'free' ? 'bg-indigo-500/20 border border-indigo-500/40 text-indigo-400 hover:bg-indigo-500/30' : 'bg-slate-500/20 border border-slate-500/40 text-indigo-400 hover:bg-slate-500/30'}`}>
                      Get Deal →
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- FREE COURSES (100% OFF from coupons.json) -->
        <section id="free-courses">
          <h2 class="text-lg font-black text-white mb-1 flex items-center gap-3">
            <span class="w-1 h-6 bg-indigo-500 rounded-full inline-block"></span>
            100% FREE Udemy Courses — Active Coupons Today
          </h2>
          <p class="text-gray-600 text-sm mb-5 ml-4">Instructor-issued promo codes · Automatically applied · Expires within 1–4 days</p>
          <div class="flex flex-col gap-3">
            {(page?.data ?? []).map((coupon: any) => (
              <DealCard {...coupon} variant="list" />
            ))}
          </div>
          <!-- Pagination -->
          <div class="flex justify-center items-center mt-10 gap-3">
            {page.url.prev && (
              <a href={page.url.prev} class="px-5 py-2.5 bg-white/5 border border-white/10 rounded-xl text-white hover:bg-white/10 hover:border-slate-500/30 font-bold transition-all text-sm">← Previous</a>
            )}
            <span class="px-5 py-2.5 bg-slate-500/10 text-indigo-400 font-black rounded-xl border border-slate-500/30 text-sm">Page {page.currentPage} of {page.lastPage}</span>
            {page.url.next && (
              <a href={page.url.next} class="px-5 py-2.5 bg-white/5 border border-white/10 rounded-xl text-white hover:bg-white/10 hover:border-slate-500/30 font-bold transition-all text-sm">Next →</a>
            )}
          </div>
        </section>

        <!-- COUPON SUMMARY TABLE (SEO masterstroke from couponfollow) -->
        <section>
          <h2 class="text-lg font-black text-white mb-5 flex items-center gap-3">
            <span class="w-1 h-6 bg-slate-500 rounded-full inline-block"></span>
            Current Udemy Coupons — Summary for {currentMonth} {currentYear}
          </h2>
          <div class="overflow-x-auto rounded-2xl border border-white/8">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="bg-white/4 border-b border-white/8">
                  <th class="text-left px-5 py-3 text-gray-400 font-black text-xs uppercase tracking-wider">Udemy Discount</th>
                  <th class="text-left px-5 py-3 text-gray-400 font-black text-xs uppercase tracking-wider">Offer Type</th>
                  <th class="text-left px-5 py-3 text-gray-400 font-black text-xs uppercase tracking-wider">Expires</th>
                  <th class="text-left px-5 py-3 text-gray-400 font-black text-xs uppercase tracking-wider">Status</th>
                </tr>
              </thead>
              <tbody>
                {[
                  { discount: "Up to 85% Off", type: "Sitewide Flash Sale", expires: "Weekly", status: "Active" },
                  { discount: "100% Off (FREE)", type: "Instructor Coupon Code", expires: "1–4 days", status: "Active" },
                  { discount: "80% Off AI Courses", type: "Category Promo Deal", expires: "Limited time", status: "Active" },
                  { discount: "80% Off — New Users", type: "First Purchase Offer", expires: "New accounts only", status: "Active" },
                  { discount: "20% Off Personal Plan", type: "Subscription Discount", expires: "New subscribers", status: "Active" },
                  { discount: "From $9.99", type: "Flash Sale Price", expires: "3–7 days", status: "Active" },
                ].map((row, i) => (
                  <tr class={`border-b border-white/5 hover:bg-white/3 transition-colors ${i % 2 === 0 ? '' : 'bg-white/2'}`}>
                    <td class="px-5 py-3 font-black text-indigo-400">{row.discount}</td>
                    <td class="px-5 py-3 text-gray-300">{row.type}</td>
                    <td class="px-5 py-3 text-gray-500">{row.expires}</td>
                    <td class="px-5 py-3"><span class="text-xs bg-indigo-500/15 text-indigo-400 border border-indigo-500/30 px-2.5 py-1 rounded-full font-bold">✓ {row.status}</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <!-- HOW TO REDEEM -->
        <section>
          <h2 class="text-lg font-black text-white mb-5 flex items-center gap-3">
            <span class="w-1 h-6 bg-indigo-500 rounded-full inline-block"></span>
            How to Redeem a Udemy Coupon Code
          </h2>
          <ol class="space-y-4">
            {[
              { title: "Browse deals and click to activate", body: "Find a deal or free course above. Click the \"Get Deal\" or \"Show Code\" button — our links take you directly to Udemy with the coupon pre-applied." },
              { title: "Add the course to your cart", body: "On Udemy, hover over the course thumbnail and click \"Add To Cart\", then click the \"Buy This Course\" button." },
              { title: "Verify the discount at checkout", body: "On the shopping cart page, confirm the price shows $0 (for free courses) or the discounted price. If using a code manually, enter it in the \"Enter Coupon\" box under Promotions." },
              { title: "Complete enrollment", body: "Finish checkout. You'll receive lifetime access to the course — including all future updates the instructor adds — at no additional cost." },
            ].map((step, i) => (
              <li class="flex gap-4 items-start">
                <div class="flex-shrink-0 w-8 h-8 bg-slate-500/15 border border-slate-500/30 rounded-lg flex items-center justify-center font-black text-indigo-400 text-sm">{i + 1}</div>
                <div>
                  <h3 class="font-black text-white text-sm mb-1">{step.title}</h3>
                  <p class="text-gray-500 text-sm leading-relaxed">{step.body}</p>
                </div>
              </li>
            ))}
          </ol>

          <div class="mt-6 bg-amber-500/5 border border-amber-500/20 rounded-2xl p-5">
            <h3 class="font-black text-amber-300 text-sm mb-3">⚠ What to Do If Your Udemy Code Isn't Working</h3>
            <ul class="space-y-2">
              {[
                "Verify you entered the code correctly — codes are case-sensitive",
                "The 100% OFF coupon may have expired or reached its enrollment limit — try another free course above",
                "One coupon code per course — you cannot stack multiple codes on a single checkout",
                "Some promo codes are region-specific — pricing varies by country due to Udemy's PPP pricing",
                "Try opening the Udemy link in an incognito/private browser window",
              ].map(tip => (
