---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import { readDeals } from "../../lib/store";
import { slugifyCategory } from "../../lib/utils";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const allDeals = await readDeals();
  return paginate(allDeals, { pageSize: 36 });
}

const { page } = Astro.props as { page: any };
const allDeals = await readDeals();
const now = new Date();

const currentItems = page.data;
const currentPage = page.currentPage;
const totalPages = page.lastPage;
const startIndex = page.start;
const endIndex = page.end + 1;

const activeDeals = allDeals.filter((d: any) => !d.expiresAt || new Date(d.expiresAt) > now);
const totalCoupons = allDeals.length;
const totalActive = activeDeals.length;
const freeDeals = allDeals.filter((d: any) => d.price === 0);
const totalFree = freeDeals.length;

let totalSavings = 0;
for (const d of allDeals) {
  if (d.originalPrice && d.price != null && d.originalPrice > 0) {
    totalSavings += (d.originalPrice - d.price);
  }
}
const savingsFormatted = Math.round(totalSavings).toLocaleString();

const selectedLanguage = Astro.url.searchParams.get('language');

const siteUrl = "https://courseswyn.com";
const baseDealsUrl = `${siteUrl}/udemy-coupon-code`;
const langQuery = selectedLanguage ? `?language=${encodeURIComponent(selectedLanguage)}` : "";
const currentUrl = currentPage === 1 ? `${baseDealsUrl}${langQuery}` : `${baseDealsUrl}/${currentPage}${langQuery}`;
const prevUrl = page.url.prev ? `${page.url.prev}${langQuery}` : null;
const nextUrl = page.url.next ? `${page.url.next}${langQuery}` : null;

const currentDate = new Date();
const monthNames = ["January","February","March","April","May","June",
  "July","August","September","October","November","December"];
const currentMonth = monthNames[currentDate.getMonth()];
const currentYear = currentDate.getFullYear();

const pageTitle = "Udemy Coupon Code - Verified Discount | CoursesWyn";

const pageDescription = `${totalActive} verified Udemy coupons & ${totalFree} free courses. Over $${savingsFormatted} in total savings. Updated daily.`;

function timeLeft(expiresAt: string): string {
  const diff = new Date(expiresAt).getTime() - now.getTime();
  if (diff <= 0) return 'Expired';
  const hours = Math.floor(diff / 3600000);
  const days = Math.floor(hours / 24);
  if (days > 0) return `${days}d left`;
  if (hours > 0) return `${hours}h left`;
  return '<1h left';
}

function mapCard(d: any) {
  const students = d.students ? d.students.toLocaleString() : null;
  const instructor = d.instructor || null;
  const expiry = d.expiresAt ? timeLeft(d.expiresAt) : null;
  let discount: string | null;
  if (d.price === 0) {
    discount = 'FREE';
  } else if (d.originalPrice && d.originalPrice > 0 && d.price != null) {
    const pct = Math.round((1 - d.price / d.originalPrice) * 100);
    discount = `${pct}% OFF`;
  } else {
    discount = null;
  }
  let ratingStars = '';
  if (d.rating) {
    const full = Math.min(5, Math.max(0, Math.round(d.rating)));
    ratingStars = '★'.repeat(full) + '☆'.repeat(5 - full);
  }
  return {
    slug: d.slug || d.id,
    image: d.image,
    title: d.title,
    students,
    instructor: typeof instructor === 'string' ? instructor.split(',')[0].trim() : null,
    expiry,
    discount,
    rating: d.rating,
    ratingStars,
    language: d.language || null,
    duration: d.duration || null,
    price: d.price,
    originalPrice: d.originalPrice,
  };
}

const paidCards = currentItems.filter((d: any) => d.price > 0 || d.price == null).map(mapCard);

const catsSet = new Set<string>();
allDeals.forEach((d: any) => { if (d.category) catsSet.add(d.category); });
const categories = Array.from(catsSet).sort();

const topicCounts: Record<string, number> = {};
for (const d of allDeals) {
  topicCounts[d.category || 'Other'] = (topicCounts[d.category || 'Other'] || 0) + 1;
}
const trendingTopics = Object.entries(topicCounts).sort((a, b) => b[1] - a[1]).slice(0, 12);

const faqs = [
  { q: "Are these Udemy coupon codes legitimate and safe?", a: "Yes! All Udemy coupons listed on CoursesWyn are 100% legitimate. We source codes directly from Udemy's official affiliate program and verified course instructors. Each coupon is manually tested by our team before listing." },
  { q: "How do I get Udemy courses for free with 100% off coupons?", a: "Getting free Udemy courses is simple: (1) Browse our deals page and find a course you want, (2) Click the 'Redeem Deal' button, (3) You'll be redirected to Udemy with the discount pre-applied, (4) Verify the price shows $0.00 at checkout, (5) Click 'Enroll Now' — no payment needed." },
  { q: "How often are new free Udemy courses added?", a: "We update our database every single day with fresh Udemy coupons. New 100% off courses are added as soon as instructors release them. Bookmark this page and check back regularly." },
  { q: "Do free Udemy courses give certificates of completion?", a: "Absolutely! When you enroll in a free Udemy course using our 100% off coupons, you receive the exact same certificate as students who paid full price — lifetime access included." },
  { q: "Why do some Udemy coupons say 'This coupon has expired'?", a: "Udemy coupons have two expiration triggers: time limit (usually 3-7 days) OR redemption limit (typically 1,000 students). Once either limit is hit, the coupon stops working. Return to CoursesWyn — we refresh our listings multiple times daily." },
  { q: "Is there a catch? Why are these courses free?", a: "No catch! Instructors offer free coupons for strategic marketing: building student numbers, generating reviews for new courses, and boosting algorithm rankings. You get premium education at zero cost — a win-win." },
];

const jsonLd: any = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${currentUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "All Coupons", "item": baseDealsUrl },
        ...(currentPage > 1 ? [{ "@type": "ListItem", "position": 3, "name": `Page ${currentPage}`, "item": currentUrl }] : [])
      ]
    },
    {
      "@type": "CollectionPage",
      "@id": currentUrl,
      "url": currentUrl,
      "name": pageTitle,
      "description": pageDescription,
      "isPartOf": { "@id": siteUrl },
      "breadcrumb": { "@id": `${currentUrl}#breadcrumb` },
      "dateModified": currentDate.toISOString().split('T')[0],
      "inLanguage": "en-US",
      "mainEntity": {
        "@type": "ItemList",
        "name": `Verified Udemy Coupons — ${currentMonth} ${currentYear}`,
        "numberOfItems": allDeals.length,
        "itemListElement": currentItems.slice(0, 20).map((d: any, i: number) => ({
          "@type": "ListItem",
          "position": startIndex + i + 1,
          "item": {
            "@type": "Course",
            "name": d.title,
            "url": `${siteUrl}/coupon/${d.slug}`,
            "image": d.image,
            "provider": { "@type": "Organization", "name": "Udemy", "url": "https://www.udemy.com" },
            "offers": {
              "@type": "Offer",
              "price": String(d.price ?? "0"),
              "priceCurrency": "USD",
              "availability": "https://schema.org/InStock",
            },
          },
        })),
      },
    },
    ...(currentPage === 1 ? [{
      "@type": "FAQPage",
      "@id": `${baseDealsUrl}#faq`,
      "mainEntity": faqs.map((f: any) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    }] : []),
  ],
};

const pageItems: ({ type: 'page'; value: number } | { type: 'ellipsis'; id: string })[] = [];
const windowSize = 2;
let lastAdded = 0;
for (let p = 1; p <= totalPages; p++) {
  const inWindow = p >= currentPage - windowSize && p <= currentPage + windowSize;
  if (p === 1 || p === totalPages || inWindow) {
    if (lastAdded > 0 && p - lastAdded > 1) {
      pageItems.push({ type: 'ellipsis', id: `gap-${p}` });
    }
    pageItems.push({ type: 'page', value: p });
    lastAdded = p;
  }
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={currentUrl}
  hideBreadcrumbs={true}
>
  <Fragment slot="head">
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
    {currentPage > 1 && <meta name="robots" content="noindex, follow" />}
  </Fragment>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <main class="cc-root">
    <div class="cc-container">

      <nav class="cc-breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li aria-hidden="true">/</li>
          <li>Verified Coupons</li>
          {currentPage > 1 && <><li aria-hidden="true">/</li><li>Page {currentPage}</li></>}
        </ol>
      </nav>

      <header class="cc-header">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="cc-header-icon"><path d="M6 2h12l4 4v14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6l4-4z"/><path d="M2 6h20"/><path d="M16 2v4H8V2"/><rect x="8" y="10" width="8" height="6"/></svg>
        <h1 class="cc-title">
          Verified Udemy Coupons
          {currentPage > 1 && <span class="cc-page-label">Page {currentPage}</span>}
        </h1>
        <p class="cc-subtitle">Browse verified Udemy coupons &mdash; saving students over <strong>${savingsFormatted}</strong> in total</p>
        <div class="cc-stats-bar">
          <div class="cc-stat">
            <span class="cc-stat-value">{totalCoupons}</span>
            <span class="cc-stat-label">Total Coupons</span>
          </div>
          <div class="cc-stat-divider"></div>
          <div class="cc-stat">
            <span class="cc-stat-value">{totalActive}</span>
            <span class="cc-stat-label">Still Active</span>
          </div>
          <div class="cc-stat-divider"></div>
          <div class="cc-stat">
            <span class="cc-stat-value">{totalFree}+</span>
            <span class="cc-stat-label">100% Free</span>
          </div>
        </div>
      </header>

      <div class="cc-filter-bar">
        <h3 class="cc-filter-bar-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="4" y1="4" x2="20" y2="4"/><line x1="8" y1="10" x2="20" y2="10"/><line x1="12" y1="16" x2="20" y2="16"/><circle cx="6" cy="4" r="1.5" fill="currentColor"/><circle cx="10" cy="10" r="1.5" fill="currentColor"/><circle cx="14" cy="16" r="1.5" fill="currentColor"/></svg>
          Categories
        </h3>
        <div class="cc-filter-links">
          <a href="/udemy-coupon-code" class="cc-filter-chip cc-filter-active">All</a>
          {categories.slice(0, 15).map((cat: string) => (
            <a href={`/categories/${slugifyCategory(cat)}`} class="cc-filter-chip">{cat}</a>
          ))}
        </div>
      </div>

      <section class="cc-deals-section">
        <div class="cc-deals-header">
          <h2 class="cc-deals-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            {currentPage === 1 ? 'Latest Coupons' : 'Latest Coupons'}
          </h2>
          <p class="cc-deals-desc">{currentItems.length} deals on this page</p>
        </div>
        <div class="cc-grid">
          {paidCards.map((deal: any) => (
            <a href={`/coupon/${deal.slug}`} class="cc-card">
              <div class="cc-card-img">
                <img src={deal.image} alt={deal.title} loading="lazy" decoding="async" onerror="this.style.display='none'" />
                {deal.discount && <span class="cc-badge-off">{deal.discount}</span>}
                {deal.language && <span class="cc-badge-lang">{deal.language}</span>}
                {deal.expiry && <span class="cc-badge-expiry">{deal.expiry}</span>}
              </div>
              <div class="cc-card-body">
                {deal.rating && (
                  <div class="cc-rating">
                    <span class="cc-stars">{deal.ratingStars}</span>
                    <span class="cc-rating-value">{deal.rating.toFixed(1)}</span>
                  </div>
                )}
                <h3 class="cc-card-title">{deal.title}</h3>
                {deal.instructor && <p class="cc-instructor">{deal.instructor}</p>}
                <div class="cc-meta">
                  {deal.students && <span>{deal.students} students</span>}
                  {deal.duration && <span>{deal.duration.replace(/^(\d+)\s*hours?.*$/i, '$1h')}</span>}
                </div>
                <div class="cc-price-row">
                  <div class="cc-price">
                    {deal.price === 0 ? (
                      <span class="cc-price-free">FREE</span>
                    ) : (
                      <>
                        <span class="cc-price-sale">${deal.price?.toFixed(2)}</span>
                        {deal.originalPrice && deal.originalPrice > 0 && (
                          <span class="cc-price-orig">${deal.originalPrice.toFixed(2)}</span>
                        )}
                      </>
                    )}
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>

          {totalPages > 1 && (
            <nav class="cc-pagination" aria-label="Pagination">
              {prevUrl ? (
                <a href={prevUrl} class="cc-page-link cc-page-prev">← Prev</a>
              ) : (
                <span class="cc-page-link cc-page-disabled">← Prev</span>
              )}
              <div class="cc-page-numbers">
                {pageItems.map((item: any) => {
                  if (item.type === 'ellipsis') {
                    return <span class="cc-page-ellipsis">...</span>;
                  }
                  const isActive = item.value === currentPage;
                  const href = item.value === 1 ? `/udemy-coupon-code${langQuery}` : `/udemy-coupon-code/${item.value}${langQuery}`;
                  return isActive
                    ? <span class="cc-page-num cc-page-active">{item.value}</span>
                    : <a href={href} class="cc-page-num">{item.value}</a>;
                })}
              </div>
              {nextUrl ? (
                <a href={nextUrl} class="cc-page-link cc-page-next">Next →</a>
              ) : (
                <span class="cc-page-link cc-page-disabled">Next →</span>
              )}
            </nav>
          )}
        </section>

        <section class="cc-seo-section">
            <h2>How CoursesWyn verifies Udemy coupons</h2>
            <p>Since <a href="https://teach.udemy.com/update-for-instructors-improving-free-coupons-better-targeting-higher-quality-learning/" rel="noopener" target="_blank">Udemy's free coupon policy update</a>, most coupons are limited to about 10 to 100 redemptions or expire within days. CoursesWyn checks every coupon against Udemy in near real time. When a coupon runs out, it disappears from this list automatically.</p>
            <p>New coupons are added throughout the day. Browse <a href="/udemy-coupons-today">today's latest deals</a> or explore <a href="/udemy-coupon-code">all verified coupons</a>.</p>
          </section>

          <section class="cc-section cc-faq">
            <h2 class="cc-section-title">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              Frequently asked questions
            </h2>
            {faqs.map((faq: any) => (
              <div class="cc-faq-item">
                <h3 class="cc-faq-q">{faq.q}</h3>
                <p class="cc-faq-a">{faq.a}</p>
              </div>
            ))}
          </section>

    </div>
  </main>
</Layout>

<style>
  .cc-root { background: var(--bg); padding: 2rem 1rem 4rem; }
  .cc-container { max-width: 1024px; margin: 0 auto; }

  .cc-breadcrumb { display: flex; justify-content: center; margin-bottom: 1rem; }
  .cc-breadcrumb ol { list-style: none; display: flex; align-items: center; gap: 0.5rem; padding: 0; margin: 0; font-size: 0.8rem; color: var(--muted); }
  .cc-breadcrumb li:not(:last-child)::after { content: '/'; margin-left: 0.5rem; color: var(--border); }
  .cc-breadcrumb a { color: var(--brand); text-decoration: none; }
  .cc-breadcrumb a:hover { text-decoration: underline; }

  .cc-header { text-align: center; margin-bottom: 2rem; }
  .cc-header-icon { display: block; margin: 0 auto 0.75rem; color: var(--brand); }
  .cc-title { font-size: 1.8rem; font-weight: 900; color: var(--text); margin: 0 0 0.5rem; letter-spacing: -0.03em; }
  .cc-page-label { font-size: 1.1rem; font-weight: 700; color: var(--muted); letter-spacing: normal; margin-left: 0.5rem; }
  .cc-subtitle { font-size: 0.92rem; color: var(--muted); max-width: 600px; margin: 0 auto 1.5rem; line-height: 1.65; }
  .cc-subtitle strong { color: var(--brand); font-weight: 700; }

  .cc-stats-bar { display: inline-flex; align-items: center; gap: 1.5rem; background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 0.75rem 1.5rem; }
  .cc-stat { display: flex; flex-direction: column; align-items: center; gap: 0.1rem; }
  .cc-stat-value { font-size: 1.15rem; font-weight: 800; color: var(--text); }
  .cc-stat-label { font-size: 0.68rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; white-space: nowrap; }
  .cc-stat-divider { width: 1px; height: 32px; background: var(--border); }

  .cc-filter-bar { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 0.75rem 1rem; margin-bottom: 1.5rem; }
  .cc-filter-bar-title { font-size: 0.75rem; font-weight: 800; color: var(--text); margin: 0 0 0.5rem; display: flex; align-items: center; gap: 0.35rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .cc-filter-bar-title svg { color: var(--brand); width: 13px; height: 13px; }
  .cc-filter-links { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .cc-filter-chip { font-size: 0.78rem; font-weight: 600; color: var(--muted); text-decoration: none; padding: 3px 10px; border-radius: 100px; border: 1px solid var(--border); transition: all 0.2s; background: var(--bg); }
  .cc-filter-chip:hover { border-color: var(--brand); color: var(--brand); }
  .cc-filter-active { background: var(--brand); color: white; border-color: var(--brand); }
  .cc-filter-active:hover { color: white; }

  .cc-deals-section { margin-bottom: 2rem; }
  .cc-deals-header { margin-bottom: 1rem; }
  .cc-deals-title { font-size: 1.1rem; font-weight: 800; color: var(--text); margin: 0 0 0.15rem; display: flex; align-items: center; gap: 0.5rem; }
  .cc-deals-title svg { color: var(--brand); flex-shrink: 0; }
  .cc-deals-desc { font-size: 0.85rem; color: var(--muted); margin: 0; }

  .cc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.85rem; }

  .cc-card { display: flex; flex-direction: column; background: var(--card); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; text-decoration: none; transition: all 0.2s; }
  .cc-card:hover { border-color: var(--brand); transform: translateY(-2px); }
  .cc-card-img { position: relative; width: 100%; aspect-ratio: 16/9; overflow: hidden; background: var(--border); }
  .cc-card-img img { width: 100%; height: 100%; object-fit: cover; }
  .cc-badge-off { position: absolute; top: 6px; left: 6px; background: linear-gradient(135deg, var(--brand), #1d4ed8); color: white; font-size: 0.65rem; font-weight: 800; padding: 2px 7px; border-radius: 3px; }
  .cc-badge-expiry { position: absolute; top: 6px; right: 6px; background: rgba(220,38,38,0.85); backdrop-filter: blur(4px); color: white; font-size: 0.6rem; font-weight: 700; padding: 2px 7px; border-radius: 3px; display: inline-flex; align-items: center; gap: 3px; }
  .cc-badge-lang { position: absolute; bottom: 6px; left: 6px; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); color: white; font-size: 0.6rem; font-weight: 600; padding: 2px 7px; border-radius: 3px; }
  .cc-card-body { padding: 0.65rem; display: flex; flex-direction: column; gap: 0.3rem; flex: 1; }
  .cc-rating { display: flex; align-items: center; gap: 0.3rem; }
  .cc-stars { color: #f59e0b; font-size: 0.7rem; letter-spacing: 0.05em; }
  .cc-rating-value { font-size: 0.7rem; font-weight: 700; color: var(--muted); }
  .cc-card-title { font-size: 0.82rem; font-weight: 600; color: var(--text); margin: 0; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .cc-card:hover .cc-card-title { color: var(--brand); }
  .cc-instructor { font-size: 0.7rem; color: var(--muted); margin: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .cc-meta { display: flex; align-items: center; gap: 0.5rem; font-size: 0.68rem; color: var(--muted); flex-wrap: wrap; }
  .cc-price-row { margin-top: auto; padding-top: 0.4rem; border-top: 1px solid var(--border); display: flex; align-items: center; }
  .cc-price { display: flex; align-items: baseline; gap: 0.4rem; }
  .cc-price-free { font-size: 0.85rem; font-weight: 800; color: var(--brand); }
  .cc-price-sale { font-size: 0.85rem; font-weight: 800; color: var(--text); }
  .cc-price-orig { font-size: 0.7rem; font-weight: 500; color: var(--muted); text-decoration: line-through; }

  .cc-pagination { display: flex; align-items: center; justify-content: center; gap: 0.75rem; padding: 1.5rem 0; border-top: 1px solid var(--border); }
  .cc-page-link { font-size: 0.85rem; font-weight: 700; color: var(--brand); text-decoration: none; padding: 0.4rem 0.85rem; border-radius: 6px; border: 1px solid var(--border); transition: all 0.2s; }
  .cc-page-link:hover { border-color: var(--brand); background: color-mix(in srgb, var(--brand) 6%, transparent); }
  .cc-page-disabled { color: var(--muted); opacity: 0.4; pointer-events: none; }
  .cc-page-numbers { display: flex; align-items: center; gap: 4px; }
  .cc-page-num { font-size: 0.85rem; font-weight: 700; color: var(--text); text-decoration: none; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; border-radius: 6px; border: 1px solid var(--border); transition: all 0.2s; }
  .cc-page-num:hover { border-color: var(--brand); color: var(--brand); }
  .cc-page-active { background: var(--brand); color: white; border-color: var(--brand); }
  .cc-page-active:hover { color: white; }
