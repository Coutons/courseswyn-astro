---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import DealCard from "../../components/DealCard.astro";
import { readDeals } from "../../lib/store";
import { slugifyCategory } from "../../lib/utils";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const allDeals = await readDeals();
  return paginate(allDeals, { pageSize: 12 });
}

const { page } = Astro.props as { page: any };
const currentItems = page.data;
const currentPage = page.currentPage;
const totalPages = page.lastPage;

// We still need allDeals for stats
const allDeals = await readDeals();

const catsSet = new Set<string>();
allDeals.forEach((d: any) => { if (d.category) catsSet.add(d.category); });
const categories = Array.from(catsSet).sort();

const selectedLanguage = Astro.url.searchParams.get('language');
let filteredDeals = allDeals;

const startIndex = page.start;
const endIndex = page.end + 1; // page.end is inclusive, so +1 for display math

// Pagination URLs
const siteUrl = "https://courseswyn.com";
const baseDealsUrl = `${siteUrl}/udemy-coupon-code`;
const langQuery = selectedLanguage ? `?language=${encodeURIComponent(selectedLanguage)}` : "";
const currentUrl = currentPage === 1 ? `${baseDealsUrl}${langQuery}` : `${baseDealsUrl}/${currentPage}${langQuery}`;

const prevUrl = page.url.prev ? `${page.url.prev}${langQuery}` : null;
const nextUrl = page.url.next ? `${page.url.next}${langQuery}` : null;

// Dynamic SEO
const currentDate = new Date();
const monthNames = ["January","February","March","April","May","June",
  "July","August","September","October","November","December"];
const currentMonth = monthNames[currentDate.getMonth()];
const currentYear = currentDate.getFullYear();

// Real stats from data
const totalDeals = allDeals.length;
const freeDeals = allDeals.filter((d: any) => d.price === 0 || d.price === null).length;
const avgSavings = (() => {
  const valid = allDeals.filter((d: any) => d.originalPrice && d.price !== undefined && d.originalPrice > 0);
  if (valid.length === 0) return 90;
  const total = valid.reduce((sum: number, d: any) =>
    sum + ((d.originalPrice - (d.price ?? 0)) / d.originalPrice) * 100, 0);
  return Math.round(total / valid.length);
})();

// Page-aware title & description - SEO optimized
const langSuffix = selectedLanguage ? ` in ${selectedLanguage}` : "";
const pageTitle = currentPage === 1
  ? `Verified Udemy Coupon Codes${langSuffix} [${currentMonth} ${currentYear}] | CoursesWyn`
  : `Udemy Coupon Codes${langSuffix} — Page ${currentPage} of ${totalPages} | CoursesWyn`;

const pageDescription = currentPage === 1
  ? `Browse verified Udemy coupon codes and 100% off deals${langSuffix}. Find promo codes for programming, Python, JavaScript, AWS, data science & more. Updated daily with working coupons.`
  : `Browse page ${currentPage} of verified Udemy deals${langSuffix}. Working coupon codes updated daily on CoursesWyn.`;

// FAQ data - SEO optimized with long-tail keywords
const faqs = [
  {
    q: "Are these Udemy coupon codes legitimate and safe?",
    a: "Yes! All Udemy coupons listed on CoursesWyn are 100% legitimate. We source codes directly from Udemy's official affiliate program and verified course instructors. Each coupon is manually tested by our team before listing. These are official promotional codes — not hacks or exploits. You get the exact same course content, certificates, and lifetime access as paying students."
  },
  {
    q: "How do I get Udemy courses for free with 100% off coupons?",
    a: "Getting free Udemy courses is simple: (1) Browse our deals page and find a course you want, (2) Click the 'Get Coupon' or 'Redeem Deal' button, (3) You'll be redirected to Udemy with the discount pre-applied, (4) Verify the price shows $0.00 at checkout, (5) Click 'Enroll Now' — no payment needed. The course is instantly added to your library with lifetime access."
  },
  {
    q: "How often are new free Udemy courses added?",
    a: "We update our database every single day with fresh Udemy coupons. New 100% off courses are added as soon as instructors release them — sometimes multiple times per day. Our team monitors Udemy daily to catch the best free course opportunities before redemption limits are reached. Bookmark this page and check back regularly."
  },
  {
    q: "Do free Udemy courses give certificates of completion?",
    a: "Absolutely! When you enroll in a free Udemy course using our 100% off coupons, you receive the exact same certificate as students who paid full price. You can download your certificate as a PDF or share it directly to LinkedIn. The certificate does not indicate that you got the course for free — it looks identical to paid certificates."
  },
  {
    q: "Why do some Udemy coupons say 'This coupon has expired'?",
    a: "Udemy coupons have two expiration triggers: time limit (usually 3-7 days) OR redemption limit (typically 1,000 students). Once either limit is hit, the coupon stops working. If you see an expired message, return to CoursesWyn — we refresh our listings multiple times daily and likely have a working replacement coupon for that course."
  },
  {
    q: "Can I use these Udemy coupons if I'm not in the United States?",
    a: "Yes! Most Udemy coupons work worldwide. However, pricing varies by country due to Udemy's regional pricing. A 100% off coupon might show a different (but still heavily discounted) price in some regions. The discount is always applied relative to your local pricing tier. Coupons sourced directly from instructors typically work globally."
  },
  {
    q: "Is there a catch? Why are these courses free?",
    a: "No catch! Instructors offer free coupons for strategic marketing reasons: building initial student numbers, generating reviews for new courses, boosting algorithm rankings, or attracting students to their paid course portfolios. You get premium education at zero cost — the instructor gets social proof and potential future customers. It's a win-win."
  }
];

// Pagination items
type PageItem = { type: 'page'; value: number } | { type: 'ellipsis', id: string };
const pageItems: PageItem[] = [];
const windowSize = 2;
let lastAdded = 0;
for (let p = 1; p <= totalPages; p++) {
  const inWindow = p >= currentPage - windowSize && p <= currentPage + windowSize;
  if (p === 1 || p === totalPages || inWindow) {
    if (lastAdded > 0 && p - lastAdded > 1) {
      pageItems.push({ type: 'ellipsis', id: `gap-${p}` });
    }
    pageItems.push({ type: 'page', value: p });
    lastAdded = p;
  }
}

// JSON-LD
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${currentUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Udemy Deals & Coupons", "item": baseDealsUrl },
        ...(currentPage > 1 ? [{ "@type": "ListItem", "position": 3, "name": `Page ${currentPage}`, "item": currentUrl }] : [])
      ]
    },
    {
      "@type": "CollectionPage",
      "@id": currentUrl,
      "url": currentUrl,
      "name": pageTitle,
      "description": pageDescription,
      "isPartOf": { "@id": siteUrl },
      "breadcrumb": { "@id": `${currentUrl}#breadcrumb` },
      "dateModified": currentDate.toISOString().split('T')[0],
      "inLanguage": "en-US",
      "mainEntity": {
        "@type": "ItemList",
        "name": `Udemy Deals & Free Coupons — ${currentMonth} ${currentYear}`,
        "description": `${totalDeals}+ verified Udemy course deals with ${freeDeals}+ free options`,
        "numberOfItems": allDeals.length,
        "itemListElement": currentItems.map((deal: any, index: number) => ({
          "@type": "ListItem",
          "position": startIndex + index + 1,
          "item": {
            "@type": "Course",
            "name": deal.title,
            "description": deal.description || `Get ${deal.title} free with a verified 100% off coupon on CoursesWyn.`,
            "url": `${siteUrl}/coupon/${deal.slug}`,
            "image": deal.image,
            "provider": {
              "@type": "Organization",
              "name": deal.provider || "Udemy",
              "url": "https://www.udemy.com"
            },
            "offers": {
              "@type": "Offer",
              "price": String(deal.price ?? "0"),
              "priceCurrency": "USD",
              "availability": "https://schema.org/InStock",
              "priceValidUntil": deal.expiresAt || new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
              "seller": { "@type": "Organization", "name": "CoursesWyn", "url": siteUrl }
            },
            ...(deal.rating ? {
              "aggregateRating": {
                "@type": "AggregateRating",
                "ratingValue": deal.rating.toString(),
                "bestRating": "5",
                "worstRating": "1",
                "ratingCount": Math.max(1, Math.round(deal.students ?? 1000))
              }
            } : {})
          }
        }))
      }
    },
    ...(currentPage === 1 ? [{
      "@type": "FAQPage",
      "@id": `${baseDealsUrl}#faq`,
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": { "@type": "Answer", "text": faq.a }
      }))
    }] : [])
  ]
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={currentUrl}
>
  <Fragment slot="head">
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
    {currentPage > 1 && <meta name="robots" content="noindex, follow" />}
  </Fragment>

  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <main style={{ background: "#fafafa" }}>

    {/* ── HERO ── */}
    {currentPage === 1 && (
      <section style={{ background: "white", borderBottom: "1px solid #e5e7eb", paddingTop: "96px", paddingBottom: "48px" }}>
        <div class="container" style={{ maxWidth: "90rem", margin: "0 auto", padding: "0 1.5rem" }}>
          <div style={{ maxWidth: "768px" }}>
            <h1 style={{ fontSize: "clamp(2.5rem, 5vw, 3.5rem)", fontWeight: 900, letterSpacing: "-0.03em", color: "#111827", margin: "0 0 16px", lineHeight: 1.1 }}>
              {totalDeals}+ Free Udemy Coupons
            </h1>
            <p style={{ fontSize: "1.125rem", color: "#6b7280", lineHeight: 1.6, maxWidth: "640px", margin: "0 0 8px", fontWeight: 500 }}>
              Verified working coupon codes for {currentMonth} {currentYear}. Get {freeDeals}+ completely free courses — programming, Python, JavaScript, AWS, data science & more.
            </p>
            <p style={{ fontSize: "0.95rem", color: "#6b7280", lineHeight: 1.6, margin: "0 0 32px", fontWeight: 500 }}>
              <strong style={{ color: "#111827" }}>How it works:</strong> Click any course below, the discount auto-applies at checkout. No credit card needed for free coupons.
            </p>
            <div style={{ display: "flex", gap: "12px", flexWrap: "wrap" }}>
              {[
                { v: `${totalDeals}+`, l: "Courses" },
                { v: `${freeDeals}+`, l: "100% Free" },
                { v: `${avgSavings}%`, l: "Avg Savings" }
              ].map(s => (
                <div style={{ background: "#f9fafb", border: "1px solid #e5e7eb", padding: "10px 20px", borderRadius: "12px", display: "flex", flexDirection: "column", alignItems: "center" }}>
                  <span style={{ fontSize: "1.5rem", fontWeight: 900, color: "#f97316" }}>{s.v}</span>
                  <span style={{ fontSize: "0.75rem", fontWeight: 700, textTransform: "uppercase", color: "#6b7280", letterSpacing: "0.05em" }}>{s.l}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    {/* Page 2+ header */}
    {currentPage > 1 && (
      <section style={{ background: "white", borderBottom: "1px solid #e5e7eb", paddingTop: "96px", paddingBottom: "48px" }}>
        <div class="container">
          <h1 style={{ fontSize: "2.5rem", fontWeight: 900, letterSpacing: "-0.03em", color: "#111827", margin: "0 0 8px" }}>
            {selectedLanguage ? `${selectedLanguage} Courses` : 'Deals'} — Page {currentPage}
          </h1>
          <p style={{ color: "#6b7280", fontWeight: 600, textTransform: "uppercase", fontSize: "0.8rem", letterSpacing: "0.1em" }}>
            Showing {startIndex + 1}–{Math.min(endIndex, filteredDeals.length)} of {filteredDeals.length} courses
          </p>
        </div>
      </section>
    )}

    {/* ── MAIN LAYOUT: sidebar + content ── */}
    <div class="container" style={{ maxWidth: "90rem", margin: "0 auto", padding: "0 1.5rem", display: "flex", gap: "24px", paddingTop: "32px", paddingBottom: "64px" }}>

      {/* Sidebar */}
      <aside style={{ width: "240px", flexShrink: 0 }} class="deals-sidebar">
        <div style={{ position: "sticky", top: "96px", display: "flex", flexDirection: "column", gap: "24px" }}>

          {/* Search */}
          <div>
            <h3 style={{ fontSize: "0.75rem", fontWeight: 900, textTransform: "uppercase", letterSpacing: "0.1em", color: "#111827", margin: "0 0 8px" }}>Search</h3>
            <form action="/udemy-coupon-code" method="get" style={{ position: "relative" }}>
              <svg style={{ position: "absolute", left: "10px", top: "50%", transform: "translateY(-50%)", color: "#9ca3af", width: "14px", height: "14px" }} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input type="text" name="q" placeholder="Find courses..." style={{ width: "100%", padding: "8px 10px 8px 32px", background: "white", border: "1px solid #e5e7eb", borderRadius: "8px", fontSize: "0.85rem", fontWeight: 500, color: "#111827", outline: "none" }} />
            </form>
          </div>

          <div style={{ height: "1px", background: "#e5e7eb" }}></div>

          {/* Categories */}
          <div>
            <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: "8px" }}>
              <h3 style={{ fontSize: "0.75rem", fontWeight: 900, textTransform: "uppercase", letterSpacing: "0.1em", color: "#111827", margin: 0 }}>Categories</h3>
            </div>
            <div style={{ display: "flex", flexDirection: "column", gap: "2px" }}>
              <a href={baseDealsUrl} style={{ display: "flex", alignItems: "center", justifyContent: "space-between", padding: "6px 10px", fontSize: "0.85rem", borderRadius: "8px", textDecoration: "none", fontWeight: 700, color: "#f97316", background: "#fff7ed" }}>
                <span>All</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
              {categories.slice(0, 10).map((cat: string) => {
                const catSlug = slugifyCategory(cat);
                return (
                  <a href={`/categories/${catSlug}`} style={{ display: "flex", alignItems: "center", justifyContent: "space-between", padding: "6px 10px", fontSize: "0.85rem", borderRadius: "8px", textDecoration: "none", fontWeight: 600, color: "#6b7280" }}
                    onmouseover="this.style.background='#f9fafb';this.style.color='#111827'" onmouseout="this.style.background='';this.style.color='#6b7280'">
                    <span style={{ overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>{cat}</span>
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      </aside>

      {/* Main Content */}
      <div style={{ flex: 1, minWidth: 0 }}>

        {/* SEO Description */}
        {currentPage === 1 && (
          <div style={{ marginBottom: "32px", padding: "24px", background: "white", border: "1px solid #e5e7eb", borderRadius: "16px" }}>
            <h2 style={{ fontSize: "1.25rem", fontWeight: 900, color: "#111827", margin: "0 0 12px", letterSpacing: "-0.02em" }}>
              Why Use Udemy 100% Off Coupons?
            </h2>
            <p style={{ color: "#6b7280", fontSize: "0.9rem", lineHeight: 1.7, fontWeight: 500, margin: 0 }}>
              Udemy 100% off coupons reduce courses to <strong style={{ color: "#111827" }}>$0.00 — completely free</strong>. These are legitimate promotional codes issued by instructors to build their student base. When you enroll, you get the same full content, lifetime access, and certificate as paying students. Browse our verified deals below — updated daily.
            </p>
          </div>
        )}

        {/* Section header */}
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-end", marginBottom: "32px" }}>
          <div>
            <h2 style={{ fontSize: "1.5rem", fontWeight: 900, color: "#111827", margin: 0, letterSpacing: "-0.02em" }}>
              {currentPage === 1 ? `Free Courses` : `Page ${currentPage} — Free Courses`}
            </h2>
            <p style={{ color: "#6b7280", fontSize: "0.9rem", fontWeight: 500, marginTop: "4px" }}>
              {currentPage === 1
                ? `100% off coupon codes for ${currentMonth} ${currentYear}`
                : `Showing ${startIndex + 1}–${Math.min(endIndex, filteredDeals.length)} of ${filteredDeals.length} deals`
              }
            </p>
          </div>
          <a href="/categories" style={{ color: "#111827", textDecoration: "none", fontWeight: 700, fontSize: "0.9rem", borderBottom: "2px solid rgba(0,0,0,0.15)", paddingBottom: "2px", whiteSpace: "nowrap" }}>
            Browse Categories
          </a>
        </div>

        {/* Deals Grid */}
        <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(300px, 1fr))", gap: "20px", marginBottom: "48px" }}>
          {currentItems.length > 0 ? (
            currentItems.map((deal: any) => (
              <DealCard deal={deal} />
            ))
          ) : (
            <div style={{ gridColumn: "1 / -1", textAlign: "center", padding: "64px 24px", background: "white", border: "1px solid #e5e7eb", borderRadius: "16px" }}>
              <div style={{ fontSize: "3rem", marginBottom: "16px" }}>🔍</div>
              <h3 style={{ fontSize: "1.25rem", fontWeight: 900, color: "#111827", marginBottom: "8px" }}>No {selectedLanguage} Courses Found</h3>
              <p style={{ color: "#6b7280", fontWeight: 500, marginBottom: "24px" }}>We couldn't find any verified free courses in {selectedLanguage} right now.</p>
              <a href={baseDealsUrl} style={{ padding: "12px 32px", borderRadius: "10px", background: "#111827", color: "white", textDecoration: "none", fontWeight: 700, fontSize: "0.9rem", display: "inline-flex", alignItems: "center", gap: "6px" }}>
                View All Courses
              </a>
            </div>
          )}
        </div>

        {/* ── PAGINATION ── */}
        {totalPages > 1 && (
          <nav aria-label="Pagination" style={{ paddingTop: "32px", borderTop: "1px solid #e5e7eb" }}>
            <div style={{ display: "flex", justifyContent: "center", alignItems: "center", gap: "12px", flexWrap: "wrap" }}>
              {prevUrl ? (
                <a href={prevUrl} style={{ padding: "10px 20px", borderRadius: "10px", border: "1px solid #e5e7eb", background: "white", color: "#111827", textDecoration: "none", fontWeight: 700, fontSize: "0.85rem", transition: "all 0.2s" }}
                  onmouseover="this.style.borderColor='#f97316';this.style.color='#f97316'" onmouseout="this.style.borderColor='#e5e7eb';this.style.color='#111827'">← PREV</a>
              ) : (
                <span style={{ padding: "10px 20px", borderRadius: "10px", border: "1px solid #e5e7eb", background: "#f9fafb", color: "#d1d5db", fontWeight: 700, fontSize: "0.85rem" }}>← PREV</span>
              )}

              <div style={{ display: "flex", gap: "6px" }}>
                {pageItems.map((item: any) => {
                  if (item.type === 'ellipsis') {
                    return <span style={{ fontWeight: 700, color: "#9ca3af", padding: "0 6px" }}>...</span>;
                  }
                  const isActive = item.value === currentPage;
                  const href = item.value === 1 ? `${baseDealsUrl}${langQuery}` : `${baseDealsUrl}/${item.value}${langQuery}`;
                  return (
                    <a href={href} style={{
                      width: "40px", height: "40px", padding: 0, display: "flex", alignItems: "center", justifyContent: "center",
                      borderRadius: "10px", fontSize: "0.85rem", fontWeight: 700, textDecoration: "none", transition: "all 0.2s",
                      background: isActive ? "#f97316" : "white",
                      color: isActive ? "white" : "#111827",
                      border: isActive ? "none" : "1px solid #e5e7eb"
                    }}
                    onmouseover={"this.style.background='#f97316';this.style.color='white';this.style.borderColor='#f97316'" }
                    onmouseout={isActive ? "" : "this.style.background='white';this.style.color='#111827';this.style.borderColor='#e5e7eb'"}
                    >
                      {item.value}
                    </a>
                  );
                })}
              </div>

              {nextUrl ? (
                <a href={nextUrl} style={{ padding: "10px 20px", borderRadius: "10px", border: "1px solid #e5e7eb", background: "white", color: "#111827", textDecoration: "none", fontWeight: 700, fontSize: "0.85rem", transition: "all 0.2s" }}
                  onmouseover="this.style.borderColor='#f97316';this.style.color='#f97316'" onmouseout="this.style.borderColor='#e5e7eb';this.style.color='#111827'">NEXT →</a>
              ) : (
                <span style={{ padding: "10px 20px", borderRadius: "10px", border: "1px solid #e5e7eb", background: "#f9fafb", color: "#d1d5db", fontWeight: 700, fontSize: "0.85rem" }}>NEXT →</span>
              )}
            </div>
            <p style={{ textAlign: "center", color: "#9ca3af", fontWeight: 700, fontSize: "0.75rem", textTransform: "uppercase", marginTop: "16px", letterSpacing: "0.05em" }}>
              Page {currentPage} of {totalPages}
            </p>
          </nav>
        )}

      </div>
    </div>

    {/* ── FAQ — page 1 only ── */}
    {currentPage === 1 && (
      <section style={{ background: "white", borderTop: "1px solid #e5e7eb", padding: "80px 0" }}>
        <div class="container" style={{ maxWidth: "800px", margin: "0 auto" }}>
          <h2 style={{ fontSize: "2rem", fontWeight: 900, color: "#111827", marginBottom: "8px", textAlign: "center", letterSpacing: "-0.02em" }}>
            Frequently Asked Questions
          </h2>
          <p style={{ textAlign: "center", color: "#6b7280", fontWeight: 500, marginBottom: "48px", lineHeight: 1.6, fontSize: "1rem" }}>
            Everything you need to know about getting Udemy courses for free with 100% off coupon codes
          </p>
          <div style={{ display: "flex", flexDirection: "column", gap: "12px" }}>
            {faqs.map((faq, idx) => (
              <details style={{ background: "white", border: "1px solid #e5e7eb", borderRadius: "12px", overflow: "hidden" }}>
                <summary style={{ padding: "20px 24px", fontWeight: 700, cursor: "pointer", display: "flex", justifyContent: "space-between", alignItems: "center", fontSize: "0.95rem", color: "#111827", listStyle: "none" }}>
                  {faq.q}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5" stroke-linecap="round" style={{ flexShrink: 0 }}><polyline points="6 9 12 15 18 9"/></svg>
                </summary>
                <div style={{ padding: "0 24px 20px", color: "#6b7280", fontSize: "0.9rem", lineHeight: 1.7, fontWeight: 500 }}>
                  {faq.a}
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* ── RELATED RESOURCES — page 1 only ── */}
    {currentPage === 1 && (
      <section style={{ background: "#fafafa", borderTop: "1px solid #e5e7eb", padding: "80px 0" }}>
        <div class="container">
          <h2 style={{ fontSize: "2rem", fontWeight: 900, color: "#111827", marginBottom: "8px", letterSpacing: "-0.02em", textAlign: "center" }}>
            Explore AI & Tech Learning Paths
          </h2>
          <p style={{ textAlign: "center", color: "#6b7280", fontWeight: 500, marginBottom: "48px", lineHeight: 1.6, maxWidth: "600px", margin: "0 auto 48px", fontSize: "1rem" }}>
            Discover the hottest AI courses with verified 100% off coupons. Master ChatGPT, AI agents, machine learning, and automation.
          </p>
          <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(280px, 1fr))", gap: "20px" }}>
            {[
              { title: "ChatGPT & Prompt Engineering", desc: "Master AI writing, coding, and automation with ChatGPT", link: "/blog/best-chatgpt-courses-udemy-2026", icon: "🤖" },
