---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - Page Not Found | CoursesWyn" description="Oops! The page you're looking for doesn't exist. Browse our free Udemy courses or search for what you need.">
  <main style="display:flex;align-items:center;justify-content:center;min-height:60vh;padding:2rem;text-align:center">
    <div>
      <h1 style="font-size:5rem;font-weight:800;color:#3b82f6;margin:0;line-height:1">404</h1>
      <p style="font-size:1.25rem;color:#94a3b8;margin:1rem 0 2rem">Page not found — the coupon may have expired or the link is broken.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.75rem 1.5rem;background:#3b82f6;color:#fff;border-radius:8px;text-decoration:none;font-weight:600">Home</a>
        <a href="/udemy-coupon-code" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.75rem 1.5rem;background:#1e293b;color:#e2e8f0;border-radius:8px;text-decoration:none;font-weight:600">Browse Coupons</a>
        <a href="/udemy-coupons-today" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.75rem 1.5rem;background:#1e293b;color:#e2e8f0;border-radius:8px;text-decoration:none;font-weight:600">Today's Deals</a>
      </div>
    </div>
  </main>
</Layout>

<style is:global>
  footer { margin-top: 0 !important; }
</style>
