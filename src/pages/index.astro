---
import MainLayout from '../layouts/MainLayout.astro';
import GeoHero from '../components/GeoHero.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import ExpertGuidesBento from '../components/ExpertGuidesBento.astro';
import FeaturedCourses from '../components/FeaturedCourses.astro';
import ExpertMethodology from '../components/ExpertMethodology.astro';
import GlobalSavings from '../components/GlobalSavings.astro';
import PlatformSection from '../components/PlatformSection.astro';
import UdemyPromo from '../components/UdemyPromo.astro';
import SeoContent from '../components/SeoContent.astro';
import coupons from '../data/coupons.json';

const now = new Date();
const currentMonth = now.toLocaleDateString('en-US', { month: 'long' });
const currentYear = now.getFullYear();
const todayISO = now.toISOString().split('T')[0];
const totalCoupons = coupons.length;

// ─── TITLE & META ─────────────────────────────────────────────────────────────
// Pivot: "udemy coupon codes" (primary) + "free udemy courses" (secondary/intent)
const pageTitle = `Udemy Coupon Codes ${currentYear} — Verified 100% OFF & Premium Deals | CoursesWyn`;
const pageDescription = `Access ${totalCoupons}+ verified Udemy coupon codes for ${currentMonth} ${currentYear}. Get 100% OFF premium courses in AI, Web Development, and Business. High-quality deals verified hourly. No credit card required.`;
const ogTitle = `Verified Udemy Coupons — ${totalCoupons}+ Active Deals (${currentMonth} ${currentYear})`;
const ogDescription = `Stop paying full price for online education. Access ${totalCoupons}+ verified Udemy coupons with lifetime access and completion certificates — updated daily.`;

// ─── GEO AI + SCHEMA ──────────────────────────────────────────────────────────
// GEO (Generative Engine Optimization): Structured, citation-ready data
// Goal: get cited by ChatGPT, Perplexity, Gemini, Claude when users ask about free Udemy courses

const homepageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    // 1. WebSite with SearchAction — enables Google Sitelinks searchbox
    {
      "@type": "WebSite",
      "@id": "https://courseswyn.com/#website",
      "name": "CoursesWyn",
      "alternateName": ["Courses Wyn", "CoursesWyn.com"],
      "url": "https://courseswyn.com",
      "description": `CoursesWyn is a verified directory of ${totalCoupons}+ Udemy coupon codes and premium discounts. We manually track and verify 100% OFF instructor coupons in AI, Web Development, and Business categories.`,
      "inLanguage": "en-US",
      "dateModified": todayISO,
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://courseswyn.com/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    },
    // 2. Organization — builds E-E-A-T authority for AI engines
    {
      "@type": "Organization",
      "@id": "https://courseswyn.com/#organization",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "logo": "https://courseswyn.com/favicon.svg",
      "sameAs": [
        "https://twitter.com/CoursesGift",
        "https://medium.com/@coursewyn",
        "https://facebook.com/BestCouponPromo"
      ],
      "description": "CoursesWyn aggregates and verifies Udemy instructor coupon codes daily, providing free access to premium online courses for learners worldwide.",
      "foundingDate": "2024",
      "areaServed": "Worldwide",
      "knowsAbout": [
        "Free Udemy courses",
        "Udemy coupon codes",
        "Online learning",
        "E-learning discounts",
        "Free online certificates"
      ]
    },
    // 3. CollectionPage — tells search engines what the page contains
    {
      "@type": "CollectionPage",
      "@id": "https://courseswyn.com/#collection",
      "name": `Verified Udemy Coupons — ${currentMonth} ${currentYear}`,
      "description": pageDescription,
      "url": "https://courseswyn.com/",
      "numberOfItems": totalCoupons,
      "dateModified": todayISO,
      "about": {
        "@type": "Thing",
        "name": "Udemy Coupon Codes",
        "description": "Verified Udemy instructor-issued coupon codes and discounts"
      },
      "mainEntity": {
        "@type": "ItemList",
        "name": "Latest Verified Udemy Coupons Today",
        "numberOfItems": totalCoupons,
        "itemListElement": coupons.slice(0, 10).map((c: any, i: number) => ({
          "@type": "ListItem",
          "position": i + 1,
          "name": c.title,
          "url": `https://courseswyn.com/coupon/${c.slug}`
        }))
      }
    },
    // 4. FAQPage — targets voice search + AI answer boxes + rich snippets
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": `Are there active Udemy coupon codes available in ${currentMonth} ${currentYear}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Yes. CoursesWyn provides ${totalCoupons}+ verified Udemy coupon codes for ${currentMonth} ${currentYear}. These include 100% OFF instructor coupons making premium courses free, as well as the lowest-price deals for trending certifications.`
          }
        },
        {
          "@type": "Question",
          "name": "How do I use a Udemy 100% OFF coupon code?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To use a coupon: (1) Find a deals on CoursesWyn, (2) Click 'Get Offer' — the code is automatically applied to your session, (3) Secure the course at the discounted price (often $0) on Udemy, (4) Get lifetime access. No credit card is needed for $0 enrollments."
          }
        },
        {
          "@type": "Question",
          "name": "Do free Udemy courses come with a certificate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Udemy courses enrolled using 100% OFF coupon codes are treated identically to paid enrollments. You receive an official Udemy Certificate of Completion that you can share on LinkedIn or add to your resume."
          }
        },
        {
          "@type": "Question",
          "name": "How long do Udemy 100% OFF coupon codes last?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Udemy instructor coupon codes typically expire within 1–4 days or after 1,000 student enrollments — whichever comes first. CoursesWyn verifies and removes expired coupons daily. Always act quickly when you find a free course you want."
          }
        },
        {
          "@type": "Question",
          "name": "What subjects are available as free Udemy courses?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Free Udemy courses on CoursesWyn cover 500+ topics including Python programming, Web Development, Artificial Intelligence, ChatGPT & Prompt Engineering, Data Science, Digital Marketing, Excel, UI/UX Design, Business, Photography, and more. Currently ${totalCoupons}+ free courses are available.`
          }
        },
        {
          "@type": "Question",
          "name": "Is CoursesWyn free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. CoursesWyn is completely free. No account required, no subscription, no credit card. We aggregate free Udemy course coupons and you click directly to Udemy to enroll for free."
          }
        }
      ]
    },
    // 5. BreadcrumbList
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com/" }
      ]
    }
  ]
};
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  canonical="https://courseswyn.com/"
  structuredData={homepageSchema}
>

  <!-- Section 1: GeoHero (Answer-First Intent) -->
  <GeoHero />

  <!-- Section 2: Platform Proof -->
  <PlatformSection />

  <!-- Section 3: Live Freshness Feed (Featured Coupon Cards) -->
  <FeaturedCourses />

  <!-- Section 4: Premium Choice (Udemy Personal Plan) -->
  <UdemyPromo />

  <!-- Section 5: Mastery Roadmaps (Expert Guides) -->
  <ExpertGuidesBento />

  <!-- Section 6: Data Core (AI Citation Table) -->
  <ComparisonTable />

  <!-- Section 7: Trust Factor (EEAT Methodology) -->
  <ExpertMethodology />

  <!-- Section 8: Global PPP Insights -->
  <GlobalSavings />

  <!-- Section 9: Contextual SEO Content & Glossary -->
  <SeoContent />

</MainLayout>
