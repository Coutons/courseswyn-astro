              autocomplete="off"
              aria-label="Search free Udemy courses"
            />
            <button type="submit" style={{
              padding: "0.75rem 1.75rem", background: "var(--brand)", color: "var(--bg)",
              border: "none", borderRadius: "12px", fontSize: "1rem", fontWeight: 600,
              cursor: "pointer", marginLeft: "0.5rem", display: "flex",
              alignItems: "center", gap: "0.5rem",
              boxShadow: "0 4px 12px hsla(45,95%,58%,0.3)"
            }}>
              Search
            </button>
          </div>
        </form>
      </div>

      <!-- CTA Buttons -->
      <div style={{ display: "flex", gap: "1rem", justifyContent: "center", flexWrap: "wrap", marginBottom: "3rem" }}>
        <a href="/udemy-coupon-code" class="btn accent-gradient" style={{
          padding: "1rem 2rem", fontSize: "1.1rem", fontWeight: 600,
          textDecoration: "none", borderRadius: "12px",
          display: "inline-flex", alignItems: "center", gap: "0.5rem",
          boxShadow: "0 8px 30px -4px hsla(45,95%,58%,0.3)"
        }}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          Browse All Udemy Deals
        </a>
        <a href="/categories" style={{
          padding: "1rem 2rem", fontSize: "1.1rem", fontWeight: 600,
          textDecoration: "none", borderRadius: "12px", background: "transparent",
          color: "var(--text)", border: "2px solid var(--border)",
          display: "inline-flex", alignItems: "center", gap: "0.5rem"
        }}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"/>
          </svg>
          Explore by Category
        </a>
