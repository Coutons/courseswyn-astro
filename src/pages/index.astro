<style>
  /* ─── Global Layout ─────────────────────────────────────────────────────── */
  .section-wrapper {
    width: 100%;
    padding: 4rem 1rem;
  }
  .section-wrapper--card {
    background: var(--card);
    border-radius: 24px;
    border: 1px solid var(--border);
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }
  .pill {
    padding: 0.6rem 1.25rem;
    border-radius: 9999px;
    background: var(--input);
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .pill:hover, .pill.active {
    background: var(--brand);
    color: var(--bg);
    border-color: var(--brand);
    transform: translateY(-1px);
  }
  .category-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
    border-color: var(--brand);
    background: var(--brand-soft) !important;
  }
  .category-card svg { transition: transform 0.2s ease; }
  .category-card:hover svg { transform: scale(1.1); }
  .category-card:hover div:last-child { color: var(--accent); }

  /* ─── Prose content section ─────────────────────────────────────────────── */
  .prose-section h2 {
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .prose-section h3 {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin: 1.5rem 0 0.5rem;
  }
  .prose-section p {
    color: var(--muted);
    line-height: 1.75;
    font-size: 1rem;
    margin-bottom: 1rem;
  }
  .prose-section a {
    color: var(--brand);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .hero-gradient {
    background: 
      radial-gradient(at 100% 0%, hsla(142, 72%, 29%, 0.1) 0px, transparent 50%),
      radial-gradient(at 0% 100%, hsla(160, 84%, 39%, 0.08) 0px, transparent 50%),
      var(--bg);
    border-bottom: 1px solid var(--border);
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (max-width: 768px) {
    h1 { font-size: 2.5rem !important; }
    .section-wrapper { padding: 3rem 1rem; }
    .featured-grid { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 480px) {
    h1 { font-size: 2rem !important; }
    h2 { font-size: 1.5rem !important; }
    .category-card { padding: 1rem !important; }
    .faq-grid { grid-template-columns: 1fr !important; }
  }
  html { scroll-behavior: smooth; }
</style>

