          <div style={{
            position: "absolute", top: "-12px", right: "20px", background: "var(--brand)",
            color: "var(--bg)", fontSize: "0.75rem", fontWeight: 700, padding: "0.25rem 0.75rem",
            borderRadius: "8px", textTransform: "uppercase"
