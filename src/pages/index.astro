function normName(raw?: string | null) {
  if (!raw) return undefined;
  let v = String(raw).trim();
  v = v.replace(/&amp;/gi, "&").replace(/\s+/g, " ");
  return v || undefined;
}
function slugifyCategory(name: string) {
  if (name === "Uncategorized") return "uncategorized";
  return name.toLowerCase()
    .replace(/&amp;/gi, "&")
    .replace(/&/g, " and ")
    .replace(/[^\w\s-]/g, "")
    .trim()
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-");
}
function getCategoryDescription(category: string) {
  const cat = category.toLowerCase();
  if (cat === "development")               return "Master programming, web development, and software engineering";
  if (cat === "programming")              return "Learn coding languages, algorithms, and software development fundamentals";
  if (cat === "it & software")            return "Learn IT infrastructure, cybersecurity, and software tools";
  if (cat.includes("business"))           return "Build business skills in management, finance, and entrepreneurship";
  if (cat === "finance")                  return "Master financial analysis, investment strategies, and accounting principles";
  if (cat.includes("marketing"))         return "Master digital marketing, SEO, and social media strategies";
  if (cat.includes("data") || cat.includes("analytics")) return "Learn data science, analytics, and machine learning techniques";
