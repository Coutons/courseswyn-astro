---
import Layout from "../layouts/Layout.astro";
import { Image } from 'astro:assets';
import { readDeals } from "../lib/store";
import { formatStringWIB, toISODateWIB } from "../lib/date";

const allDeals = await readDeals();

const todayStr = toISODateWIB(new Date());
const todayDeals = allDeals.filter((d) => {
  const dDate = toISODateWIB(new Date(d.updatedAt ?? d.createdAt ?? d.expiresAt ?? 0));
  return dDate === todayStr;
});

const now = new Date();
const activeDeals = allDeals.filter((d) => !d.expiresAt || new Date(d.expiresAt) > now);
const featuredDeals = activeDeals.sort((a, b) => new Date(b.updatedAt ?? b.createdAt ?? 0).getTime() - new Date(a.updatedAt ?? a.createdAt ?? 0).getTime()).slice(0, 8);

const categoryList = [...new Set(allDeals.map((d) => d.category).filter(Boolean))] as string[];
const totalStudents = allDeals.reduce((sum, d) => sum + (d.students ?? 0), 0);
const uniqueInstructors = [...new Set(allDeals.filter(d => d.instructor).map(d => d.instructor))].length;
const monthName = formatStringWIB(new Date(), { month: 'long', year: 'numeric' });
const pageTitle = `Free Udemy Courses 100% OFF Coupons & Promo Codes [${monthName}] | CoursesWyn`;
const pageDescription = `Get ${allDeals.length.toLocaleString()}+ verified Udemy coupon codes 100% OFF. Free access to top-rated courses in AI, Python, data science, cloud, and web development. Expert-reviewed & manually verified daily. Start learning for free at CoursesWyn.`;
const instructorUrl = "https://teach.udemy.com/update-for-instructors-improving-free-coupons-better-targeting-higher-quality-learning/";
const toISODate = (d?: string) => toISODateWIB(new Date(d ?? 0));

const jsonLd = {
  "@context": "https://schema.org", "@graph": [
    { "@type": "WebSite", "@id": "https://courseswyn.com/#website", "url": "https://courseswyn.com", "name": "CoursesWyn", "description": pageDescription, "potentialAction": { "@type": "SearchAction", "target": { "@type": "EntryPoint", "urlTemplate": "https://courseswyn.com/search?q={search_term_string}" }, "query-input": "required name=search_term_string" } },
    { "@type": "Organization", "@id": "https://courseswyn.com/#organization", "name": "CoursesWyn", "url": "https://courseswyn.com", "logo": { "@type": "ImageObject", "url": "https://courseswyn.com/logo.svg", "width": 200, "height": 60 }, "sameAs": ["https://twitter.com/CoursesGift", "https://facebook.com/BestCouponPromo"] },
    { "@type": "BreadcrumbList", "@id": "https://courseswyn.com/#breadcrumb", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" }, { "@type": "ListItem", "position": 2, "name": "Coupons", "item": "https://courseswyn.com/udemy-coupon-code" }] },
    { "@type": "FAQPage", "@id": "https://courseswyn.com/#faq", "mainEntity": [
      { "@type": "Question", "name": "Can free users use the coupons?", "acceptedAnswer": { "@type": "Answer", "text": "Free users can browse every deal. All coupons are unlocked — no premium paywall required. Click any deal and enroll directly on Udemy." } },
      { "@type": "Question", "name": "Where do the coupons come from?", "acceptedAnswer": { "@type": "Answer", "text": "From CoursesWyn proprietary discovery systems and instructor submissions. Every coupon is manually verified before listing. We do not accept auto-submitted or unverified coupons." } },
      { "@type": "Question", "name": "Why would instructors submit coupons here?", "acceptedAnswer": { "@type": "Answer", "text": "Public feeds burn coupons quickly. CoursesWyn brings them learners who are more likely to study, finish, and leave a review." } },
      { "@type": "Question", "name": "Do coupons always work?", "acceptedAnswer": { "@type": "Answer", "text": "CoursesWyn checks coupon validity close to real time. However, Udemy can still expire a coupon when its enrollment limit is reached. We remove expired deals within hours." } },
      { "@type": "Question", "name": "Do I need a Udemy account?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. CoursesWyn helps you find and open the coupon. Enrollment and course access happen on Udemy. A free Udemy account is all you need." } },
      { "@type": "Question", "name": "How to redeem a coupon?", "acceptedAnswer": { "@type": "Answer", "text": "Follow our step-by-step redemption guide on CoursesWyn to claim any coupon and enroll on Udemy in under 60 seconds." } }
    ] },
    { "@type": "WebPage", "@id": "https://courseswyn.com/#webpage", "url": "https://courseswyn.com", "name": pageTitle, "description": pageDescription, "isPartOf": { "@id": "https://courseswyn.com/#website" }, "datePublished": "2024-06-01", "dateModified": toISODate() }
  ]
};
---

<Layout title={pageTitle} description={pageDescription} canonical="https://courseswyn.com" image="/assets/images/og-default.svg">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

  <style>
    .hero-gradient-text {
      background: linear-gradient(135deg, var(--brand), #60a5fa, #3b82f6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .home-card-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.85rem;
      margin-bottom: 2.5rem;
    }

    .home-card {
      display: flex;
      flex-direction: column;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      text-decoration: none;
      transition: all 0.2s;
    }
    .home-card:hover {
      border-color: var(--brand);
      transform: translateY(-2px);
    }
    .home-card-img {
      position: relative;
      width: 100%;
      aspect-ratio: 16/9;
      overflow: hidden;
      background: var(--border);
    }
    .home-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .home-badge-off {
      position: absolute;
      top: 6px;
      left: 6px;
      background: linear-gradient(135deg, var(--brand), #1d4ed8);
      color: white;
      font-size: 0.65rem;
      font-weight: 800;
      padding: 2px 7px;
      border-radius: 3px;
    }
    .home-card-body {
      padding: 0.65rem;
      flex: 1;
    }
    .home-card-title {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--text);
      margin: 0 0 0.15rem;
      line-height: 1.35;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .home-card:hover .home-card-title {
      color: var(--brand);
    }
    .home-card-instructor {
      font-size: 0.7rem;
      color: var(--muted);
      margin: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    @media (max-width: 768px) {
      .home-card-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 0.65rem;
      }
    }
    @media (max-width: 480px) {
      .home-card-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content anim-up">
        <h1>
          <span style="display:block">Verified Udemy Coupons</span>
          <span class="hero-gradient-text" style="display:block;font-size:clamp(2.5rem,6vw,4.5rem)">100% OFF</span>
          <span style="display:block">Always Working</span>
        </h1>
        <p>Get instant access to top-rated Udemy courses for free.</p>
        <div class="hero-cta">
          <a href="/udemy-coupon-code" class="btn btn-primary btn-lg" style="border-radius:999px;padding:1rem 2.5rem">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            Browse Coupons
          </a>
          <a href="https://trk.udemy.com/c/6564357/3775958/39854" target="_blank" rel="noopener noreferrer" class="btn btn-ghost btn-lg" style="border-radius:999px;padding:1rem 2.5rem;color:#fbbf24;border-color:#fbbf24">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4l3 12h14l3-12-6 7-4-7-4 7-6-7z"/><path d="M3 20h18"/></svg>
            Unlock Coupon Access
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section style="padding-bottom:2rem">
    <div class="container">
      <div class="stat-grid">
        <div class="stat-box">
          <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg>
            <span class="stat-value">{allDeals.length.toLocaleString()}</span>
          </div>
          <div class="stat-label">Active Coupons</div>
        </div>
        <div class="stat-box">
          <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 7h6v6"/><path d="m22 7-8.5 8.5-5-5L2 17"/></svg>
            <span class="stat-value">{todayDeals.length.toLocaleString()}</span>
          </div>
          <div class="stat-label">Added Today</div>
        </div>
        <div class="stat-box">
          <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
            <span class="stat-value">{uniqueInstructors}</span>
          </div>
          <div class="stat-label">Expert Instructors</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SPONSORS -->
  <section class="sponsor-section">
    <div class="container">
      <p class="sponsor-label">Trusted by learners on these platforms</p>
      <div style="display:flex;overflow:hidden;mask-image:linear-gradient(to right,transparent 0,#000 5%,#000 95%,transparent 100%);-webkit-mask-image:linear-gradient(to right,transparent 0,#000 5%,#000 95%,transparent 100%)">
        <div class="sponsor-track">
          <span class="sponsor-item" style="color:#A435F0">Udemy</span>
          <span class="sponsor-item" style="color:#0056D2">Coursera</span>
          <span class="sponsor-item" style="color:#FF7D00">Skillshare</span>
          <span class="sponsor-item" style="color:#F05B2A">Pluralsight</span>
          <span class="sponsor-item" style="color:#02B3E4">Udacity</span>
          <span class="sponsor-item" style="color:#0A66C2">LinkedIn Learning</span>
          <span class="sponsor-item" style="color:#2D6CDF">edX</span>
          <span class="sponsor-item" style="color:#A435F0">Udemy</span>
          <span class="sponsor-item" style="color:#0056D2">Coursera</span>
          <span class="sponsor-item" style="color:#FF7D00">Skillshare</span>
          <span class="sponsor-item" style="color:#F05B2A">Pluralsight</span>
          <span class="sponsor-item" style="color:#02B3E4">Udacity</span>
          <span class="sponsor-item" style="color:#0A66C2">LinkedIn Learning</span>
          <span class="sponsor-item" style="color:#2D6CDF">edX</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ADVANTAGE -->
  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="adv-grid">
        <div>
          <span class="section-title">The CoursesWyn Advantage</span>
          <h2 class="section-heading" style="max-width:450px">Expert reviews make the difference.</h2>
        </div>
        <p style="color:var(--text-secondary);font-size:1rem;line-height:1.7;margin:0">
          Not just coupon hunters. CoursesWyn attracts learners who are more likely to study, finish, and review the course. <a href="/how-to-redeem-coupon" style="color:var(--brand);text-decoration:underline">How to redeem &rarr;</a>
        </p>
      </div>

      <div class="adv-cards">
        <div class="adv-card">
          <div class="adv-icon" style="color:var(--brand)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </div>
          <h3>Browse before paying</h3>
          <p>Browse all deals with expert ratings and detailed reviews. Pay only for the courses worth your time and money.</p>
        </div>
        <div class="adv-card">
          <div class="adv-icon" style="color:#059669">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M12 2a10 10 0 1 0 10 10"/></svg>
          </div>
          <h3>Expert-curated picks</h3>
          <p>Every course reviewed by industry professionals. Our "Expert Pick" badges highlight the best AI, LLM, and agentic AI courses.</p>
        </div>
        <div class="adv-card">
          <div class="adv-icon" style="color:var(--brand)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3>Manually verified daily</h3>
          <p>Every coupon checked by hand, not a bot. Expired deals removed within hours. You only see working coupons.</p>
        </div>
        <div class="adv-card">
          <div class="adv-icon" style="color:#7c3aed">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3>Live coupon checks</h3>
          <p>CoursesWyn checks coupon validity close to real time. What you see is what works — no dead links.</p>
        </div>
      </div>

      <div class="adv-banner">
        <div>
          <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:var(--brand)">Built for learners and instructors</span>
          </div>
          <p style="font-size:1rem;font-weight:600;color:var(--text);margin:0;line-height:1.5">Better learners attract better courses.<br>Better courses make CoursesWyn stronger.</p>
        </div>
        <a href="/udemy-coupon-code" class="btn btn-primary" style="padding:0.75rem 2rem;border-radius:999px;white-space:nowrap;margin-top:1rem;display:inline-flex;width:auto">Browse All Coupons &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FEATURED DEALS -->
  <section class="section" style="padding-top:0;padding-bottom:0">
    <div class="container">
      <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:0.5rem">
        <div>
          <span class="section-title">Fresh Deals</span>
          <h2 class="section-heading" style="margin-bottom:0">Latest coupon codes</h2>
        </div>
        <a href="/udemy-coupon-code" style="color:var(--brand);font-size:0.85rem;font-weight:600;text-decoration:none;white-space:nowrap">View all {allDeals.length.toLocaleString()} deals &rarr;</a>
      </div>
      <div class="home-card-grid">
        {featuredDeals.map((deal) => {
          const slug = deal.slug || deal.id;
          const instructor = deal.instructor?.split(',')[0]?.trim() || null;
          const discount = deal.price === 0 ? 'FREE' : (deal.originalPrice && deal.originalPrice > 0 && deal.price != null ? `${Math.round((1 - deal.price / deal.originalPrice) * 100)}% OFF` : null);
          return (
            <a href={`/coupon/${slug}`} class="home-card">
              <div class="home-card-img">
                <Image src={deal.image} alt={deal.title} width={400} height={225} loading="lazy" inferSize={false} />
                {discount && <span class="home-badge-off">{discount}</span>}
              </div>
              <div class="home-card-body">
                {deal.rating && (
                  <div style="display:flex;align-items:center;gap:0.25rem;margin-bottom:0.2rem">
                    <span style="color:#f59e0b;font-size:0.7rem">{'★'.repeat(Math.min(5,Math.max(0,Math.round(deal.rating)))).padEnd(5,'☆')}</span>
                    <span style="font-size:0.7rem;font-weight:700;color:var(--muted)">{deal.rating.toFixed(1)}</span>
                  </div>
                )}
                <h3 class="home-card-title">{deal.title}</h3>
                {instructor && <p class="home-card-instructor">{instructor}</p>}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="faq-header">
        <div>
          <span class="section-title">Straight Answers</span>
          <h2 class="section-heading">What learners ask before enrolling</h2>
        </div>
        <p style="color:var(--text-secondary);font-size:1rem;line-height:1.6;margin:0">Short version: browse free, find coupons, enroll on Udemy. <a href="/udemy-coupons-guide" style="color:var(--brand);text-decoration:underline">Read the full guide &rarr;</a></p>
      </div>
      <div class="faq-grid">
        {[
          { q: "Can free users use the coupons?", a: "Free users can browse every deal. All coupons are unlocked — no premium paywall required. Click any deal and enroll directly on Udemy." },
          { q: "Where do the coupons come from?", a: "From CoursesWyn proprietary discovery systems and instructor submissions. Every coupon is manually verified before listing. We do not accept auto-submitted or unverified coupons." },
          { q: "Why would instructors submit coupons here?", a: `Public feeds burn coupons quickly. CoursesWyn brings them learners who are more likely to study, finish, and leave a review. <a href="${instructorUrl}" target="_blank" rel="noopener noreferrer" style="color:var(--brand);text-decoration:underline">Learn more about Udemy coupon targeting.</a>` },
          { q: "Do coupons always work?", a: "CoursesWyn checks coupon validity close to real time. However, Udemy can still expire a coupon when its enrollment limit is reached. We remove expired deals within hours." },
          { q: "Do I need a Udemy account?", a: "Yes. CoursesWyn helps you find and open the coupon. Enrollment and course access happen on Udemy. A free Udemy account is all you need." },
          { q: "How to redeem a coupon?", a: `<a href="/how-to-redeem-coupon" style="color:var(--brand);text-decoration:underline">Follow our step-by-step redemption guide &rarr;</a>` }
        ].map((faq) => (
          <div class="faq-item">
            <div class="faq-question">
              <span>{faq.q}</span>
            </div>
            <div class="faq-answer"><p set:html={faq.a} /></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Go Unlimited with Udemy Personal Plan<br>26,000+ Premium Courses, One Subscription</h2>
        <div class="cta-actions">
          <a href="https://trk.udemy.com/c/6564357/3775958/39854" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg" style="border-radius:999px;padding:1rem 2.5rem">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z"/><path d="M5 21h14"/></svg>
            Start Free Trial
          </a>
        </div>
        <div class="cta-features">
          <span><span class="cta-dot"></span>26,000+ courses</span>
          <span><span class="cta-dot"></span>7-day free trial</span>
          <span><span class="cta-dot"></span>From $20/month</span>
        </div>
      </div>
    </div>
  </section>
</Layout>
