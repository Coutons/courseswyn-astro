  <section class="section-wrapper" aria-label="Platform comparison" style={{ background: "linear-gradient(180deg, var(--bg) 0%, var(--card) 100%)", borderBottom: "1px solid var(--border)" }}>
    <div class="container">
      <div style={{ textAlign: "center", marginBottom: "3rem" }}>
        <span style={{ fontSize: "0.85rem", fontWeight: 600, letterSpacing: "0.08em", textTransform: "uppercase", color: "var(--brand)", border: "1px solid var(--border)", padding: "4px 12px", borderRadius: "4px" }}>How we compare</span>
        <h2 style={{ fontSize: "1.8rem", fontWeight: 700, color: "var(--text)", marginTop: "0.5rem", marginBottom: "0.5rem" }}>
          CoursesWyn vs other free course platforms
        </h2>
        <p style={{ color: "var(--muted)", fontSize: "1.05rem", maxWidth: "600px", margin: "0 auto" }}>
          See why 150,000+ learners choose CoursesWyn over alternatives.
        </p>
      </div>

      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(280px, 1fr))", gap: "1.5rem" }}>
