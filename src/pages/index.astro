---
import Layout from "../layouts/Layout.astro";
import { Image } from 'astro:assets';
import { getCollection } from "astro:content";
import { readDeals } from "../lib/store";
import { formatStringWIB, toISODateWIB, formatDateWIB } from "../lib/date";
import { normName, slugifyCategory } from "../lib/utils";
import { CATEGORY_ICONS } from "../lib/categories";
import DealCard from "../components/DealCard.astro";

const allDeals = await readDeals();

const todayStr = toISODateWIB(new Date());
const todayDeals = allDeals.filter((d) => {
  const dDate = toISODateWIB(new Date(d.updatedAt ?? d.createdAt ?? d.expiresAt ?? 0));
  return dDate === todayStr;
});

const now = new Date();
const activeDeals = allDeals.filter((d) => !d.expiresAt || new Date(d.expiresAt) > now);
const featuredDeals = activeDeals.sort((a, b) => new Date(b.updatedAt ?? b.createdAt ?? 0).getTime() - new Date(a.updatedAt ?? a.createdAt ?? 0).getTime()).slice(0, 6);

const categoryMap = new Map<string, { name: string; count: number; subs: Map<string, number> }>();
allDeals.forEach(deal => {
  const cName = normName(deal.category) || "Uncategorized";
  const cKey = cName.toLowerCase();
  if (!categoryMap.has(cKey)) categoryMap.set(cKey, { name: cName, count: 0, subs: new Map() });
  const bucket = categoryMap.get(cKey)!;
  bucket.count++;
  const sName = normName(deal.subcategory);
  if (sName && sName.toLowerCase() !== cKey) {
    bucket.subs.set(sName, (bucket.subs.get(sName) || 0) + 1);
  }
});
function getCategoryDescription(cat: string) {
  const c = cat.toLowerCase();
  if (c === "development") return "Master programming, web development, and software engineering";
  if (c === "programming") return "Learn coding languages, algorithms, and software development fundamentals";
  if (c.includes("it") || c === "it-and-software") return "Learn IT infrastructure, cybersecurity, and software tools";
  if (c.includes("business")) return "Build business skills in management, finance, and entrepreneurship";
  if (c.includes("finance")) return "Master financial analysis, investment strategies, and accounting principles";
  if (c.includes("marketing")) return "Master digital marketing, SEO, and social media strategies";
  if (c.includes("data") || c.includes("analytics")) return "Learn data science, analytics, and machine learning techniques";
  if (c.includes("teaching")) return "Advance your academic knowledge with specialised educational courses";
  if (c.includes("design")) return "Explore graphic design, UI/UX, and creative tools";
  if (c.includes("photography")) return "Master photography techniques and digital image processing";
  if (c.includes("music")) return "Learn music production, composition, and audio engineering";
  if (c.includes("personal")) return "Develop personal growth and soft skills for career success";
  if (c.includes("office")) return "Boost productivity with Microsoft Office, Google Workspace, and collaboration tools";
  if (c.includes("programming")) return "Learn coding languages, algorithms, and software development fundamentals";
  return "Explore premium courses with exclusive coupons and deals";
}
const topCategories = Array.from(categoryMap.values())
  .filter(c => c.name.toLowerCase() !== "programming")
  .sort((a, b) => b.count - a.count).slice(0, 8)
  .map(c => ({ ...c, slug: slugifyCategory(c.name), description: getCategoryDescription(c.name) }));
const totalStudents = allDeals.reduce((sum, d) => sum + (d.students ?? 0), 0);
const uniqueInstructors = [...new Set(allDeals.filter(d => d.instructor).map(d => d.instructor))].length;
const dealsWithPrice = allDeals.filter(d => d.originalPrice && d.price && d.originalPrice > d.price);
const avgDiscount = dealsWithPrice.length > 0
  ? Math.round(dealsWithPrice.reduce((sum, d) => sum + (1 - (d.price ?? 0) / (d.originalPrice ?? 1)) * 100, 0) / dealsWithPrice.length)
  : 0;
const monthName = formatStringWIB(new Date(), { month: 'long', year: 'numeric' });
const pageTitle = `Free Udemy Courses 100% OFF Coupons & Promo Codes [${monthName}] | CoursesWyn`;
const pageDescription = `Get ${allDeals.length.toLocaleString()}+ verified Udemy coupon codes 100% OFF. Free access to top-rated courses in AI, Python, data science, cloud, and web development. Expert-reviewed & manually verified daily. Start learning for free at CoursesWyn.`;
const instructorUrl = "https://teach.udemy.com/update-for-instructors-improving-free-coupons-better-targeting-higher-quality-learning/";
const toISODate = (d?: string) => toISODateWIB(new Date(d ?? 0));

const allPosts = await getCollection("blog");
const recentPosts = allPosts.sort((a: any, b: any) => {
  const dateA = a.data.updatedAt || a.data.pubDate;
  const dateB = b.data.updatedAt || b.data.pubDate;
  return dateB.getTime() - dateA.getTime();
}).slice(0, 4);

const jsonLd = {
  "@context": "https://schema.org", "@graph": [
    { "@type": "WebSite", "@id": "https://courseswyn.com/#website", "url": "https://courseswyn.com", "name": "CoursesWyn", "description": pageDescription, "potentialAction": { "@type": "SearchAction", "target": { "@type": "EntryPoint", "urlTemplate": "https://courseswyn.com/search?q={search_term_string}" }, "query-input": "required name=search_term_string" } },
    { "@type": "Organization", "@id": "https://courseswyn.com/#organization", "name": "CoursesWyn", "url": "https://courseswyn.com", "logo": { "@type": "ImageObject", "url": "https://courseswyn.com/logo.svg", "width": 200, "height": 60 }, "sameAs": ["https://x.com/CoursesWyn", "https://www.facebook.com/CoursesWyn"] },
    { "@type": "BreadcrumbList", "@id": "https://courseswyn.com/#breadcrumb", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" }, { "@type": "ListItem", "position": 2, "name": "Coupons", "item": "https://courseswyn.com/udemy-coupon-code" }] },
    { "@type": "FAQPage", "@id": "https://courseswyn.com/#faq", "mainEntity": [
      { "@type": "Question", "name": "Can free users use the coupons?", "acceptedAnswer": { "@type": "Answer", "text": "Free users can browse every deal. All coupons are unlocked — no premium paywall required. Click any deal and enroll directly on Udemy." } },
      { "@type": "Question", "name": "Where do the coupons come from?", "acceptedAnswer": { "@type": "Answer", "text": "From CoursesWyn proprietary discovery systems and instructor submissions. Every coupon is manually verified before listing. We do not accept auto-submitted or unverified coupons." } },
      { "@type": "Question", "name": "Why would instructors submit coupons here?", "acceptedAnswer": { "@type": "Answer", "text": "Public feeds burn coupons quickly. CoursesWyn brings them learners who are more likely to study, finish, and leave a review." } },
      { "@type": "Question", "name": "Do coupons always work?", "acceptedAnswer": { "@type": "Answer", "text": "CoursesWyn checks coupon validity close to real time. However, Udemy can still expire a coupon when its enrollment limit is reached. We remove expired deals within hours." } },
      { "@type": "Question", "name": "Do I need a Udemy account?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. CoursesWyn helps you find and open the coupon. Enrollment and course access happen on Udemy. A free Udemy account is all you need." } },
      { "@type": "Question", "name": "How to redeem a coupon?", "acceptedAnswer": { "@type": "Answer", "text": "Follow our step-by-step redemption guide on CoursesWyn to claim any coupon and enroll on Udemy in under 60 seconds." } }
    ] },
    { "@type": "WebPage", "@id": "https://courseswyn.com/#webpage", "url": "https://courseswyn.com", "name": pageTitle, "description": pageDescription, "isPartOf": { "@id": "https://courseswyn.com/#website" }, "datePublished": "2024-06-01", "dateModified": toISODate() }
  ]
};
---

<Layout title={pageTitle} description={pageDescription} canonical="https://courseswyn.com" image="/assets/images/og-default.svg">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

  <style>

    .home-card-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin-bottom: 2.5rem;
    }

    .home-card {
      display: flex;
      flex-direction: column;
      background: var(--card);
      border: 1px solid rgba(212,167,55,0.08);
      border-top: 1px solid transparent;
      border-radius: 16px;
      overflow: hidden;
      transition: all 0.4s ease;
      position: relative;
    }
    .home-card::before {
      content: '';
      position: absolute;
      top: -1px;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, #B8860B, #D4AF37, #E8C547, #D4AF37, #B8860B);
      opacity: 0.15;
      transition: opacity 0.4s ease;
      z-index: 1;
    }
    .home-card:hover {
      border-color: rgba(212,167,55,0.3);
      transform: translateY(-4px);
      box-shadow: 0 16px 40px -8px rgba(212,167,55,0.15);
    }
    .home-card:hover::before {
      opacity: 1;
    }
    .home-card:hover .home-card-img img {
      transform: scale(1.06);
    }
    .home-card-img {
      position: relative;
      height: 180px;
      overflow: hidden;
      background: var(--border);
    }
    .home-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .home-badge-updated {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      background: rgba(0,0,0,0.75);
      backdrop-filter: blur(4px);
      color: white;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      font-size: 0.7rem;
      font-weight: 600;
    }
    .home-badge-discount {
      position: absolute;
      top: 0.75rem;
      left: 0.75rem;
      background: #ef4444;
      color: white;
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: 700;
    }
    .home-badge-free {
      position: absolute;
      top: 0.75rem;
      left: 0.75rem;
      background: linear-gradient(135deg, #B8860B, #D4AF37, #E8C547, #D4AF37);
      color: #1a1814;
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: 700;
      box-shadow: 0 2px 8px rgba(212,167,55,0.3);
    }
    .home-card-body {
      padding: 1.25rem;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .home-card-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text);
      margin: 0;
      line-height: 1.35;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .home-card-title a {
      color: inherit;
      text-decoration: none;
    }
    .home-card-title a:hover {
      color: var(--brand);
    }
    .home-card-instructor {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.85rem;
      color: var(--text);
      font-weight: 500;
      margin: 0;
    }
    .home-card-instructor svg {
      width: 14px;
      height: 14px;
      fill: var(--muted);
      flex-shrink: 0;
    }
    .home-card-instructor a {
      color: var(--text);
      text-decoration: none;
    }
    .home-card-instructor a:hover {
      color: var(--brand);
    }
    .home-card-desc {
      font-size: 0.85rem;
      color: var(--muted);
      margin: 0;
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .home-card-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .home-card-rating {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 0.85rem;
    }
    .home-card-rating svg {
      width: 14px;
      height: 14px;
      fill: var(--brand);
      flex-shrink: 0;
    }
    .home-card-rating-value {
      font-weight: 600;
      color: var(--muted);
    }
    .home-card-students {
      font-weight: 600;
      color: var(--muted);
    }
    .home-card-cat {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--brand);
      text-decoration: none;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      background: var(--card-hover, rgba(212,167,55,0.06));
      transition: all 0.3s ease;
    }
    .home-card-cat:hover {
      color: var(--brand);
      opacity: 0.85;
    }
    .home-card-cat svg {
      width: 12px;
      height: 12px;
      fill: currentColor;
    }
    .home-card-price-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }
    .home-card-price {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--brand);
    }
    .home-card-price del {
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--muted);
      margin-left: 8px;
      text-decoration: line-through;
    }
    .home-card-discount-badge {
      background: #ef4444;
      color: white;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: 700;
    }
    .home-card-verified-badge {
      background: linear-gradient(135deg, hsl(142,76%,36%), hsl(142,76%,45%));
      color: white;
      padding: 0.125rem 0.5rem;
      border-radius: 12px;
      font-size: 0.7rem;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 3px;
    }
    .home-card-verified-badge svg {
      width: 10px;
      height: 10px;
      fill: currentColor;
    }
    .home-card-duration {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.8rem;
      color: var(--muted);
      font-weight: 500;
    }
    .home-card-duration svg {
      width: 14px;
      height: 14px;
      fill: var(--muted);
      flex-shrink: 0;
    }
    .home-card-btn {
      display: block;
      width: 100%;
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      background: linear-gradient(135deg, #B8860B 0%, #D4AF37 25%, #E8C547 50%, #D4AF37 75%, #B8860B 100%);
      color: #1a1814;
      font-size: 0.9rem;
      font-weight: 700;
      text-align: center;
      text-decoration: none;
      transition: all 0.3s;
    }
    .home-card-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 0 16px 2px rgba(212,167,55,0.3);
    }

    @media (max-width: 768px) {
      .home-card-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }
    }
    @media (max-width: 480px) {
      .home-card-grid {
        grid-template-columns: 1fr;
      }
    }

    .steps-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 2rem;
    }
    .step-card {
      text-align: center;
      padding: 2rem 1.5rem;
      background: var(--card);
      border: 1px solid rgba(212,167,55,0.08);
      border-radius: 16px;
      transition: all 0.4s ease;
      position: relative;
      overflow: hidden;
    }
    .step-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, #B8860B, #D4AF37, #E8C547, #D4AF37, #B8860B);
      opacity: 0.15;
      transition: opacity 0.4s ease;
    }
    .step-card:hover {
      border-color: rgba(212,167,55,0.3);
      transform: translateY(-4px);
      box-shadow: 0 12px 32px -8px rgba(212,167,55,0.15);
    }
    .step-card:hover::before {
      opacity: 1;
    }
    .step-number {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 52px;
      height: 52px;
      border-radius: 50%;
      background: linear-gradient(135deg, #B8860B, #D4AF37, #E8C547);
      color: #1a1814;
      font-weight: 900;
      font-size: 1.3rem;
      margin: 0 auto 1rem;
      box-shadow: 0 0 20px rgba(212,167,55,0.2);
    }
    .step-card h3 {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      margin: 0 0 0.5rem;
    }
    .step-card p {
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.5;
      margin: 0;
    }
    @media (max-width: 768px) {
      .steps-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
      }
    }

    .blog-mini-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .blog-mini-card {
      display: flex;
      flex-direction: column;
      background: var(--card);
      border: 1px solid rgba(212,167,55,0.08);
      border-top: 1px solid transparent;
      border-radius: 12px;
      overflow: hidden;
      text-decoration: none;
      transition: all 0.4s ease;
      position: relative;
    }
    .blog-mini-card::before {
      content: '';
      position: absolute;
      top: -1px;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, #B8860B, #D4AF37, #E8C547, #D4AF37, #B8860B);
      opacity: 0.15;
      transition: opacity 0.4s ease;
      z-index: 1;
    }
    .blog-mini-card:hover {
      border-color: rgba(212,167,55,0.3);
      transform: translateY(-4px);
      box-shadow: 0 12px 32px -8px rgba(212,167,55,0.15);
    }
    .blog-mini-card:hover::before {
      opacity: 1;
    }
    .blog-mini-body {
      padding: 1rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .blog-mini-tag {
      font-size: 0.65rem;
      font-weight: 700;
      color: var(--brand);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.4rem;
    }
    .blog-mini-body h3 {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text);
      margin: 0 0 0.4rem;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .blog-mini-card:hover .blog-mini-body h3 {
      color: var(--brand);
    }
    .blog-mini-desc {
      font-size: 0.72rem;
      color: var(--text-secondary);
      line-height: 1.4;
      margin: 0.25rem 0 0.4rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .blog-mini-date {
      font-size: 0.7rem;
      color: var(--muted);
      margin-top: auto;
    }
    @media (max-width: 640px) {
      .blog-mini-grid {
        grid-template-columns: 1fr;
      }
    }
    .topic-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }
    .topic-card {
      border-radius: var(--radius);
      border: 1px solid rgba(212,167,55,0.08);
      background: var(--card);
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      transition: all 0.4s ease;
      position: relative;
      overflow: hidden;
    }
    .topic-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, #B8860B, #D4AF37, #E8C547, #D4AF37, #B8860B);
      opacity: 0.15;
      transition: opacity 0.4s ease;
    }
    .topic-card:hover {
      border-color: rgba(212,167,55,0.3);
      transform: translateY(-4px);
      box-shadow: 0 12px 32px -8px rgba(212,167,55,0.15);
    }
    .topic-card:hover::before {
      opacity: 1;
    }
    .topic-card-head {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 1rem;
    }
    .topic-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(212,167,55,0.2);
      background: var(--brand-soft);
      font-size: 1.1rem;
      flex-shrink: 0;
      color: var(--brand);
    }
    .topic-card h3 {
      font-size: 0.95rem;
      font-weight: 800;
      margin: 0;
      color: var(--text);
    }
    .topic-links {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .topic-link {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
      text-decoration: none;
    }
    .topic-link-title {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--brand);
      transition: all 0.2s;
      border-bottom: 1px solid transparent;
    }
    .topic-link:hover .topic-link-title {
      border-bottom-color: var(--brand);
    }
    .topic-link-desc {
      font-size: 0.78rem;
      color: var(--muted);
      line-height: 1.4;
    }

    .stat-grid-home {
      grid-template-columns: repeat(4, 1fr);
    }
    @media (max-width: 768px) {
      .stat-grid-home {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 768px) {
      .home-card-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
      }
    }
    @media (max-width: 480px) {
      .home-card-grid {
        grid-template-columns: 1fr;
      }
    }
    .cc-root { background: var(--bg); padding: 2rem 1rem 0; }
    .cc-container { max-width: 1024px; margin: 0 auto; }
    .cc-header { text-align: center; margin-bottom: 2rem; }
    .cc-header-icon { display: block; margin: 0 auto 0.75rem; color: var(--brand); }
    .cc-title { font-size: 1.8rem; font-weight: 900; color: var(--text); margin: 0 0 0.5rem; letter-spacing: -0.03em; }
    .cc-title-highlight { background: var(--brand); color: #fff; padding: 0 6px; }
    .cc-subtitle { font-size: 0.92rem; color: var(--muted); max-width: 600px; margin: 0 auto 1.5rem; line-height: 1.65; }
    .cc-search-wrap { max-width: 640px; margin: 0 auto 1.5rem; }
    .cc-search-form { display: flex; align-items: center; border-radius: 999px; border: 2px solid var(--border); padding: 0.25rem 0.25rem 0.25rem 1.25rem; height: 52px; background: var(--card); }
