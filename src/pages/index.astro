          <div style={{ padding: "1.5rem" }}>
            <span class="tag">Course Review</span>
            <h3 style={{ fontSize: "1.1rem", fontWeight: 700, color: "#f1f5f9", margin: "0.75rem 0 0.5rem 0", lineHeight: 1.3 }}>Best AI Engineer Courses on Udemy 2026</h3>
            <p style={{ color: "#64748b", fontSize: "0.85rem", lineHeight: 1.6, margin: 0 }}>We analyzed and compared top AI engineering courses. Find the best training for Agentic AI and LLMs.</p>
            <p style={{ marginTop: "1rem", color: "#10b981", fontWeight: 600, fontSize: "0.85rem", display: "flex", alignItems: "center", gap: "0.4rem" }}>Read Full Review <span class="arrow">→</span></p>
          </div>
        </a>
        <a href="/blog/ai-engineer-agentic-track-ed-donner-review" class="blog-card anim-up anim-3">
          <img src="/assets/images/review-course-ai-engineer-agentic-track-udemy.jpg" alt="AI Engineer Agentic Track Review" loading="lazy" />
          <div style={{ padding: "1.5rem" }}>
            <span class="tag">Review</span>
            <h3 style={{ fontSize: "1.1rem", fontWeight: 700, color: "#f1f5f9", margin: "0.75rem 0 0.5rem 0", lineHeight: 1.3 }}>AI Engineer Agentic Track: Ed Donner Review</h3>
            <p style={{ color: "#64748b", fontSize: "0.85rem", lineHeight: 1.6, margin: 0 }}>In-depth review of the popular AI Engineer Agentic Track course. Curriculum deep-dive and pricing analysis.</p>
            <p style={{ marginTop: "1rem", color: "#10b981", fontWeight: 600, fontSize: "0.85rem", display: "flex", alignItems: "center", gap: "0.4rem" }}>Read Full Review <span class="arrow">→</span></p>
          </div>
        </a>
      </div>
      <div style={{ textAlign: "center", marginTop: "2.5rem" }}>
        <a href="/blog" style={{ color: "#10b981", textDecoration: "none", fontWeight: 600, fontSize: "0.9rem", borderBottom: "1px solid rgba(16,185,129,0.3)", paddingBottom: "2px" }}>View All Articles →</a>
      </div>
    </div>
  </section>

  <!-- ═══ COUPONS ═══ -->
  <section class="sec-pad" style={{ background: "#0f0f18", borderBottom: "1px solid #1e1e2e" }}>
    <div class="container">
      <div class="anim-up" style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-end", marginBottom: "2rem", flexWrap: "wrap", gap: "1rem" }}>
        <div><p class="sec-label">🔥 Hot Deals</p><h2 class="sec-title">Latest Free Udemy Coupons</h2></div>
                <a href="/udemy-coupon-code" style={{ color: "#14b8a6", textDecoration: "none", fontWeight: 600, fontSize: "0.9rem", borderBottom: "1px solid rgba(20,184,166,0.3)", paddingBottom: "2px" }}>View All {allDeals.length.toLocaleString()} →</a>
              </div>
              <p class="anim-up anim-1" style={{ color: "#64748b", fontSize: "0.9rem", maxWidth: "600px", marginBottom: "2rem", lineHeight: 1.6 }}>Hand-picked and manually verified Udemy coupons updated daily. Each deal is checked for validity before being published — no expired codes, no fake discounts.</p>
      <div class="anim-up anim-1" style={{ display: "flex", gap: "0.5rem", marginBottom: "2rem", flexWrap: "wrap" }}>
        <span class="cat-pill active">🔥 All</span>
        {categories.slice(0, 8).map((cat) => (<a href={`/categories/${slugifyCategory(cat)}`} class="cat-pill">{cat}</a>))}
      </div>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(280px, 1fr))", gap: "1.25rem" }}>
        {initialItems.map((deal) => (<DealCard deal={deal} />))}
      </div>
      <div style={{ textAlign: "center", marginTop: "3rem" }}>
        <a href="/udemy-coupon-code" style={{ padding: "0.9rem 2.5rem", borderRadius: "12px", background: "linear-gradient(135deg,#10b981,#059669)", color: "#0a0a0f", textDecoration: "none", fontWeight: 700, fontSize: "1rem", display: "inline-flex", alignItems: "center", gap: "0.5rem", boxShadow: "0 8px 24px -4px rgba(16,185,129,0.2)", transition: "all 0.3s" }} onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">Browse All {allDeals.length.toLocaleString()} Coupons →</a>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURES ═══ -->
  <section class="sec-pad" style={{ background: "#0a0a0f", borderBottom: "1px solid #1e1e2e" }}>
    <div class="container">
      <div class="anim-up" style={{ textAlign: "center", marginBottom: "1rem" }}><p class="sec-label">Why CoursesWyn</p><h2 class="sec-title">Trusted by 150,000+ Learners</h2></div>
            <p class="anim-up anim-1" style={{ color: "#64748b", fontSize: "0.9rem", textAlign: "center", maxWidth: "600px", margin: "0 auto 2.5rem", lineHeight: 1.6 }}>We manually verify every coupon before publishing. Our team ensures each deal is genuine, the instructor is credible, and the discount actually works.</p>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(240px, 1fr))", gap: "1.25rem" }}>
        {[
          { icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", title: "100% Verified", desc: "Every coupon checked manually. No expired codes." },
          { icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z", title: "Save up to $200", desc: "Premium courses for $0. Same certificate." },
          { icon: "M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z", title: "Free to Use", desc: "No account needed. Just click & enroll." },
