          <h3 style={{ fontSize: "1.3rem", fontWeight: 700, color: "var(--text)", margin: "0 0 0.25rem 0" }}>CoursesWyn</h3>
          <p style={{ fontSize: "0.85rem", color: "var(--muted)", margin: "0 0 1.5rem 0" }}>Udemy coupon aggregator</p>

          {[
            { key: "Manual verification", val: "Yes — every coupon", ok: true },
            { key: "Update frequency", val: "Every 4 hours", ok: true },
            { key: "Min. course rating", val: "4.0 stars", ok: true },
            { key: "Account required", val: "No", ok: true },
            { key: "Expiry indicators", val: "Yes", ok: true }
          ].map((row) => (
            <div style={{ display: "flex", justifyContent: "space-between", padding: "0.75rem 0", borderBottom: "1px solid var(--border)" }}>
              <span style={{ fontSize: "0.9rem", color: "var(--muted)" }}>{row.key}</span>
              <span style={{ fontSize: "0.9rem", fontWeight: 600, color: row.ok ? "var(--brand)" : "var(--text)" }}>{row.val}</span>
            </div>
          ))}
        </div>

        {/* Discudemy */}
        <div style={{
          background: "var(--bg)", padding: "1.75rem", borderRadius: "20px",
          border: "1px solid var(--border)"
        }}>
          <h3 style={{ fontSize: "1.3rem", fontWeight: 700, color: "var(--text)", margin: "0 0 0.25rem 0" }}>Discudemy</h3>
          <p style={{ fontSize: "0.85rem", color: "var(--muted)", margin: "0 0 1.5rem 0" }}>Udemy coupon aggregator</p>

          {[
            { key: "Manual verification", val: "Partial", ok: false },
            { key: "Update frequency", val: "Varies", ok: false },
            { key: "Min. course rating", val: "No filter", ok: false },
            { key: "Account required", val: "Yes", ok: false },
            { key: "Expiry indicators", val: "Limited", ok: false }
          ].map((row) => (
            <div style={{ display: "flex", justifyContent: "space-between", padding: "0.75rem 0", borderBottom: "1px solid var(--border)" }}>
              <span style={{ fontSize: "0.9rem", color: "var(--muted)" }}>{row.key}</span>
              <span style={{ fontSize: "0.9rem", fontWeight: 600, color: "var(--text)" }}>{row.val}</span>
            </div>
          ))}
        </div>

        {/* Real.Discount */}
        <div style={{
          background: "var(--bg)", padding: "1.75rem", borderRadius: "20px",
          border: "1px solid var(--border)"
        }}>
          <h3 style={{ fontSize: "1.3rem", fontWeight: 700, color: "var(--text)", margin: "0 0 0.25rem 0" }}>Real.Discount</h3>
          <p style={{ fontSize: "0.85rem", color: "var(--muted)", margin: "0 0 1.5rem 0" }}>Udemy coupon aggregator</p>

          {[
            { key: "Manual verification", val: "Automated only", ok: false },
            { key: "Update frequency", val: "Daily", ok: false },
            { key: "Min. course rating", val: "No filter", ok: false },
            { key: "Account required", val: "No", ok: true },
            { key: "Expiry indicators", val: "Yes", ok: true }
          ].map((row) => (
            <div style={{ display: "flex", justifyContent: "space-between", padding: "0.75rem 0", borderBottom: "1px solid var(--border)" }}>
              <span style={{ fontSize: "0.9rem", color: "var(--muted)" }}>{row.key}</span>
              <span style={{ fontSize: "0.9rem", fontWeight: 600, color: "var(--text)" }}>{row.val}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════
       10. FAQ (GRID LAYOUT)
       ══════════════════════════════════════════════════════════════════════ -->
  <section class="section-wrapper" aria-label="Frequently asked questions" style={{ background: "var(--bg)", borderBottom: "1px solid var(--border)" }}>
    <div class="container">
      <div style={{ textAlign: "center", marginBottom: "3rem" }}>
        <span style={{ fontSize: "0.85rem", fontWeight: 600, letterSpacing: "0.08em", textTransform: "uppercase", color: "var(--brand)", border: "1px solid var(--border)", padding: "4px 12px", borderRadius: "4px" }}>FAQ</span>
        <h2 style={{ fontSize: "1.8rem", fontWeight: 700, color: "var(--text)", marginTop: "0.5rem", marginBottom: "0.5rem" }}>
