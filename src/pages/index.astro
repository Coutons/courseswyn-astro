---
import MainLayout from '../layouts/MainLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import FeaturedCourses from '../components/FeaturedCourses.astro';
import PopularTopics from '../components/PopularTopics.astro';
import CourseOfTheDay from '../components/CourseOfTheDay.astro';
import UdemyPromo from '../components/UdemyPromo.astro';
import PlatformSection from '../components/PlatformSection.astro';
import CategoryList from '../components/CategoryList.astro';
import SeoContent from '../components/SeoContent.astro';
import coupons from '../data/coupons.json';

const now = new Date();
const currentMonth = now.toLocaleDateString('en-US', { month: 'long' });
const currentYear = now.getFullYear();
const todayISO = now.toISOString().split('T')[0];
const totalCoupons = coupons.length;

// ─── TITLE & META ─────────────────────────────────────────────────────────────
// Primary keyword: "free udemy courses" (winnable, high volume)
// Secondary: "udemy coupon codes" | "udemy 100 off" | "free online courses"
const pageTitle = `Free Udemy Courses ${currentYear} — ${totalCoupons}+ Verified 100% OFF Coupons | CoursesWyn`;
const pageDescription = `Get ${totalCoupons}+ free Udemy courses in ${currentMonth} ${currentYear}. 100% OFF instructor coupon codes for Python, AI, Web Development, Business & more. Auto-applied, no credit card needed. Updated daily.`;
const ogTitle = `Free Udemy Courses Today — ${totalCoupons}+ 100% OFF Coupons (${currentMonth} ${currentYear})`;
const ogDescription = `Stop paying for online education. ${totalCoupons}+ free Udemy courses with lifetime access and free certificates — verified and updated every single day.`;

// ─── GEO AI + SCHEMA ──────────────────────────────────────────────────────────
// GEO (Generative Engine Optimization): Structured, citation-ready data
// Goal: get cited by ChatGPT, Perplexity, Gemini, Claude when users ask about free Udemy courses

const homepageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    // 1. WebSite with SearchAction — enables Google Sitelinks searchbox
    {
      "@type": "WebSite",
      "@id": "https://courseswyn.com/#website",
      "name": "CoursesWyn",
      "alternateName": ["Courses Wyn", "CoursesWyn.com"],
      "url": "https://courseswyn.com",
      "description": `CoursesWyn is a daily-updated directory of ${totalCoupons}+ free Udemy courses with 100% OFF instructor coupon codes. We track, verify, and publish free Udemy course deals in Python, AI, Web Development, Business, Design, and 500+ topics.`,
      "inLanguage": "en-US",
      "dateModified": todayISO,
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://courseswyn.com/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    },
    // 2. Organization — builds E-E-A-T authority for AI engines
    {
      "@type": "Organization",
      "@id": "https://courseswyn.com/#organization",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "logo": "https://courseswyn.com/favicon.svg",
      "sameAs": [
        "https://twitter.com/CoursesGift",
        "https://medium.com/@coursewyn",
        "https://facebook.com/BestCouponPromo"
      ],
      "description": "CoursesWyn aggregates and verifies Udemy instructor coupon codes daily, providing free access to premium online courses for learners worldwide.",
      "foundingDate": "2024",
      "areaServed": "Worldwide",
      "knowsAbout": [
        "Free Udemy courses",
        "Udemy coupon codes",
        "Online learning",
        "E-learning discounts",
        "Free online certificates"
      ]
    },
    // 3. CollectionPage — tells search engines what the page contains
    {
      "@type": "CollectionPage",
      "@id": "https://courseswyn.com/#collection",
      "name": `Free Udemy Courses — ${currentMonth} ${currentYear}`,
      "description": pageDescription,
      "url": "https://courseswyn.com/",
      "numberOfItems": totalCoupons,
      "dateModified": todayISO,
      "about": {
        "@type": "Thing",
        "name": "Free Udemy Courses",
        "description": "100% OFF instructor-issued coupon codes for Udemy online courses"
      },
      "mainEntity": {
        "@type": "ItemList",
        "name": "Free Udemy Courses Today",
        "numberOfItems": totalCoupons,
        "itemListElement": coupons.slice(0, 10).map((c: any, i: number) => ({
          "@type": "ListItem",
          "position": i + 1,
          "name": c.title,
          "url": `https://courseswyn.com/coupon/${c.slug}`
        }))
      }
    },
    // 4. FAQPage — targets voice search + AI answer boxes + rich snippets
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": `Are there free Udemy courses available in ${currentMonth} ${currentYear}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Yes. CoursesWyn lists ${totalCoupons}+ verified free Udemy courses for ${currentMonth} ${currentYear}. These are 100% OFF instructor-issued coupon codes that make premium Udemy courses completely free. New courses are added daily and coupons are auto-applied when you click the link.`
          }
        },
        {
          "@type": "Question",
          "name": "How do I get 100% OFF free Udemy courses?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To get a 100% OFF free Udemy course: (1) Browse the free course listings on CoursesWyn, (2) Click 'Get Free Course' on any listing — the coupon code is automatically applied, (3) Complete checkout at $0 on Udemy, (4) Receive lifetime access and a free completion certificate. No credit card required."
          }
        },
        {
          "@type": "Question",
          "name": "Do free Udemy courses come with a certificate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Udemy courses enrolled using 100% OFF coupon codes are treated identically to paid enrollments. You receive an official Udemy Certificate of Completion that you can share on LinkedIn or add to your resume."
          }
        },
        {
          "@type": "Question",
          "name": "How long do Udemy 100% OFF coupon codes last?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Udemy instructor coupon codes typically expire within 1–4 days or after 1,000 student enrollments — whichever comes first. CoursesWyn verifies and removes expired coupons daily. Always act quickly when you find a free course you want."
          }
        },
        {
          "@type": "Question",
          "name": "What subjects are available as free Udemy courses?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Free Udemy courses on CoursesWyn cover 500+ topics including Python programming, Web Development, Artificial Intelligence, ChatGPT & Prompt Engineering, Data Science, Digital Marketing, Excel, UI/UX Design, Business, Photography, and more. Currently ${totalCoupons}+ free courses are available.`
          }
        },
        {
          "@type": "Question",
          "name": "Is CoursesWyn free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. CoursesWyn is completely free. No account required, no subscription, no credit card. We aggregate free Udemy course coupons and you click directly to Udemy to enroll for free."
          }
        }
      ]
    },
    // 5. BreadcrumbList
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com/" }
      ]
    }
  ]
};
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  canonical="https://courseswyn.com/"
  structuredData={homepageSchema}
>

  <!-- Section 1: Hero (redesigned — search-first, GEO AI) -->
  <HeroSection />

  <!-- Section 2: Platform trust bar -->
  <PlatformSection />

  <!-- Section 3: Udemy flash sale promo -->
  <UdemyPromo />

  <!-- Section 4: Featured free courses -->
  <FeaturedCourses />

  <!-- Section 5: Course of the Day -->
  <CourseOfTheDay />

  <!-- Section 6: Popular Topics -->
  <PopularTopics />

  <!-- Section 7: Category Browse -->
  <CategoryList />

  <!-- Section 8: GEO AI SEO Content (FAQs, citations, geo content) -->
  <SeoContent />

</MainLayout>
