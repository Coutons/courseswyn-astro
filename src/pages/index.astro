---
import Layout from "../layouts/Layout.astro";
import DealCard from "../components/DealCard.astro";
import FeaturedDealCard from "../components/FeaturedDealCard.astro";
import DealsList from "../components/DealsList";
import HeaderSearch from "../components/HeaderSearch";
import { readDeals } from "../lib/store";
import { uniqueProviders } from "../lib/mockData";

// ─── Date helpers ────────────────────────────────────────────────────────────
const currentDate = new Date();
const utcDate     = new Date(currentDate.toISOString());
const monthNames  = [
  "January","February","March","April","May","June",
  "July","August","September","October","November","December"
];
const currentMonth = monthNames[utcDate.getMonth()];
const currentYear  = utcDate.getFullYear();

// ─── Helpers ──────────────────────────────────────────────────────────────────
function genStudents(key: string): number {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < key.length; i++) {
    h ^= key.charCodeAt(i);
    h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24);
  }
  const r = (h >>> 0) / 0xffffffff;
  const min = 1000, max = 80000;
  const val = Math.floor(min + (max - min) * Math.pow(r, 0.6));
  return Math.round(val / 10) * 10;
}

function formatStudents(n: number) {
  if (n >= 1000000) return (n / 1000000).toFixed(1).replace(/\.0$/, "") + "m";
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, "") + "k";
  return String(n);
}

// ─── SEO Meta ────────────────────────────────────────────────────────────────
// [SEO TITLE]
const pageTitle       = `Verified Udemy Promo Codes ${currentMonth} ${currentYear} | Udemy Discount Deals`;
// [SEO DESCRIPTION]
const pageDescription = `Access verified Udemy promo codes and discount vouchers updated daily for ${currentMonth} ${currentYear}. Get premium course deals verified by CoursesWyn experts in programming, data science, and business.`;

// ─── Deals Data ──────────────────────────────────────────────────────────────
const allDeals     = await readDeals();
const PAGE_SIZE    = 6;
const initialItems = allDeals.slice(0, PAGE_SIZE);
const totalPages   = Math.ceil(allDeals.length / PAGE_SIZE);

// ─── Categories ──────────────────────────────────────────────────────────────
function normName(raw?: string | null) {
  if (!raw) return undefined;
  let v = String(raw).trim();
  v = v.replace(/&amp;/gi, "&").replace(/\s+/g, " ");
  return v || undefined;
}
function slugifyCategory(name: string) {
  if (name === "Uncategorized") return "uncategorized";
  return name.toLowerCase()
    .replace(/&amp;/gi, "&")
    .replace(/&/g, " and ")
    .replace(/[^\w\s-]/g, "")
    .trim()
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-");
}
function getCategoryDescription(category: string) {
  const cat = category.toLowerCase();
  if (cat === "development")               return "Master programming, web development, and software engineering";
  if (cat === "programming")              return "Learn coding languages, algorithms, and software development fundamentals";
  if (cat === "it & software")            return "Learn IT infrastructure, cybersecurity, and software tools";
  if (cat.includes("business"))           return "Build business skills in management, finance, and entrepreneurship";
  if (cat === "finance")                  return "Master financial analysis, investment strategies, and accounting principles";
  if (cat.includes("marketing"))         return "Master digital marketing, SEO, and social media strategies";
  if (cat.includes("data") || cat.includes("analytics")) return "Learn data science, analytics, and machine learning techniques";
  if (cat.includes("teaching"))          return "Advance your academic knowledge with specialised educational courses";
  if (cat.includes("design"))            return "Explore graphic design, UI/UX, and creative tools";
  if (cat.includes("photography"))       return "Master photography techniques and digital image processing";
  if (cat.includes("music"))             return "Learn music production, composition, and audio engineering";
  if (cat.includes("personal"))          return "Develop personal growth and soft skills for career success";
  if (cat.includes("office"))            return "Boost productivity with Microsoft Office, Google Workspace, and collaboration tools";
  return "Explore premium courses with exclusive coupons and deals";
}

const categories = [
  ...new Set(allDeals.map((d) => d.category).filter(Boolean).map(normName).filter(Boolean)),
] as string[];

// ─── Featured Deal ────────────────────────────────────────────────────────────
const featuredDeals = allDeals
  .filter((d) => d.rating && d.rating >= 4.8)
  .sort((a, b) => (b.rating || 0) - (a.rating || 0))
  .slice(0, 1);
const featuredImage = featuredDeals.length > 0 ? featuredDeals[0].image : "/og-image.jpg";

// ─── Trust Indicators ────────────────────────────────────────────────────────
const trustIndicators = [
  {
    icon: `<path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>`,
    title: "100% Verified Coupons",
    description: "Every coupon is manually tested and verified to work before publishing. No more expired codes or fake discounts wasting your time."
  },
  {
    icon: `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>`,
    title: "4.9/5 Average Rating",
    description: "Based on 50,000+ verified student reviews across all platforms. Our curated courses consistently deliver exceptional learning outcomes."
  },
  {
    icon: `<path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>`,
    title: "Daily Fresh Deals",
    description: "Fresh Udemy coupons added every single day. Our team scours the web so you never miss a limited-time free course offer."
  },
  {
    icon: `<path d="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V7h10v2z"/>`,
    title: "Lifetime Access",
    description: "Keep courses forever — once enrolled, your access never expires. Includes completion certificates, downloadable resources, and all future updates."
  },
  {
    icon: `<path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm3 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/>`,
    title: "No Hidden Fees",
    description: "100% free — no credit card required, no subscription, no catch. We partner with instructors who want to reach more students worldwide."
  },
  {
    icon: `<path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/>`,
    title: "Premium Courses Free",
    description: "Access courses that normally cost $12–$200 completely free. Learn from top-rated instructors without spending a single dollar."
  }
];

// ─── FAQ Data ─────────────────────────────────────────────────────────────────
const faqs = [
  {
    icon: "M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z",
    q: "Are Udemy coupons on CoursesWyn really 100% free?",
    a: "Yes! Every coupon we publish gives you 100% off the course price — you pay absolutely nothing. No hidden fees, no subscription, and no credit card required. Simply click the coupon link and enroll on Udemy for free."
  },
  {
    icon: "M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z",
    q: "How often are new Udemy coupons added?",
    a: "We add new free Udemy course coupons every single day. Our team works around the clock to source, verify, and publish the latest deals across all categories — from programming and web development to marketing and personal development."
  },
  {
    icon: "M15 1H9v2h6V1zm-4 13h2V8h-2v6zm8.03-6.61l1.42-1.42c-.43-.51-.9-.99-1.41-1.41l-1.42 1.42C16.07 4.74 14.12 4 12 4c-4.97 0-9 4.03-9 9s4.02 9 9 9 9-4.03 9-9c0-2.12-.74-4.07-1.97-5.61zM12 20c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z",
    q: "How long do Udemy coupon codes last?",
    a: "Udemy coupon validity typically ranges from 1–7 days, though some last up to a month. Each coupon also has a maximum enrollment limit (usually 1,000 students). We recommend enrolling immediately when you find a course you want — free spots fill up fast!"
  },
  {
    icon: "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z",
    q: "Will I receive a certificate after completing a free course?",
    a: "Absolutely! Courses enrolled via our 100% off coupons include the exact same benefits as paid courses — including an official Udemy completion certificate, lifetime access, downloadable resources, and instructor Q&A support."
  },
  {
    icon: "M17 1.01L7 1c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-1.99-2-2zM17 19H7V5h10v14z",
    q: "Can I access Udemy courses on mobile devices?",
    a: "Yes! All Udemy courses are fully accessible via the Udemy iOS and Android apps, as well as on any desktop browser. You can also download lectures for offline viewing — perfect for learning on the go."
  },
  {
    icon: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z",
    q: "What should I do if a coupon code doesn't work?",
    a: "We verify all coupons before publishing, but Udemy coupons can expire or hit their enrollment limit quickly. If a code doesn't work, refresh our page for the latest deals or check the comments section — our community often posts working alternatives within minutes."
  }
];

// ─── JSON-LD Structured Data ──────────────────────────────────────────────────
// [SEO JSON-LD]
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    // WebSite dengan SearchAction → enables Google Sitelinks Searchbox
    {
      "@type": "WebSite",
      "@id": "https://courseswyn.com/#website",
      "url": "https://courseswyn.com",
      "name": "CoursesWyn",
      "description": pageDescription,
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://courseswyn.com/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    },
    // Organization untuk E-E-A-T
    {
      "@type": "Organization",
      "@id": "https://courseswyn.com/#organization",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://courseswyn.com/logo.png",
        "width": 200,
        "height": 60
      },
      "sameAs": [
        "https://twitter.com/courseswyn",
        "https://facebook.com/courseswyn"
      ]
    },
    // EducationalOrganization dengan offer catalog
    {
      "@type": "EducationalOrganization",
      "@id": "https://courseswyn.com/#educational",
      "name": "CoursesWyn Learning Platform",
      "description": "Free access to premium online courses from top providers like Udemy, Coursera, and edX.",
      "url": "https://courseswyn.com",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": `Free Udemy Coupons ${currentMonth} ${currentYear}`,
        "itemListElement": allDeals.slice(0, 10).map((deal, index) => ({
          "@type": "Course",
          "position": index + 1,
          "name": deal.title,
          "description": deal.description,
          "provider": { "@type": "Organization", "name": deal.provider || "Udemy" },
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD",
            "availability": "https://schema.org/InStock",
            "validFrom": (deal as any).createdAt || new Date().toISOString().split('T')[0],
            "priceValidUntil": deal.expiresAt,
            "description": "100% off - completely free Udemy course"
          },
          ...(deal.rating ? {
            "aggregateRating": {
              "@type": "AggregateRating",
              "ratingValue": deal.rating.toString(),
              "reviewCount": Math.max(1, Math.round(deal.students ?? 1000)),
              "bestRating": "5"
            }
          } : {})
        }))
      }
    },
    // BreadcrumbList
    {
      "@type": "BreadcrumbList",
      "@id": "https://courseswyn.com/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" },
        { "@type": "ListItem", "position": 2, "name": "Free Course Coupons", "item": "https://courseswyn.com/udemy-coupon-code" },
        { "@type": "ListItem", "position": 3, "name": "Course Categories", "item": "https://courseswyn.com/categories" }
      ]
    },
    // FAQPage → rich snippet di SERP
    {
      "@type": "FAQPage",
      "@id": "https://courseswyn.com/#faq",
      "mainEntity": faqs.map((faq) => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": { "@type": "Answer", "text": faq.a }
      }))
    },
    // ItemList untuk featured courses → sitelinks
    {
      "@type": "ItemList",
      "@id": "https://courseswyn.com/#courselist",
      "name": `Top Free Udemy Courses ${currentMonth} ${currentYear}`,
      "itemListElement": initialItems.map((deal, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": `https://courseswyn.com/coupon/${deal.slug || deal.id}`,
        "name": deal.title
      }))
    }
  ]
};
---

<style>
  /* ─── Global Layout ─────────────────────────────────────────────────────── */
  .section-wrapper {
    width: 100%;
    padding: 4rem 1rem;
  }
  .section-wrapper--card {
    background: linear-gradient(135deg, var(--card) 0%, rgba(255,193,7,0.02) 100%);
    border-radius: 24px;
    border: 1px solid rgba(255,193,7,0.08);
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }
  .pill {
    padding: 0.6rem 1.25rem;
    border-radius: 9999px;
    background: var(--input);
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .pill:hover, .pill.active {
    background: var(--brand);
    color: var(--bg);
    border-color: var(--brand);
    transform: translateY(-1px);
  }
  .category-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
    border-color: var(--brand);
    background: #2d3348 !important;
  }
  .category-card svg { transition: transform 0.2s ease; }
  .category-card:hover svg { transform: scale(1.1); }
  .category-card:hover div:last-child { color: var(--accent); }

  /* ─── Prose content section ─────────────────────────────────────────────── */
  .prose-section h2 {
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .prose-section h3 {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin: 1.5rem 0 0.5rem;
  }
  .prose-section p {
    color: var(--muted);
    line-height: 1.75;
    font-size: 1rem;
    margin-bottom: 1rem;
  }
  .prose-section a {
    color: var(--brand);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (max-width: 768px) {
    h1 { font-size: 2.5rem !important; }
    .section-wrapper { padding: 3rem 1rem; }
    .featured-grid { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 480px) {
    h1 { font-size: 2rem !important; }
    h2 { font-size: 1.5rem !important; }
    .category-card { padding: 1rem !important; }
    .faq-grid { grid-template-columns: 1fr !important; }
  }
  html { scroll-behavior: smooth; }
</style>

<Layout
  title={pageTitle}
  description={pageDescription}
  image={featuredImage}
  canonical="https://courseswyn.com"
>
  <!-- [SEO FIX] Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- [SEO ADD] Preload critical image for LCP -->
  {featuredDeals.length > 0 && featuredDeals[0].image && (
    <link rel="preload" as="image" href={featuredDeals[0].image} slot="head" />
  )}

  <!-- ══════════════════════════════════════════════════════════════════════
       1. HERO
       ══════════════════════════════════════════════════════════════════════ -->
  <section
    class="hero-gradient section-wrapper"
    style={{ textAlign: "center", overflow: "hidden", position: "relative" }}
    aria-label="Hero — Free Udemy Coupons"
  >
    <div class="container" style={{ position: "relative", zIndex: 10 }}>

      <div style={{
        display: "inline-flex", alignItems: "center", gap: "0.5rem",
        background: "var(--brand-soft)", padding: "0.5rem 1rem",
        borderRadius: "9999px", marginBottom: "2rem",
        fontSize: "0.9rem", color: "var(--brand)", fontWeight: 600
      }}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        Helping Learners Save Over $1.2M in Course Fees
      </div>

      <!-- [SEO H1] -->
      <h1 style={{
        fontSize: "clamp(2.5rem, 5vw, 4rem)", fontWeight: 800,
        lineHeight: 1.1, maxWidth: "900px", margin: "0 auto 1.5rem"
      }}>
        <span style={{
          background: "linear-gradient(135deg, var(--brand) 0%, var(--secondary) 100%)",
          WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent", backgroundClip: "text"
        }}>
          {`Verified Udemy Promo Codes ${currentMonth} ${currentYear}`}
        </span>
        <br/>
        <span style={{
          background: "linear-gradient(135deg, var(--text) 0%, var(--muted) 100%)",
          WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent", backgroundClip: "text"
        }}>
          Get Premium Udemy Discount Deals
        </span>
      </h1>

      <!-- Hero subheading -->
      <p style={{
        fontSize: "clamp(1.1rem, 2.5vw, 1.3rem)", color: "var(--muted)",
        maxWidth: "680px", margin: "0 auto 2.5rem", lineHeight: 1.7, fontWeight: 400
      }}>
        Access exclusive Udemy promo codes and discount vouchers updated daily for {`${currentMonth} ${currentYear}`}.
        Find premium course deals in programming, data science, and professional development verified by our team.
      </p>

      <!-- Search Bar -->
      <div style={{ display: "flex", justifyContent: "center", marginBottom: "2.5rem" }}>
        <form action="/search" method="GET" role="search" aria-label="Search free Udemy courses"
          style={{ position: "relative", width: "100%", maxWidth: "700px" }}>
          <div style={{
            display: "flex", alignItems: "center", background: "var(--card)",
            borderRadius: "16px", border: "2px solid var(--border)", padding: "0.25rem",
            boxShadow: "0 8px 32px rgba(0,0,0,0.15)", height: "60px"
          }}>
            <div style={{ padding: "0 1.25rem", color: "#9ca3af" }}>
              <svg style={{ width: "1.4rem", height: "1.4rem" }} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            </div>
            <input
              type="search"
              name="q"
              style={{
                flex: 1, background: "transparent", border: "none", outline: "none",
                color: "var(--text)", fontSize: "1rem", height: "100%", fontWeight: 500
