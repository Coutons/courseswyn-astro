---
import Layout from "../layouts/Layout.astro";
import DealCard from "../components/DealCard.astro";
import { getCollection } from "astro:content";
import { readDeals } from "../lib/store";
import { formatStringWIB, toISODateWIB } from "../lib/date";

const allPosts = await getCollection("blog");
const latestPosts = allPosts.sort((a: any, b: any) => {
  const dateA = a.data.updatedAt || a.data.pubDate;
  const dateB = b.data.updatedAt || b.data.pubDate;
  return dateB.getTime() - dateA.getTime();
}).slice(0, 3);

function resolveImage(imagePath: string | undefined | { src: string }): string | null {
  if (!imagePath) return null;
  if (typeof imagePath === 'object' && 'src' in imagePath) return imagePath.src;
  if (typeof imagePath !== 'string') return null;
  if (imagePath.startsWith('http')) return imagePath;
  const filename = imagePath.split('/').pop();
  if (!filename) return null;
  return `/assets/images/${filename}`;
}

const allDeals = await readDeals();

const categoryList = [...new Set(allDeals.map((d) => d.category).filter(Boolean))] as string[];
const categoryCards = categoryList.slice(0, 8).map((name) => ({
  name,
  count: allDeals.filter((d) => d.category === name).length,
  slug: name === "Uncategorized" ? "uncategorized" : name.toLowerCase().replace(/&/g, "and").replace(/[^\w\s-]/g, "").trim().replace(/\s+/g, "-"),
}));

const now = new Date();
const expiringDeals = allDeals
  .filter((d) => d.expiresAt && new Date(d.expiresAt) > now)
  .sort((a: any, b: any) => new Date(a.expiresAt).getTime() - new Date(b.expiresAt).getTime())
  .slice(0, 8);

const hoursUntilExpiry = (dateStr: string) => {
  const diff = new Date(dateStr).getTime() - now.getTime();
  if (diff <= 0) return "Expired";
  const hours = Math.floor(diff / 3600000);
  const days = Math.floor(hours / 24);
  if (days > 0) return `${days}d ${hours % 24}h left`;
  return `${hours}h left`;
};

const monthName = formatStringWIB(now, { month: 'long', year: 'numeric' });
const pageTitle = `Udemy Coupons & Verified Promo Codes [Updated ${monthName}] | CoursesWyn`;
const pageDescription = `Find verified Udemy coupon codes and course deals. Browse expert reviews, get 100% off promo codes, and discover top-rated courses in programming, AI, design & more. Updated daily.`;

const jsonLd = {
  "@context": "https://schema.org", "@graph": [
    { "@type": "WebSite", "@id": "https://courseswyn.com/#website", "url": "https://courseswyn.com", "name": "CoursesWyn", "description": pageDescription, "potentialAction": { "@type": "SearchAction", "target": { "@type": "EntryPoint", "urlTemplate": "https://courseswyn.com/search?q={search_term_string}" }, "query-input": "required name=search_term_string" } },
    { "@type": "Organization", "@id": "https://courseswyn.com/#organization", "name": "CoursesWyn", "url": "https://courseswyn.com", "logo": { "@type": "ImageObject", "url": "https://courseswyn.com/logo.png", "width": 200, "height": 60 }, "sameAs": ["https://twitter.com/CoursesGift", "https://facebook.com/BestCouponPromo"] },
    { "@type": "BreadcrumbList", "@id": "https://courseswyn.com/#breadcrumb", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" }, { "@type": "ListItem", "position": 2, "name": "Coupons", "item": "https://courseswyn.com/udemy-coupon-code" }] },
    { "@type": "FAQPage", "@id": "https://courseswyn.com/#faq", "mainEntity": [
      { "@type": "Question", "name": "Are these coupons 100% free?", "acceptedAnswer": { "@type": "Answer", "text": "Most coupons give 100% off. Some offer discounts — each deal shows the exact savings before you click." } },
      { "@type": "Question", "name": "How often are new coupons added?", "acceptedAnswer": { "@type": "Answer", "text": "New coupons added daily. Expired deals removed within 4 hours." } },
      { "@type": "Question", "name": "Do I get a certificate with free courses?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely! Official Udemy certificate, lifetime access included." } }
    ] },
    { "@type": "WebPage", "@id": "https://courseswyn.com/#webpage", "url": "https://courseswyn.com", "name": pageTitle, "description": pageDescription, "isPartOf": { "@id": "https://courseswyn.com/#website" }, "datePublished": "2024-06-01", "dateModified": toISODateWIB(now) }
  ]
};
---

<Layout title={pageTitle} description={pageDescription} canonical="https://courseswyn.com" image="/assets/images/og-default.svg">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

  <style>
    @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    .anim-up { animation: fadeUp 0.5s ease-out both; }
    .anim-1 { animation-delay: 0.1s; } .anim-2 { animation-delay: 0.2s; }
    .card-hover { transition: all 0.25s ease; }
    .card-hover:hover { transform: translateY(-3px); box-shadow: 0 12px 28px -8px rgba(0,0,0,0.1); }
    .btn-p { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.9rem 2.2rem; border-radius: 10px; background: #ea580c; color: white; text-decoration: none; font-weight: 800; font-size: 1rem; transition: all 0.25s; box-shadow: 0 4px 14px rgba(234,88,12,0.25); }
    .btn-p:hover { background: #d97706; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(234,88,12,0.35); }
    .btn-s { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.85rem 2rem; border-radius: 10px; background: transparent; color: #111827; text-decoration: none; font-weight: 700; font-size: 1rem; border: 2px solid #cbd5e1; transition: all 0.25s; }
    .btn-s:hover { border-color: #ea580c; color: #ea580c; }
    .blog-card { transition: all 0.3s ease; }
    .blog-card:hover { transform: translateY(-4px); box-shadow: 0 16px 32px -8px rgba(0,0,0,0.12); }
    .blog-card:hover img { transform: scale(1.05); }
  </style>

  <!-- HERO -->
  <section style="background:linear-gradient(135deg,#f8fafc,#f1f5f9,#faf5ff);padding:5rem 0 4rem;border-bottom:1px solid #e2e8f0">
    <div class="container" style="max-width:800px">
      <div class="anim-up" style="text-align:center">
        <span style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.35rem 1rem;border-radius:100px;background:white;border:1px solid #e2e8f0;font-size:0.8rem;font-weight:700;color:#ea580c;margin-bottom:1rem">
          <span style="width:7px;height:7px;border-radius:50%;background:#22c55e"></span>
          Verified Daily
        </span>
        <h1 style="font-size:clamp(2rem,4vw,3rem);font-weight:900;line-height:1.15;color:#0f172a;margin:0 0 0.75rem;letter-spacing:-0.03em">
          {allDeals.length.toLocaleString()}+ Udemy Coupons & Verified Promo Codes
        </h1>
        <p style="font-size:1.1rem;color:#475569;max-width:600px;margin:0 auto 1.25rem;line-height:1.6">
          Hand-picked Udemy coupon codes and course deals across {categoryList.length} categories. From 100% off free courses to top-rated classes at the best price — updated every day.
        </p>
        <form action="/search" method="GET" style="display:flex;gap:0.5rem;max-width:460px;margin:0 auto 1.75rem">
          <input type="text" name="q" placeholder="Search courses..." aria-label="Search courses" style="flex:1;padding:0 1rem;border-radius:10px;border:2px solid #e2e8f0;font-size:0.95rem;font-weight:500;color:#0f172a;outline:none;background:white;height:48px;font-family:inherit" />
          <button type="submit" style="height:48px;padding:0 1.5rem;border-radius:10px;background:#111827;color:white;border:none;font-weight:700;font-size:0.95rem;cursor:pointer;font-family:inherit">Search</button>
        </form>
        <div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap">
          <a href="/udemy-coupon-code" class="btn-p">Browse All Coupons</a>
          <a href="/categories" class="btn-s">All Categories</a>
        </div>
        <div style="display:flex;gap:2rem;justify-content:center;flex-wrap:wrap;margin-top:2rem;padding-top:1.5rem;border-top:1px solid #e2e8f0">
          <div><div style="font-size:1.4rem;font-weight:900;color:#0f172a">{allDeals.length.toLocaleString()}+</div><div style="color:#64748b;font-size:0.8rem;font-weight:600">Coupons Listed</div></div>
          <div style="width:1px;background:#e2e8f0"></div>
          <div><div style="font-size:1.4rem;font-weight:900;color:#0f172a">{categoryList.length}</div><div style="color:#64748b;font-size:0.8rem;font-weight:600">Categories</div></div>
          <div style="width:1px;background:#e2e8f0"></div>
          <div><div style="font-size:1.4rem;font-weight:900;color:#0f172a">Daily</div><div style="color:#64748b;font-size:0.8rem;font-weight:600">Updates</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- LATEST DEALS -->
  <section style="padding:4rem 0;background:white">
    <div class="container">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;margin-bottom:2rem">
        <div>
          <span style="font-size:0.8rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#ea580c;display:block;margin-bottom:0.4rem">Fresh Deals</span>
          <h2 style="font-size:clamp(1.6rem,2.5vw,2.2rem);font-weight:900;color:#0f172a;margin:0;letter-spacing:-0.02em">Latest Udemy Coupons</h2>
        </div>
        <a href="/popular" style="font-size:0.9rem;font-weight:700;color:#ea580c;text-decoration:none;white-space:nowrap">See Popular Courses &rarr;</a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1rem">
        {allDeals.slice(0, 6).map((deal) => (<DealCard deal={deal} />))}
      </div>
    </div>
  </section>

  <!-- EXPIRING SOON -->
  {expiringDeals.length > 0 && (
  <section style="padding:3rem 0;background:#fff7ed;border-top:1px solid #fed7aa;border-bottom:1px solid #fed7aa">
    <div class="container">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem">
        <div>
          <span style="font-size:0.8rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#ea580c;display:block;margin-bottom:0.4rem">Hurry! Limited Time</span>
          <h2 style="font-size:clamp(1.6rem,2.5vw,2.2rem);font-weight:900;color:#0f172a;margin:0;letter-spacing:-0.02em">
            <span style="display:inline-flex;align-items:center;gap:0.4rem">
              Expiring Soon
              <span style="font-size:0.6rem;background:#dc2626;color:white;padding:0.1rem 0.45rem;border-radius:4px;font-weight:800">LIVE</span>
            </span>
          </h2>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:0.75rem">
        {expiringDeals.map((deal) => (
          <a href={`/coupon/${deal.slug}`} class="card-hover" style="background:white;border:1px solid #fed7aa;border-radius:10px;padding:0.85rem 1rem;text-decoration:none;color:inherit;display:flex;align-items:center;gap:0.75rem">
            {deal.image && <img src={deal.image} alt="" style="width:44px;height:44px;border-radius:6px;object-fit:cover;flex-shrink:0" />}
            <div style="flex:1;min-width:0">
              <div style="font-size:0.85rem;font-weight:700;color:#0f172a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{deal.title}</div>
              <div style="display:flex;gap:0.5rem;margin-top:0.2rem">
                <span style="font-size:0.7rem;color:#dc2626;font-weight:700">{deal.expiresAt ? hoursUntilExpiry(deal.expiresAt) : ''}</span>
                <span style="font-size:0.7rem;color:#64748b;font-weight:600">{deal.category}</span>
              </div>
            </div>
            <span style="font-size:0.8rem;color:#ea580c;font-weight:800;flex-shrink:0">&rarr;</span>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:1.25rem">
        <a href="/popular" class="btn-p" style="background:#dc2626">
          View Expiring Deals &rarr;
        </a>
      </div>
    </div>
  </section>
  )}

  <!-- CATEGORIES -->
  <section style="padding:3rem 0;background:#f8fafc;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0">
    <div class="container">
      <div style="text-align:center;margin-bottom:1.5rem">
        <span style="font-size:0.8rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#ea580c;display:block;margin-bottom:0.4rem">Browse by Category</span>
        <h2 style="font-size:clamp(1.6rem,2.5vw,2.2rem);font-weight:900;color:#0f172a;margin:0;letter-spacing:-0.02em">All Categories</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.75rem">
        {categoryCards.map((cat) => (
          <a href={`/categories/${cat.slug}`} class="card-hover" style="background:white;border:1px solid #e2e8f0;border-radius:10px;padding:0.9rem 1.1rem;text-decoration:none;color:inherit;display:flex;align-items:center;justify-content:space-between">
            <span style="font-size:0.9rem;font-weight:700;color:#0f172a">{cat.name}</span>
            <span style="font-size:0.75rem;font-weight:700;color:#94a3b8;background:#f1f5f9;padding:0.15rem 0.55rem;border-radius:6px">{cat.count}</span>
          </a>
        ))}
        <a href="/categories" class="card-hover" style="background:#f8fafc;border:1px dashed #cbd5e1;border-radius:10px;padding:0.9rem 1.1rem;text-decoration:none;color:inherit;display:flex;align-items:center;justify-content:center;gap:0.4rem;font-weight:700;font-size:0.85rem;color:#64748b">
          +{categoryList.length - 8} more &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS + TRUST -->
  <section style="padding:3rem 0;background:white">
    <div class="container">
      <div style="text-align:center;margin-bottom:2rem">
        <span style="font-size:0.8rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#ea580c;display:block;margin-bottom:0.4rem">How It Works</span>
        <h2 style="font-size:clamp(1.6rem,2.5vw,2.2rem);font-weight:900;color:#0f172a;margin:0;letter-spacing:-0.02em">Start Saving in Three Steps</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-bottom:2.5rem;position:relative">
        <div style="text-align:center;padding:1.5rem 1rem;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;position:relative">
          <div style="width:48px;height:48px;margin:0 auto 0.75rem;border-radius:50%;background:linear-gradient(135deg,#fef3c7,#fde68a);display:flex;align-items:center;justify-content:center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </div>
          <span style="position:absolute;top:-8px;left:50%;transform:translateX(-50%);background:#ea580c;color:white;width:22px;height:22px;border-radius:50%;font-size:0.7rem;font-weight:900;display:flex;align-items:center;justify-content:center">1</span>
          <h3 style="font-size:0.95rem;font-weight:800;color:#0f172a;margin:0 0 0.35rem">Browse Coupons</h3>
          <p style="font-size:0.8rem;color:#64748b;line-height:1.5;margin:0">Explore {allDeals.length.toLocaleString()}+ deals sorted by category, popularity, or date.</p>
        </div>
        <div style="display:none;align-items:center;justify-content:center;font-size:1.5rem;color:#cbd5e1;font-weight:300">&#8594;</div>
        <div style="text-align:center;padding:1.5rem 1rem;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;position:relative">
          <div style="width:48px;height:48px;margin:0 auto 0.75rem;border-radius:50%;background:linear-gradient(135deg,#dbeafe,#bfdbfe);display:flex;align-items:center;justify-content:center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <span style="position:absolute;top:-8px;left:50%;transform:translateX(-50%);background:#ea580c;color:white;width:22px;height:22px;border-radius:50%;font-size:0.7rem;font-weight:900;display:flex;align-items:center;justify-content:center">2</span>
          <h3 style="font-size:0.95rem;font-weight:800;color:#0f172a;margin:0 0 0.35rem">Redeem Code</h3>
          <p style="font-size:0.8rem;color:#64748b;line-height:1.5;margin:0">Click any deal to reveal the coupon. No signup or account needed.</p>
        </div>
        <div style="text-align:center;padding:1.5rem 1rem;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;position:relative">
          <div style="width:48px;height:48px;margin:0 auto 0.75rem;border-radius:50%;background:linear-gradient(135deg,#d1fae5,#a7f3d0);display:flex;align-items:center;justify-content:center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          </div>
          <span style="position:absolute;top:-8px;left:50%;transform:translateX(-50%);background:#ea580c;color:white;width:22px;height:22px;border-radius:50%;font-size:0.7rem;font-weight:900;display:flex;align-items:center;justify-content:center">3</span>
          <h3 style="font-size:0.95rem;font-weight:800;color:#0f172a;margin:0 0 0.35rem">Learn Free or Save Big</h3>
          <p style="font-size:0.8rem;color:#64748b;line-height:1.5;margin:0">Hundreds of courses at 100% off. Others at the best price guaranteed.</p>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;padding-top:2rem;border-top:1px solid #e2e8f0">
        <div style="text-align:center;padding:1.25rem 0.75rem;background:white;border-radius:10px;border:1px solid #e2e8f0">
          <div style="width:36px;height:36px;margin:0 auto 0.6rem;border-radius:8px;background:#fef2f2;display:flex;align-items:center;justify-content:center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round"><path d="M12 2v20M2 12h20"/></svg>
          </div>
          <h3 style="font-size:0.85rem;font-weight:800;color:#0f172a;margin:0 0 0.25rem">Always Free Options</h3>
          <p style="font-size:0.75rem;color:#64748b;line-height:1.5;margin:0">Fresh courses at 100% off added daily. No credit card needed.</p>
        </div>
        <div style="text-align:center;padding:1.25rem 0.75rem;background:white;border-radius:10px;border:1px solid #e2e8f0">
          <div style="width:36px;height:36px;margin:0 auto 0.6rem;border-radius:8px;background:#f0fdf4;display:flex;align-items:center;justify-content:center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round"><path d="M9 12l2 2 4-4"/><path d="M12 2a10 10 0 1 0 10 10"/></svg>
          </div>
          <h3 style="font-size:0.85rem;font-weight:800;color:#0f172a;margin:0 0 0.25rem">Manually Verified</h3>
          <p style="font-size:0.75rem;color:#64748b;line-height:1.5;margin:0">Every coupon checked by hand. Expired deals removed within hours.</p>
        </div>
        <div style="text-align:center;padding:1.25rem 0.75rem;background:white;border-radius:10px;border:1px solid #e2e8f0">
          <div style="width:36px;height:36px;margin:0 auto 0.6rem;border-radius:8px;background:#fefce8;display:flex;align-items:center;justify-content:center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ca8a04" stroke-width="2" stroke-linecap="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3 style="font-size:0.85rem;font-weight:800;color:#0f172a;margin:0 0 0.25rem">{categoryList.length} Categories</h3>
          <p style="font-size:0.75rem;color:#64748b;line-height:1.5;margin:0">From AI and web dev to design and business — all refreshed daily.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG -->
  {latestPosts.length > 0 && (
  <section style="padding:3rem 0;background:#f8fafc;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0">
    <div class="container">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:1.5rem">
        <div>
          <span style="font-size:0.8rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#ea580c;display:block;margin-bottom:0.4rem">Expert Reviews</span>
          <h2 style="font-size:clamp(1.6rem,2.5vw,2.2rem);font-weight:900;color:#0f172a;margin:0;letter-spacing:-0.02em">Course Reviews & Career Guides</h2>
        </div>
        <a href="/blog" style="font-size:0.9rem;font-weight:700;color:#ea580c;text-decoration:none">View all &rarr;</a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.25rem">
        {latestPosts.map((post: any, i: any) => {
          const imgSrc = resolveImage(post.data.image) || '';
          const primaryTag = post.data.tags?.[0] || 'Review';
          return (
        <a href={`/blog/${post.id}`} class="blog-card" style="background:white;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;text-decoration:none;color:inherit;display:flex;flex-direction:column">
          <div style="position:relative;aspect-ratio:16/9;overflow:hidden;background:#f1f5f9">
            {imgSrc && <img src={imgSrc} alt={post.data.title} loading={i === 0 ? 'eager' : 'lazy'} style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s" />}
            <span style="position:absolute;top:10px;left:10px;background:#0f172a;color:white;padding:3px 10px;border-radius:6px;font-size:0.65rem;font-weight:800">{primaryTag}</span>
          </div>
          <div style="padding:1rem;flex:1;display:flex;flex-direction:column">
            <h3 style="font-size:0.9rem;font-weight:700;color:#0f172a;margin:0;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">{post.data.title}</h3>
            <p style="color:#64748b;font-size:0.8rem;line-height:1.5;margin:0.4rem 0 0;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">{post.data.description}</p>
            <span style="margin-top:auto;padding-top:0.75rem;color:#ea580c;font-weight:700;font-size:0.8rem;display:flex;align-items:center;gap:0.25rem">
              Read Review &rarr;
            </span>
          </div>
        </a>
          );
        })}
      </div>
    </div>
  </section>
  )}

  <!-- FAQ -->
  <section style="padding:3rem 0;background:white">
    <div class="container" style="max-width:640px;margin:0 auto">
      <div style="text-align:center;margin-bottom:1.5rem">
        <span style="font-size:0.8rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#ea580c;display:block;margin-bottom:0.4rem">FAQ</span>
        <h2 style="font-size:clamp(1.6rem,2.5vw,2.2rem);font-weight:900;color:#0f172a;margin:0;letter-spacing:-0.02em">Frequently Asked Questions</h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:0.5rem">
        {[
          { q: "Are all coupons 100% free?", a: "Most give 100% off. Some offer discounts — each deal shows the exact savings before you click." },
          { q: "How often are new coupons added?", a: "New coupons added daily across all categories. Expired deals removed within hours." },
          { q: "Will I get a certificate with a free course?", a: "Yes! Official Udemy certificate with lifetime access included for all courses." },
          { q: "How long do coupons last?", a: "Usually 1-7 days or until 1,000 enrollments. Enroll immediately when you see a course you like." }
        ].map((faq) => (
          <div style="background:white;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden">
            <button onclick="const p=this.parentElement;const o=p.dataset.open==='true';p.dataset.open=!o;const a=this.nextElementSibling;a.style.display=o?'none':'block';this.querySelector('.fi').style.transform=o?'rotate(0deg)':'rotate(180deg)'" style="width:100%;padding:0.85rem 1.25rem;background:none;border:none;text-align:left;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:1rem;font-size:0.9rem;font-weight:700;color:#0f172a;font-family:inherit">
              <span>{faq.q}</span>
              <span class="fi" style="flex-shrink:0;color:#ea580c;font-size:0.65rem;transition:transform 0.3s">▼</span>
            </button>
            <div style="display:none;padding:0 1.25rem 0.85rem;color:#64748b;line-height:1.6;font-size:0.85rem"><p style="margin:0">{faq.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:#0f172a;padding:4rem 0;text-align:center;border-top:1px solid #1e293b">
    <div class="container" style="max-width:540px;margin:0 auto">
      <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:900;color:white;margin:0 0 0.75rem;letter-spacing:-0.02em;line-height:1.2">Ready to Save on Udemy?</h2>
      <p style="color:#94a3b8;font-size:0.95rem;margin:0 auto 1.5rem;line-height:1.5">Join thousands of students who never pay full price. Start learning today with verified coupons.</p>
      <div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap">
        <a href="/udemy-coupon-code" class="btn-p">
          Browse {allDeals.length.toLocaleString()} Coupons &rarr;
        </a>
        <a href="/categories" class="btn-s" style="border-color:#334155;color:#cbd5e1">
          Browse Categories &rarr;
        </a>
      </div>
    </div>
  </section>
</Layout>
