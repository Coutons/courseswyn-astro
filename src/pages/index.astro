  <!-- ══════════════════════════════════════════════════════════════════════
       10. FAQ — rich snippet ready
       ══════════════════════════════════════════════════════════════════════ -->
  <section class="section-wrapper" style={{ background: "hsl(280, 15%, 97%)" }} aria-label="Frequently asked questions">
    <div class="container">
      <div style={{ textAlign: "center", marginBottom: "3rem" }}>
        <div style={{
          display: "inline-flex", alignItems: "center", gap: "0.75rem",
          background: "linear-gradient(135deg, hsla(15, 85%, 55%, 0.1) 0%, hsla(15, 80%, 65%, 0.08) 100%)",
          padding: "0.5rem 1rem", borderRadius: "20px",
          border: "1px solid hsla(15, 85%, 55%, 0.2)", marginBottom: "1.5rem"
        }}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style={{ color: "var(--brand)" }} aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-6h2v6zm0-8h-2V7h2v4z"/>
          </svg>
          <span style={{ color: "var(--brand)", fontWeight: 600, fontSize: "0.85rem" }}>FAQ</span>
        </div>
        <h2 style={{ fontSize: "clamp(1.8rem, 4vw, 2.5rem)", fontWeight: 700, color: "var(--text)", marginBottom: "0.75rem" }}>
          Frequently Asked Questions About <span style={{ color: "var(--brand)" }}>Free Udemy Courses</span>
        </h2>
        <p style={{ color: "var(--muted)", fontSize: "1rem", maxWidth: "650px", margin: "0 auto", lineHeight: 1.65 }}>
          Everything you need to know about using CoursesWyn to find and claim free Udemy coupons —
          from how coupons work to certificate eligibility.
        </p>
      </div>

      <div class="faq-grid" style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(420px, 1fr))", gap: "1.5rem" }}>
        {faqs.map((faq) => (
          <div
            itemscope itemtype="https://schema.org/Question"
            style={{
              background: "var(--card)", padding: "1.75rem 2rem", borderRadius: "20px",
              border: "1px solid hsla(15, 85%, 55%, 0.15)", position: "relative",
              overflow: "hidden", boxShadow: "0 4px 12px -2px hsla(15, 85%, 55%, 0.08)"
            }}
          >
            <div style={{
              position: "absolute", top: "1rem", left: "1rem",
              width: "44px", height: "44px",
              background: "linear-gradient(135deg, hsla(15, 85%, 55%, 0.12) 0%, hsla(15, 80%, 65%, 0.08) 100%)",
              borderRadius: "10px", display: "flex", alignItems: "center", justifyContent: "center",
              border: "1px solid hsla(15, 85%, 55%, 0.2)"
            }}>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style={{ color: "var(--brand)" }} aria-hidden="true">
                <path d={faq.icon} />
              </svg>
            </div>
            <h3 itemprop="name" style={{ color: "var(--text)", fontSize: "1.1rem", marginBottom: "0.75rem", marginLeft: "3.5rem", fontWeight: 700, lineHeight: 1.4 }}>
              {faq.q}
            </h3>
            <div itemscope itemtype="https://schema.org/Answer" itemprop="acceptedAnswer">
              <p itemprop="text" style={{ color: "var(--muted)", lineHeight: 1.75, fontSize: "0.95rem", margin: 0 }}>
                {faq.a}
              </p>
            </div>
          </div>
        ))}
      </div>

      <!-- [SEO ADD] CTA below FAQ to /deals -->
      <div style={{ textAlign: "center", marginTop: "3rem" }}>
        <p style={{ color: "var(--muted)", marginBottom: "1rem" }}>Still have questions? Browse our full coupon library.</p>
        <a href="/udemy-coupon-code" style={{
          display: "inline-flex", alignItems: "center", gap: "0.5rem",
          padding: "0.875rem 2rem", borderRadius: "12px",
          background: "hsla(15, 85%, 55%, 0.1)", color: "var(--brand)",
          textDecoration: "none", fontWeight: 600, fontSize: "1rem",
          border: "1px solid hsla(15, 85%, 55%, 0.3)"
        }}>
          Browse Free Udemy Courses
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
          </svg>
        </a>
      </div>
    </div>
  </section>


</Layout>
