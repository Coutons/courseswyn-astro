---
import Layout from "../layouts/Layout.astro";
import DealCard from "../components/DealCard.astro";
import { readDeals } from "../lib/store";

const allDeals = await readDeals();
const PAGE_SIZE = 6;
const initialItems = allDeals.slice(0, PAGE_SIZE);

function slugifyCategory(name: string) {
  if (name === "Uncategorized") return "uncategorized";
  return name.toLowerCase().replace(/&amp;/gi, "&").replace(/&/g, " and ").replace(/[^\w\s-]/g, "").trim().replace(/\s+/g, "-").replace(/-+/g, "-");
}

const categories = [...new Set(allDeals.map((d) => d.category).filter(Boolean))] as string[];

const now = new Date();
const monthName = now.toLocaleString('en-US',{month:'long',year:'numeric'});
const pageTitle = `Free Udemy Coupons ${monthName} — 1,200+ Verified Discounts | CoursesWyn`;
const pageDescription = `Find 1,200+ verified free Udemy coupons updated daily. Save on AI, coding, design, business & more courses. No signup required.`;

const jsonLd = {
  "@context": "https://schema.org", "@graph": [
    { "@type": "WebSite", "@id": "https://courseswyn.com/#website", "url": "https://courseswyn.com", "name": "CoursesWyn — Free Udemy Coupons", "description": pageDescription, "potentialAction": { "@type": "SearchAction", "target": { "@type": "EntryPoint", "urlTemplate": "https://courseswyn.com/search?q={search_term_string}" }, "query-input": "required name=search_term_string" } },
    { "@type": "Organization", "@id": "https://courseswyn.com/#organization", "name": "CoursesWyn", "url": "https://courseswyn.com", "logo": { "@type": "ImageObject", "url": "https://courseswyn.com/logo.png", "width": 200, "height": 60 }, "sameAs": ["https://twitter.com/CoursesGift", "https://facebook.com/BestCouponPromo"] },
    { "@type": "BreadcrumbList", "@id": "https://courseswyn.com/#breadcrumb", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" }, { "@type": "ListItem", "position": 2, "name": "Free Coupons", "item": "https://courseswyn.com/udemy-coupon-code" }] },
    { "@type": "FAQPage", "@id": "https://courseswyn.com/#faq", "mainEntity": [
      { "@type": "Question", "name": "Are these coupons 100% free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes! Every coupon gives 100% off. No hidden fees." } },
      { "@type": "Question", "name": "How often are new coupons added?", "acceptedAnswer": { "@type": "Answer", "text": "New coupons added daily. Expired deals removed within 4 hours." } },
      { "@type": "Question", "name": "Do I get a certificate with free courses?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely! Official Udemy certificate, lifetime access included." } }
    ] },
    { "@type": "WebPage", "@id": "https://courseswyn.com/#webpage", "url": "https://courseswyn.com", "name": pageTitle, "description": pageDescription, "isPartOf": { "@id": "https://courseswyn.com/#website" }, "datePublished": "2024-06-01", "dateModified": now.toISOString().split('T')[0] }
  ]
};
---
<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .sec-pad { padding: 5rem 0; }
  @media (max-width: 768px) { .sec-pad { padding: 3rem 0; } }

  @keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
  @keyframes pulse-dot { 0%,100%{opacity:0.6} 50%{opacity:1} }
  .anim-up { animation: fadeUp 0.5s ease-out both; }
  .anim-1 { animation-delay: 0.1s; } .anim-2 { animation-delay: 0.2s; } .anim-3 { animation-delay: 0.3s; } .anim-4 { animation-delay: 0.4s; }

  .hero-wrap { position: relative; background: linear-gradient(135deg, #0a0a0f 0%, #12121a 50%, #0f1f17 100%); overflow: hidden; }
  .hero-wrap::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 30% 50%, rgba(16,185,129,0.08) 0%, transparent 50%), radial-gradient(ellipse at 70% 50%, rgba(5,150,105,0.04) 0%, transparent 50%); pointer-events: none; }
  .hero-grid { position: absolute; inset: 0; opacity: 0.02; pointer-events: none; background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 80px 80px; }
  .hero-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.4rem 1rem; border-radius: 100px; background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.2); font-size: 0.8rem; font-weight: 600; color: #10b981; }
  .hero-badge .dot { width: 6px; height: 6px; border-radius: 50%; background: #14b8a6; animation: pulse-dot 2s ease infinite; }
  .hero-stat { text-align: center; padding: 1.25rem 2rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; backdrop-filter: blur(12px); transition: all 0.3s ease; }
  .hero-stat:hover { background: rgba(255,255,255,0.06); transform: translateY(-2px); border-color: rgba(16,185,129,0.2); }
  .hero-stat-num { font-size: 1.8rem; font-weight: 800; background: linear-gradient(135deg,#14b8a6,#0d9488); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

  .sec-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #14b8a6; margin-bottom: 0.5rem; }
  .sec-title { font-size: 2rem; font-weight: 800; color: #f1f5f9; margin: 0; letter-spacing: -0.02em; }
  @media (max-width: 768px) { .sec-title { font-size: 1.5rem; } }

  .blog-card { border-radius: 16px; overflow: hidden; background: #12121a; border: 1px solid #1e1e2e; transition: all 0.4s cubic-bezier(0.4,0,0.2,1); text-decoration: none; color: inherit; display: flex; flex-direction: column; }
  .blog-card:hover { transform: translateY(-6px); border-color: rgba(16,185,129,0.3); box-shadow: 0 24px 48px -12px rgba(0,0,0,0.4); }
  .blog-card .arrow { transition: transform 0.3s ease; display: inline-block; }
  .blog-card:hover .arrow { transform: translateX(6px); }
  .blog-card .tag { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 6px; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; background: rgba(20,184,166,0.08); color: #14b8a6; }
  .blog-card img { width: 100%; height: 180px; object-fit: cover; border-bottom: 1px solid #1e1e2e; }

  .feat-card { background: #12121a; border: 1px solid #1e1e2e; border-radius: 14px; padding: 1.5rem; display: flex; gap: 1rem; align-items: flex-start; transition: all 0.4s cubic-bezier(0.4,0,0.2,1); }
  .feat-card:hover { transform: translateY(-4px); border-color: rgba(16,185,129,0.2); box-shadow: 0 16px 32px -8px rgba(0,0,0,0.3); }
  .feat-card .icon-box { width: 46px; height: 46px; min-width: 46px; border-radius: 12px; background: rgba(20,184,166,0.08); color: #14b8a6; display: flex; align-items: center; justify-content: center; transition: all 0.4s ease; }
  .feat-card:hover .icon-box { background: rgba(16,185,129,0.15); }

  .cat-pill { padding: 0.5rem 1.25rem; border-radius: 100px; background: #12121a; border: 1px solid #1e1e2e; color: #94a3b8; text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: all 0.3s ease; white-space: nowrap; }
  .cat-pill:hover { background: rgba(16,185,129,0.1); color: #10b981; border-color: rgba(16,185,129,0.3); transform: translateY(-2px); }
  .cat-pill.active { background: rgba(16,185,129,0.12); color: #10b981; border-color: rgba(16,185,129,0.3); }

  .faq-item { background: #12121a; border: 1px solid #1e1e2e; border-radius: 12px; overflow: hidden; transition: border-color 0.3s; }
  .faq-item:hover { border-color: rgba(16,185,129,0.2); }
  .faq-btn { width: 100%; padding: 1.25rem 1.5rem; background: none; border: none; text-align: left; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 1rem; font-size: 0.95rem; font-weight: 600; color: #f1f5f9; transition: background 0.2s; }
  .faq-btn:hover { background: rgba(255,255,255,0.03); }
  .faq-icon { flex-shrink: 0; color: #14b8a6; font-size: 0.75rem; transition: transform 0.3s ease; }
  .faq-answer { display: none; padding: 0 1.5rem 1.25rem; color: #64748b; line-height: 1.7; font-size: 0.9rem; }

  .prose-content h2 { font-size: 1.5rem; font-weight: 700; color: #f1f5f9; margin: 2rem 0 1rem; }
  .prose-content h3 { font-size: 1.15rem; font-weight: 600; color: #f1f5f9; margin: 1.5rem 0 0.75rem; }
  .prose-content p { color: #94a3b8; line-height: 1.75; margin-bottom: 1rem; font-size: 0.95rem; }
  .prose-content a { color: #14b8a6; text-decoration: underline; }
  .prose-content ul { color: #94a3b8; padding-left: 1.25rem; margin-bottom: 1rem; line-height: 1.8; }
</style>

<Layout title={pageTitle} description={pageDescription} canonical="https://courseswyn.com">
  <meta property="og:type" content="website" slot="head" />
  <meta property="og:url" content="https://courseswyn.com" slot="head" />
  <meta property="og:title" content={pageTitle} slot="head" />
  <meta property="og:description" content={pageDescription} slot="head" />
  <meta property="og:site_name" content="CoursesWyn" slot="head" />
  <meta property="og:locale" content="en_US" slot="head" />
  <meta name="twitter:card" content="summary_large_image" slot="head" />
  <meta name="twitter:title" content={pageTitle} slot="head" />
  <meta name="twitter:description" content={pageDescription} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- ═══ HERO ═══ -->
  <section class="hero-wrap sec-pad" style={{ paddingBottom: "8rem" }}>
    <div class="hero-grid" />
    <div class="container" style={{ position: "relative", zIndex: 2, textAlign: "center" }}>
      <div class="hero-badge anim-up" style={{ marginBottom: "2rem" }}><span class="dot" /><span>1,200+ Verified Coupons · Updated Daily</span></div>
      <h1 class="anim-up anim-1" style={{ fontSize: "clamp(2.5rem, 5vw, 4rem)", fontWeight: 800, lineHeight: 1.05, marginBottom: "1.25rem", letterSpacing: "-0.03em", color: "white" }}>
        <span style={{ background: "linear-gradient(135deg, #10b981, #059669)", WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent", backgroundClip: "text" }}>Free Udemy Courses</span><br />
        <span style={{ color: "#64748b", fontWeight: 600 }}>with Verified 100% Off Coupons</span>
      </h1>
      <p class="anim-up anim-2" style={{ fontSize: "1.15rem", color: "#64748b", maxWidth: "580px", margin: "0 auto 2.5rem", lineHeight: 1.7 }}>Save thousands on premium courses. Expert reviews + working coupons updated every 4 hours.</p>
      <div class="anim-up anim-3" style={{ display: "flex", gap: "1rem", justifyContent: "center", flexWrap: "wrap", marginBottom: "4rem" }}>
        <a href="/udemy-coupon-code" style={{ padding: "0.9rem 2.5rem", borderRadius: "12px", background: "linear-gradient(135deg,#10b981,#059669)", color: "#0a0a0f", textDecoration: "none", fontWeight: 700, fontSize: "1rem", display: "inline-flex", alignItems: "center", gap: "0.5rem", boxShadow: "0 8px 24px -4px rgba(16,185,129,0.3)", transition: "all 0.3s" }} onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 12px 32px -4px rgba(16,185,129,0.4)'" onmouseout="this.style.transform='';this.style.boxShadow='0 8px 24px -4px rgba(16,185,129,0.3)'">🔥 Browse {allDeals.length.toLocaleString()} Coupons</a>
        <a href="/blog" style={{ padding: "0.9rem 2.5rem", borderRadius: "12px", background: "rgba(255,255,255,0.03)", color: "#94a3b8", textDecoration: "none", fontWeight: 600, fontSize: "1rem", border: "1px solid rgba(255,255,255,0.06)", transition: "all 0.3s" }} onmouseover="this.style.background='rgba(255,255,255,0.06)';this.style.color='#f1f5f9'" onmouseout="this.style.background='rgba(255,255,255,0.03)';this.style.color='#94a3b8'">📖 Expert Reviews</a>
      </div>
      <div class="anim-up anim-4" style={{ maxWidth: "560px", margin: "0 auto" }}>
        <form action="/search" method="GET" role="search" style={{ display: "flex", alignItems: "center", background: "rgba(255,255,255,0.03)", borderRadius: "14px", border: "1px solid rgba(255,255,255,0.06)", padding: "0.3rem" }}>
          <div style={{ padding: "0 1rem", color: "#475569", display: "flex" }}><svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg></div>
          <input type="search" name="q" placeholder="Search courses..." autocomplete="off" aria-label="Search" style={{ flex: 1, background: "transparent", border: "none", outline: "none", color: "white", fontSize: "0.95rem", height: "46px", fontWeight: 400 }} />
          <button type="submit" style={{ padding: "0.5rem 1.5rem", borderRadius: "10px", background: "linear-gradient(135deg,#10b981,#059669)", color: "#0a0a0f", border: "none", fontSize: "0.85rem", fontWeight: 700, cursor: "pointer", marginRight: "0.2rem" }}>Search</button>
        </form>
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section style={{ marginTop: "-3.5rem", position: "relative", zIndex: 3 }}>
    <div class="container">
      <div style={{ display: "flex", justifyContent: "center", gap: "1rem", flexWrap: "wrap" }}>
        <div class="hero-stat anim-up anim-1"><div class="hero-stat-num">150K+</div><div style={{ color: "#64748b", fontSize: "0.8rem", marginTop: "0.15rem" }}>Learners</div></div>
        <div class="hero-stat anim-up anim-2"><div class="hero-stat-num">{allDeals.length.toLocaleString()}+</div><div style={{ color: "#64748b", fontSize: "0.8rem", marginTop: "0.15rem" }}>Coupons</div></div>
        <div class="hero-stat anim-up anim-3"><div class="hero-stat-num">4.8★</div><div style={{ color: "#64748b", fontSize: "0.8rem", marginTop: "0.15rem" }}>Avg Rating</div></div>
        <div class="hero-stat anim-up anim-4"><div class="hero-stat-num">24/7</div><div style={{ color: "#64748b", fontSize: "0.8rem", marginTop: "0.15rem" }}>Fresh</div></div>
      </div>
    </div>
  </section>

  <!-- ═══ BLOG ═══ -->
  <section class="sec-pad" style={{ background: "#0a0a0f", borderBottom: "1px solid #1e1e2e" }}>
    <div class="container">
      <div class="anim-up" style={{ marginBottom: "1rem" }}>
              <p class="sec-label">Expert Reviews</p>
              <h2 class="sec-title">Course Reviews & Career Guides</h2>
            </div>
            <p class="anim-up anim-1" style={{ color: "#64748b", fontSize: "0.9rem", maxWidth: "600px", marginBottom: "2.5rem", lineHeight: 1.6 }}>In-depth analysis of the best Udemy courses. Our editorial team reviews curriculum quality, instructor expertise, and career outcomes to help you choose the right course.</p>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(300px, 1fr))", gap: "1.5rem" }}>
        <a href="/blog/ai-engineer-roadmap-2026" class="blog-card anim-up anim-1">
          <img src="/assets/images/ai-engineer-roadmap-2026.jpg" alt="AI Engineer Roadmap 2026" loading="lazy" />
          <div style={{ padding: "1.5rem" }}>
            <span class="tag">Career Guide</span>
            <h3 style={{ fontSize: "1.1rem", fontWeight: 700, color: "#f1f5f9", margin: "0.75rem 0 0.5rem 0", lineHeight: 1.3 }}>AI Engineer Roadmap 2026: 7 Best Udemy Courses</h3>
            <p style={{ color: "#64748b", fontSize: "0.85rem", lineHeight: 1.6, margin: 0 }}>Complete roadmap from beginner to AI Engineer. MCP Protocol, RAG pipelines, LangChain — all under $80.</p>
            <p style={{ marginTop: "1rem", color: "#10b981", fontWeight: 600, fontSize: "0.85rem", display: "flex", alignItems: "center", gap: "0.4rem" }}>Read Full Review <span class="arrow">→</span></p>
          </div>
        </a>
        <a href="/blog/best-ai-engineer-courses-udemy-2026" class="blog-card anim-up anim-2">
