---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { readDeals } from "../lib/store";
import DealCard from "../components/DealCard.astro";

const currentDate = new Date();
const monthNames  = ["January","February","March","April","May","June","July","August","September","October","November","December"];
const currentMonth = monthNames[currentDate.getMonth()];
const currentYear  = currentDate.getFullYear();

const allBlogPosts = await getCollection("blog");
const featuredArticles = allBlogPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);

const featuredSide = featuredArticles.slice(0, 3);
const remainingPosts = featuredArticles.slice(3, 6);

// Manual hero article - Claude Code
const heroArticle = await getCollection("blog").then(posts => 
  posts.find(p => p.id === "best-udemy-claude-code-courses-2026")
);

const allDeals = await readDeals();
const latestDeals = allDeals.slice(0, 6);

const pageTitle       = `Best Udemy Courses & Verified Promo Codes | CoursesWyn`;
const pageDescription = `Expert-reviewed rankings of the best Udemy courses by topic, plus verified promo codes updated daily. Save up to 100% on top-rated courses in 2026.`;

function slugifyTopic(name: string) {
  return name.toLowerCase().replace(/[^a-z0-9\s-]/g, "").replace(/\s+/g, "-").replace(/-+/g, "-");
}

const decodeHtml = (str: string) =>
  str.replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/&#39;/g, "'");

const topicCounts: Record<string, number> = {};
allDeals.forEach(deal => {
  if (deal.subcategory) {
    const sub = decodeHtml(deal.subcategory);
    topicCounts[sub] = (topicCounts[sub] || 0) + 1;
  }
});

const topTopics = Object.entries(topicCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10)
  .map(([name, count]) => ({
    name,
    slug: slugifyTopic(name),
    count
  }));
---

<Layout title={pageTitle} description={pageDescription}>

  <!-- ══ 1. HERO ══════════════════════════════════════════════════════════ -->
  <section style={{ background: "var(--bg)", borderBottom: "2px solid var(--border)", padding: "80px 0 64px" }}>
    <div class="container">
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "64px", alignItems: "center" }}>

        {/* Left: Big editorial headline */}
        <div>
          <div style={{
            display: "inline-flex", alignItems: "center", gap: "8px",
            border: "2px solid var(--border)", borderRadius: "4px",
            padding: "5px 14px", marginBottom: "28px",
            background: "var(--accent)", color: "white",
            fontSize: "0.75rem", fontWeight: 800, letterSpacing: "0.1em",
            textTransform: "uppercase",
            boxShadow: "3px 3px 0 var(--border)"
          }}>
            <span>●</span> {currentMonth} {currentYear} — Updated Daily
          </div>

          <h1 style={{
            fontSize: "clamp(2.8rem, 5vw, 4rem)",
            fontWeight: 900,
            lineHeight: 1.05,
            letterSpacing: "-0.04em",
            color: "var(--text)",
            marginBottom: "24px",
            margin: "0 0 24px"
          }}>
            The Internet's Most <span style={{
              background: "var(--accent)",
              color: "white",
              padding: "0 6px",
              display: "inline-block",
              transform: "rotate(-0.8deg)",
              boxDecorationBreak: "clone"
            }}>Opinionated</span><br/>
            Udemy Course Reviews.
          </h1>

          <p style={{ fontSize: "1.1rem", color: "var(--muted)", lineHeight: 1.65, marginBottom: "36px", fontWeight: 500 }}>
            We read thousands of reviews so you don't have to. Expert analysis of the <strong>best Udemy courses</strong> by topic — plus verified promo codes that actually work.
          </p>

          <div style={{ display: "flex", gap: "12px", flexWrap: "wrap" }}>
            <a href="/blog" class="btn" style={{ fontSize: "1rem", padding: "14px 28px" }}>
              Browse Best Courses →
            </a>
            <a href="/udemy-coupon-code" class="btn btn-outline" style={{ fontSize: "1rem", padding: "14px 28px" }}>
              Get Free Promo Codes
            </a>
          </div>

          <div style={{ display: "flex", gap: "32px", marginTop: "40px", paddingTop: "32px", borderTop: "2px solid var(--border)" }}>
            {[
              { num: "1,200+", label: "Courses Analyzed" },
              { num: "100%", label: "Codes Verified" },
              { num: "Daily", label: "Updates" }
            ].map(stat => (
              <div>
                <div style={{ fontSize: "1.5rem", fontWeight: 900, color: "var(--text)" }}>{stat.num}</div>
                <div style={{ fontSize: "0.8rem", color: "var(--muted)", fontWeight: 600, textTransform: "uppercase", letterSpacing: "0.08em" }}>{stat.label}</div>
              </div>
            ))}
          </div>
        </div>

        {/* Right: Featured article card */}
        {heroArticle && (
          <div>
            <div style={{
              border: "2px solid var(--border)",
              borderRadius: "4px",
              overflow: "hidden",
              boxShadow: "8px 8px 0 var(--border)",
              background: "var(--card)",
              transition: "all 0.15s ease"
            }} class="hero-card">
              <div style={{ height: "240px", overflow: "hidden", borderBottom: "2px solid var(--border)", position: "relative" }}>
                <img
                  src={typeof heroArticle.data.image === 'string' ? heroArticle.data.image : (heroArticle.data.image as any)?.src || '/og-image.jpg'}
                  alt={heroArticle.data.title}
                  style={{ width: "100%", height: "100%", objectFit: "cover" }}
                />
                <div style={{
                  position: "absolute", top: "12px", left: "12px",
                  background: "var(--accent)", color: "white",
                  border: "2px solid var(--border)", boxShadow: "2px 2px 0 var(--border)",
                  padding: "3px 10px", fontSize: "0.68rem", fontWeight: 800,
                  textTransform: "uppercase", letterSpacing: "0.08em", borderRadius: "4px"
                }}>
                  {heroArticle.data.tags?.[0] || "Featured"}
                </div>
              </div>
              <div style={{ padding: "28px" }}>
                <p style={{ fontSize: "0.75rem", fontWeight: 800, color: "var(--muted)", textTransform: "uppercase", letterSpacing: "0.1em", marginBottom: "10px" }}>
                  #1 EDITOR'S PICK
                </p>
                <h2 style={{ fontSize: "1.3rem", fontWeight: 900, lineHeight: 1.2, marginBottom: "16px", color: "var(--text)" }}>
                  <a href={`/blog/${heroArticle.id}`} style={{ textDecoration: "none", color: "inherit" }}>
                    {heroArticle.data.title}
                  </a>
                </h2>
                <a href={`/blog/${heroArticle.id}`} style={{
                  display: "inline-flex", alignItems: "center", gap: "6px",
                  fontWeight: 800, fontSize: "0.88rem", color: "var(--accent)",
                  textDecoration: "none", textTransform: "uppercase", letterSpacing: "0.06em"
                }}>
                  Read Full Review →
                </a>
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- ══ 2. TOPIC PILLS ═══════════════════════════════════════════════════ -->
  <section style={{ background: "var(--card)", borderBottom: "2px solid var(--border)", padding: "20px 0" }}>
    <div class="container">
      <div style={{ display: "flex", alignItems: "center", gap: "12px", flexWrap: "wrap" }}>
        <span style={{ fontSize: "0.72rem", fontWeight: 800, textTransform: "uppercase", letterSpacing: "0.12em", color: "var(--muted)", whiteSpace: "nowrap" }}>
          Browse by topic:
        </span>
        {topTopics.map((topic, i) => (
          <a href={`/topics/${topic.slug}`} class="pill" style={{
            background: i === 0 ? "var(--text)" : "var(--bg)",
            color: i === 0 ? "var(--bg)" : "var(--text)",
            borderColor: i === 0 ? "var(--text)" : "var(--border)"
          }}>
            {topic.name}
          </a>
        ))}
        <a href="/topics" style={{ fontSize: "0.8rem", fontWeight: 700, color: "var(--accent)", textDecoration: "none", marginLeft: "4px" }}>
          View all →
        </a>
      </div>
    </div>
  </section>

  <!-- ══ 3. FEATURED GUIDES (Editorial grid) ══════════════════════════════ -->
  <section style={{ padding: "80px 0", background: "var(--bg)", borderBottom: "2px solid var(--border)" }}>
    <div class="container">
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-end", marginBottom: "40px" }}>
        <div>
          <p style={{ fontSize: "0.72rem", fontWeight: 800, textTransform: "uppercase", letterSpacing: "0.15em", color: "var(--muted)", marginBottom: "8px" }}>
            Expert Analysis
          </p>
          <h2 style={{ fontSize: "2.25rem", fontWeight: 900, color: "var(--text)", margin: 0, letterSpacing: "-0.04em" }}>
            Best Udemy Courses<br/>
            <span style={{ background: "var(--accent)", color: "white", padding: "0 8px" }}>by Topic</span>
          </h2>
        </div>
        <a href="/blog" class="btn btn-outline" style={{ fontSize: "0.85rem", padding: "10px 20px" }}>All Reviews →</a>
      </div>

      {/* Editorial 2-col layout: 1 large + 2 small */}
      <div style={{ display: "grid", gridTemplateColumns: "1.4fr 1fr", gap: "24px", marginBottom: "24px" }}>

        {/* Large feature */}
        {featuredSide[0] && (
          <article style={{
            border: "2px solid var(--border)", borderRadius: "4px",
            overflow: "hidden", background: "var(--card)",
            boxShadow: "5px 5px 0 var(--border)",
            transition: "all 0.15s ease"
          }} class="article-card">
            <div style={{ height: "260px", overflow: "hidden", borderBottom: "2px solid var(--border)" }}>
              <img
                src={typeof featuredSide[0].data.image === 'string' ? featuredSide[0].data.image : (featuredSide[0].data.image as any)?.src || '/og-image.jpg'}
                alt={featuredSide[0].data.title}
                style={{ width: "100%", height: "100%", objectFit: "cover", transition: "transform 0.4s ease" }}
                class="article-img"
              />
            </div>
            <div style={{ padding: "28px" }}>
              <span style={{
                display: "inline-block", background: "var(--text)", color: "var(--bg)",
                padding: "2px 10px", fontSize: "0.68rem", fontWeight: 800,
                textTransform: "uppercase", letterSpacing: "0.1em",
                borderRadius: "3px", marginBottom: "12px"
              }}>
                {featuredSide[0].data.tags?.[0] || 'Guide'}
              </span>
              <h3 style={{ fontSize: "1.4rem", fontWeight: 900, color: "var(--text)", marginBottom: "12px", lineHeight: 1.2 }}>
                <a href={`/blog/${featuredSide[0].id}`} style={{ color: "inherit", textDecoration: "none" }}>
                  {featuredSide[0].data.title}
                </a>
              </h3>
              <p style={{ color: "var(--muted)", fontSize: "0.9rem", lineHeight: 1.6, marginBottom: "20px", display: "-webkit-box", WebkitLineClamp: 2, WebkitBoxOrient: "vertical", overflow: "hidden" }}>
                {featuredSide[0].data.description}
              </p>
              <a href={`/blog/${featuredSide[0].id}`} style={{ fontWeight: 800, color: "var(--accent)", textDecoration: "none", fontSize: "0.85rem", textTransform: "uppercase", letterSpacing: "0.06em" }}>
                Read Review →
              </a>
            </div>
          </article>
        )}

        {/* 2 stacked small cards */}
        <div style={{ display: "flex", flexDirection: "column", gap: "24px" }}>
          {featuredSide.slice(1, 3).map((post) => (
            <article style={{
              border: "2px solid var(--border)", borderRadius: "8px",
              overflow: "hidden", background: "var(--card)",
              boxShadow: "4px 4px 0 var(--border)",
              transition: "all 0.15s ease"
            }} class="article-card">
              <div style={{ height: "180px", overflow: "hidden", borderBottom: "2px solid var(--border)" }}>
                <img
                  src={typeof post.data.image === 'string' ? post.data.image : (post.data.image as any)?.src || '/og-image.jpg'}
                  alt={post.data.title}
                  style={{ width: "100%", height: "100%", objectFit: "cover", transition: "transform 0.4s ease" }}
                  class="article-img"
                />
              </div>
              <div style={{ padding: "20px" }}>
                <span style={{
                  display: "inline-block", border: "1.5px solid var(--border)",
                  padding: "1px 8px", fontSize: "0.65rem", fontWeight: 800,
                  textTransform: "uppercase", letterSpacing: "0.1em",
                  borderRadius: "3px", marginBottom: "8px", color: "var(--muted)"
                }}>
                  {post.data.tags?.[0] || 'Guide'}
                </span>
                <h3 style={{ fontSize: "0.95rem", fontWeight: 800, color: "var(--text)", lineHeight: 1.25, marginBottom: "10px" }}>
                  <a href={`/blog/${post.id}`} style={{ color: "inherit", textDecoration: "none" }}>
                    {post.data.title}
                  </a>
                </h3>
                <p style={{ color: "var(--muted)", fontSize: "0.8rem", lineHeight: 1.5, marginBottom: "14px", display: "-webkit-box", WebkitLineClamp: 2, WebkitBoxOrient: "vertical", overflow: "hidden" }}>
                  {post.data.description}
                </p>
                <a href={`/blog/${post.id}`} style={{ fontWeight: 700, color: "var(--accent)", textDecoration: "none", fontSize: "0.78rem", textTransform: "uppercase", letterSpacing: "0.06em" }}>
                  Read →
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>

      {/* 3 more articles in a row */}
      {remainingPosts.length > 0 && (
        <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: "20px" }}>
          {remainingPosts.map((post) => (
            <article style={{
              border: "2px solid var(--border)", borderRadius: "8px",
              overflow: "hidden", background: "var(--card)",
              boxShadow: "4px 4px 0 var(--border)",
              transition: "all 0.15s ease"
            }} class="article-card">
              <div style={{ height: "180px", overflow: "hidden", borderBottom: "2px solid var(--border)" }}>
                <img
                  src={typeof post.data.image === 'string' ? post.data.image : (post.data.image as any)?.src || '/og-image.jpg'}
                  alt={post.data.title}
                  style={{ width: "100%", height: "100%", objectFit: "cover" }}
                  class="article-img"
                />
              </div>
              <div style={{ padding: "20px" }}>
                <span style={{
                  display: "inline-block", background: "var(--accent)", color: "white",
                  padding: "2px 8px", fontSize: "0.62rem", fontWeight: 800,
                  textTransform: "uppercase", letterSpacing: "0.08em",
                  borderRadius: "3px", marginBottom: "10px"
                }}>
                  {post.data.tags?.[0] || 'Guide'}
                </span>
                <h3 style={{ fontSize: "0.95rem", fontWeight: 800, color: "var(--text)", lineHeight: 1.25, marginBottom: "12px" }}>
                  <a href={`/blog/${post.id}`} style={{ color: "inherit", textDecoration: "none" }}>
                    {post.data.title}
                  </a>
                </h3>
                <p style={{ color: "var(--muted)", fontSize: "0.8rem", lineHeight: 1.5, marginBottom: "14px", display: "-webkit-box", WebkitLineClamp: 2, WebkitBoxOrient: "vertical", overflow: "hidden" }}>
                  {post.data.description}
                </p>
                <a href={`/blog/${post.id}`} style={{ fontWeight: 700, color: "var(--accent)", textDecoration: "none", fontSize: "0.78rem", textTransform: "uppercase", letterSpacing: "0.06em" }}>Read →</a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ══ 4. WHY COURSESWYN (Flat info blocks) ══════════════════════════════ -->
  <section style={{ padding: "72px 0", background: "var(--text)", borderBottom: "2px solid var(--border)" }}>
    <div class="container">
      <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: "0" }}>
        {[
          { num: "01", title: "Verified Promo Codes", body: "Every code is tested before listing. We remove expired codes within 4 hours — not 4 days." },
          { num: "02", title: "Expert Course Reviews", body: "We don't just list courses. We audit curriculum, instructor quality, and real student outcomes." },
          { num: "03", title: "Daily Deal Tracking", body: "Udemy flash sales move fast. We track price drops and new 100% off coupons every single day." }
        ].map((item, i) => (
          <div style={{
            padding: "48px 36px",
            borderRight: i < 2 ? "2px solid rgba(255,255,255,0.12)" : "none"
          }}>
            <span style={{ fontSize: "0.72rem", fontWeight: 800, color: "var(--accent)", display: "block", marginBottom: "20px", textTransform: "uppercase", letterSpacing: "0.15em" }}>
              {item.num}
            </span>
            <h3 style={{ fontSize: "1.3rem", fontWeight: 900, color: "white", marginBottom: "14px", letterSpacing: "-0.03em" }}>
              {item.title}
            </h3>
            <p style={{ color: "rgba(255,255,255,0.5)", lineHeight: 1.7, fontSize: "0.92rem", margin: 0 }}>
              {item.body}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 5. DEALS ══════════════════════════════════════════════════════════ -->
  <section style={{ padding: "80px 0", background: "var(--bg)", borderBottom: "2px solid var(--border)" }}>
    <div class="container">
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-end", marginBottom: "40px" }}>
        <div>
          <p style={{ fontSize: "0.72rem", fontWeight: 800, textTransform: "uppercase", letterSpacing: "0.15em", color: "var(--muted)", marginBottom: "8px" }}>
            Updated {currentMonth} {currentYear}
          </p>
          <h2 style={{ fontSize: "2rem", fontWeight: 900, color: "var(--text)", margin: 0, letterSpacing: "-0.04em" }}>
            Udemy Promo Codes —{" "}
            <span style={{ background: "var(--accent)", color: "white", padding: "0 8px" }}>Working Now</span>
          </h2>
        </div>
        <a href="/udemy-coupon-code" class="btn btn-black" style={{ fontSize: "0.85rem", padding: "10px 20px" }}>All Deals →</a>
      </div>

      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(300px, 1fr))", gap: "20px" }}>
        {latestDeals.map(deal => (
          <DealCard deal={deal} />
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 6. HOW IT WORKS (Steps) ═══════════════════════════════════════════ -->
  <section style={{ padding: "80px 0", background: "var(--card)", borderBottom: "2px solid var(--border)" }}>
    <div class="container">
      <div style={{ maxWidth: "720px" }}>
        <h2 style={{ fontSize: "2rem", fontWeight: 900, marginBottom: "48px", letterSpacing: "-0.04em", color: "var(--text)" }}>
          How to Use Our<br/>
          <span style={{ background: "var(--text)", color: "var(--bg)", padding: "0 10px" }}>Udemy Promo Codes</span>
        </h2>
        <div style={{ display: "flex", flexDirection: "column", gap: "0" }}>
          {[
            { n: "01", t: "Find your course", d: "Use our expert guides to find the best Udemy course for your specific goal — not just the most popular one." },
            { n: "02", t: "Claim the code", d: "Click 'Get Promo Code'. We redirect you directly to Udemy checkout with the best available discount pre-applied." },
            { n: "03", t: "Start learning", d: "Lifetime access. Real skills. Fraction of the cost — sometimes completely free." }
          ].map((s, i) => (
            <div style={{
              display: "grid", gridTemplateColumns: "80px 1fr",
              borderTop: "2px solid var(--border)",
              paddingTop: "28px", paddingBottom: "28px",
              gap: "24px"
            }}>
              <span style={{ fontSize: "2.5rem", fontWeight: 900, color: "var(--border-light)", letterSpacing: "-0.05em" }}>{s.n}</span>
              <div>
                <h4 style={{ fontSize: "1.1rem", fontWeight: 800, color: "var(--text)", marginBottom: "8px" }}>{s.t}</h4>
                <p style={{ color: "var(--muted)", lineHeight: 1.65, fontSize: "0.92rem", margin: 0 }}>{s.d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 7. TESTIMONIALS ═══════════════════════════════════════════════════ -->
  <section style={{ padding: "80px 0", background: "var(--card)", borderBottom: "2px solid var(--border)" }}>
    <div class="container">
      <div style={{ textAlign: "center", marginBottom: "48px" }}>
        <p style={{ fontSize: "0.72rem", fontWeight: 800, textTransform: "uppercase", letterSpacing: "0.15em", color: "var(--muted)", marginBottom: "8px" }}>
          Social Proof
        </p>
        <h2 style={{ fontSize: "2rem", fontWeight: 900, color: "var(--text)", margin: 0, letterSpacing: "-0.04em" }}>
          What Learners Say<br/>
          <span style={{ background: "var(--accent)", color: "white", padding: "0 8px" }}>About Us</span>
        </h2>
      </div>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: "24px" }}>
        {[
          { name: "Sarah M.", role: "Frontend Developer", text: "Found the perfect React course here. Saved $200 compared to buying directly from Udemy. The course reviews are actually accurate!" },
          { name: "James K.", role: "Data Analyst", text: "The AWS certification guide helped me pass my exam on the first try. The promo codes work every single time. Best resource for Udemy learners." },
          { name: "Emily R.", role: "Career Changer", text: "Used CoursesWyn to find Python courses that actually taught me job skills. Got hired 3 months after completing the recommended learning path." }
        ].map((testimonial, i) => (
          <div style={{
            border: "2px solid var(--border)", borderRadius: "8px",
            padding: "32px", background: "var(--bg)",
            boxShadow: "4px 4px 0 var(--border)"
          }}>
            <div style={{ fontSize: "2rem", color: "var(--accent)", marginBottom: "16px" }}>★</div>
            <p style={{ fontSize: "0.95rem", lineHeight: 1.7, color: "var(--text)", marginBottom: "20px" }}>
              {testimonial.text}
            </p>
            <div style={{ display: "flex", alignItems: "center", gap: "12px" }}>
              <div style={{
                width: "48px", height: "48px", borderRadius: "50%",
                background: "var(--accent)", display: "flex",
                alignItems: "center", justifyContent: "center",
                color: "white", fontWeight: 800, fontSize: "1.2rem"
              }}>
                {testimonial.name[0]}
              </div>
              <div>
                <div style={{ fontWeight: 800, color: "var(--text)", fontSize: "0.95rem" }}>{testimonial.name}</div>
                <div style={{ fontSize: "0.8rem", color: "var(--muted)" }}>{testimonial.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 8. POPULAR COURSES BY CATEGORY ═══════════════════════════════════ -->
  <section style={{ padding: "80px 0", background: "var(--bg)", borderBottom: "2px solid var(--border)" }}>
    <div class="container">
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-end", marginBottom: "40px" }}>
        <div>
          <p style={{ fontSize: "0.72rem", fontWeight: 800, textTransform: "uppercase", letterSpacing: "0.15em", color: "var(--muted)", marginBottom: "8px" }}>
            Trending Now
          </p>
