// ─── FAQ Data ─────────────────────────────────────────────────────────────────
const faqs = [
  {
    icon: "M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z",
    q: "Are Udemy coupons on CoursesWyn really 100% free?",
    a: "Yes! Every coupon we publish gives you 100% off the course price — you pay absolutely nothing. No hidden fees, no subscription, and no credit card required. Simply click the coupon link and enroll on Udemy for free."
  },
  {
    icon: "M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z",
    q: "How often are new Udemy coupons added?",
    a: "We add new free Udemy course coupons every single day. Our team works around the clock to source, verify, and publish the latest deals across all categories — from programming and web development to marketing and personal development."
