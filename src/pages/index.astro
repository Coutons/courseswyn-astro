            <div style={{ display: "flex", alignItems: "center", gap: "0.75rem", marginBottom: "1rem" }}>
              <div style={{
                width: "40px", height: "40px", borderRadius: "50%", background: "var(--brand-soft)",
                color: "var(--brand)", display: "flex", alignItems: "center", justifyContent: "center",
                fontWeight: 600, fontSize: "0.95rem"
              }}>
                {story.initials}
              </div>
              <div>
                <div style={{ fontWeight: 700, fontSize: "0.95rem", color: "var(--text)" }}>{story.name}</div>
                <div style={{ fontSize: "0.8rem", color: "var(--muted)" }}>{story.role}</div>
              </div>
            </div>
            <div style={{
              display: "inline-block", background: "var(--brand-soft)", color: "var(--brand)",
              padding: "0.25rem 0.75rem", borderRadius: "99px", fontSize: "0.8rem",
              fontWeight: 700, alignSelf: "flex-start", marginBottom: "1rem"
            }}>
              {story.badge}
            </div>
            <p style={{ color: "var(--text)", fontSize: "0.95rem", fontStyle: "italic", lineHeight: 1.5, margin: 0, flex: 1 }}>
              "{story.quote}"
            </p>
            <div style={{
              marginTop: "1.5rem", borderTop: "1px solid var(--border)", paddingTop: "1rem",
              fontSize: "0.85rem", color: "var(--muted)", display: "flex", alignItems: "center", gap: "0.4rem"
            }}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
              </svg>
              {story.course}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════
       9. PLATFORM COMPARISON
