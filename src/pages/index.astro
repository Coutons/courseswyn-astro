    q: "Can I access Udemy courses on mobile devices?",
    a: "Yes! All Udemy courses are fully accessible via the Udemy iOS and Android apps, as well as on any desktop browser. You can also download lectures for offline viewing — perfect for learning on the go."
  },
  {
    icon: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z",
    q: "What should I do if a coupon code doesn't work?",
    a: "We verify all coupons before publishing, but Udemy coupons can expire or hit their enrollment limit quickly. If a code doesn't work, refresh our page for the latest deals or check the comments section — our community often posts working alternatives within minutes."
  }
];

// ─── JSON-LD Structured Data ──────────────────────────────────────────────────
// [SEO JSON-LD]
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    // WebSite dengan SearchAction → enables Google Sitelinks Searchbox
    {
      "@type": "WebSite",
      "@id": "https://courseswyn.com/#website",
      "url": "https://courseswyn.com",
      "name": "CoursesWyn",
      "description": pageDescription,
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://courseswyn.com/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    },
    // Organization untuk E-E-A-T
    {
      "@type": "Organization",
      "@id": "https://courseswyn.com/#organization",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://courseswyn.com/logo.png",
        "width": 200,
        "height": 60
      },
      "sameAs": [
        "https://twitter.com/courseswyn",
        "https://facebook.com/courseswyn"
      ]
    },
    // EducationalOrganization dengan offer catalog
    {
      "@type": "EducationalOrganization",
      "@id": "https://courseswyn.com/#educational",
      "name": "CoursesWyn Learning Platform",
      "description": "Free access to premium online courses from top providers like Udemy, Coursera, and edX.",
      "url": "https://courseswyn.com",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": `Free Udemy Coupons ${currentMonth} ${currentYear}`,
        "itemListElement": allDeals.slice(0, 10).map((deal, index) => ({
          "@type": "Course",
          "position": index + 1,
          "name": deal.title,
          "description": deal.description,
          "provider": { "@type": "Organization", "name": deal.provider || "Udemy" },
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD",
            "availability": "https://schema.org/InStock",
            "validFrom": (deal as any).createdAt || new Date().toISOString().split('T')[0],
            "priceValidUntil": deal.expiresAt,
            "description": "100% off - completely free Udemy course"
          },
          ...(deal.rating ? {
            "aggregateRating": {
              "@type": "AggregateRating",
              "ratingValue": deal.rating.toString(),
              "reviewCount": Math.max(1, Math.round(deal.students ?? 1000)),
              "bestRating": "5"
            }
          } : {})
        }))
      }
    },
    // BreadcrumbList
    {
      "@type": "BreadcrumbList",
      "@id": "https://courseswyn.com/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" },
        { "@type": "ListItem", "position": 2, "name": "Free Course Coupons", "item": "https://courseswyn.com/udemy-coupon-code" },
        { "@type": "ListItem", "position": 3, "name": "Course Categories", "item": "https://courseswyn.com/categories" }
      ]
    },
    // FAQPage → rich snippet di SERP
    {
      "@type": "FAQPage",
      "@id": "https://courseswyn.com/#faq",
      "mainEntity": faqs.map((faq) => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": { "@type": "Answer", "text": faq.a }
      }))
    },
    // ItemList untuk Online Learning Platforms → rich snippet
    {
      "@type": "ItemList",
      "@id": "https://courseswyn.com/#platforms",
      "name": "Popular Online Learning Platforms 2026",
      "description": "Comparison of top online course platforms including Udemy, Coursera, edX, LinkedIn Learning, Skillshare, and Khan Academy",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@type": "Organization",
            "name": "Udemy",
            "url": "https://www.udemy.com",
            "description": "200,000+ courses with frequent 100% off coupons. Best for skill-based learning.",
            "sameAs": "https://www.udemy.com"
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": {
            "@type": "Organization",
            "name": "Coursera",
            "url": "https://coursera.org",
            "description": "University-accredited courses and degrees from top institutions worldwide.",
            "sameAs": "https://coursera.org"
          }
        },
        {
          "@type": "ListItem",
          "position": 3,
          "item": {
            "@type": "Organization",
            "name": "edX",
            "url": "https://edx.org",
            "description": "Harvard, MIT, and Berkeley courses with free audit options available.",
            "sameAs": "https://edx.org"
          }
        },
        {
          "@type": "ListItem",
          "position": 4,
          "item": {
            "@type": "Organization",
            "name": "LinkedIn Learning",
            "url": "https://linkedin.com/learning",
            "description": "Business and creative skills with LinkedIn certificates for professionals.",
            "sameAs": "https://linkedin.com/learning"
          }
        },
        {
          "@type": "ListItem",
          "position": 5,
          "item": {
            "@type": "Organization",
            "name": "Skillshare",
            "url": "https://skillshare.com",
            "description": "Creative arts, design, and lifestyle courses with project-based learning.",
            "sameAs": "https://skillshare.com"
          }
        },
        {
          "@type": "ListItem",
          "position": 6,
          "item": {
            "@type": "Organization",
            "name": "Khan Academy",
            "url": "https://khanacademy.org",
            "description": "Completely free K-12 and test prep education from non-profit organization.",
            "sameAs": "https://khanacademy.org"
          }
        }
      ]
    },
    // ItemList untuk featured courses → sitelinks
    {
      "@type": "ItemList",
      "@id": "https://courseswyn.com/#courselist",
      "name": `Top Free Udemy Courses ${currentMonth} ${currentYear}`,
      "itemListElement": initialItems.map((deal, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": `https://courseswyn.com/coupon/${deal.slug || deal.id}`,
        "name": deal.title
      }))
    }
  ]
};
---

<style>
  /* ─── Global Layout ─────────────────────────────────────────────────────── */
  .section-wrapper {
    width: 100%;
    padding: 4rem 1rem;
  }
  .section-wrapper--card {
    background: linear-gradient(135deg, var(--card) 0%, hsla(15, 85%, 55%, 0.02) 100%);
    border-radius: 24px;
    border: 1px solid hsla(15, 85%, 55%, 0.08);
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }
  .pill {
    padding: 0.6rem 1.25rem;
    border-radius: 9999px;
    background: var(--input);
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .pill:hover, .pill.active {
    background: var(--brand);
    color: var(--bg);
    border-color: var(--brand);
    transform: translateY(-1px);
  }
  .category-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 25px -5px hsla(15, 85%, 55%, 0.15), 0 10px 10px -5px hsla(15, 85%, 55%, 0.1);
    border-color: var(--brand);
    background: hsla(15, 85%, 55%, 0.05) !important;
  }
  .category-card svg { transition: transform 0.2s ease; }
  .category-card:hover svg { transform: scale(1.1); }
  .category-card:hover div:last-child { color: var(--accent); }

  /* ─── Prose content section ─────────────────────────────────────────────── */
  .prose-section h2 {
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .prose-section h3 {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin: 1.5rem 0 0.5rem;
  }
  .prose-section p {
    color: var(--muted);
    line-height: 1.75;
    font-size: 1rem;
    margin-bottom: 1rem;
  }
  .prose-section a {
    color: var(--brand);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (max-width: 768px) {
    h1 { font-size: 2.5rem !important; }
    .section-wrapper { padding: 3rem 1rem; }
    .featured-grid { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 480px) {
    h1 { font-size: 2rem !important; }
    h2 { font-size: 1.5rem !important; }
    .category-card { padding: 1rem !important; }
    .faq-grid { grid-template-columns: 1fr !important; }
  }
  html { scroll-behavior: smooth; }

  /* Platform cards hover effects */
  .platform-card {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .platform-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px -12px rgba(0, 0, 0, 0.15);
    border-color: hsla(15, 85%, 55%, 0.4) !important;
  }
  .platform-card.coursera:hover {
    border-color: hsla(210, 80%, 50%, 0.4) !important;
    box-shadow: 0 12px 40px -12px rgba(0, 86, 210, 0.2);
  }
  .platform-card.edx:hover {
    border-color: hsla(340, 80%, 50%, 0.4) !important;
    box-shadow: 0 12px 40px -12px rgba(201, 0, 60, 0.2);
  }
  .platform-card.linkedin:hover {
    border-color: hsla(200, 80%, 40%, 0.4) !important;
    box-shadow: 0 12px 40px -12px rgba(10, 102, 194, 0.2);
  }
  .platform-card.skillshare:hover {
    border-color: hsla(140, 70%, 40%, 0.4) !important;
    box-shadow: 0 12px 40px -12px rgba(0, 200, 100, 0.2);
  }
  .platform-card.khan:hover {
    border-color: hsla(160, 70%, 40%, 0.4) !important;
    box-shadow: 0 12px 40px -12px rgba(20, 191, 150, 0.2);
  }

  /* Language selector buttons */
  .lang-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.85rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    color: var(--text);
    font-size: 0.8rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .lang-btn:hover {
    border-color: var(--brand);
    background: hsla(15, 85%, 55%, 0.05);
    transform: translateY(-1px);
  }
  .lang-btn img {
    box-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
</style>

<Layout
  title={pageTitle}
  description={pageDescription}
  image={featuredImage}
  canonical="https://courseswyn.com"
>
  <!-- [SEO FIX] Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- [SEO ADD] Preload critical image for LCP -->
  {featuredDeals.length > 0 && featuredDeals[0].image && (
    <link rel="preload" as="image" href={featuredDeals[0].image} slot="head" />
  )}

  <!-- ══════════════════════════════════════════════════════════════════════
       1. HERO
       ══════════════════════════════════════════════════════════════════════ -->
  <section
    class="hero-gradient section-wrapper"
    style={{ textAlign: "center", overflow: "hidden", position: "relative" }}
    aria-label="Hero — Free Udemy Coupons"
  >
    <div class="container" style={{ position: "relative", zIndex: 10 }}>

      <div style={{
        display: "inline-flex", alignItems: "center", gap: "0.5rem",
        background: "linear-gradient(135deg, var(--brand) 0%, hsl(15, 85%, 65%) 100%)",
        padding: "0.5rem 1rem", borderRadius: "9999px", marginBottom: "2rem",
        fontSize: "0.9rem", color: "white", fontWeight: 700,
        boxShadow: "0 4px 12px hsla(15, 85%, 55%, 0.3)"
      }}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        Helping Learners Save Over $1.2M in Course Fees
      </div>

      <!-- [SEO H1] -->
