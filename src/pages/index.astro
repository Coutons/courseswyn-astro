---
import Layout from "../layouts/Layout.astro";
import DealCard from "../components/DealCard.astro";
import FeaturedDealCard from "../components/FeaturedDealCard.astro";
import DealsList from "../components/DealsList";
import HeaderSearch from "../components/HeaderSearch";
import { readDeals } from "../lib/store";
import { uniqueProviders } from "../lib/mockData";

// ─── Date helpers ────────────────────────────────────────────────────────────
const currentDate = new Date();
const utcDate     = new Date(currentDate.toISOString());
const monthNames  = [
  "January","February","March","April","May","June",
  "July","August","September","October","November","December"
];
const currentMonth = monthNames[utcDate.getMonth()];
const currentYear  = utcDate.getFullYear();

// ─── Helpers ──────────────────────────────────────────────────────────────────
function genStudents(key: string): number {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < key.length; i++) {
    h ^= key.charCodeAt(i);
    h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24);
  }
  const r = (h >>> 0) / 0xffffffff;
  const min = 1000, max = 80000;
  const val = Math.floor(min + (max - min) * Math.pow(r, 0.6));
  return Math.round(val / 10) * 10;
}

function formatStudents(n: number) {
  if (n >= 1000000) return (n / 1000000).toFixed(1).replace(/\.0$/, "") + "m";
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, "") + "k";
  return String(n);
}

// ─── SEO Meta ────────────────────────────────────────────────────────────────
// [SEO TITLE]
const pageTitle       = `Verified Udemy Coupons ${currentMonth} ${currentYear} | Free Coupon Codes`;
// [SEO DESCRIPTION]
const pageDescription = `Access verified Udemy coupons and discount codes updated daily for ${currentMonth} ${currentYear}. Get 100% off free courses and premium deals verified by CoursesWyn experts.`;

// ─── Deals Data ──────────────────────────────────────────────────────────────
const allDeals     = await readDeals();
const PAGE_SIZE    = 6;
const initialItems = allDeals.slice(0, PAGE_SIZE);
const totalPages   = Math.ceil(allDeals.length / PAGE_SIZE);

// ─── Categories ──────────────────────────────────────────────────────────────
function normName(raw?: string | null) {
  if (!raw) return undefined;
  let v = String(raw).trim();
  v = v.replace(/&amp;/gi, "&").replace(/\s+/g, " ");
  return v || undefined;
}
function slugifyCategory(name: string) {
  if (name === "Uncategorized") return "uncategorized";
  return name.toLowerCase()
    .replace(/&amp;/gi, "&")
    .replace(/&/g, " and ")
    .replace(/[^\w\s-]/g, "")
    .trim()
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-");
}
function getCategoryDescription(category: string) {
  const cat = category.toLowerCase();
  if (cat === "development")               return "Master programming, web development, and software engineering";
  if (cat === "programming")              return "Learn coding languages, algorithms, and software development fundamentals";
  if (cat === "it & software")            return "Learn IT infrastructure, cybersecurity, and software tools";
  if (cat.includes("business"))           return "Build business skills in management, finance, and entrepreneurship";
  if (cat === "finance")                  return "Master financial analysis, investment strategies, and accounting principles";
  if (cat.includes("marketing"))         return "Master digital marketing, SEO, and social media strategies";
  if (cat.includes("data") || cat.includes("analytics")) return "Learn data science, analytics, and machine learning techniques";
  if (cat.includes("teaching"))          return "Advance your academic knowledge with specialised educational courses";
  if (cat.includes("design"))            return "Explore graphic design, UI/UX, and creative tools";
  if (cat.includes("photography"))       return "Master photography techniques and digital image processing";
  if (cat.includes("music"))             return "Learn music production, composition, and audio engineering";
  if (cat.includes("personal"))          return "Develop personal growth and soft skills for career success";
  if (cat.includes("office"))            return "Boost productivity with Microsoft Office, Google Workspace, and collaboration tools";
  return "Explore premium courses with exclusive coupons and deals";
}

const categories = [
  ...new Set(allDeals.map((d) => d.category).filter(Boolean).map(normName).filter(Boolean)),
] as string[];

// ─── Featured Deal ────────────────────────────────────────────────────────────
const featuredDeals = allDeals
  .filter((d) => d.rating && d.rating >= 4.8)
  .sort((a, b) => (b.rating || 0) - (a.rating || 0))
  .slice(0, 1);
const featuredImage = featuredDeals.length > 0 ? featuredDeals[0].image : "/og-image.jpg";

// ─── Trust Indicators ────────────────────────────────────────────────────────
const trustIndicators = [
