---
import Layout from "../layouts/Layout.astro";
import { readDeals } from "../lib/store";

function normName(raw?: string | null) {
  if (!raw) return undefined;
  let v = String(raw).trim();
  v = v.replace(/&amp;/gi, "&");
  v = v.replace(/\s+/g, " ");
  return v || undefined;
}

function slugifyCategory(name: string) {
  if (name === "Uncategorized") return "uncategorized";
  let v = name.toLowerCase();
  v = v.replace(/&amp;/gi, "&");
  v = v.replace(/&/g, " and ");
  v = v.replace(/[^\w\s-]/g, "");
  v = v.trim();
  v = v.replace(/\s+/g, "-");
  v = v.replace(/-+/g, "-");
  return v;
}

const CATEGORY_ICONS: Record<string, string> = {
  "development": '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
  "it-and-software": '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>',
  "business": '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>',
  "design": '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>',
  "marketing": '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/><line x1="9" y1="10" x2="15" y2="10"/><line x1="12" y1="7" x2="12" y2="13"/></svg>',
  "data-science": '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>',
  "personal-development": '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
  "photography-and-video": '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>',
  "music": '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>',
  "teaching-and-academics": '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="14" y2="11"/></svg>',
  "office-productivity": '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><path d="M9 14l2 2 4-4"/></svg>',
  "finance-and-accounting": '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>',
  "programming-languages": '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>',
};

const CATEGORY_DESCRIPTIONS: Record<string, string> = {
  "development": "Web development, mobile apps, game dev, and software engineering courses.",
  "it-and-software": "IT fundamentals, cybersecurity, cloud computing, and networking certifications.",
  "business": "Entrepreneurship, management, finance, and business strategy courses.",
  "design": "Graphic design, UI/UX, illustration, and digital art with pro tools.",
  "marketing": "Digital marketing, SEO, social media, email campaigns, and growth hacking.",
  "data-science": "Machine learning, Python, data analytics, statistics, and AI fundamentals.",
  "personal-development": "Productivity, leadership, communication, and career advancement skills.",
  "photography-and-video": "Photography techniques, video production, editing, and post-processing.",
  "music": "Music theory, production, audio engineering, and instrument learning.",
  "teaching-and-academics": "Academic subjects, test prep, language learning, and teaching methods.",
  "office-productivity": "Microsoft Office, Google Workspace, project management, and workflow tools.",
  "finance-and-accounting": "Accounting, investing, financial modeling, cryptocurrency, and budgeting.",
  "programming-languages": "Python, JavaScript, Java, C++, Rust, Go, and other coding languages.",
};

const deals = await readDeals();
const cats = new Map<string, { name: string; count: number; subs: Map<string, number> }>();

for (const d of deals) {
  const cName = normName(d.category);
  if (!cName) continue;
  const cKey = cName.toLowerCase();
  if (!cats.has(cKey)) cats.set(cKey, { name: cName, count: 0, subs: new Map() });
  const bucket = cats.get(cKey)!;
  bucket.count++;
  const sName = normName(d.subcategory);
  if (sName && sName.toLowerCase() !== cKey) {
    bucket.subs.set(sName, (bucket.subs.get(sName) || 0) + 1);
  }
}

const listRaw = Array.from(cats.values()).sort((a, b) => b.count - a.count);

const list = listRaw.map((c) => {
  const slug = slugifyCategory(c.name);
  const description = CATEGORY_DESCRIPTIONS[slug] ?? `Browse ${c.count} ${c.name} courses with verified Udemy coupons and discounts.`;
  return { ...c, slug, description };
});

const faqs = [
  {
    q: "Are all courses in each category really free?",
    a: "Most coupons listed on CoursesWyn apply a 100% discount, making the course temporarily free. Some coupons apply a partial discount (e.g., 90% off). The price shown reflects the coupon price at time of verification."
  },
  {
    q: "How often are categories updated?",
    a: "New courses are added to categories daily as we source and verify fresh Udemy coupons. Each category page shows only deals with currently active coupons."
  },
  {
    q: "Can I browse subcategories?",
    a: "Yes — each category page includes subcategory filters so you can narrow down results. For example, within Development you can filter by Web Development, Mobile Development, Game Development, and more."
  },
  {
    q: "Which categories have the most courses?",
    a: `The largest categories on CourseWyn are currently ${list.slice(0, 3).map(c => c.name).join(", ")} — reflecting the most popular learning topics on Udemy.`
  },
  {
    q: "Do category pages include all Udemy courses?",
    a: "Category pages show only courses with currently active verified coupons. This ensures you only see deals that actually work. We remove expired coupons daily to maintain quality."
  },
  {
    q: "Can I filter categories by language?",
    a: "Yes! You can filter courses by language within each category. We support English, Spanish, Portuguese, French, German, Japanese, Chinese, and many other languages, making learning accessible globally."
  }
];

const totalCategories = list.length;
const totalCourses = deals.length;

const pageTitle = `Online Course Categories — Browse ${totalCategories} Subjects | CoursesWyn`;
const pageDescription = `Explore ${totalCategories} course categories with verified Udemy coupon codes. Python, web development, data science, AI, design, business & more — updated daily.`;

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://courseswyn.com/categories#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" },
        { "@type": "ListItem", "position": 2, "name": "Course Categories", "item": "https://courseswyn.com/categories" }
      ]
    },
    {
      "@type": "CollectionPage",
      "@id": "https://courseswyn.com/categories",
      "url": "https://courseswyn.com/categories",
      "name": pageTitle,
      "description": pageDescription,
      "isPartOf": { "@id": "https://courseswyn.com" },
      "breadcrumb": { "@id": "https://courseswyn.com/categories#breadcrumb" },
      "dateModified": new Date().toISOString().split("T")[0],
      "inLanguage": "en-US",
      "about": {
        "@type": "Thing",
        "name": "Udemy Course Categories",
        "description": "Browse course categories with verified Udemy coupons and discounts for online learning"
      },
      "audience": {
        "@type": "Audience",
        "audienceType": "Learners worldwide seeking free and discounted online courses by category",
        "geographicArea": ["United States", "United Kingdom", "India", "Canada", "Australia", "Germany", "France", "Brazil", "Japan", "Global"]
      },
      "mainEntity": {
        "@type": "ItemList",
        "name": "Udemy Course Categories on CourseWyn",
        "description": `${totalCategories} categories with ${totalCourses}+ verified coupon deals`,
        "numberOfItems": totalCategories,
        "itemListElement": list.map((c, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "item": {
            "@type": "ItemList",
            "name": `${c.name} Courses`,
            "description": c.description,
            "url": `https://courseswyn.com/categories/${c.slug}`,
            "numberOfItems": c.count,
            "areaServed": ["United States", "United Kingdom", "India", "Canada", "Australia", "Germany", "France", "Brazil", "Japan", "Global"]
          }
        }))
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://courseswyn.com/categories#faq",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": { "@type": "Answer", "text": faq.a }
      }))
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <style>
  </style>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content anim-up">
        <h1>
          <span style="display:block">{totalCategories}+ Course Categories</span>
          <span class="hero-gradient-text" style="display:block;font-size:clamp(2.5rem,6vw,4.5rem)">Free Udemy Coupons</span>
          <span style="display:block">by Topic</span>
        </h1>
        <p>Browse {totalCategories} learning categories with {totalCourses}+ verified Udemy coupon codes — updated daily.</p>
        <div class="hero-cta">
          <a href="/udemy-coupon-code" class="btn btn-primary btn-lg" style="border-radius:999px;padding:1rem 2.5rem">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            Browse Coupons
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section style="padding-bottom:2rem">
    <div class="container">
      <div class="stat-grid">
        <div class="stat-box">
          <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
            <span class="stat-value">{totalCategories}</span>
          </div>
          <div class="stat-label">Categories</div>
        </div>
        <div class="stat-box">
          <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg>
            <span class="stat-value">{totalCourses.toLocaleString()}</span>
          </div>
          <div class="stat-label">Active Coupons</div>
        </div>
        <div class="stat-box">
          <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
            <span class="stat-value">100%</span>
          </div>
          <div class="stat-label">Verified Coupons</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORIES GRID -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-title">Categories</span>
        <h2 class="section-heading">Browse All {totalCategories} Categories</h2>
      </div>

      {list.length === 0 ? (
        <div style="text-align:center;padding:3rem;background:var(--card);border-radius:var(--radius);border:1px solid var(--border);">
          <h3 style="color:var(--text);margin-bottom:1rem;">No categories found</h3>
          <p style="color:var(--text-secondary);margin-bottom:1.5rem;">We loaded {deals.length} deals but couldn't group them into categories.</p>
        </div>
      ) : (
        <div class="adv-cards">
          {list.map((c) => (
            <a href={`/categories/${c.slug}`} title={`Browse ${c.count} ${c.name} courses with Udemy coupons`} class="adv-card" style="text-decoration:none;cursor:pointer;">
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
                <div style="width:44px;height:44px;border-radius:10px;background:linear-gradient(135deg,var(--brand),#C5A028);display:flex;align-items:center;justify-content:center;color:#1a1814;flex-shrink:0;" set:html={CATEGORY_ICONS[c.slug] || `<span style="font-weight:800;font-size:1rem;">${c.name.charAt(0).toUpperCase()}</span>`}></div>
                <div>
                  <h3 style="margin:0;font-size:1rem;font-weight:700;color:var(--text);line-height:1.2;">{c.name}</h3>
                  <p style="margin:2px 0 0;font-size:0.82rem;color:var(--brand);font-weight:600;">{c.count} coupons</p>
                </div>
              </div>
              <p style="font-size:0.85rem;color:var(--text-secondary);line-height:1.55;margin:0 0 12px;">{c.description}</p>
              {c.subs.size > 0 && (
                <div style="display:flex;gap:4px;flex-wrap:wrap;">
                  {Array.from(c.subs.entries()).sort((a, b) => b[1] - a[1]).slice(0, 3).map(([sub]) => (
                    <span style="display:inline-block;padding:2px 8px;border-radius:999px;font-size:0.7rem;background:var(--bg-secondary);border:1px solid var(--border);color:var(--text-secondary);font-weight:500;">{sub}</span>
                  ))}
                  {c.subs.size > 3 && <span style="font-size:0.7rem;color:var(--muted);padding:2px 4px;">+{c.subs.size - 3}</span>}
                </div>
              )}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section" style="background:var(--bg-secondary);padding:4rem 0;">
    <div class="container">
      <div class="section-header" style="margin-bottom:2rem;">
        <span class="section-title">About</span>
        <h2 class="section-heading">About Course Categories</h2>
      </div>
      <div class="adv-grid">
        {[
          { title: "What Are Course Categories?", desc: `CoursesWyn organizes Udemy courses into ${totalCategories} distinct categories based on subject matter. Each category contains courses with verified coupons, making it easy to find discounted courses in your specific area of interest.` },
          { title: "How to Browse Categories", desc: "Simply click on any category card to view all available courses with coupons in that topic. Each category page shows course count, subcategories for filtering, and detailed descriptions." },
          { title: "Subcategory Filtering", desc: "Each category includes subcategories for more precise filtering. For example, the Development category includes Web Development, Mobile Development, Game Development, and more." },
          { title: "Verified Coupons Only", desc: "Every course listed in our categories has a verified, working coupon. Our team manually checks each coupon daily to ensure it provides the advertised discount." },
          { title: "Popular Categories", desc: `The most popular categories on CoursesWyn are ${list.slice(0, 3).map(c => c.name).join(", ")}. These categories reflect the most in-demand skills in today's job market.` }
        ].map(item => (
          <div class="adv-card">
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="faq-header">
        <div>
          <span class="section-title">FAQ</span>
          <h2 class="section-heading">Frequently Asked Questions</h2>
        </div>
        <p style="color:var(--text-secondary);font-size:1rem;line-height:1.6;margin:0">Get answers to common questions about browsing course categories and finding coupons by topic on CoursesWyn.</p>
      </div>
      <div class="faq-grid">
        {faqs.map((faq) => (
          <div class="faq-item">
            <div class="faq-question">
              <span>{faq.q}</span>
            </div>
            <div class="faq-answer"><p>{faq.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Can't Find What You're Looking For?</h2>
        <p style="color:var(--text-secondary);font-size:1.05rem;line-height:1.6;margin:0 0 2rem">Browse our full collection of <strong style="color:var(--text);">{totalCourses}+ Udemy deals</strong> or reach out to suggest a new category.</p>
        <div class="cta-actions">
          <a href="/udemy-coupon-code" class="btn btn-primary btn-lg" style="border-radius:999px;padding:1rem 2.5rem">
            Browse All Coupons
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="/contact" class="btn btn-ghost btn-lg" style="border-radius:999px;padding:1rem 2.5rem">Request a Category</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
