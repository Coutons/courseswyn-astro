---
import Layout from "../layouts/Layout.astro";
import { readDeals } from "../lib/store";

function normName(raw?: string | null) {
  if (!raw) return undefined;
  let v = String(raw).trim();
  v = v.replace(/&amp;/gi, "&");
  v = v.replace(/\s+/g, " ");
  return v || undefined;
}

function slugifyCategory(name: string) {
  if (name === "Uncategorized") return "uncategorized";
  let v = name.toLowerCase();
  v = v.replace(/&amp;/gi, "&");
  v = v.replace(/&/g, " and ");
  v = v.replace(/[^\w\s-]/g, "");
  v = v.trim();
  v = v.replace(/\s+/g, "-");
  v = v.replace(/-+/g, "-");
  return v;
}

// Category descriptions for SEO — unique, informative text per category
const CATEGORY_DESCRIPTIONS: Record<string, string> = {
  "development": "Web development, mobile apps, game dev, and software engineering courses.",
  "it-and-software": "IT fundamentals, cybersecurity, cloud computing, and networking certifications.",
  "business": "Entrepreneurship, management, finance, and business strategy courses.",
  "design": "Graphic design, UI/UX, illustration, and digital art with pro tools.",
  "marketing": "Digital marketing, SEO, social media, email campaigns, and growth hacking.",
  "data-science": "Machine learning, Python, data analytics, statistics, and AI fundamentals.",
  "personal-development": "Productivity, leadership, communication, and career advancement skills.",
  "photography-and-video": "Photography techniques, video production, editing, and post-processing.",
  "music": "Music theory, production, audio engineering, and instrument learning.",
  "teaching-and-academics": "Academic subjects, test prep, language learning, and teaching methods.",
  "office-productivity": "Microsoft Office, Google Workspace, project management, and workflow tools.",
  "finance-and-accounting": "Accounting, investing, financial modeling, cryptocurrency, and budgeting.",
  "programming-languages": "Python, JavaScript, Java, C++, Rust, Go, and other coding languages.",
};

const deals = await readDeals();
const cats = new Map<string, { name: string; count: number; subs: Map<string, number> }>();

for (const d of deals) {
  const cName = normName(d.category) ?? "Uncategorized";
  const cKey = cName.toLowerCase();
  if (!cats.has(cKey)) cats.set(cKey, { name: cName, count: 0, subs: new Map() });
  const bucket = cats.get(cKey)!;
  bucket.count += 1;
  const sName = normName(d.subcategory);
  if (sName) {
    bucket.subs.set(sName, (bucket.subs.get(sName) || 0) + 1);
  }
}

const listRaw = Array.from(cats.values()).sort((a, b) => b.count - a.count);

const list = listRaw.map((c) => {
  const slug = slugifyCategory(c.name);
  const description = CATEGORY_DESCRIPTIONS[slug] ?? `Browse ${c.count} ${c.name} courses with verified Udemy coupons and discounts.`;
  return { ...c, slug, description };
});

const totalCategories = list.length;
const totalCourses = deals.length;

// Proper interpolated values for structured data
const pageTitle = `Browse ${totalCategories}+ Course Categories — ${totalCourses}+ Free Udemy Coupons | CoursesWyn`;
const pageDescription = `Explore ${totalCategories} course categories with ${totalCourses}+ verified Udemy coupons. Python, web development, data science, AI, design, business & more — updated daily.`;

// Build structured data with real interpolated values (not template strings)
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://courseswyn.com/categories#webpage",
      "url": "https://courseswyn.com/categories",
      "name": pageTitle,
      "description": pageDescription,
      "isPartOf": { "@id": "https://courseswyn.com/#website" },
      "inLanguage": "en-US",
      "dateModified": new Date().toISOString().split("T")[0],
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" },
          { "@type": "ListItem", "position": 2, "name": "Categories", "item": "https://courseswyn.com/categories" }
        ]
      }
    },
    {
      "@type": "ItemList",
      "@id": "https://courseswyn.com/categories#list",
      "name": "Udemy Course Categories on CoursesWyn",
      "description": `${totalCategories} categories with ${totalCourses}+ verified coupon deals`,
      "numberOfItems": totalCategories,
      "itemListElement": list.map((c, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "ItemList",
          "name": `${c.name} Courses`,
          "description": c.description,
          "url": `https://courseswyn.com/categories/${c.slug}`,
          "numberOfItems": c.count
        }
      }))
    },
    {
      "@type": "Organization",
      "@id": "https://courseswyn.com/#organization",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://courseswyn.com/logo.svg"
      },
      "sameAs": [
        "https://x.com/courseswyn",
        "https://www.facebook.com/BestCouponPromo/",
        "https://www.linkedin.com/company/courseswyn"
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <main style="background: var(--bg); color: var(--text);">
    
    {/* ── HERO ── */}
    <section style="padding: 100px 0 80px; border-bottom: 2px solid var(--border); background: var(--card);">
      <div class="container">
        <h1 style={{ 
          fontSize: "clamp(2.5rem, 7vw, 4.5rem)", 
          fontWeight: 900, 
          lineHeight: 1.05, 
          letterSpacing: "-0.04em",
          marginBottom: "32px"
        }}>
          {totalCategories}+ Course<br/>
          <span style={{ background: "var(--accent)", color: "white", padding: "0 10px" }}>Categories.</span>
        </h1>
        
        <p style={{ 
          fontSize: "clamp(1.1rem, 3vw, 1.3rem)", 
          color: "var(--muted)", 
          maxWidth: "800px", 
          lineHeight: 1.6,
          fontWeight: 500,
          marginBottom: "48px"
        }}>
          CoursesWyn organizes <strong style="color:var(--text)">{totalCourses}+ verified Udemy coupons</strong> across {totalCategories} learning categories — updated daily.
        </p>

        <div style="display: flex; gap: 16px; flex-wrap: wrap;">
          {[
            { v: `${totalCategories}+`, l: "Categories" },
            { v: `${totalCourses}+`, l: "Courses" },
            { v: "100%", l: "Verified" }
          ].map(s => (
            <div style="background: white; border: 2px solid var(--border); padding: 12px 24px; border-radius: 4px; box-shadow: 4px 4px 0 var(--border); display: flex; flex-direction: column; align-items: center;">
              <span style="font-size: 1.5rem; font-weight: 900; color: var(--accent);">{s.v}</span>
              <span style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--muted);">{s.l}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── GRID ── */}
    <section style="padding: 80px 0;">
      <div class="container">
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px;">
          {list.map((c) => (
            <a href={`/categories/${c.slug}`} class="neo-cat-card">
              <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 20px;">
                <div style="background: var(--accent); color: white; width: 56px; height: 56px; border-radius: 4px; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.5rem; box-shadow: 3px 3px 0 var(--border);">
                  {c.name.charAt(0).toUpperCase()}
                </div>
                <div>
                  <h3 style="font-size: 1.25rem; font-weight: 900; margin: 0;">{c.name}</h3>
                  <div style="font-size: 0.85rem; font-weight: 800; color: var(--accent); text-transform: uppercase;">{c.count} Courses</div>
                </div>
              </div>
              <p style="margin: 0 0 24px; color: var(--muted); font-size: 0.95rem; line-height: 1.6; font-weight: 500;">
                {c.description}
              </p>
              {c.subs.size > 0 && (
                <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                  {Array.from(c.subs.entries()).slice(0, 3).map(([sub]) => (
                    <span style="background: var(--bg); border: 1.5px solid var(--border); padding: 4px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: 700;">
                      {sub}
                    </span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* ── FAQ ── */}
    <section style="padding: 80px 0; border-top: 2px solid var(--border); background: var(--card);">
      <div class="container" style="max-width: 800px;">
        <h2 style="font-size: 2.5rem; font-weight: 900; margin-bottom: 48px; text-align: center; letter-spacing: -0.02em;">How It Works.</h2>
        <div style="display: flex; flex-direction: column; gap: 16px;">
          {[
            { q: "Are all courses really free?", a: "Most coupons apply a 100% discount. Some apply 90-95% off. Each category page shows only deals with currently active coupons." },
            { q: "How often are categories updated?", a: "New courses are added daily. When a coupon expires, it's automatically removed from the list." }
          ].map(faq => (
            <details class="neo-details">
              <summary style="padding: 24px; font-weight: 900; cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-size: 1.1rem;">
                {faq.q}
                <span style="color: var(--accent); font-size: 1.5rem;">+</span>
              </summary>
              <div style="padding: 0 24px 24px; color: var(--muted); font-size: 1rem; line-height: 1.6; font-weight: 500;">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

  </main>

  <style>
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .neo-cat-card {
      background: white; border: 2px solid var(--border); border-radius: 8px; padding: 32px;
      text-decoration: none; color: inherit; transition: all 0.2s;
      box-shadow: 4px 4px 0 var(--border);
    }
    .neo-cat-card:hover { transform: translate(-4px, -4px); box-shadow: 8px 8px 0 var(--border); border-color: var(--accent); }
    .neo-details { border: 2px solid var(--border); border-radius: 8px; background: white; margin-bottom: 12px; box-shadow: 4px 4px 0 var(--border); }
    .neo-details[open] { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--border); }
    summary::-webkit-details-marker { display: none; }
  </style>
</Layout>