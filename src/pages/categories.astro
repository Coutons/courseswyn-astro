---
import Layout from "../layouts/Layout.astro";
import { readDeals } from "../lib/store";

function normName(raw?: string | null) {
  if (!raw) return undefined;
  let v = String(raw).trim();
  v = v.replace(/&amp;/gi, "&");
  v = v.replace(/\s+/g, " ");
  return v || undefined;
}

function slugifyCategory(name: string) {
  if (name === "Uncategorized") return "uncategorized";
  let v = name.toLowerCase();
  v = v.replace(/&amp;/gi, "&");
  v = v.replace(/&/g, " and ");
  v = v.replace(/[^\w\s-]/g, "");
  v = v.trim();
  v = v.replace(/\s+/g, "-");
  v = v.replace(/-+/g, "-");
  return v;
}

// Category descriptions for SEO — unique, informative text per category
const CATEGORY_DESCRIPTIONS: Record<string, string> = {
  "development": "Web development, mobile apps, game dev, and software engineering courses.",
  "it-and-software": "IT fundamentals, cybersecurity, cloud computing, and networking certifications.",
  "business": "Entrepreneurship, management, finance, and business strategy courses.",
  "design": "Graphic design, UI/UX, illustration, and digital art with pro tools.",
  "marketing": "Digital marketing, SEO, social media, email campaigns, and growth hacking.",
  "data-science": "Machine learning, Python, data analytics, statistics, and AI fundamentals.",
  "personal-development": "Productivity, leadership, communication, and career advancement skills.",
  "photography-and-video": "Photography techniques, video production, editing, and post-processing.",
  "music": "Music theory, production, audio engineering, and instrument learning.",
  "teaching-and-academics": "Academic subjects, test prep, language learning, and teaching methods.",
  "office-productivity": "Microsoft Office, Google Workspace, project management, and workflow tools.",
  "finance-and-accounting": "Accounting, investing, financial modeling, cryptocurrency, and budgeting.",
  "programming-languages": "Python, JavaScript, Java, C++, Rust, Go, and other coding languages.",
};

const deals = await readDeals();
const cats = new Map<string, { name: string; count: number; subs: Map<string, number> }>();

for (const d of deals) {
  const cName = normName(d.category) ?? "Uncategorized";
  const cKey = cName.toLowerCase();
  if (!cats.has(cKey)) cats.set(cKey, { name: cName, count: 0, subs: new Map() });
  const bucket = cats.get(cKey)!;
  bucket.count += 1;
  const sName = normName(d.subcategory);
  if (sName) {
    bucket.subs.set(sName, (bucket.subs.get(sName) || 0) + 1);
  }
}

const listRaw = Array.from(cats.values()).sort((a, b) => b.count - a.count);

const list = listRaw.map((c) => {
  const slug = slugifyCategory(c.name);
  const description = CATEGORY_DESCRIPTIONS[slug] ?? `Browse ${c.count} ${c.name} courses with verified Udemy coupons and discounts.`;
  return { ...c, slug, description };
});

// FAQ data for categories page
const faqs = [
  {
    q: "Are all courses in each category really free?",
    a: "Most coupons listed on CoursesWyn apply a 100% discount, making the course temporarily free. Some coupons apply a partial discount (e.g., 90% off). The price shown reflects the coupon price at time of verification."
  },
  {
    q: "How often are categories updated?",
    a: "New courses are added to categories daily as we source and verify fresh Udemy coupons. Each category page shows only deals with currently active coupons."
  },
  {
    q: "Can I browse subcategories?",
    a: "Yes — each category page includes subcategory filters so you can narrow down results. For example, within Development you can filter by Web Development, Mobile Development, Game Development, and more."
  },
  {
    q: "Which categories have the most courses?",
    a: `The largest categories on CourseWyn are currently ${list.slice(0, 3).map(c => c.name).join(", ")} — reflecting the most popular learning topics on Udemy.`
  },
  {
    q: "Do category pages include all Udemy courses?",
    a: "Category pages show only courses with currently active verified coupons. This ensures you only see deals that actually work. We remove expired coupons daily to maintain quality."
  },
  {
    q: "Can I filter categories by language?",
    a: "Yes! You can filter courses by language within each category. We support English, Spanish, Portuguese, French, German, Japanese, Chinese, and many other languages, making learning accessible globally."
  }
];

const totalCategories = list.length;
const totalCourses = deals.length;

// Proper interpolated values for structured data
const pageTitle = `Online Course Categories — ${totalCourses}+ Free Udemy Coupons | CourseWyn`;
const pageDescription = `Explore ${totalCategories} course categories with ${totalCourses}+ verified Udemy coupons. Python, web development, data science, AI, design, business & more — updated daily.`;

// Build structured data with real interpolated values (not template strings)
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://courseswyn.com/categories#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://courseswyn.com" },
        { "@type": "ListItem", "position": 2, "name": "Course Categories", "item": "https://courseswyn.com/categories" }
      ]
    },
    {
      "@type": "CollectionPage",
      "@id": "https://courseswyn.com/categories",
      "url": "https://courseswyn.com/categories",
      "name": pageTitle,
      "description": pageDescription,
      "isPartOf": { "@id": "https://courseswyn.com" },
      "breadcrumb": { "@id": "https://courseswyn.com/categories#breadcrumb" },
      "dateModified": new Date().toISOString().split("T")[0],
      "inLanguage": "en-US",
      "about": {
        "@type": "Thing",
        "name": "Udemy Course Categories",
        "description": "Browse course categories with verified Udemy coupons and discounts for online learning"
      },
      "audience": {
        "@type": "Audience",
        "audienceType": "Learners worldwide seeking free and discounted online courses by category",
        "geographicArea": ["United States", "United Kingdom", "India", "Canada", "Australia", "Germany", "France", "Brazil", "Japan", "Global"]
      },
      "mainEntity": {
        "@type": "ItemList",
        "name": "Udemy Course Categories on CourseWyn",
        "description": `${totalCategories} categories with ${totalCourses}+ verified coupon deals`,
        "numberOfItems": totalCategories,
        "itemListElement": list.map((c, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "item": {
            "@type": "ItemList",
            "name": `${c.name} Courses`,
            "description": c.description,
            "url": `https://courseswyn.com/categories/${c.slug}`,
            "numberOfItems": c.count,
            "areaServed": ["United States", "United Kingdom", "India", "Canada", "Australia", "Germany", "France", "Brazil", "Japan", "Global"]
          }
        }))
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://courseswyn.com/categories#faq",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": { "@type": "Answer", "text": faq.a }
      }))
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Structured Data with real interpolated values -->
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <main style="background: #fafafa;">

      <!-- ── Hero ── -->
      <section aria-labelledby="categories-hero-heading" style="background: linear-gradient(135deg, #eef2ff, #faf5ff, #fdf2f8); padding: 6rem 0 5rem; position: relative; overflow: hidden;">
        <div aria-hidden="true" style="position:absolute;top:-20%;right:-10%;width:600px;height:600px;background:radial-gradient(circle,rgba(249,115,22,0.1) 0%,rgba(236,72,153,0.06) 40%,transparent 70%);border-radius:50%;pointer-events:none;"></div>
        <div aria-hidden="true" style="position:absolute;bottom:-15%;left:-5%;width:500px;height:500px;background:radial-gradient(circle,rgba(99,102,241,0.06) 0%,transparent 70%);border-radius:50%;pointer-events:none;"></div>

        <div class="container" style="position:relative;z-index:1;">

          <div style="display:inline-flex;align-items:center;gap:.5rem;padding:.5rem 1.25rem;border-radius:100px;background:linear-gradient(135deg,rgba(249,115,22,0.12),rgba(236,72,153,0.12));border:2px solid rgba(249,115,22,0.35);font-size:.85rem;font-weight:700;color:#c2410c;margin-bottom:1.5rem;">
            Browse All Categories
          </div>

          <h1 id="categories-hero-heading" style="font-size:clamp(2.5rem,5vw,3.5rem);font-weight:900;line-height:1.1;color:#111827;margin:1.5rem 0 1rem;letter-spacing:-0.03em;">
            {totalCategories}+ Course Categories —
            <span style="background:linear-gradient(135deg,#ea580c,#db2777,#9333ea);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
              Find Free Udemy Coupons
            </span>
            by Topic
          </h1>

          <p style="font-size:1.125rem;color:#6b7280;max-width:680px;line-height:1.7;font-weight:500;margin:0 0 2.5rem;">
            CoursesWyn organizes <strong style="color:#111827;">{totalCourses}+ verified Udemy coupons</strong> across {totalCategories} learning categories — from programming and data science to design and business. Browse by topic to find discounted courses in your field, updated daily.
          </p>

          <div style="display:flex;gap:2rem;flex-wrap:wrap;padding-top:1.5rem;border-top:2px solid rgba(0,0,0,0.08);">
            {[
              { value: `${totalCategories}+`, label: "Categories" },
              { value: `${totalCourses}+`, label: "Udemy Courses" },
              { value: "100%", label: "Verified Coupons" },
              { value: "Daily", label: "Fresh Updates" },
            ].map(({ value, label }) => (
              <div style="display:flex;flex-direction:column;">
                <strong style="font-size:1.75rem;font-weight:900;color:#111827;">{value}</strong>
                <span style="color:#6b7280;font-size:.875rem;font-weight:600;">{label}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ── Categories Grid ── -->
      <section aria-labelledby="categories-grid-heading" style="background:white;padding:5rem 0;">
        <div class="container">
          <div style="display:inline-block;font-size:1rem;font-weight:900;text-transform:uppercase;letter-spacing:0.12em;color:#ea580c;margin-bottom:.75rem;">Categories</div>
          <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;margin-bottom:3rem;">
            <h2 id="categories-grid-heading" style="font-size:2.5rem;font-weight:900;color:#111827;margin:0;letter-spacing:-0.02em;">Browse All {totalCategories} Categories</h2>
          </div>

          {list.length === 0 ? (
            <div style="text-align:center;padding:3rem;background:white;border-radius:20px;border:3px solid rgba(0,0,0,0.07);">
              <h3 style="color:#111827;margin-bottom:1rem;">No categories found</h3>
              <p style="color:#6b7280;margin-bottom:1.5rem;">We loaded {deals.length} deals but couldn't group them into categories. Please try again later.</p>
              <a href="/deals" style="padding:.875rem 1.75rem;background:linear-gradient(135deg,#f97316,#ea580c);color:#fff;text-decoration:none;border-radius:12px;font-weight:700;">Browse All Deals</a>
            </div>
          ) : (
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;">
              {list.map((c) => (
                <a href={`/categories/${c.slug}`} title={`Browse ${c.count} ${c.name} courses with Udemy coupons`} class="cat-card" style="display:block;background:white;border:3px solid rgba(0,0,0,0.07);border-radius:20px;padding:1.5rem;text-decoration:none;color:inherit;transition:all 0.3s ease;height:100%;">
                  <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;">
                    <div aria-hidden="true" style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#f97316,#ea580c);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:1.25rem;flex-shrink:0;">
                      {c.name.charAt(0).toUpperCase()}
                    </div>
                    <div>
                      <h3 style="margin:0;color:#111827;font-size:1.1rem;font-weight:700;line-height:1.2;margin-bottom:.2rem;">{c.name} Courses</h3>
                      <p style="margin:0;color:#6b7280;font-size:.875rem;"><strong style="color:#f97316;">{c.count}</strong> Udemy coupons</p>
                    </div>
                  </div>
                  <p style="color:#6b7280;font-size:.85rem;line-height:1.55;margin:0 0 1rem;">{c.description}</p>
                  {c.subs.size > 0 && (
                    <div>
                      <p style="color:#6b7280;font-size:.78rem;font-weight:600;margin:0 0 .5rem;text-transform:uppercase;letter-spacing:.04em;">Topics:</p>
                      <div style="display:flex;gap:.4rem;flex-wrap:wrap;">
                        {Array.from(c.subs.entries()).sort((a, b) => b[1] - a[1]).slice(0, 4).map(([sub]) => (
                          <span style="display:inline-block;padding:.3rem .65rem;border-radius:20px;font-size:.75rem;background:rgba(249,115,22,0.1);border:1px solid rgba(249,115,22,0.25);color:#f97316;font-weight:500;">{sub}</span>
                        ))}
                        {c.subs.size > 4 && <span style="font-size:.75rem;color:#6b7280;padding:.3rem .4rem;">+{c.subs.size - 4} more</span>}
                      </div>
                    </div>
                  )}
                </a>
              ))}
            </div>
          )}
        </div>
      </section>

      <!-- ── ABOUT COURSE CATEGORIES ── -->
      <section style="background:#fafafa;padding:5rem 0;">
        <div class="container">
          <div style="display:inline-block;font-size:1rem;font-weight:900;text-transform:uppercase;letter-spacing:0.12em;color:#ea580c;margin-bottom:.75rem;">About</div>
          <h2 style="font-size:2.5rem;font-weight:900;color:#111827;margin:0 0 3rem;letter-spacing:-0.02em;">About Course Categories</h2>

          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem;">
            {[
              { title: "What Are Course Categories?", desc: `CoursesWyn organizes Udemy courses into ${totalCategories} distinct categories based on subject matter. Each category contains courses with verified coupons, making it easy to find discounted courses in your specific area of interest. From programming to design, business to personal development, our categories cover all major learning topics.` },
              { title: "How to Browse Categories", desc: "Simply click on any category card to view all available courses with coupons in that topic. Each category page shows course count, subcategories for filtering, and detailed descriptions. You can further filter by language, rating, and price to find exactly what you need. All coupons are verified and updated daily." },
              { title: "Subcategory Filtering", desc: "Each category includes subcategories for more precise filtering. For example, the Development category includes Web Development, Mobile Development, Game Development, and more. This granular organization helps you find courses that match your exact learning needs without browsing through irrelevant content." },
              { title: "Global Category Access", desc: "Our course categories work globally, serving learners in the US, UK, India, Canada, Australia, Germany, France, Brazil, Japan, and 150+ other countries. All categories support multiple languages including English, Spanish, Portuguese, French, German, Japanese, Chinese, and more." },
              { title: "Verified Coupons Only", desc: "Every course listed in our categories has a verified, working coupon. Our team manually checks each coupon daily to ensure it provides the advertised discount. Expired or invalid coupons are immediately removed, so you can trust that every deal you see is legitimate and ready to use." },
              { title: "Popular Categories", desc: `The most popular categories on CoursesWyn are ${list.slice(0, 3).map(c => c.name).join(", ")}. These categories reflect the most in-demand skills in today's job market. Whether you want to learn programming, data science, digital marketing, or business management, our popular categories have the most courses and coupons available.` }
            ].map(item => (
              <div style="background:white;padding:2rem;border-radius:20px;border:3px solid rgba(0,0,0,0.07);">
                <h3 style="font-size:1.25rem;font-weight:700;color:#111827;margin:0 0 1rem;">{item.title}</h3>
                <p style="color:#6b7280;line-height:1.7;margin:0;">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ── FAQ ── -->
      <section style="background:white;padding:5rem 0;">
        <div class="container">
          <div style="display:inline-block;font-size:1rem;font-weight:900;text-transform:uppercase;letter-spacing:0.12em;color:#ea580c;margin-bottom:.75rem;">FAQ</div>
          <h2 style="font-size:2.5rem;font-weight:900;color:#111827;margin:0 0 1rem;letter-spacing:-0.02em;">Frequently Asked Questions</h2>
          <p style="color:#6b7280;font-size:1.125rem;line-height:1.7;max-width:550px;margin:0 0 3rem;font-weight:600;">Get answers to common questions about browsing course categories and finding coupons by topic on CoursesWyn</p>

          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(400px,1fr));gap:1.5rem;">
            {faqs.map((faq) => (
              <div style="background:white;border-radius:20px;border:3px solid rgba(0,0,0,0.07);padding:1.5rem;">
                <h3 style="margin:0 0 0.75rem;color:#111827;font-size:1.05rem;font-weight:700;">{faq.q}</h3>
                <p style="color:#6b7280;line-height:1.7;margin:0;font-size:0.95rem;">{faq.a}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ── CTA ── -->
      <section style="background:linear-gradient(135deg,#fff7ed,#fef2f2,#faf5ff);padding:5rem 0;text-align:center;">
        <div class="container">
          <div style="max-width:700px;margin:0 auto;">
            <h2 style="font-size:2.5rem;font-weight:900;color:#111827;margin:0 0 1rem;letter-spacing:-0.02em;">Can't Find What You're Looking For?</h2>
            <p style="color:#6b7280;font-size:1.125rem;line-height:1.7;margin-bottom:2rem;font-weight:500;">
              Browse our full collection of <strong style="color:#111827;">{totalCourses}+ Udemy deals</strong> or reach out to suggest a new category.
            </p>
            <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
              <a href="/udemy-coupon-code" style="padding:1rem 2.5rem;background:linear-gradient(135deg,#ea580c,#db2777,#9333ea);color:#fff;text-decoration:none;border-radius:16px;font-size:1rem;font-weight:700;box-shadow:0 12px 24px rgba(234,88,12,0.3);transition:all 0.3s ease;display:inline-flex;align-items:center;gap:0.5rem;">
                Browse All Coupons
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <a href="/contact" style="padding:1rem 2.5rem;background:#111827;color:#fff;text-decoration:none;border-radius:16px;font-size:1rem;font-weight:700;transition:all 0.3s ease;">
                Request a Category
              </a>
            </div>
          </div>
        </div>
      </section>

    </main>

  <style>
    .container { max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; }
    .cat-card:hover { transform: translateY(-4px) scale(1.01); box-shadow: 0 16px 32px -8px rgba(0,0,0,0.12); border-color: rgba(249,115,22,0.3) !important; }
    .cat-card:hover img { transform: scale(1.05); }
  </style>
</Layout>
