---
import "../styles/globals.css";

import { readDeals } from "../lib/store";
import { currentYearWIB } from "../lib/date";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  canonical?: string;
  hideBreadcrumbs?: boolean;
  pubDate?: Date;
  updatedDate?: Date;
}

const allDeals = await readDeals();
const activeCouponCount = "679990";

const {
  title = "CoursesWyn - Free Udemy Courses and Verified Coupons Daily",
  description = "Find the latest 100% off Udemy coupons. Browse 1,200+ free courses in AI, coding, design & more. Updated daily. No signup needed — start learning for free today.",
  image,
  type = "website",
  canonical,
  pubDate,
  updatedDate,
  hideBreadcrumbs = false,
} = Astro.props;

const siteUrl = import.meta.env.SITE || "https://courseswyn.com";
const canonicalURL = canonical || new URL(Astro.url.pathname, siteUrl).href;

const currentYear = currentYearWIB();
const absoluteImageUrl = image ? (image.startsWith('http') ? image : new URL(image, siteUrl).href) : new URL('/assets/images/og-default.svg', siteUrl).href;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="google-site-verification" content="440e92a0ff41e1b5" />

        <meta name="theme-color" content="#3b82f6" />
    <meta name="msapplication-TileColor" content="#3b82f6" />
    <meta name="referrer" content="no-referrer-when-downgrade" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="CoursesWyn" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://img-c.udemycdn.com" />

    <link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml" />

    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    {canonicalURL.includes('/coupon/') && !canonicalURL.includes('.amp') && (
      <link rel="amphtml" href={canonicalURL + '.amp'} />
    )}

    <link rel="alternate" type="application/rss+xml" title="CoursesWyn Blog RSS Feed" href={`${siteUrl}/rss.xml`} />

    <title>{title}</title>

    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    {type === "article" && <meta property="article:author" content="Andrew Derek" />}
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />
    <meta name="revisit-after" content="1 days" />
    <meta name="language" content="English" />
    <meta name="distribution" content="global" />
    <meta name="rating" content="general" />
    <meta name="keywords" content="free udemy courses, udemy coupon code 100 off, udemy promo code, udemy discount coupon, udemy free certificate courses, udemy personal plan, free online courses 2026, udemy 100 free coupon, learn to code free, udemy deals today" />
    <meta name="classification" content="Education, Online Learning, Course Deals" />
    <meta name="category" content="Education" />

    <script type="application/ld+json">
    [{
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "logo": "https://courseswyn.com/logo.svg",
      "description": "Find verified Udemy courses with 100% off coupons.",
      "sameAs": ["https://www.facebook.com/BestCouponPromo", "https://x.com/CoursesGift"]
    },
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "description": "Find verified Udemy courses with 100% off coupons. Daily updated deals for online learning.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://courseswyn.com/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }]
    </script>

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="CoursesWyn" />
    <meta property="og:locale" content="en_US" />
    {absoluteImageUrl && <meta property="og:image" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="og:image:secure_url" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="og:image:width" content="1200" />}
    {absoluteImageUrl && <meta property="og:image:height" content="630" />}
    {absoluteImageUrl && <meta property="og:image:alt" content={title} />}
    {absoluteImageUrl && <meta property="og:image:type" content="image/jpeg" />}

    <meta property="twitter:card" content={absoluteImageUrl ? "summary_large_image" : "summary"} />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:site" content="@CourseGift" />
    <meta property="twitter:creator" content="@CourseGift" />
    {absoluteImageUrl && <meta property="twitter:image" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="twitter:image:alt" content={title} />}

    <meta name="author" content="Andrew Derek" />
    <meta property="article:author" content="Andrew Derek" />
    <meta property="article:publisher" content="https://courseswyn.com" />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap&text=ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/inter/v13/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuLyfAZ9hiJ-Ek-_EeA.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <script src="https://f.convertkit.com/ckjs/ck.5.js" defer></script>

    <style>
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, Apple Color Emoji, Segoe UI Emoji;
      }

      .nav-link:hover {
        background: rgba(59, 130, 246, 0.1) !important;
        transform: translateY(-1px);
      }

      .nav-link:active {
        transform: translateY(0);
      }
    </style>
    <slot name="head" />
  </head>
  <body>
    <header role="banner" class="site-header">
      <nav
        itemscope
        itemtype="https://schema.org/SiteNavigationElement"
        class="container"
        aria-label="Main navigation"
        style={{
          display: "flex",
          justifyContent: "space-between",
          alignItems: "center",
          padding: "0 1.5rem",
          maxWidth: "1400px",
          margin: "0 auto",
          height: "70px"
        }}
      >
        <a href="/" class="logo" style={{ flexShrink: 0, textDecoration: "none" }}>
          <span style={{ fontSize: "1.15rem", fontWeight: 700, letterSpacing: "0.03em", color: "#f1f5f9" }}>CoursesWyn</span>
        </a>

        <div style={{ display: "flex", alignItems: "center", justifyContent: "center", flex: 1, gap: "10px" }}>
          <div style={{ display: "flex", gap: "4px", alignItems: "center" }}>
            <a href="/udemy-coupons-today" itemprop="url" style={{
              display: "inline-flex", alignItems: "center", gap: "5px",
              padding: "6px 12px", borderRadius: "8px",
              fontSize: "0.82rem", fontWeight: 600,
              color: "#f1f5f9",
              textDecoration: "none",
              background: currentPath === '/udemy-coupons-today' ? 'rgba(59,130,246,0.15)' : 'rgba(255,255,255,0.05)',
              border: currentPath === '/udemy-coupons-today' ? '1px solid rgba(59,130,246,0.4)' : '1px solid rgba(255,255,255,0.1)',
              transition: "all 0.2s ease",
              whiteSpace: "nowrap"
            }}
            onmouseover="this.style.background='rgba(59,130,246,0.15)';this.style.borderColor='rgba(59,130,246,0.4)'" onmouseout="this.style.background=this.style.borderColor=''"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2h12l4 4v14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6l4-4z"/><path d="M2 6h20"/><path d="M16 2v4H8V2"/><rect x="8" y="10" width="8" height="6"/></svg>
              <span itemprop="name">Today's Coupons</span>
            </a>
            <a href="/udemy-coupon-code" itemprop="url" style={{
              display: "inline-flex", alignItems: "center", gap: "5px",
              padding: "6px 12px", borderRadius: "8px",
              fontSize: "0.82rem", fontWeight: 600,
              color: "#f1f5f9",
              textDecoration: "none",
              background: currentPath === '/udemy-coupon-code' ? 'rgba(59,130,246,0.15)' : 'rgba(255,255,255,0.05)',
              border: currentPath === '/udemy-coupon-code' ? '1px solid rgba(59,130,246,0.4)' : '1px solid rgba(255,255,255,0.1)',
              transition: "all 0.2s ease",
              whiteSpace: "nowrap"
            }}
            onmouseover="this.style.background='rgba(59,130,246,0.15)';this.style.borderColor='rgba(59,130,246,0.4)'" onmouseout="this.style.background=this.style.borderColor=''"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span itemprop="name">Coupon Codes</span>
            </a>
            <a href="/topics" itemprop="url" style={{
              display: "inline-flex", alignItems: "center", gap: "5px",
              padding: "6px 12px", borderRadius: "8px",
              fontSize: "0.82rem", fontWeight: 600,
              color: "#f1f5f9",
              textDecoration: "none",
              background: (currentPath === '/topics' || currentPath.startsWith('/topics/')) ? 'rgba(59,130,246,0.15)' : 'rgba(255,255,255,0.05)',
              border: (currentPath === '/topics' || currentPath.startsWith('/topics/')) ? '1px solid rgba(59,130,246,0.4)' : '1px solid rgba(255,255,255,0.1)',
              transition: "all 0.2s ease",
              whiteSpace: "nowrap"
            }}
            onmouseover="this.style.background='rgba(59,130,246,0.15)';this.style.borderColor='rgba(59,130,246,0.4)'" onmouseout="this.style.background=this.style.borderColor=''"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              <span itemprop="name">Topics</span>
            </a>
            <a href="/blog" itemprop="url" style={{
              display: "inline-flex", alignItems: "center", gap: "5px",
              padding: "6px 12px", borderRadius: "8px",
              fontSize: "0.82rem", fontWeight: 600,
              color: "#f1f5f9",
              textDecoration: "none",
              background: (currentPath === '/blog' || currentPath.startsWith('/blog/')) ? 'rgba(59,130,246,0.15)' : 'rgba(255,255,255,0.05)',
              border: (currentPath === '/blog' || currentPath.startsWith('/blog/')) ? '1px solid rgba(59,130,246,0.4)' : '1px solid rgba(255,255,255,0.1)',
              transition: "all 0.2s ease",
              whiteSpace: "nowrap"
            }}
            onmouseover="this.style.background='rgba(59,130,246,0.15)';this.style.borderColor='rgba(59,130,246,0.4)'" onmouseout="this.style.background=this.style.borderColor=''"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              <span itemprop="name">Blog</span>
            </a>
          </div>
          <form action="/search" method="get" style={{
            display: "flex",
            alignItems: "center",
            gap: "8px",
            background: "rgba(255,255,255,0.05)",
            border: "1px solid rgba(255,255,255,0.1)",
            borderRadius: "8px",
            padding: "6px 12px",
            width: "200px",
            transition: "all 0.2s ease",
            cursor: "text"
          }}
          onmouseover="this.style.borderColor='rgba(59,130,246,0.4)';this.style.background='rgba(59,130,246,0.15)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(255,255,255,0.05)'"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style={{ color: "rgba(241,245,249,0.7)", flexShrink: 0 }}>
              <path d="m21 21-4.34-4.34"/><circle cx="11" cy="11" r="8"/>
            </svg>
            <input
              type="text"
              name="q"
              placeholder="Search courses..."
              style={{
                background: 'transparent',
                color: '#f1f5f9',
                border: 'none',
                fontSize: '0.82rem',
                width: '100%',
                outline: 'none',
                padding: 0
              }}
            />
          </form>
        </div>

        <span style={{ fontSize: "0.75rem", fontWeight: 600, color: "#64748b" }}>{activeCouponCount}</span>
      </nav>
    </header>

    <!-- Breadcrumb Navigation -->
    {!hideBreadcrumbs && currentPath !== '/' && !currentPath.startsWith('/coupon/') && !currentPath.startsWith('/blog/') && (
      <nav
        aria-label="Breadcrumb"
        class="container"
        style={{
          padding: "12px 0",
          fontSize: "0.85rem",
          borderBottom: "1px solid var(--border)"
        }}
      >
        <ol style={{ display: "flex", gap: "8px", listStyle: "none", margin: 0, padding: 0, alignItems: "center", flexWrap: "wrap" }}>
          <li style={{ display: "flex", alignItems: "center" }}>
            <a href="/" style={{ color: "var(--muted)", textDecoration: "none", display: "flex", alignItems: "center", gap: "4px" }}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
              </svg>
              <span>Home</span>
            </a>
          </li>

          {currentPath === '/udemy-coupon-code' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>All Deals</span></li></>
          )}

          {currentPath === '/categories' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Categories</span></li></>
          )}

          {currentPath.startsWith('/categories/') && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><a href="/categories" style={{ color: "var(--muted)", textDecoration: "none" }}>Categories</a></li>
            <li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>{currentPath.split('/')[2]?.replace(/-/g, ' ')?.replace(/\b\w/g, l => l.toUpperCase()) || 'Category'}</span></li></>
          )}

          {currentPath === '/topics' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Topics</span></li></>
          )}

          {currentPath.startsWith('/topic/') && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><a href="/topics" style={{ color: "var(--muted)", textDecoration: "none" }}>Topics</a></li>
            <li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>{currentPath.split('/')[2]?.replace(/-/g, ' ')?.replace(/\b\w/g, l => l.toUpperCase()) || 'Topic'}</span></li></>
          )}

          {currentPath === '/popular' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Popular</span></li></>
          )}

          {currentPath === '/instructors' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Instructors</span></li></>
          )}

          {currentPath.startsWith('/instructor/') && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><a href="/instructors" style={{ color: "var(--muted)", textDecoration: "none" }}>Instructors</a></li>
            <li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>{currentPath.split('/')[2]?.replace(/-/g, ' ')?.replace(/\b\w/g, l => l.toUpperCase()) || 'Instructor'}</span></li></>
          )}

          {currentPath === '/udemy-coupons-guide' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Udemy Coupon Guide</span></li></>
          )}

          {currentPath === '/blog' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Blog</span></li></>
          )}

          {currentPath.startsWith('/blog/') && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><a href="/blog" style={{ color: "var(--muted)", textDecoration: "none" }}>Blog</a></li>
            <li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Post</span></li></>
          )}

          {currentPath === '/about' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>About</span></li></>
          )}

          {currentPath === '/contact' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Contact</span></li></>
          )}

          {currentPath === '/privacy' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Privacy Policy</span></li></>
          )}

          {currentPath === '/terms' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Terms of Service</span></li></>
          )}

          {currentPath === '/sitemap' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Sitemap</span></li></>
          )}

          {currentPath === '/how-to-redeem-coupon' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>How to Redeem</span></li></>
          )}

          {currentPath === '/udemy-coupons-guide' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Udemy Guide</span></li></>
          )}

          {currentPath === '/udemy-coupons-today' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Coupons Today</span></li></>
          )}

          {currentPath.startsWith('/udemy-coupons-today/') && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><a href="/udemy-coupons-today" style={{ color: "var(--muted)", textDecoration: "none" }}>Coupons Today</a></li>
            <li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>{currentPath.split('/')[2]}</span></li></>
          )}

          {!['/udemy-coupon-code', '/categories', '/topics', '/popular', '/instructors', '/blog', '/about', '/contact', '/privacy', '/terms', '/sitemap', '/how-to-redeem-coupon', '/udemy-coupons-guide', '/udemy-coupons-today'].includes(currentPath) &&
           !currentPath.startsWith('/categories/') &&
           !currentPath.startsWith('/topic/') &&
           !currentPath.startsWith('/instructor/') &&
           !currentPath.startsWith('/blog/') &&
           !currentPath.startsWith('/udemy-coupons-today/') && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Page</span></li></>
          )}
        </ol>
      </nav>
    )}

    <main style={{ minHeight: "calc(100vh - 300px)" }}>
      <slot />
    </main>

    <footer
      role="contentinfo"
      itemscope
      itemtype="https://schema.org/WPFooter"
      style={{
        background: "#0f172a",
        borderTop: "1px solid #334155",
        padding: "60px 0 32px",
        marginTop: "auto"
      }}
    >
      <div style={{ maxWidth: "1280px", margin: "0 auto", padding: "0 1.5rem" }}>
        <div style={{
          display: "grid",
          gridTemplateColumns: "2fr 1fr 1fr 1fr",
          gap: "40px",
          marginBottom: "48px"
        }}>
          <div>
