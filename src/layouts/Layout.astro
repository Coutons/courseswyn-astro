---
import "../styles/globals.css";
import HeaderSearch from "../components/HeaderSearch";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  canonical?: string;
  faqs?: Array<{ question: string; answer: string }>;
  hideBreadcrumbs?: boolean;
}


const {
  title = "CoursesWyn - Verified Udemy Promo Codes & Discount Deals",
  description = "Access the latest Udemy promo codes and discount vouchers. Get real-time verified deals updated daily to help you save on premium online courses.",
  image, // No default - let each page provide its own image
  type = "website",
  canonical,
  faqs = [],
  hideBreadcrumbs = false,
} = Astro.props;

const siteUrl = import.meta.env.SITE || "https://courseswyn.com";
const canonicalURL = canonical || new URL(Astro.url.pathname, siteUrl).href;

// Dynamic copyright year
const currentYear = new Date().getFullYear();
const absoluteImageUrl = image ? (image.startsWith('http') ? image : new URL(image, siteUrl).href) : null;

// Get current path for navigation active states
const currentPath = Astro.url.pathname;

// Breadcrumb logic for JSON-LD
const pathSegments = currentPath.split('/').filter(Boolean);
const breadcrumbList = [
  {
    "@type": "ListItem",
    "position": 1,
    "name": "Home",
    "item": "https://courseswyn.com/"
  },
  ...pathSegments.map((segment, index) => ({
    "@type": "ListItem",
    "position": index + 2,
    "name": segment.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
    "item": `https://courseswyn.com/${pathSegments.slice(0, index + 1).join('/')}`
  }))
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Performance & SEO Meta Tags -->
    <meta name="theme-color" content="#1a1a2e" />
    <meta name="msapplication-TileColor" content="#1a1a2e" />
    <meta name="referrer" content="no-referrer-when-downgrade" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="CoursesWyn" />
    
    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    
    <!-- DNS prefetch for external domains -->
    <link rel="dns-prefetch" href="//www.udemy.com" />
    <link rel="dns-prefetch" href="//www.coursera.org" />
    <link rel="dns-prefetch" href="//www.edx.org" />
    
    <!-- Resource hints -->
    <link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml" />
    
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="HISPISPt9Gk-zER-OUkGcPtm6cyiQ7snnKwzn7aDgTY" />
    <link rel="canonical" href={canonicalURL} />
    {canonicalURL.includes('/coupon/') && !canonicalURL.includes('.amp') && (
      <link rel="amphtml" href={canonicalURL.replace('/coupon/', '/coupon/') + '.amp'} />
    )}

    <title>{title}</title>

    <!-- Comprehensive SEO Meta Tags -->
    <meta name="author" content="CoursesWyn" />
    <meta name="publisher" content="CoursesWyn" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />
    <meta name="revisit-after" content="1 days" />
    <meta name="language" content="English" />
    <meta name="distribution" content="global" />
    <meta name="rating" content="general" />
    <meta name="keywords" content="udemy promo code, udemy discount voucher, udemy deals, verified udemy coupons, online course discounts, learning deals 2026, educational vouchers, professional skill coupons" />
    <meta name="classification" content="Education, Online Learning, Course Deals" />
    <meta name="category" content="Education" />
    <link rel="author" href="https://courseswyn.com" />
    <link rel="publisher" href="https://courseswyn.com" />

    <!-- Search Engine Specific -->
    <meta name="yandex-verification" content="verification-code" />
    <meta name="baidu-site-verification" content="verification-code" />

    <!-- Organization Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "logo": "https://courseswyn.com/logo.svg",
      "description": "Find verified Udemy courses with 100% off coupons. Updated daily with free courses and discounts.",
      "foundingDate": "2023",
      "sameAs": [
        "https://www.facebook.com/CoursesWynOfficial",
        "https://x.com/courseswyn"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "url": "https://courseswyn.com/contact"
      }
    }
    </script>

    <!-- Site Sitemap Structured Data -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "SiteNavigationElement",
      "@id": "https://courseswyn.com/sitemap",
      "name": "CoursesWyn Sitemap",
      "description": "Complete navigation structure for CoursesWyn website",
      "url": "https://courseswyn.com/sitemap",
      "potentialAction": {
        "@type": "ReadAction",
        "target": [
          "https://courseswyn.com/",
          "https://courseswyn.com/udemy-coupon-code",
          "https://courseswyn.com/instructors",
          "https://courseswyn.com/categories",
          "https://courseswyn.com/topics",
          "https://courseswyn.com/popular",
          "https://courseswyn.com/about",
          "https://courseswyn.com/contact",
          "https://courseswyn.com/privacy",
          "https://courseswyn.com/terms",
          "https://courseswyn.com/udemy-coupons-guide",
          "https://courseswyn.com/how-to-redeem-coupon"
        ]
      }
    }
    </script>

    <!-- BreadcrumbList Structured Data -->
    {!currentPath.startsWith('/coupon/') && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": breadcrumbList
      })} />
    )}

    <!-- WebSite Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "description": "Access the latest Udemy promo codes and discount vouchers. Daily updated deals for online learning verified by the CoursesWyn editorial team.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://courseswyn.com/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      },
      "publisher": {
        "@id": "https://courseswyn.com/#organization"
      },
      "inLanguage": "en-US",
      "copyrightHolder": {
        "@id": "https://courseswyn.com/#organization"
      }
    }
    </script>

    <!-- Site Navigation Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SiteNavigationElement",
      "name": "Main Navigation",
      "url": "https://courseswyn.com",
      "potentialAction": [
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/udemy-coupon-code",
          "name": "Latest Coupons"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/instructors",
          "name": "Instructors"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/categories",
          "name": "Categories"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/topics",
          "name": "Topics"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/udemy-coupons-guide",
          "name": "Blog/Guide"
        }
      ]
    }
    </script>

    {faqs.length > 0 && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map(faq => ({
          "@type": "Question",
          "name": faq.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": faq.answer
          }
        }))
      })} />
    )}

    <!-- Enhanced Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="CoursesWyn" />
    <meta property="og:locale" content="en_US" />
    {absoluteImageUrl && <meta property="og:image" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="og:image:secure_url" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="og:image:width" content="1200" />}
    {absoluteImageUrl && <meta property="og:image:height" content="630" />}
    {absoluteImageUrl && <meta property="og:image:alt" content={title} />}
    {absoluteImageUrl && <meta property="og:image:type" content="image/jpeg" />}

    <!-- Enhanced Twitter Cards -->
    <meta property="twitter:card" content={absoluteImageUrl ? "summary_large_image" : "summary"} />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:site" content="@courseswyn" />
    <meta property="twitter:creator" content="@courseswyn" />
    {absoluteImageUrl && <meta property="twitter:image" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="twitter:image:alt" content={title} />}

    <!-- Additional Social Sharing Meta Tags -->
    <meta property="article:author" content="CoursesWyn" />
    <meta property="article:publisher" content="https://courseswyn.com" />

    <!-- Optimized Font Loading for Core Web Vitals -->


    <!-- Preload critical fonts -->
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/inter/v13/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuLyfAZ9hiJ-Ek-_EeA.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- ConvertKit Embed Script -->
    <script src="https://f.convertkit.com/ckjs/ck.5.js"></script>

    <!-- AdSense Script -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8220442576502761"
     crossorigin="anonymous"></script>

    <style>
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
      }
      .breadcrumb-link:hover { color: var(--accent) !important; }
      .nav-link:hover { border-bottom-color: var(--accent); }
    </style>
    <slot name="head" />
  </head>
  <body>
    {/* ── Ticker strip — live deals ── */}
    <div class="ticker-strip" style={{ position: "relative", zIndex: 101 }}>
      <div class="ticker-inner">
        {["🔥 Python Bootcamp — FREE", "⚡ React 2026 — $9.99", "✅ Data Science — FREE", "🚀 AWS Certification — $12.99", "🎯 Web Dev Bootcamp — FREE", "💡 Machine Learning — $9.99", "🔥 Python Bootcamp — FREE", "⚡ React 2026 — $9.99", "✅ Data Science — FREE", "🚀 AWS Certification — $12.99", "🎯 Web Dev Bootcamp — FREE", "💡 Machine Learning — $9.99"].map(item => (
          <span style={{ padding: "0 40px", fontSize: "0.78rem", fontWeight: 700, letterSpacing: "0.04em" }}>{item}</span>
        ))}
      </div>
    </div>

    {/* ── Main Header ── */}
    <header class="site-header" style={{ height: "72px", display: "flex", alignItems: "center", borderBottom: "2px solid var(--border)", background: "var(--bg)" }}>
      <nav class="container" style={{ display: "flex", alignItems: "center", justifyContent: "space-between", width: "100%" }}>

        {/* Logo */}
        <a href="/" style={{ display: "flex", alignItems: "center", gap: "12px", textDecoration: "none" }}>
          <div style={{
            width: "38px", height: "38px",
            background: "var(--accent)",
            border: "2px solid var(--border)",
            boxShadow: "3px 3px 0 var(--border)",
            borderRadius: "4px",
            display: "flex", alignItems: "center", justifyContent: "center",
            color: "white", fontWeight: 900, fontSize: "1.1rem"
          }}>W</div>
          <span style={{ fontSize: "1.4rem", fontWeight: 900, letterSpacing: "-0.04em", color: "var(--text)" }}>CoursesWyn</span>
        </a>

        {/* Nav links — Refactored to avoid duplicates and include key pages */}
        <div style={{ display: "flex", alignItems: "center", gap: "24px" }} class="hidden xl:flex">
          <a href="/udemy-coupon-code" class="nav-link" style={{ color: currentPath === '/udemy-coupon-code' ? "var(--accent)" : "var(--text)", fontWeight: 800 }}>DEALS</a>
          <a href="/blog" class="nav-link" style={{ color: currentPath.startsWith('/blog') ? "var(--accent)" : "var(--text)", fontWeight: 800 }}>REVIEWS</a>
          <a href="/udemy-coupons-guide" class="nav-link" style={{ color: currentPath === '/udemy-coupons-guide' ? "var(--accent)" : "var(--text)", fontWeight: 800 }}>GUIDE</a>
          <a href="/topics" class="nav-link" style={{ color: currentPath === '/topics' ? "var(--accent)" : "var(--text)", fontWeight: 800 }}>TOPICS</a>
          <a href="/popular" class="nav-link" style={{ color: currentPath === '/popular' ? "var(--accent)" : "var(--text)", fontWeight: 800 }}>TRENDING</a>
          <a href="/success-stories" class="nav-link" style={{ color: currentPath === '/success-stories' ? "var(--accent)" : "var(--text)", fontWeight: 800 }}>STORIES</a>
        </div>

        {/* Search & Actions */}
        <div style={{ display: "flex", alignItems: "center", gap: "16px" }}>
          <HeaderSearch client:load />
          <a href="/udemy-coupon-code" class="btn" style={{ padding: "6px 14px", fontSize: "0.75rem", background: "var(--text)", color: "white" }}>
            COUPONS
          </a>
          <div style={{ display: "flex", flexDirection: "column", lineHeight: 1 }}>
            <span style={{ fontSize: "0.85rem", fontWeight: 900, color: "var(--accent)" }}>679990</span>
          </div>
        </div>
      </nav>
    </header>

    {/* Breadcrumb */}
    {!hideBreadcrumbs && currentPath !== '/' && !currentPath.includes('/blog/') && !currentPath.includes('/coupon/') && (
      <nav aria-label="Breadcrumb" style={{
        background: "var(--bg)",
        borderBottom: "2px solid var(--border)",
        padding: "10px 0"
      }}>
        <div class="container" style={{
          maxWidth: "1400px",
          margin: "0 auto",
          padding: "0 24px",
          display: "flex",
          alignItems: "center",
          gap: "8px",
          fontSize: "0.85rem",
          color: "var(--muted)"
        }}>
          <a href="/" style={{ color: "var(--muted)", textDecoration: "none", transition: "color 0.2s" }} class="breadcrumb-link">
            Home
          </a>
          <span style={{ color: "var(--border)" }}>/</span>
          {currentPath.startsWith('/udemy-coupon-code') && (
            <>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Free Udemy Coupons</span>
            </>
          )}
          {currentPath.startsWith('/instructors') && (
            <>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Top Instructors</span>
            </>
          )}
          {currentPath.startsWith('/categories') && (
            <>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Course Categories</span>
            </>
          )}
          {currentPath.startsWith('/topics') && (
            <>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Popular Topics</span>
            </>
          )}
          {currentPath.startsWith('/popular') && (
            <>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Trending Deals</span>
            </>
          )}
          {currentPath.startsWith('/blog') && (
            <>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Guides & Blog</span>
            </>
          )}
          {currentPath.startsWith('/coupon/') && (
            <>
              <a href="/udemy-coupon-code" style={{ color: "var(--muted)", textDecoration: "none", transition: "color 0.2s" }} class="breadcrumb-link">
                Free Udemy Coupons
              </a>
              <span style={{ color: "var(--border)" }}>/</span>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Course Details</span>
            </>
          )}
          {currentPath.startsWith('/search') && (
            <>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Search Results</span>
            </>
          )}
        </div>
      </nav>
    )}

    <main style={{ minHeight: "calc(100vh - 300px)" }}>
      <slot />
    </main>

    <footer style={{
      background: "var(--text)",
      color: "rgba(255,255,255,0.7)",
      borderTop: "2px solid var(--border)",
      padding: "0"
    }}>
      {/* Newsletter bar — full width orange strip */}
      <div style={{ background: "var(--accent)", borderBottom: "2px solid var(--border)", padding: "32px 0" }}>
        <div class="container" style={{ display: "flex", alignItems: "center", justifyContent: "space-between", gap: "32px", flexWrap: "wrap" }}>
          <div>
            <p style={{ margin: "0 0 4px", fontSize: "1.1rem", fontWeight: 900, color: "white", letterSpacing: "-0.02em" }}>
              Get daily Udemy promo codes in your inbox.
            </p>
            <p style={{ margin: 0, fontSize: "0.82rem", color: "rgba(255,255,255,0.75)", fontWeight: 500 }}>
              No spam. Unsubscribe anytime. 100% verified deals only.
            </p>
          </div>
          <form action="/api/newsletter-signup" method="POST" style={{ display: "flex", gap: "8px", flexShrink: 0 }}>
            <input
              type="email" name="email" placeholder="your@email.com" required autocomplete="email"
              style={{
                padding: "11px 16px", border: "2px solid white", borderRadius: "4px",
                background: "rgba(255,255,255,0.15)", color: "white",
                fontSize: "0.88rem", fontWeight: 600, outline: "none", width: "240px",
                fontFamily: "inherit"
              }}
            />
            <button type="submit" style={{
              padding: "11px 24px", border: "2px solid white", borderRadius: "4px",
              background: "white", color: "var(--accent)", fontWeight: 900,
              fontSize: "0.85rem", cursor: "pointer", fontFamily: "inherit",
              boxShadow: "3px 3px 0 rgba(0,0,0,0.2)", transition: "all 0.12s ease",
              letterSpacing: "0.03em"
            }}>SUBSCRIBE</button>
          </form>
        </div>
      </div>

      {/* Main footer grid */}
      <div class="container" style={{ padding: "56px 24px 0" }}>
        <div style={{ display: "grid", gridTemplateColumns: "1.6fr 1fr 1fr 1fr", gap: "48px", paddingBottom: "48px", borderBottom: "1px solid rgba(255,255,255,0.1)" }}>

          {/* Brand column */}
          <div>
            <a href="/" style={{ display: "inline-flex", alignItems: "center", gap: "10px", textDecoration: "none", marginBottom: "20px" }}>
              <div style={{
                width: "34px", height: "34px", background: "var(--accent)",
                border: "2px solid white", borderRadius: "5px",
                display: "flex", alignItems: "center", justifyContent: "center",
                color: "white", fontWeight: 900, fontSize: "0.95rem",
                boxShadow: "2px 2px 0 rgba(255,255,255,0.3)"
              }}>W</div>
              <span style={{ fontSize: "1.15rem", fontWeight: 900, color: "white", letterSpacing: "-0.04em" }}>CoursesWyn</span>
            </a>
            <p style={{ fontSize: "0.88rem", lineHeight: 1.65, color: "rgba(255,255,255,0.45)", marginBottom: "24px", maxWidth: "280px" }}>
              Expert reviews of the <strong style={{ color: "rgba(255,255,255,0.75)" }}>best Udemy courses</strong> by topic, plus verified promo codes updated daily since 2023.
            </p>
            <div style={{ display: "flex", gap: "10px" }}>
              {[
                { href: "https://facebook.com/BestCouponPromo", label: "FB" },
                { href: "https://twitter.com/CoursesGift", label: "X" },
                { href: "https://medium.com/@coursewyn", label: "M" }
              ].map(s => (
                <a href={s.href} target="_blank" rel="noopener noreferrer" style={{
                  width: "34px", height: "34px", border: "2px solid rgba(255,255,255,0.2)",
                  borderRadius: "4px", display: "flex", alignItems: "center", justifyContent: "center",
                  color: "rgba(255,255,255,0.5)", textDecoration: "none", fontSize: "0.72rem",
                  fontWeight: 900, transition: "all 0.12s ease"
                }} class="footer-social-btn">{s.label}</a>
              ))}
            </div>
          </div>

          {/* Directory column */}
          <div>
            <h4 style={{ color: "white", fontWeight: 800, fontSize: "0.72rem", textTransform: "uppercase", letterSpacing: "0.15em", marginBottom: "20px" }}>Directory</h4>
            <ul style={{ listStyle: "none", padding: 0, margin: 0, display: "flex", flexDirection: "column", gap: "12px" }}>
              {[
                { label: "Latest Coupons", href: "/udemy-coupon-code" },
                { label: "Trending Deals", href: "/popular" },
                { label: "All Topics", href: "/topics" },
                { label: "Top Instructors", href: "/instructors" }
              ].map(l => (
                <li><a href={l.href} class="footer-nav-link">{l.label}</a></li>
              ))}
            </ul>
          </div>

          {/* Learning column */}
          <div>
            <h4 style={{ color: "white", fontWeight: 800, fontSize: "0.72rem", textTransform: "uppercase", letterSpacing: "0.15em", marginBottom: "20px" }}>Learning</h4>
            <ul style={{ listStyle: "none", padding: 0, margin: 0, display: "flex", flexDirection: "column", gap: "12px" }}>
              {[
                { label: "Best Reviews", href: "/blog" },
                { label: "Coupon Guide", href: "/udemy-coupons-guide" },
                { label: "How to Redeem", href: "/how-to-redeem-coupon" },
                { label: "Categories", href: "/categories" }
              ].map(l => (
                <li><a href={l.href} class="footer-nav-link">{l.label}</a></li>
              ))}
            </ul>
          </div>

          {/* Company column */}
          <div>
            <h4 style={{ color: "white", fontWeight: 800, fontSize: "0.72rem", textTransform: "uppercase", letterSpacing: "0.15em", marginBottom: "20px" }}>Company</h4>
            <ul style={{ listStyle: "none", padding: 0, margin: 0, display: "flex", flexDirection: "column", gap: "12px" }}>
              {[
                { label: "About Us", href: "/about" },
                { label: "Contact Us", href: "/contact" },
                { label: "Sitemap Index", href: "/sitemap" },
                { label: "Privacy Policy", href: "/privacy" }
              ].map(l => (
                <li><a href={l.href} class="footer-nav-link">{l.label}</a></li>
              ))}
            </ul>
          </div>
        </div>

        {/* Bottom bar */}
        <div style={{ padding: "24px 0", display: "flex", justifyContent: "space-between", alignItems: "center", flexWrap: "wrap", gap: "12px" }}>
          <p style={{ margin: 0, fontSize: "0.78rem", color: "rgba(255,255,255,0.3)", fontWeight: 500 }}>
            © {currentYear} CoursesWyn — Verified Udemy Promo Codes & Expert Reviews
          </p>
          <div style={{ display: "flex", gap: "20px" }}>
            {[{ l: "Terms", h: "/terms" }, { l: "Success Stories", h: "/success-stories" }].map(x => (
              <a href={x.h} style={{ fontSize: "0.75rem", color: "rgba(255,255,255,0.25)", textDecoration: "none", fontWeight: 600, transition: "color 0.15s" }} class="footer-bottom-link">{x.l}</a>
            ))}
          </div>
        </div>
      </div>

      <style>
        .footer-nav-link { color: rgba(255,255,255,0.4); text-decoration: none; font-size: 0.86rem; font-weight: 500; transition: color 0.15s; }
        .footer-nav-link:hover { color: var(--accent); }
        .footer-social-btn:hover { border-color: var(--accent) !important; color: var(--accent) !important; }
        .footer-bottom-link:hover { color: rgba(255,255,255,0.6) !important; }
        @media (max-width: 900px) {
          footer .container > div[style*="1.6fr"] { grid-template-columns: 1fr 1fr !important; }
        }
        @media (max-width: 600px) {
          footer .container > div[style*="1.6fr"] { grid-template-columns: 1fr !important; }
        }
      </style>
    </footer>

    {/* Back to Top Button */}
    <button
      id="backToTop"
      style={{
        position: "fixed",
        bottom: "20px",
        right: "20px",
        width: "44px",
        height: "44px",
        borderRadius: "6px",
        background: "var(--bg)",
        color: "var(--text)",
        border: "2px solid var(--border)",
        boxShadow: "4px 4px 0 var(--border)",
        cursor: "pointer",
        display: "none",
        alignItems: "center",
        justifyContent: "center",
        transition: "all 0.15s ease",
        zIndex: 1000,
        fontWeight: 900
      }}
      aria-label="Back to top"
    >
      ↑
    </button>

    <script>
      // Newsletter form feedback
      const newsletterForm = document.querySelector('footer form');
      if (newsletterForm) {
        newsletterForm.addEventListener('submit', function(e) {
          e.preventDefault();
          const emailInput = newsletterForm.querySelector('input[name="email"]') as HTMLInputElement;
          
          if (emailInput) {
            const email = emailInput.value.trim();
            if (email) {
              alert('Thank you for subscribing! We\'ll send you the latest Udemy coupons and deals.');
              emailInput.value = '';
            }
          }
        });
      }

      // Back to top functionality
      const backToTopButton = document.getElementById('backToTop');
      window.addEventListener('scroll', () => {
        if (backToTopButton) {
          if (window.pageYOffset > 300) {
            backToTopButton.style.display = 'flex';
          } else {
            backToTopButton.style.display = 'none';
          }
        }
      });
      
      if (backToTopButton) {
        backToTopButton.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
      
    </script>
  </body>
</html>
