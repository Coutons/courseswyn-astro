---
import "../styles/globals.css";

import { readDeals } from "../lib/store";
import { currentYearWIB } from "../lib/date";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  canonical?: string;
  hideBreadcrumbs?: boolean;
  pubDate?: Date;
  updatedDate?: Date;
}

const allDeals = await readDeals();
const activeCouponCount = "679990";

const siteUrl = import.meta.env.SITE || "https://courseswyn.com";
const currentYear = currentYearWIB();
const months = ["January","February","March","April","May","June","July","August","September","October","November","December"];
const currentMonth = months[new Date().getMonth()];
const currentMonthYear = `${currentMonth} ${currentYear}`;

const {
  title = "Free Udemy Courses 100% OFF Coupons & Promo Codes [" + currentMonthYear + "] | CoursesWyn",
  description = "Find the latest 100% off Udemy coupons. Browse free courses in AI, coding, design & more. Updated daily. Free to browse — start learning for free today.",
  image,
  type = "website",
  canonical,
  pubDate,
  updatedDate,
  hideBreadcrumbs = false,
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, siteUrl).href;
const absoluteImageUrl = image ? (image.startsWith('http') ? image : new URL(image, siteUrl).href) : new URL('/assets/images/og-default.svg', siteUrl).href;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="google-site-verification" content="440e92a0ff41e1b5" />

        <meta name="theme-color" content="#D4AF37" />
    <meta name="msapplication-TileColor" content="#D4AF37" />
    <meta name="referrer" content="no-referrer-when-downgrade" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://f.convertkit.com https://cdn.ampproject.org; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' https: data:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://ipapi.co; frame-src 'none'; object-src 'none'; base-uri 'self'" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="CoursesWyn" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://img-c.udemycdn.com" />

    <link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml" />

    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    {canonicalURL.includes('/coupon/') && !canonicalURL.includes('.amp') && (
      <link rel="amphtml" href={canonicalURL + '.amp'} />
    )}

    <link rel="alternate" type="application/rss+xml" title="CoursesWyn Blog RSS Feed" href={`${siteUrl}/rss.xml`} />

    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    {type === "article" && <meta property="article:author" content="Andrew Derek" />}
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />
    <meta name="revisit-after" content="1 days" />
    <meta name="language" content="English" />
    <meta name="distribution" content="global" />
    <meta name="rating" content="general" />
    <meta name="keywords" content="free udemy courses, udemy coupon code 100 off, udemy promo code, udemy discount coupon, udemy free certificate courses, udemy personal plan, free online courses 2026, udemy 100 free coupon, learn to code free, udemy deals today" />
    <meta name="classification" content="Education, Online Learning, Course Deals" />
    <meta name="category" content="Education" />

    <script type="application/ld+json">
    [{
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "logo": "https://courseswyn.com/logo.svg",
      "description": "Find verified Udemy courses with 100% off coupons.",
      "sameAs": ["https://www.facebook.com/CoursesWyn", "https://x.com/CoursesWyn"]
    },
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "description": "Find verified Udemy courses with 100% off coupons. Daily updated deals for online learning.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://courseswyn.com/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }]
    </script>

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="CoursesWyn" />
    <meta property="og:locale" content="en_US" />
    {absoluteImageUrl && <meta property="og:image" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="og:image:secure_url" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="og:image:width" content="1200" />}
    {absoluteImageUrl && <meta property="og:image:height" content="630" />}
    {absoluteImageUrl && <meta property="og:image:alt" content={title} />}
    {absoluteImageUrl && <meta property="og:image:type" content="image/jpeg" />}

    <meta property="twitter:card" content={absoluteImageUrl ? "summary_large_image" : "summary"} />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:site" content="@CoursesGift" />
    <meta property="twitter:creator" content="@CoursesGift" />
    {absoluteImageUrl && <meta property="twitter:image" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="twitter:image:alt" content={title} />}

    <meta name="author" content="Andrew Derek" />
    <meta property="article:author" content="Andrew Derek" />
    <meta property="article:publisher" content="https://courseswyn.com" />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap&text=ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/inter/v13/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuLyfAZ9hiJ-Ek-_EeA.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <script src="https://f.convertkit.com/ckjs/ck.5.js" defer></script>

    <style>
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, Apple Color Emoji, Segoe UI Emoji;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        flex-shrink: 0;
      }
      .brand-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: linear-gradient(135deg, #B8860B 0%, #D4AF37 40%, #E8C547 60%, #D4AF37 100%);
        color: #1a1814;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 0 16px rgba(212,167,55,0.25), inset 0 1px 0 rgba(255,255,255,0.15);
        position: relative;
      }
      .brand-icon::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.12);
        pointer-events: none;
      }
      .brand-text {
        display: flex;
        flex-direction: column;
      }
      .brand-name {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        color: #f5f0e8;
        line-height: 1.2;
      }
      .brand-tagline {
        font-size: 0.62rem;
        color: #8a7e6a;
        font-weight: 500;
        letter-spacing: 0.03em;
        line-height: 1.2;
        text-transform: uppercase;
      }

      .nav-links {
        display: flex;
        gap: 2px;
        align-items: center;
        flex: 1;
        justify-content: center;
      }
      .nav-item {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.82rem;
        font-weight: 600;
        color: #f5f0e8;
        text-decoration: none;
        border: 1px solid rgba(212,167,55,0.15);
        background: rgba(212,167,55,0.04);
        transition: all 0.25s ease;
        white-space: nowrap;
        position: relative;
      }
      .nav-item::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 50%;
        transform: translateX(-50%);
        width: 0;
        height: 2px;
        background: linear-gradient(90deg, #B8860B, #D4AF37, #E8C547);
        border-radius: 1px;
        transition: all 0.3s ease;
      }
      .nav-item:hover {
        background: rgba(212, 167, 55, 0.12);
        border-color: rgba(212, 167, 55, 0.3);
      }
      .nav-item:hover::after {
        width: 60%;
      }
      .nav-item.active {
        background: rgba(212, 167, 55, 0.18);
        border-color: rgba(212, 167, 55, 0.4);
      }
      .nav-item.active::after {
        width: 60%;
      }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
      }
      .search-form {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(212,167,55,0.05);
        border: 1px solid rgba(212, 167, 55, 0.25);
        border-radius: 10px;
        padding: 7px 14px;
        width: 190px;
        transition: all 0.3s ease;
        cursor: text;
        backdrop-filter: blur(4px);
        position: relative;
      }
      .search-form:hover {
        border-color: rgba(212, 167, 55, 0.4);
        background: rgba(212, 167, 55, 0.08);
      }
      .search-form:focus-within {
        border-color: rgba(212, 167, 55, 0.6);
        background: rgba(212, 167, 55, 0.12);
        box-shadow: 0 0 28px -6px rgba(212,167,55,0.3);
      }
      .nav-count {
        font-size: 0.75rem;
        font-weight: 600;
        color: #8a7e6a;
        display: flex;
        align-items: center;
        gap: 4px;
      }
      .nav-count::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #D4AF37;
        display: inline-block;
        animation: pulse 2s ease-in-out infinite;
      }
      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
      }

      .ft { border-top: 1px solid rgba(212,167,55,0.08); padding: 60px 0 32px; margin-top: auto; }
      .ft-inner { max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; }
      .ft-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 48px; }
      @media (max-width: 768px) { .ft-grid { grid-template-columns: 1fr 1fr; gap: 30px; } }
      @media (max-width: 480px) { .ft-grid { grid-template-columns: 1fr; } }
      .ft-heading { font-size: 0.78rem; font-weight: 700; margin-bottom: 18px; text-transform: uppercase; letter-spacing: 0.08em; background: linear-gradient(135deg, #D4AF37, #E8C547); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
      .ft-link { color: #8a7e6a; text-decoration: none; font-size: 0.85rem; transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px; }
      .ft-link:hover { color: #D4AF37; }
      .ft-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
      .ft-text { font-size: 0.88rem; line-height: 1.7; margin: 0 0 20px; max-width: 320px; }
      .ft-bottom { padding-top: 28px; text-align: center; font-size: 0.8rem; color: #6b6050; position: relative; }
      .ft-bottom::before { content: ''; display: block; width: 80px; height: 1px; background: linear-gradient(90deg, transparent, #D4AF37, #E8C547, #D4AF37, transparent); margin: 0 auto 24px; border-radius: 1px; }
      .ft-logo-sm { display: inline-flex; align-items: center; gap: 8px; }
      .ft-brand-icon { width: 28px; height: 28px; border-radius: 8px; background: linear-gradient(135deg, #B8860B, #D4AF37, #E8C547); display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
    </style>
    <slot name="head" />
  </head>
  <body>
    <header role="banner" class="site-header">
      <nav
        itemscope
        itemtype="https://schema.org/SiteNavigationElement"
        class="container"
        aria-label="Main navigation"
        style={{
          display: "flex",
          justifyContent: "space-between",
          alignItems: "center",
          padding: "0 1.5rem",
          maxWidth: "1400px",
          margin: "0 auto",
          height: "70px"
        }}
      >
        <a href="/" class="brand" aria-label="CoursesWyn Home">
          <span class="brand-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 44 44" fill="none">
              <defs>
                <mask id="cw-mask">
                  <rect width="44" height="44" fill="white"/>
                  <path d="M28 16H18a3 3 0 0 0-3 3v6a3 3 0 0 0 3 3h10" stroke="black" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                </mask>
              </defs>
              <path d="M22 3L40 13v18L22 41 4 31V13L22 3Z" fill="#1a1814" mask="url(#cw-mask)"/>
              <path d="M22 3L4 13 22 23 40 13 22 3Z" fill="rgba(255,255,248,0.06)" mask="url(#cw-mask)"/>
              <path d="M4 13v18l7-5 11-14Z" fill="rgba(0,0,0,0.12)" mask="url(#cw-mask)"/>
              <path d="M40 13v18l-7-5L22 13Z" fill="rgba(0,0,0,0.04)" mask="url(#cw-mask)"/>
              <path d="M11 31l-7-5 7-5 11 10Z" fill="rgba(0,0,0,0.08)" mask="url(#cw-mask)"/>
              <path d="M33 31l7-5-7-5-11 10Z" fill="rgba(0,0,0,0.02)" mask="url(#cw-mask)"/>
              <circle cx="28" cy="9" r="1.2" fill="#E8C547" opacity="0.8"/>
              <circle cx="35" cy="15" r="0.6" fill="#E8C547" opacity="0.5"/>
              <circle cx="17" cy="36" r="0.5" fill="#E8C547" opacity="0.3"/>
            </svg>
          </span>
          <div class="brand-text">
            <span class="brand-name">CoursesWyn</span>
            <span class="brand-tagline">Verified Free Courses Daily</span>
          </div>
        </a>

        <div class="nav-links">
          <a href="/udemy-coupons-today" itemprop="url"
            class:list={['nav-item', { active: currentPath === '/udemy-coupons-today' }]}
            aria-current={currentPath === '/udemy-coupons-today' ? 'page' : undefined}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2h12l4 4v14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6l4-4z"/><path d="M2 6h20"/><path d="M16 2v4H8V2"/><rect x="8" y="10" width="8" height="6"/></svg>
            <span itemprop="name">Today's Coupons</span>
          </a>
          <a href="/udemy-coupon-code" itemprop="url"
            class:list={['nav-item', { active: currentPath === '/udemy-coupon-code' }]}
            aria-current={currentPath === '/udemy-coupon-code' ? 'page' : undefined}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span itemprop="name">Coupon Codes</span>
          </a>
          <a href="/popular" itemprop="url"
            class:list={['nav-item', { active: currentPath === '/popular' }]}
            aria-current={currentPath === '/popular' ? 'page' : undefined}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
            <span itemprop="name">Popular Courses</span>
          </a>
          <a href="/categories" itemprop="url"
            class:list={['nav-item', { active: currentPath === '/categories' || currentPath.startsWith('/categories/') }]}
            aria-current={currentPath === '/categories' || currentPath.startsWith('/categories/') ? 'page' : undefined}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            <span itemprop="name">Categories</span>
          </a>
          <a href="/topics" itemprop="url"
            class:list={['nav-item', { active: currentPath === '/topics' || currentPath.startsWith('/topics/') }]}
            aria-current={currentPath === '/topics' || currentPath.startsWith('/topics/') ? 'page' : undefined}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            <span itemprop="name">Topics</span>
          </a>
          <a href="/blog" itemprop="url"
            class:list={['nav-item', { active: currentPath === '/blog' || currentPath.startsWith('/blog/') }]}
            aria-current={currentPath === '/blog' || currentPath.startsWith('/blog/') ? 'page' : undefined}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            <span itemprop="name">Blog</span>
          </a>
        </div>

        <div class="nav-right">
          <form action="/search" method="get" class="search-form" role="search">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style={{ flexShrink: 0, opacity: 0.9 }}>
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input
              type="text"
              name="q"
              placeholder="Search courses..."
              style={{
                background: 'transparent',
                color: '#f5f0e8',
                border: 'none',
                fontSize: '0.82rem',
                width: '100%',
                outline: 'none',
                padding: 0
              }}
            />
          </form>
          <span class="nav-count">{activeCouponCount}</span>
        </div>
      </nav>
    </header>

    <!-- Breadcrumb Navigation -->
    {!hideBreadcrumbs && currentPath !== '/' && !currentPath.startsWith('/coupon/') && !currentPath.startsWith('/blog/') && currentPath !== '/blog' && (
      <nav
        aria-label="Breadcrumb"
        class="container"
        style={{
          padding: "12px 0",
          fontSize: "0.85rem",
          borderBottom: "1px solid var(--border)"
        }}
      >
        <ol style={{ display: "flex", gap: "8px", listStyle: "none", margin: 0, padding: 0, alignItems: "center", flexWrap: "wrap" }}>
          <li style={{ display: "flex", alignItems: "center" }}>
            <a href="/" style={{ color: "var(--muted)", textDecoration: "none", display: "flex", alignItems: "center", gap: "4px" }}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
              </svg>
              <span>Home</span>
            </a>
          </li>

          {currentPath === '/udemy-coupon-code' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>All Deals</span></li></>
          )}

          {currentPath === '/categories' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Categories</span></li></>
          )}

          {currentPath.startsWith('/categories/') && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><a href="/categories" style={{ color: "var(--muted)", textDecoration: "none" }}>Categories</a></li>
            <li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>{currentPath.split('/')[2]?.replace(/-/g, ' ')?.replace(/\b\w/g, l => l.toUpperCase()) || 'Category'}</span></li></>
          )}

          {currentPath === '/topics' && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><span style={{ color: "var(--text)", fontWeight: 500 }}>Topics</span></li></>
          )}

          {currentPath.startsWith('/topic/') && (
            <><li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
            <li><a href="/topics" style={{ color: "var(--muted)", textDecoration: "none" }}>Topics</a></li>
            <li aria-hidden="true" style={{ color: "var(--muted)" }}>/</li>
