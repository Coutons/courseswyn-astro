---
import "../styles/globals.css";

import { readDeals } from "../lib/store";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  canonical?: string;
  hideBreadcrumbs?: boolean;
}

const allDeals = await readDeals();
const activeCouponCount = "679990";

const {
  title = "CoursesWyn - Free Udemy Courses and Verified Coupons Daily",
  description = "Find the latest 100% off Udemy coupons for ${currentMonth} ${currentYear}. Browse 1,200+ free courses in AI, coding, design & more. Updated every hours. No signup needed — start learning for free today.",
  image, // No default - let each page provide its own image
  type = "website",
  canonical,
} = Astro.props;

const siteUrl = import.meta.env.SITE || "https://courseswyn.com";
const canonicalURL = canonical || new URL(Astro.url.pathname, siteUrl).href;

// Dynamic copyright year
const currentYear = new Date().getFullYear();
const absoluteImageUrl = image ? (image.startsWith('http') ? image : new URL(image, siteUrl).href) : null;

// Get current path for navigation active states
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Performance & SEO Meta Tags -->
    <meta name="theme-color" content="#1a1a2e" />
    <meta name="msapplication-TileColor" content="#1a1a2e" />
    <meta name="referrer" content="no-referrer-when-downgrade" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="CoursesWyn" />

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />

    <!-- DNS prefetch for external domains -->
    <link rel="dns-prefetch" href="//www.udemy.com" />
    <link rel="dns-prefetch" href="//www.coursera.org" />
    <link rel="dns-prefetch" href="//www.edx.org" />

    <!-- Resource hints -->
    <link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml" />

    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    {canonicalURL.includes('/coupon/') && !canonicalURL.includes('.amp') && (
      <link rel="amphtml" href={canonicalURL.replace('/coupon/', '/coupon/') + '.amp'} />
    )}

    <title>{title}</title>

    <!-- Comprehensive SEO Meta Tags -->
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />
    <meta name="revisit-after" content="1 days" />
    <meta name="language" content="English" />
    <meta name="distribution" content="global" />
    <meta name="rating" content="general" />
    <meta name="keywords" content="verified udemy coupons, 100% off udemy promo codes, free udemy courses with certificates, daily udemy deals, CoursesWyn free coupons, latest udemy discount codes, online learning deals" />
    <meta name="classification" content="Education, Online Learning, Course Deals" />
    <meta name="category" content="Education" />

    <!-- Organization Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "logo": "https://courseswyn.com/logo.svg",
      "description": "Find verified Udemy courses with 100% off coupons. Updated daily with free courses and discounts.",
      "foundingDate": "2023",
      "sameAs": [
        "https://www.facebook.com/BestCouponPromo",
        "https://x.com/CoursesGift"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "url": "https://courseswyn.com/contact"
      }
    }
    </script>

    <!-- Site Sitemap Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SiteNavigationElement",
      "@id": "https://courseswyn.com/sitemap",
      "name": "CoursesWyn Sitemap",
      "description": "Complete navigation structure for CoursesWyn website",
      "url": "https://courseswyn.com/sitemap",
      "potentialAction": {
        "@type": "ReadAction",
        "target": [
          "https://courseswyn.com/",
          "https://courseswyn.com/udemy-coupon-code",
          "https://courseswyn.com/udemy-coupons-today",
          "https://courseswyn.com/blog",
          "https://courseswyn.com/instructors",
          "https://courseswyn.com/categories",
          "https://courseswyn.com/topics",
          "https://courseswyn.com/popular",
          "https://courseswyn.com/about",
          "https://courseswyn.com/contact",
          "https://courseswyn.com/privacy",
          "https://courseswyn.com/terms",
          "https://courseswyn.com/udemy-coupons-guide",
          "https://courseswyn.com/how-to-redeem-coupon"
        ]
      }
    }
    </script>

    <!-- WebSite Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "description": "Find verified Udemy courses with 100% off coupons. Daily updated deals for online learning.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://courseswyn.com/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      },
      "publisher": {
        "@id": "https://courseswyn.com/#organization"
      },
      "inLanguage": "en-US",
      "copyrightHolder": {
        "@id": "https://courseswyn.com/#organization"
      }
    }
    </script>

    <!-- Site Navigation Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SiteNavigationElement",
      "name": "Main Navigation",
      "url": "https://courseswyn.com",
      "potentialAction": [
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/udemy-coupon-code",
          "name": "Latest Coupons"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/udemy-coupons-today",
          "name": "Coupons Today"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/blog",
          "name": "Blog/Guide"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/instructors",
          "name": "Instructors"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/categories",
          "name": "Categories"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/topics",
          "name": "Topics"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/udemy-coupons-guide",
          "name": "Blog/Guide"
        }
      ]
    }
    </script>

    <!-- Enhanced Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="CoursesWyn" />
    <meta property="og:locale" content="en_US" />
    {absoluteImageUrl && <meta property="og:image" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="og:image:secure_url" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="og:image:width" content="1200" />}
    {absoluteImageUrl && <meta property="og:image:height" content="630" />}
    {absoluteImageUrl && <meta property="og:image:alt" content={title} />}
    {absoluteImageUrl && <meta property="og:image:type" content="image/jpeg" />}

    <!-- Enhanced Twitter Cards -->
    <meta property="twitter:card" content={absoluteImageUrl ? "summary_large_image" : "summary"} />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:site" content="@CourseGift" />
    <meta property="twitter:creator" content="@CourseGift" />
    {absoluteImageUrl && <meta property="twitter:image" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="twitter:image:alt" content={title} />}

    <!-- Additional Social Sharing Meta Tags -->
    <meta name="author" content="CoursesWyn" />
    <meta property="article:author" content="CoursesWyn" />
    <meta property="article:publisher" content="https://courseswyn.com" />

    <!-- Optimized Font Loading for Core Web Vitals -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap&text=ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Preload critical fonts -->
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/inter/v13/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuLyfAZ9hiJ-Ek-_EeA.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- ConvertKit Embed Script -->
    <script src="https://f.convertkit.com/ckjs/ck.5.js"></script>

    <style>
      /* Basic styles */
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, Apple Color Emoji, Segoe UI Emoji;
      }

      /* Optimized social media hover effects */
      .facebook-hover:hover,
      .x-hover:hover,
      .linkedin-hover:hover {
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(16, 185, 129, 0.15);
        border-color: var(--brand);
      }

      .facebook-hover:hover span,
      .x-hover:hover span,
      .linkedin-hover:hover span {
        color: var(--brand);
      }

      /* Top Promo Bar */
      .top-promo { background: linear-gradient(90deg, #a855f7 0%, #7c3aed 100%); color: white; text-align: center; padding: 8px 16px; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 12px; font-size: 0.85rem; font-weight: 600; transition: all 0.3s; position: relative; z-index: 1100; }
      .top-promo:hover { filter: brightness(1.1); }
      .top-promo-tag { background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3); padding: 1px 6px; border-radius: 4px; font-size: 0.65rem; font-weight: 800; text-transform: uppercase; }
      .top-promo-arrow { font-size: 1rem; transition: transform 0.2s; }
      .top-promo:hover .top-promo-arrow { transform: translateX(4px); }
      @media (max-width: 640px) {
        .top-promo-tag { display: none; }
        .top-promo { font-size: 0.75rem; padding: 6px 12px; }
      }

      /* Navigation link hover effects */
      .nav-link:hover {
        background: rgba(16, 185, 129, 0.08) !important;
        transform: translateY(-1px);
      }

      .nav-link:active {
        transform: translateY(0);
      }
    </style>
    <slot name="head" />
  </head>
  <body>
    <header
      role="banner"
      class="site-header"
      style={{
        position: "sticky",
        top: 0,
        zIndex: 1000,
        background: "var(--bg)",
        borderBottom: "1px solid var(--border)"
      }}
    >

      <nav
        itemscope
        itemtype="https://schema.org/SiteNavigationElement"
        class="container"
        aria-label="Main navigation"
        style={{
          display: "flex",
          justifyContent: "space-between",
          alignItems: "center",
          padding: "10px 16px",
          maxWidth: "1400px",
          margin: "0 auto"
        }}
      >
        {/* Logo on left */}
        <a href="/" class="logo" style={{ flexShrink: 0 }}>
          <div style={{ display: "flex", alignItems: "center", gap: "12px" }}>
            <div style={{
              width: "42px",
              height: "42px",
              background: "var(--brand)",
              borderRadius: "12px",
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              position: "relative",
              boxShadow: "0 8px 16px -4px var(--brand-soft)",
              overflow: "hidden"
            }}>
              {/* Modern W Bolt Icon */}
              <svg
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M3 12l3 9 4-12 4 12 7-21" />
                <path d="M13 18l3 3 5-5" stroke-width="2" />
              </svg>
              <div style={{
                position: "absolute",
                top: 0,
                left: 0,
                width: "100%",
                height: "100%",
                background: "linear-gradient(45deg, transparent 0%, rgba(255,255,255,0.2) 100%)"
              }}></div>
            </div>
            <div style={{ display: "flex", flexDirection: "column" }}>
              <span
                style={{
                  fontSize: "1.6rem",
                  fontWeight: 800,
                  lineHeight: "1.2"
                }}
              >
                <span style={{
                  color: "var(--text)",
                  letterSpacing: "-0.02em"
                }}>Courses</span>
                <span style={{
                  color: "var(--brand)",
                  letterSpacing: "-0.02em"
                }}>Wyn</span>
              </span>
              <span
                style={{
                  fontSize: "0.7rem",
                  color: "var(--muted)",
                  fontWeight: 700,
                  letterSpacing: "0.05em",
                  textTransform: "uppercase"
                }}
              >Verified Daily Deals</span>
            </div>
          </div>
        </a>

        {/* Navigation: All Links on Left - Search on Right */}
        <div style={{ display: "flex", gap: "8px", alignItems: "center", flex: 1, justifyContent: "space-between", minWidth: 0, flexWrap: "wrap" }}>

          {/* LEFT SIDE: All Menu Links */}
          <div style={{ display: "flex", gap: "4px", alignItems: "center" }}>
            <a
              itemprop="url"
              href="/udemy-coupon-code"
              style={{
                color: currentPath === '/udemy-coupon-code' ? 'var(--brand)' : 'var(--text)',
                textDecoration: "none",
                fontSize: "0.8rem",
                fontWeight: 600,
                padding: "5px 8px",
                borderRadius: "4px",
                transition: "all 0.2s ease",
                display: "flex",
                alignItems: "center",
                gap: "4px",
                whiteSpace: "nowrap",
                background: currentPath === '/udemy-coupon-code' ? 'rgba(16, 185, 129, 0.1)' : 'transparent'
              }}
              class={currentPath === '/udemy-coupon-code' ? 'active' : 'nav-link'}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.41l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.41zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z"/>
              </svg>
              <span itemprop="name">Latest Coupons</span>
            </a>

            <a
              itemprop="url"
              href="/categories"
              style={{
                color: currentPath === '/categories' ? 'var(--brand)' : 'var(--text)',
                textDecoration: "none",
                fontSize: "0.8rem",
                fontWeight: 600,
                padding: "5px 8px",
                borderRadius: "4px",
                transition: "all 0.2s ease",
                display: "flex",
                alignItems: "center",
                gap: "4px",
                whiteSpace: "nowrap",
                background: currentPath === '/categories' ? 'rgba(16, 185, 129, 0.1)' : 'transparent'
              }}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l-5.5 9h11z"/>
                <circle cx="17.5" cy="17.5" r="4.5"/>
                <path d="M3 13.5h8v8H3z"/>
              </svg>
              <span itemprop="name">Categories</span>
            </a>

            <a
              itemprop="url"
              href="/instructors"
              style={{
                color: currentPath === '/instructors' ? 'var(--brand)' : 'var(--text)',
                textDecoration: "none",
                fontSize: "0.8rem",
                fontWeight: 600,
                padding: "5px 8px",
                borderRadius: "4px",
                transition: "all 0.2s ease",
                display: "flex",
                alignItems: "center",
                gap: "4px",
                whiteSpace: "nowrap",
                background: currentPath === '/instructors' ? 'rgba(16, 185, 129, 0.1)' : 'transparent'
              }}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              <span itemprop="name">Instructors</span>
            </a>

            <a
              itemprop="url"
              href="/topics"
              style={{
                color: currentPath === '/topics' ? 'var(--brand)' : 'var(--text)',
                textDecoration: "none",
                fontSize: "0.8rem",
                fontWeight: 600,
                padding: "5px 8px",
                borderRadius: "4px",
                transition: "all 0.2s ease",
                display: "flex",
                alignItems: "center",
                gap: "4px",
                whiteSpace: "nowrap",
                background: currentPath === '/topics' ? 'rgba(16, 185, 129, 0.1)' : 'transparent'
              }}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"/>
              </svg>
              <span itemprop="name">Topics</span>
            </a>

            <a
              itemprop="url"
              href="/popular"
              style={{
                color: currentPath === '/popular' ? 'var(--brand)' : 'var(--text)',
                textDecoration: "none",
                fontSize: "0.8rem",
                fontWeight: 600,
                padding: "5px 8px",
                borderRadius: "4px",
                transition: "all 0.2s ease",
                display: "flex",
                alignItems: "center",
                gap: "4px",
                whiteSpace: "nowrap",
                background: currentPath === '/popular' ? 'rgba(16, 185, 129, 0.1)' : 'transparent'
              }}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
              </svg>
              <span itemprop="name">Popular</span>
            </a>

            <a
              itemprop="url"
              href="/udemy-coupons-today"
              style={{
                color: currentPath === '/udemy-coupons-today' || currentPath.startsWith('/udemy-coupons-today/') ? 'var(--brand)' : 'var(--text)',
                textDecoration: "none",
                fontSize: "0.8rem",
                fontWeight: 600,
                padding: "5px 8px",
                borderRadius: "4px",
                transition: "all 0.2s ease",
                display: "flex",
                alignItems: "center",
                gap: "4px",
                whiteSpace: "nowrap",
                background: currentPath === '/udemy-coupons-today' || currentPath.startsWith('/udemy-coupons-today/') ? 'rgba(16, 185, 129, 0.1)' : 'transparent'
              }}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2L1 9l11 6 9-4.91V17h2V9L12 3z"/>
              </svg>
              <span itemprop="name">Coupons Today</span>
            </a>
          </div>

          <div style={{ display: "flex", alignItems: "center", gap: "10px", flexWrap: "wrap", justifyContent: "flex-end" }}>
            <form action="/search" method="get" style={{
              display: "flex",
              gap: "0",
              background: "var(--card)",
              borderRadius: "8px",
              border: "1px solid var(--border)",
              overflow: "hidden",
              width: "240px",
              flexShrink: 1,
            }}>
              <input
                type="text"
                name="q"
                placeholder="Search courses..."
                style={{
                  background: 'transparent',
                  color: 'var(--text)',
                  border: 'none',
                  padding: '6px 10px',
                  fontSize: '0.8rem',
                  width: '100%',
                  outline: 'none',
                  minWidth: '0'
                }}
              />
              <button
                type="submit"
                style={{
                  background: 'var(--brand)',
                  color: 'var(--bg)',
                  border: 'none',
                  padding: '6px 10px',
                  fontSize: '0.8rem',
                  cursor: 'pointer',
                  fontWeight: '600',
                  display: 'flex',
                  alignItems: 'center'
                }}
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                </svg>
              </button>
            </form>
            <span style={{
              fontSize: "0.85rem",
              fontWeight: 800,
              color: "var(--brand)",
              letterSpacing: "1px",
              background: "var(--brand-soft)",
              padding: "4px 10px",
              borderRadius: "6px",
              border: "1px solid var(--brand-soft)",
              margin: "4px 0",
              whiteSpace: "nowrap"
            }}>{activeCouponCount}</span>
          </div>
        </div>
      </nav>
    </header>

    <!-- Breadcrumb Navigation -->
    {currentPath !== '/' && !currentPath.startsWith('/coupon/') && !currentPath.startsWith('/blog/') && (
      <nav
        aria-label="Breadcrumb"
        class="container"
