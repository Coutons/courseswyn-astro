---
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  canonical?: string;
}


const {
  title = "CoursesWyn - Verified Udemy Promo Codes & Discount Deals",
  description = "Access the latest Udemy promo codes and discount vouchers. Get real-time verified deals updated daily to help you save on premium online courses.",
  image, // No default - let each page provide its own image
  type = "website",
  canonical,
} = Astro.props;

const siteUrl = import.meta.env.SITE || "https://courseswyn.com";
const canonicalURL = canonical || new URL(Astro.url.pathname, siteUrl).href;

// Dynamic copyright year
const currentYear = new Date().getFullYear();
const absoluteImageUrl = image ? (image.startsWith('http') ? image : new URL(image, siteUrl).href) : null;

// Get current path for navigation active states
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Performance & SEO Meta Tags -->
    <meta name="theme-color" content="#1a1a2e" />
    <meta name="msapplication-TileColor" content="#1a1a2e" />
    <meta name="referrer" content="no-referrer-when-downgrade" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="CoursesWyn" />
    
    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
    
    <!-- DNS prefetch for external domains -->
    <link rel="dns-prefetch" href="//www.udemy.com" />
    <link rel="dns-prefetch" href="//www.coursera.org" />
    <link rel="dns-prefetch" href="//www.edx.org" />
    
    <!-- Resource hints -->
    <link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml" />
    
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="HISPISPt9Gk-zER-OUkGcPtm6cyiQ7snnKwzn7aDgTY" />
    <link rel="canonical" href={canonicalURL} />
    {canonicalURL.includes('/coupon/') && !canonicalURL.includes('.amp') && (
      <link rel="amphtml" href={canonicalURL.replace('/coupon/', '/coupon/') + '.amp'} />
    )}

    <title>{title}</title>

    <!-- Comprehensive SEO Meta Tags -->
    <meta name="author" content="CoursesWyn" />
    <meta name="publisher" content="CoursesWyn" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />
    <meta name="revisit-after" content="1 days" />
    <meta name="language" content="English" />
    <meta name="distribution" content="global" />
    <meta name="rating" content="general" />
    <meta name="keywords" content="udemy promo code, udemy discount voucher, udemy deals, verified udemy coupons, online course discounts, learning deals 2026, educational vouchers, professional skill coupons" />
    <meta name="classification" content="Education, Online Learning, Course Deals" />
    <meta name="category" content="Education" />
    <link rel="author" href="https://courseswyn.com" />
    <link rel="publisher" href="https://courseswyn.com" />

    <!-- Search Engine Specific -->
    <meta name="yandex-verification" content="verification-code" />
    <meta name="baidu-site-verification" content="verification-code" />

    <!-- Organization Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "logo": "https://courseswyn.com/logo.svg",
      "description": "Find verified Udemy courses with 100% off coupons. Updated daily with free courses and discounts.",
      "foundingDate": "2023",
      "sameAs": [
        "https://www.facebook.com/CoursesWynOfficial",
        "https://x.com/courseswyn"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "url": "https://courseswyn.com/contact"
      }
    }
    </script>

    <!-- Site Sitemap Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SiteNavigationElement",
      "@id": "https://courseswyn.com/sitemap",
      "name": "CoursesWyn Sitemap",
      "description": "Complete navigation structure for CoursesWyn website",
      "url": "https://courseswyn.com/sitemap",
      "potentialAction": {
        "@type": "ReadAction",
        "target": [
          "https://courseswyn.com/",
          "https://courseswyn.com/udemy-coupon-code",
          "https://courseswyn.com/instructors",
          "https://courseswyn.com/categories",
          "https://courseswyn.com/topics",
          "https://courseswyn.com/popular",
          "https://courseswyn.com/about",
          "https://courseswyn.com/contact",
          "https://courseswyn.com/privacy",
          "https://courseswyn.com/terms",
          "https://courseswyn.com/udemy-coupons-guide",
          "https://courseswyn.com/how-to-redeem-coupon"
        ]
      }
    }
    </script>

    <!-- WebSite Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "CoursesWyn",
      "url": "https://courseswyn.com",
      "description": "Access the latest Udemy promo codes and discount vouchers. Daily updated deals for online learning verified by the CoursesWyn editorial team.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://courseswyn.com/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      },
      "publisher": {
        "@id": "https://courseswyn.com/#organization"
      },
      "inLanguage": "en-US",
      "copyrightHolder": {
        "@id": "https://courseswyn.com/#organization"
      }
    }
    </script>

    <!-- Site Navigation Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SiteNavigationElement",
      "name": "Main Navigation",
      "url": "https://courseswyn.com",
      "potentialAction": [
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/udemy-coupon-code",
          "name": "Latest Coupons"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/instructors",
          "name": "Instructors"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/categories",
          "name": "Categories"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/topics",
          "name": "Topics"
        },
        {
          "@type": "ReadAction",
          "target": "https://courseswyn.com/udemy-coupons-guide",
          "name": "Blog/Guide"
        }
      ]
    }
    </script>

    <!-- Enhanced Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="CoursesWyn" />
    <meta property="og:locale" content="en_US" />
    {absoluteImageUrl && <meta property="og:image" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="og:image:secure_url" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="og:image:width" content="1200" />}
    {absoluteImageUrl && <meta property="og:image:height" content="630" />}
    {absoluteImageUrl && <meta property="og:image:alt" content={title} />}
    {absoluteImageUrl && <meta property="og:image:type" content="image/jpeg" />}

    <!-- Enhanced Twitter Cards -->
    <meta property="twitter:card" content={absoluteImageUrl ? "summary_large_image" : "summary"} />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:site" content="@courseswyn" />
    <meta property="twitter:creator" content="@courseswyn" />
    {absoluteImageUrl && <meta property="twitter:image" content={absoluteImageUrl} />}
    {absoluteImageUrl && <meta property="twitter:image:alt" content={title} />}

    <!-- Additional Social Sharing Meta Tags -->
    <meta property="article:author" content="CoursesWyn" />
    <meta property="article:publisher" content="https://courseswyn.com" />

    <!-- Optimized Font Loading for Core Web Vitals -->
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Preload critical fonts -->
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/inter/v13/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuLyfAZ9hiJ-Ek-_EeA.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- ConvertKit Embed Script -->
    <script src="https://f.convertkit.com/ckjs/ck.5.js"></script>

    <!-- AdSense Script -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8220442576502761"
     crossorigin="anonymous"></script>

    <style>
      /* Basic styles */
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        font-family: 'Plus Jakarta Sans', ui-sans-serif, system-ui, -apple-system, sans-serif;
      }
      
      /* Optimized social media hover effects */
      .facebook-hover:hover,
      .x-hover:hover,
      .linkedin-hover:hover {
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(255, 193, 7, 0.15);
        border-color: var(--brand);
      }

      .facebook-hover:hover span,
      .x-hover:hover span,
      .linkedin-hover:hover span {
        color: var(--brand);
      }

      /* Navigation dropdown hover effects */
      .nav-dropdown {
        opacity: 0;
        visibility: hidden;
        transform: translateY(-8px);
        transition: all 0.2s ease;
      }
      .nav-link:hover + .nav-dropdown,
      .nav-dropdown:hover {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
        display: block;
      }
      .dropdown-item:hover {
        background: hsla(15, 85%, 55%, 0.08) !important;
        color: var(--brand) !important;
      }
      .footer-link:hover {
        color: var(--brand) !important;
      }
      .breadcrumb-link:hover {
        color: var(--brand) !important;
      }
    </style>
    <slot name="head" />
  </head>
  <body>
    <header
      class="site-header"
      style={{
        position: "sticky",
        top: "0",
        zIndex: 1000,
        background: "hsla(0, 0%, 100%, 0.9)",
        backdropFilter: "blur(20px) saturate(180%)",
        borderBottom: "1px solid hsla(15, 85%, 55%, 0.1)",
        boxShadow: "0 4px 20px hsla(15, 85%, 55%, 0.15)"
      }}
    >
      <nav
        class="container"
        aria-label="Main navigation"
        style={{
          display: "flex",
          justifyContent: "space-between",
          alignItems: "center",
          padding: "12px 24px",
          maxWidth: "1400px",
          margin: "0 auto",
          gap: "24px"
        }}
      >
        <!-- Logo Section -->
        <a href="/" style={{ display: "flex", alignItems: "center", gap: "10px", textDecoration: "none", flexShrink: 0 }}>
          <div style={{ 
            width: "32px", height: "32px", 
            background: "linear-gradient(135deg, var(--brand) 0%, var(--secondary) 100%)",
            borderRadius: "8px", display: "flex", alignItems: "center", justifyContent: "center",
            boxShadow: "0 0 15px var(--brand-soft)"
          }}>
            <span style={{ color: "#000", fontWeight: "900", fontSize: "1.1rem" }}>W</span>
          </div>
          <div style={{ display: "flex", alignItems: "baseline", gap: "6px" }}>
            <span style={{ fontSize: "1.3rem", fontWeight: "850", color: "var(--text)", letterSpacing: "-0.03em" }}>
              Courses<span style={{ color: "var(--brand)" }}>Wyn</span>
            </span>
            <span style={{ fontSize: "0.6rem", color: "var(--brand)", fontWeight: "800", letterSpacing: "0.05em", opacity: 0.8, textTransform: "uppercase", display: "none", sm: "block" }}>
              Verified Promo
            </span>
          </div>
        </a>

        <!-- Navigation Links -->
        <div style={{ display: "flex", alignItems: "center", gap: "8px", flex: 1, justifyContent: "flex-end" }}>
          <div style={{ display: "flex", gap: "4px" }}>
            {[
              { label: "Free Udemy Coupons", url: "/udemy-coupon-code" },
              { label: "Top Instructors", url: "/instructors", hot: true },
              { label: "Course Categories", url: "/categories", hasDropdown: true },
              { label: "Popular Topics", url: "/topics" },
              { label: "Guides & Blog", url: "/blog" }
            ].map(link => (
              <div style={{ position: "relative" }}>
                <a 
                  href={link.url} 
                  style={{
                    fontSize: "0.85rem", fontWeight: "600",
                    color: (currentPath === link.url || (link.url !== '/' && currentPath.startsWith(link.url))) ? "var(--brand)" : "var(--muted)",
                    padding: "6px 12px", borderRadius: "8px",
                    textDecoration: "none", transition: "all 0.2s",
                    background: (currentPath === link.url || (link.url !== '/' && currentPath.startsWith(link.url))) ? "hsla(15, 85%, 55%, 0.1)" : "transparent",
                    display: "flex", alignItems: "center", gap: "4px"
                  }}
                  class="nav-link"
                >
                  {link.label}
                  {link.hasDropdown && (
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style={{ marginLeft: "2px" }}>
                      <path d="M7 10l5 5 5-5z"/>
                    </svg>
                  )}
                  {link.hot && (
                    <span style={{ fontSize: "0.5rem", background: "var(--brand)", color: "#000", padding: "1px 4px", borderRadius: "4px", fontWeight: "900" }}>HOT</span>
                  )}
                </a>
                {/* Dropdown Menu for Course Categories */}
                {link.hasDropdown && (
                  <div style={{
                    position: "absolute",
                    top: "100%",
                    left: "0",
                    marginTop: "8px",
                    minWidth: "220px",
                    background: "var(--card)",
                    borderRadius: "12px",
                    boxShadow: "0 8px 32px rgba(0, 0, 0, 0.12)",
                    border: "1px solid var(--border)",
                    padding: "8px",
                    display: "none",
                    zIndex: 100
                  }} class="nav-dropdown">
                    <a href="/categories/development" style={{
                      display: "block",
                      padding: "8px 12px",
                      color: "var(--text)",
                      textDecoration: "none",
                      borderRadius: "6px",
                      fontSize: "0.85rem",
                      transition: "background 0.2s"
                    }} class="dropdown-item">
                      💻 Development
                    </a>
                    <a href="/categories/business" style={{
                      display: "block",
                      padding: "8px 12px",
                      color: "var(--text)",
                      textDecoration: "none",
                      borderRadius: "6px",
                      fontSize: "0.85rem",
                      transition: "background 0.2s"
                    }} class="dropdown-item">
                      📈 Business
                    </a>
                    <a href="/categories/design" style={{
                      display: "block",
                      padding: "8px 12px",
                      color: "var(--text)",
                      textDecoration: "none",
                      borderRadius: "6px",
                      fontSize: "0.85rem",
                      transition: "background 0.2s"
                    }} class="dropdown-item">
                      🎨 Design
                    </a>
                    <a href="/categories/marketing" style={{
                      display: "block",
                      padding: "8px 12px",
                      color: "var(--text)",
                      textDecoration: "none",
                      borderRadius: "6px",
                      fontSize: "0.85rem",
                      transition: "background 0.2s"
                    }} class="dropdown-item">
                      📢 Marketing
                    </a>
                    <a href="/categories/it-software" style={{
                      display: "block",
                      padding: "8px 12px",
                      color: "var(--text)",
                      textDecoration: "none",
                      borderRadius: "6px",
                      fontSize: "0.85rem",
                      transition: "background 0.2s"
                    }} class="dropdown-item">
                      🔧 IT & Software
                    </a>
                    <div style={{ height: "1px", background: "var(--border)", margin: "4px 0" }}></div>
                    <a href="/categories" style={{
                      display: "block",
                      padding: "8px 12px",
                      color: "var(--brand)",
                      textDecoration: "none",
                      borderRadius: "6px",
                      fontSize: "0.85rem",
                      fontWeight: 600,
                      transition: "background 0.2s"
                    }} class="dropdown-item">
                      View All Categories →
                    </a>
                  </div>
                )}
              </div>
            ))}
          </div>

          <div style={{ width: "1px", height: "20px", background: "hsla(15, 85%, 55%, 0.2)", margin: "0 8px" }}></div>

          {/* Search bar */}
          <form action="/search" method="get" style={{ position: "relative", maxWidth: "160px", width: "100%" }}>
            <input 
              type="text" name="q" placeholder="Search..." 
              style={{
                background: "hsla(15, 85%, 55%, 0.05)", color: "var(--text)", border: "1px solid hsla(15, 85%, 55%, 0.2)",
                borderRadius: "20px", padding: "6px 32px 6px 12px", fontSize: "0.8rem", width: "100%", outline: "none"
              }}
            />
            <button type="submit" style={{ position: "absolute", right: "8px", top: "50%", transform: "translateY(-50%)", background: "none", border: "none", color: "var(--muted)", cursor: "pointer", display: "flex", alignItems: "center" }}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
            </button>
          </form>

          {/* Affiliate text */}
          <div style={{ fontSize: "0.8rem", fontWeight: "900", color: "var(--brand)", letterSpacing: "1px", flexShrink: 0, paddingLeft: "12px", borderLeft: "1px solid hsla(15, 85%, 55%, 0.2)" }}>
            679990
          </div>
        </div>
      </nav>
    </header>

    {/* Breadcrumb Navigation */}
    {currentPath !== '/' && (
      <nav aria-label="Breadcrumb" style={{
        background: "hsla(15, 85%, 55%, 0.03)",
        borderBottom: "1px solid hsla(15, 85%, 55%, 0.08)",
        padding: "12px 0"
      }}>
        <div class="container" style={{
          maxWidth: "1400px",
          margin: "0 auto",
          padding: "0 24px",
          display: "flex",
          alignItems: "center",
          gap: "8px",
          fontSize: "0.85rem",
          color: "var(--muted)"
        }}>
          <a href="/" style={{ color: "var(--muted)", textDecoration: "none", transition: "color 0.2s" }} class="breadcrumb-link">
            Home
          </a>
          <span style={{ color: "var(--border)" }}>/</span>
          {currentPath.startsWith('/udemy-coupon-code') && (
            <>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Free Udemy Coupons</span>
            </>
          )}
          {currentPath.startsWith('/instructors') && (
            <>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Top Instructors</span>
            </>
          )}
          {currentPath.startsWith('/categories') && (
            <>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Course Categories</span>
            </>
          )}
          {currentPath.startsWith('/topics') && (
            <>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Popular Topics</span>
            </>
          )}
          {currentPath.startsWith('/blog') && (
            <>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Guides & Blog</span>
            </>
          )}
          {currentPath.startsWith('/coupon/') && (
            <>
              <a href="/udemy-coupon-code" style={{ color: "var(--muted)", textDecoration: "none", transition: "color 0.2s" }} class="breadcrumb-link">
                Free Udemy Coupons
              </a>
              <span style={{ color: "var(--border)" }}>/</span>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Course Details</span>
            </>
          )}
          {currentPath.startsWith('/search') && (
            <>
              <span style={{ color: "var(--text)", fontWeight: 500 }}>Search Results</span>
            </>
          )}
        </div>
      </nav>
    )}

    <main style={{ minHeight: "calc(100vh - 300px)" }}>
      <slot />
    </main>

    <footer
      style={{
        color: "hsl(215, 20%, 65%)",
        padding: "80px 0 40px",
        marginTop: "auto",
        position: "relative",
        overflow: "hidden",
        background: "linear-gradient(135deg, hsl(0, 0%, 100%) 0%, hsla(15, 85%, 55%, 0.02) 100%)"
      }}
    >
      <div style={{ maxWidth: "1400px", margin: "0 auto", padding: "0 1rem" }}>
        {/* Newsletter Section - Functional */}
        <div style={{
          background: "var(--card)",
          padding: "1.5rem",
          borderRadius: "16px",
          marginBottom: "32px",
          border: "1px solid var(--border)",
          textAlign: "center",
          position: "relative",
          overflow: "hidden"
        }}>
          <h3 style={{
            color: "var(--text)",
            fontSize: "1.25rem",
            fontWeight: 700,
            marginBottom: "0.75rem",
            background: "linear-gradient(135deg, var(--brand) 0%, var(--secondary) 100%)",
            WebkitBackgroundClip: "text",
            WebkitTextFillColor: "transparent",
            backgroundClip: "text"
          }}>
            Get Udemy Coupons
          </h3>
          <p style={{
            color: "var(--muted)",
            marginBottom: "1.5rem",
            maxWidth: "500px",
            margin: "0 auto 1.5rem",
            fontSize: "0.9rem",
            lineHeight: 1.5
          }}>
            Subscribe for daily Udemy coupon deals delivered to your inbox.
          </p>
          <form
            action="/api/newsletter-signup"
            method="POST"
            style={{
              display: "flex",
              gap: "0.75rem",
              maxWidth: "500px",
              margin: "0 auto",
              flexWrap: "wrap",
              justifyContent: "center"
            }}
          >
            <input
              type="email"
              name="email"
              placeholder="Enter your email"
              required
              autocomplete="email"
              style={{
                flex: 1,
                minWidth: "200px",
                padding: "0.75rem",
                borderRadius: "8px",
                border: "1px solid var(--border)",
                background: "var(--input)",
                color: "var(--text)",
                fontSize: "0.9rem",
                transition: "border-color 0.3s ease"
              }}
            />
            <button
              type="submit"
              style={{
                padding: "0.75rem 1.5rem",
                borderRadius: "8px",
